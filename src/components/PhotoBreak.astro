---
/**
 * PhotoBreak - Full-bleed edge-to-edge photo section.
 * Creates visual breathing room between content sections.
 *
 * Optional `quote` + `attribution` props turn the section into an
 * overlay-quote PhotoBreak: a real couple testimonial set in Cormorant
 * Garamond over a dark gradient on the photo. Used on /weddings/ Section 6
 * to land a value-justifier quote immediately before the pricing reveal.
 *
 * `quotePosition` controls where the quote sits and where the dark gradient
 * falls. Default is "bottom" (original behaviour). Use "top" to push the
 * quote and gradient to the top of the image, leaving the lower portion
 * unobscured so vivid photo content (e.g. colourful wedding party) pops.
 *
 * Usage:
 *   <PhotoBreak
 *     image="/images/hackney-wedding-couple.webp"
 *     alt="Wedding couple at The Hackney"
 *     position="center 40%"
 *   />
 *
 *   <PhotoBreak
 *     image="/images/hackney-wedding-confetti.webp"
 *     alt="Wedding party confetti on Hackney Road"
 *     position="center 50%"
 *     quote="It felt far more put together than weddings of friends who paid triple the amount. Absolutely the best day."
 *     attribution="Rosemary, married November 2024"
 *     quotePosition="top"
 *   />
 */

interface Props {
  image: string;
  alt: string;
  /** CSS background-position value. Default: "center center" */
  position?: string;
  /** CSS height value. Default: "60vh" */
  height?: string;
  /** Optional pull-quote. When set, the photo gets a dark overlay + serif quote treatment. */
  quote?: string;
  /** Optional attribution line. Renders below the quote with an em-dash prefix. */
  attribution?: string;
  /** Where the quote + dark gradient sit. "bottom" (default) or "top". */
  quotePosition?: 'top' | 'bottom';
}

const {
  image,
  alt,
  position = 'center center',
  height = '60vh',
  quote,
  attribution,
  quotePosition = 'bottom',
} = Astro.props;

const quoteTopClass = quotePosition === 'top' ? ' photo-break-quote-top' : '';
---

<section class={`photo-break${quote ? ' photo-break-with-quote' : ''}${quoteTopClass}`}>
  <div
    class="photo-break-image"
    style={`background-image: url('${image}'); background-position: ${position}; --photo-height: ${height};`}
    role="img"
    aria-label={alt}
  >
    {quote && (
      <div class="photo-break-overlay">
        <figure class="photo-break-quote-figure">
          <blockquote class="photo-break-quote">{quote}</blockquote>
          {attribution && (
            <figcaption class="photo-break-attribution">- {attribution}</figcaption>
          )}
        </figure>
      </div>
    )}
  </div>
</section>

<style>
  .photo-break {
    width: 100%;
    overflow: hidden;
  }

  .photo-break-image {
    width: 100%;
    height: var(--photo-height, 60vh);
    min-height: 350px;
    background-size: cover;
    position: relative;
  }

  /* Quote variant - dark gradient overlay + Cormorant Garamond serif quote.
     Default (bottom): gradient is anchored bottom-heavy so the photo reads
     in the upper third while the quote sits in the lower third. */
  .photo-break-with-quote .photo-break-image {
    min-height: 420px;
  }

  .photo-break-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(44, 24, 16, 0.10) 0%,
      rgba(44, 24, 16, 0.35) 45%,
      rgba(44, 24, 16, 0.78) 100%
    );
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0 32px 56px;
  }

  /* Top variant: flip the gradient so it's dark at top, clear at bottom.
     Quote sits at the top, letting vibrant photo content below pop. */
  .photo-break-quote-top .photo-break-overlay {
    background: linear-gradient(
      180deg,
      rgba(44, 24, 16, 0.82) 0%,
      rgba(44, 24, 16, 0.55) 40%,
      rgba(44, 24, 16, 0.08) 70%,
      rgba(44, 24, 16, 0) 100%
    );
    align-items: flex-start;
    padding: 48px 32px 0;
  }

  .photo-break-quote-figure {
    max-width: 760px;
    margin: 0;
    text-align: center;
  }

  .photo-break-quote {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: clamp(22px, 2.6vw, 34px);
    font-weight: 400;
    line-height: 1.35;
    color: var(--warm-canvas, #F5F0E8);
    margin: 0 0 18px;
    quotes: '\201C' '\201D';
  }

  .photo-break-quote::before {
    content: open-quote;
  }

  .photo-break-quote::after {
    content: close-quote;
  }

  .photo-break-attribution {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--warm-canvas, #F5F0E8);
    opacity: 0.85;
    margin: 0;
  }

  @media (max-width: 768px) {
    .photo-break-image {
      height: 40vh;
      min-height: 250px;
    }

    .photo-break-with-quote .photo-break-image {
      height: 56vh;
      min-height: 380px;
    }

    .photo-break-overlay {
      padding: 0 24px 36px;
    }

    .photo-break-quote-top .photo-break-overlay {
      padding: 32px 24px 0;
    }

    .photo-break-quote {
      font-size: 20px;
      margin-bottom: 14px;
    }

    .photo-break-attribution {
      font-size: 13px;
    }
  }
</style>
