<style>
  .site-footer {
    background-color: var(--brewery-dark);
    color: var(--warm-canvas);
    position: relative;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 48px;
    align-items: start;
    padding-block: 56px 48px;
  }

  /* ---- Brand column ---- */
  .footer-logo {
    display: block;
    margin-bottom: 16px;
  }

  .footer-logo img {
    height: 72px;
    width: auto;
    display: block;
  }

  .footer-address,
  .footer-phone {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.7;
    line-height: 1.65;
  }

  .footer-address a,
  .footer-phone a {
    color: rgba(245, 240, 232, 0.7);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer-address a:hover,
  .footer-phone a:hover {
    opacity: 1;
    color: var(--warm-canvas);
  }

  .footer-phone {
    margin-top: 4px;
  }

  .footer-social {
    display: flex;
    gap: 16px;
    margin-top: 20px;
    align-items: center;
  }

  .footer-social a {
    color: var(--warm-canvas);
    opacity: 0.5;
    transition: opacity 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-social svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .footer-social a:hover {
    opacity: 1;
  }

  /* ---- Nav columns ---- */
  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-nav-col a {
    color: var(--warm-canvas);
    text-decoration: none;
    font-size: 0.875rem;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .footer-nav-col a:hover {
    opacity: 1;
  }

  .footer-col-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--warm-canvas);
    opacity: 0.4;
    margin-bottom: 4px;
  }

  /* ---- Bottom bar ---- */
  .footer-bottom {
    padding: 20px 0;
    border-top: 1px solid rgba(245, 240, 232, 0.1);
  }

  .footer-bottom p {
    margin: 0 auto;
    font-size: 0.75rem;
    opacity: 0.4;
    text-align: center;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 32px 24px;
      padding-block: 40px 32px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-social {
      gap: 16px;
    }
  }
</style>
