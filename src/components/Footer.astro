---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <img src="/images/the-hackney-logo-white.webp" alt="The Hackney" />
      </a>
      <p class="footer-address">503 Hackney Road, London E2 9ED</p>
      <p class="footer-phone"><a href="tel:+442079611604">+44 20 7961 1604</a></p>
      <div class="footer-social">
        <a href="https://instagram.com/thehackney.co" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.tiktok.com/@thehackney" target="_blank" rel="noopener">TikTok</a>
        <a href="https://www.facebook.com/TheHackney.Co/" target="_blank" rel="noopener">Facebook</a>
        <a href="https://uk.pinterest.com/TheHackneyCo/_saved/" target="_blank" rel="noopener">Pinterest</a>
      </div>
    </div>

    <nav class="footer-nav">
      <div class="footer-nav-col">
        <a href="/weddings/">Weddings</a>
        <a href="/private-events/">Private Events</a>
        <a href="/corporate/">Corporate</a>
        <a href="/supper-club/">Supper Club</a>
        <a href="/cafe-bar/">Cafe & Bar</a>
      </div>
      <div class="footer-nav-col">
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
        <a href="/journal/">Journal</a>
        <a href="/privacy/">Privacy Policy</a>
      </div>
    </nav>

  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {currentYear} The Hackney. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--brewery-dark);
    color: var(--warm-canvas);
    position: relative;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 64px;
    align-items: start;
    padding: 56px 0 48px;
  }

  /* ---- Brand column ---- */
  .footer-logo {
    display: block;
    margin-bottom: 16px;
  }

  .footer-logo img {
    height: 52px;
    width: auto;
    display: block;
  }

  .footer-address,
  .footer-phone {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.7;
    line-height: 1.65;
  }

  .footer-phone {
    margin-top: 4px;
  }

  .footer-phone a {
    color: rgba(245, 240, 232, 0.7);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer-phone a:hover {
    opacity: 1;
    color: var(--warm-canvas);
  }

  .footer-social {
    display: flex;
    gap: 20px;
    margin-top: 20px;
  }

  .footer-social a {
    color: var(--warm-canvas);
    text-decoration: none;
    font-size: 0.8125rem;
    opacity: 0.6;
    transition: opacity 0.2s ease;
    letter-spacing: 0.02em;
  }

  .footer-social a:hover {
    opacity: 1;
  }

  /* ---- Nav columns ---- */
  .footer-nav {
    display: flex;
    gap: 48px;
  }

  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-nav a {
    color: var(--warm-canvas);
    text-decoration: none;
    font-size: 0.875rem;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .footer-nav a:hover {
    opacity: 1;
  }

  /* ---- Bottom bar ---- */
  .footer-bottom {
    padding: 20px 0;
    border-top: 1px solid rgba(245, 240, 232, 0.1);
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.75rem;
    opacity: 0.4;
    width: 100%;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 40px 0 32px;
    }

    .footer-nav {
      gap: 40px;
    }

    .footer-social {
      flex-wrap: wrap;
    }
  }
</style>
