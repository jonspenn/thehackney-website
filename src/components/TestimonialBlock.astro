---
/**
 * TestimonialBlock - Quote with attribution
 *
 * Displays one or more testimonials in a grid.
 * Quote text uses Fired Brick per brand guide (warm highlight for quotes).
 * Attribution uses Dusty Coral.
 *
 * Props:
 *   testimonials - array of { quote, attribution }
 *   columns      - 1 or 2 (default: 2 for multiple, 1 for single)
 */

interface Testimonial {
  quote: string;
  attribution: string;
}

interface Props {
  testimonials: Testimonial[];
  columns?: 1 | 2;
}

const { testimonials, columns } = Astro.props;
const cols = columns || (testimonials.length > 1 ? 2 : 1);
---

<div class="testimonial-grid" style={`--testimonial-cols: ${cols}`}>
  {testimonials.map((t) => (
    <div class="testimonial-item fade-in">
      <blockquote class="testimonial-quote">{t.quote}</blockquote>
      <p class="testimonial-attr">{t.attribution}</p>
    </div>
  ))}
</div>

<style>
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(var(--testimonial-cols, 2), 1fr);
    gap: 3rem;
  }

  .testimonial-quote {
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-style: italic;
    line-height: 1.5;
    margin-bottom: 1.25rem;
    color: inherit;
  }

  .testimonial-quote::before {
    content: none;
  }

  .testimonial-attr {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dusty-coral);
    margin: 0;
  }

  @media (max-width: 768px) {
    .testimonial-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
