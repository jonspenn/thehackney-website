---
/**
 * ProofBar - Social proof stats strip.
 * Warm Canvas background, bordered card per stat, consistent visual weight.
 *
 * Usage:
 *   <ProofBar
 *     stats={[
 *       { number: "98", label: "NPS Score" },
 *       { number: "4.6", label: "Google Rating" },
 *       { number: "75+", label: "Weddings Per Year" },
 *       { number: "1856", label: "Brewery Building" }
 *     ]}
 *   />
 */

interface Props {
  stats: Array<{ number: string; label: string }>;
}

const { stats } = Astro.props;

---

<section class="proof-bar">
  <div class="container">
    <div class="proof-bar-inner" style={`--stat-cols: ${stats.length};`}>
      {stats.map((stat) => (
        <div class="proof-stat fade-in">
          <div class="proof-stat-number">{stat.number}</div>
          <div class="proof-stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .proof-bar {
    background: var(--warm-canvas);
    border-bottom: 1px solid rgba(44, 24, 16, 0.08);
    padding: 40px 0;
  }

  .proof-bar-inner {
    display: grid;
    grid-template-columns: repeat(var(--stat-cols, 4), 1fr);
    gap: 20px;
    text-align: center;
  }

  .proof-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(44, 24, 16, 0.12);
    border-radius: 4px;
    padding: 28px 16px;
    min-height: 120px;
  }

  .proof-stat-number {
    font-family: var(--font-heading);
    font-size: clamp(16px, 1.8vw, 22px);
    font-weight: 700;
    color: var(--brewery-dark);
    letter-spacing: 0.02em;
    line-height: 1.25;
    text-align: center;
  }

  .proof-stat-label {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dusty-coral);
    margin-top: 10px;
    font-weight: 500;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .proof-bar-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .proof-stat {
      min-height: 100px;
      padding: 24px 12px;
    }
  }
</style>
