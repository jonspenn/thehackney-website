---
const navItems = [
  { label: 'Weddings', href: '/weddings/' },
  {
    label: 'Events',
    href: '#',
    submenu: [
      { label: 'Private Events', href: '/private-events/' },
      { label: 'Corporate', href: '/corporate/' }
    ]
  },
  { label: 'Supper Club', href: '/supper-club/' },
  { label: 'Cafe & Bar', href: '/cafe-bar/' },
  { label: 'About', href: '/about/' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="nav">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="The Hackney - Home">
      <img src="/images/the-hackney-logo.webp" alt="The Hackney" width="160" height="113" />
    </a>

    <nav id="primary-nav" class="primary-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class={item.submenu ? 'has-submenu' : ''}>
            {item.submenu ? (
              <>
                <button class="nav-link dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                  {item.label}
                </button>
                <ul class="nav-submenu">
                  {item.submenu.map((subitem) => (
                    <li>
                      <a
                        href={subitem.href}
                        class:list={['nav-sublink', { active: currentPath === subitem.href || (currentPath.startsWith(subitem.href) && subitem.href !== '/') }]}
                      >
                        {subitem.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={item.href}
                class:list={['nav-link', { active: currentPath === item.href || (currentPath.startsWith(item.href) && item.href !== '/') }]}
              >
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <a href="/check-your-date/" class="btn btn-primary btn-nav nav-cta-desktop">Check Your Date</a>

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <a href="/check-your-date/" class="btn btn-primary btn-nav nav-cta-mobile">Check Your Date</a>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--header-height);
    background-color: var(--color-bg);
    border-bottom: 1px solid rgba(44, 24, 16, 0.08);
    transition: box-shadow 0.3s ease;
  }

  .site-header.scrolled {
    box-shadow: 0 1px 0 rgba(44, 24, 16, 0.08);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: var(--space-lg);
  }

  .logo {
    text-decoration: none;
    color: var(--color-text);
    flex-shrink: 0;
  }

  .logo img {
    height: 40px;
    width: auto;
    display: block;
  }

  .primary-nav {
    flex: 1;
  }

  .nav-list {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text);
    padding-block: var(--space-xs);
    position: relative;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
  }

  .has-submenu {
    position: relative;
  }

  .dropdown-toggle {
    background: none;
    border: none;
    font: inherit;
    cursor: pointer;
  }

  .nav-submenu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: var(--color-bg);
    border: 1px solid rgba(44, 24, 16, 0.08);
    border-top: none;
    list-style: none;
    margin: 0;
    padding: var(--space-sm) 0;
    min-width: 160px;
    box-shadow: 0 4px 6px rgba(44, 24, 16, 0.1);
  }

  .has-submenu:hover .nav-submenu {
    display: block;
  }

  .nav-submenu li {
    margin: 0;
  }

  .nav-sublink {
    display: block;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .nav-sublink:hover {
    color: var(--color-accent);
  }

  .nav-sublink.active {
    color: var(--color-accent);
  }

  .nav-cta-desktop {
    display: inline-flex;
  }

  .nav-cta-mobile {
    display: none;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-sm);
    margin-left: auto;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .hamburger.open span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
  }

  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.open span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  @media (max-width: 768px) {
    .header-inner {
      gap: var(--space-md);
    }

    .primary-nav {
      display: none;
      position: absolute;
      top: var(--header-height);
      left: 0;
      right: 0;
      background-color: var(--color-bg);
      border-bottom: 1px solid rgba(44, 24, 16, 0.08);
      padding: var(--space-lg);
      flex: none;
    }

    .primary-nav.open {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      gap: var(--space-md);
    }

    .nav-link {
      display: block;
      padding-block: var(--space-sm);
    }

    .nav-link.active::after {
      display: none;
    }

    .nav-submenu {
      position: static;
      display: none;
      background-color: rgba(44, 24, 16, 0.05);
      border: none;
      box-shadow: none;
      padding: var(--space-sm) 0 var(--space-sm) var(--space-md);
      margin-top: var(--space-sm);
    }

    .has-submenu.open .nav-submenu {
      display: block;
    }

    .nav-submenu li {
      margin: var(--space-xs) 0;
    }

    .nav-sublink {
      padding: var(--space-xs) 0;
      font-size: 0.75rem;
    }

    .hamburger {
      display: flex;
      order: 3;
    }

    .nav-cta-desktop {
      display: none;
    }

    .nav-cta-mobile {
      display: inline-flex;
      order: 4;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const nav = document.getElementById('primary-nav');
  const navLinks = nav?.querySelectorAll('a');
  const dropdownToggles = nav?.querySelectorAll('.dropdown-toggle');
  const headerNav = document.getElementById('nav');

  // Toggle mobile menu
  hamburger?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    hamburger.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  // Handle dropdown toggles on mobile
  dropdownToggles?.forEach(toggle => {
    toggle.addEventListener('click', (e) => {
      e.preventDefault();
      const parentLi = toggle.closest('li');
      const isOpen = parentLi?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  });

  // Close mobile menu on regular link click
  navLinks?.forEach(link => {
    if (!link.classList.contains('dropdown-toggle')) {
      link.addEventListener('click', () => {
        nav?.classList.remove('open');
        hamburger?.classList.remove('open');
        hamburger?.setAttribute('aria-expanded', 'false');
      });
    }
  });

  // Close submenu when clicking a sublink
  nav?.querySelectorAll('.nav-sublink')?.forEach(link => {
    link.addEventListener('click', () => {
      nav?.classList.remove('open');
      hamburger?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });

  // Add scroll state to header
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      headerNav?.classList.add('scrolled');
    } else {
      headerNav?.classList.remove('scrolled');
    }
  });
</script>
