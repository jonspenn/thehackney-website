---
/**
 * CheckDateForm.astro
 * Astro wrapper for the Check Your Date availability calendar.
 * The calendar is the primary element - users see availability instantly.
 * Clicking an available date surfaces CTAs to get in touch.
 *
 * Props:
 *   eventType - "wedding" | "corporate" | "private" | undefined
 *              Passed through to the React component for context-aware CTAs.
 */
import CheckDateForm from './CheckDateForm.jsx';

interface Props {
  eventType?: "wedding" | "corporate" | "private";
}

const { eventType } = Astro.props;
---

<section class="check-date-section" id="check-your-date">
  <div class="container">
    <CheckDateForm client:load eventType={eventType} />
  </div>
</section>

<style is:global>
  /* ==================== CHECK DATE FORM ==================== */
  .check-date-section {
    padding: 24px 0 80px;
    scroll-margin-top: var(--header-height, 96px);
  }

  .cd {
    max-width: 580px;
    margin: 0 auto;
    scroll-margin-top: calc(var(--header-height, 96px) + 2rem);
  }

  /* ── Typography (shared wq- tokens) ── */
  .cd .wq-eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dusty-coral);
    margin-bottom: 16px;
  }

  .cd .wq-heading {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--brewery-dark);
    margin: 0 0 16px;
    letter-spacing: -0.01em;
  }

  .cd .wq-subtext {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--brewery-dark);
    opacity: 0.7;
    margin: 0 0 32px;
    max-width: 440px;
  }

  .cd .wq-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dusty-coral);
    margin-bottom: 12px;
  }

  /* ── Buttons ── */
  .cd .wq-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 14px 40px;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }

  .cd .wq-btn--primary {
    background: var(--mid-olive);
    color: #fff;
  }

  .cd .wq-btn--primary:hover {
    background: var(--forest-olive);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(46,64,9,0.25);
  }

  .cd .wq-btn--outline {
    background: transparent;
    color: var(--forest-olive);
    border: 1.5px solid var(--forest-olive);
    padding: 12px 36px;
  }

  .cd .wq-btn--outline:hover {
    background: rgba(46,64,9,0.06);
  }

  /* ==================== AVAILABILITY CALENDAR ==================== */

  .ac {
    margin-bottom: 8px;
  }

  /* ── Month navigation ── */
  .ac-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .ac-nav__title {
    font-family: var(--font-heading);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 600;
    color: var(--brewery-dark);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .ac-nav__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1.5px solid rgba(44,24,16,0.12);
    border-radius: 2px;
    background: transparent;
    color: var(--brewery-dark);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .ac-nav__btn:hover:not(:disabled) {
    border-color: rgba(44,24,16,0.25);
    background: rgba(255,255,255,0.6);
  }

  .ac-nav__btn:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }

  /* ── Calendar grid ── */
  .ac-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }

  .ac-grid--header {
    margin-bottom: 4px;
  }

  /* ── Cells ── */
  .ac-cell {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 2px;
    font-family: var(--font-body);
    padding: 0;
    position: relative;
    background: transparent;
  }

  .ac-cell--header {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brewery-dark);
    opacity: 0.4;
    aspect-ratio: auto;
    padding: 4px 0;
  }

  .ac-cell--empty {
    background: transparent;
  }

  .ac-cell--day {
    cursor: default;
    transition: all 0.15s ease;
  }

  .ac-cell__num {
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    color: var(--brewery-dark);
    z-index: 1;
  }

  /* Available dates */
  .ac-cell--available {
    background: rgba(46,64,9,0.06);
    cursor: pointer;
  }

  .ac-cell--available:hover {
    background: rgba(46,64,9,0.14);
    transform: scale(1.05);
  }

  .ac-cell--available .ac-cell__num {
    color: var(--forest-olive);
    font-weight: 600;
  }

  /* Weekend available dates - slightly different tone */
  .ac-cell--available.ac-cell--weekend {
    background: rgba(46,64,9,0.10);
  }

  .ac-cell--available.ac-cell--weekend:hover {
    background: rgba(46,64,9,0.18);
  }

  /* Selected date */
  .ac-cell--selected {
    background: var(--forest-olive) !important;
    transform: scale(1.05);
  }

  .ac-cell--selected .ac-cell__num {
    color: #fff !important;
    font-weight: 700;
  }

  /* Today indicator */
  .ac-cell--today {
    box-shadow: inset 0 0 0 2px var(--dusty-coral);
  }

  /* Booked dates */
  .ac-cell--booked {
    background: rgba(44,24,16,0.08);
    cursor: not-allowed;
  }

  .ac-cell--booked .ac-cell__num {
    opacity: 0.25;
  }

  /* Held / enquired dates */
  .ac-cell--held {
    background: rgba(191,114,86,0.08);
    cursor: not-allowed;
  }

  .ac-cell--held .ac-cell__num {
    opacity: 0.5;
    color: var(--dusty-coral);
  }

  /* Past dates */
  .ac-cell--past {
    cursor: not-allowed;
  }

  .ac-cell--past .ac-cell__num {
    opacity: 0.2;
  }

  /* ── Indicators (booked line, held dot) ── */
  .ac-cell__indicator {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ac-cell__indicator--booked {
    bottom: 4px;
  }

  .ac-cell__indicator--held {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--dusty-coral);
    opacity: 0.6;
  }

  /* ── Loading state ── */
  .ac-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(245,240,232,0.7);
    z-index: 10;
    border-radius: 2px;
  }

  .ac-spinner {
    width: 24px;
    height: 24px;
    border: 2.5px solid rgba(44,24,16,0.1);
    border-top-color: var(--forest-olive);
    border-radius: 50%;
    animation: ac-spin 0.6s linear infinite;
  }

  @keyframes ac-spin {
    to { transform: rotate(360deg); }
  }

  /* ── Error state ── */
  .ac-error {
    text-align: center;
    padding: 20px;
    margin-top: 12px;
    background: rgba(140,71,46,0.04);
    border: 1px solid rgba(140,71,46,0.12);
    border-radius: 2px;
  }

  .ac-error p {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--brewery-dark);
    opacity: 0.7;
    margin: 0 0 12px;
  }

  .ac-error__retry {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--dusty-coral);
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    padding: 0;
  }

  /* ── Legend ── */
  .ac-legend {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(44,24,16,0.06);
  }

  .ac-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--brewery-dark);
    opacity: 0.55;
  }

  .ac-legend__dot {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ── Prompt text ── */
  .ac-prompt {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--brewery-dark);
    opacity: 0.45;
    text-align: center;
    margin: 20px 0 0;
  }

  /* ==================== DATE RESULT (shown after selecting a date) ==================== */

  .cd-date-result {
    margin-top: 28px;
    padding: 28px;
    background: rgba(46,64,9,0.03);
    border: 1px solid rgba(46,64,9,0.12);
    border-radius: 2px;
    text-align: center;
  }

  .cd-date-result__status {
    display: flex;
    align-items: center;
    gap: 14px;
    text-align: left;
    margin-bottom: 24px;
  }

  .cd-date-result__date {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    color: var(--brewery-dark);
    line-height: 1.2;
  }

  .cd-date-result__available {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--forest-olive);
    font-weight: 500;
    margin-top: 2px;
  }

  .cd-date-result__actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cd-date-result__whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 16px;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--brewery-dark);
    opacity: 0.5;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cd-date-result__whatsapp:hover {
    opacity: 0.75;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .cd-date-result__change {
    display: inline-block;
    margin-top: 10px;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--brewery-dark);
    opacity: 0.45;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    padding: 0;
    transition: opacity 0.2s;
  }

  .cd-date-result__change:hover {
    opacity: 0.7;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .check-date-section {
      padding: 48px 0 64px;
    }

    .ac-cell__num {
      font-size: 13px;
    }

    .ac-cell__indicator {
      bottom: 2px;
    }

    .ac-legend {
      gap: 12px;
    }

    .cd-date-result {
      padding: 20px;
    }
  }
</style>
