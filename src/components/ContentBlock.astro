---
/**
 * ContentBlock - Two-column text + image layout
 *
 * The core content section. Text on one side, image on the other.
 * Alternating layouts create visual rhythm per benchmark research.
 *
 * Props:
 *   image     - path to image
 *   alt       - image alt text
 *   reverse   - if true, image goes on the left (default: image right)
 *   aspect    - image aspect ratio: '4/3' (default), '3/2', '1/1', '4/5'
 *   class     - additional classes
 */

interface Props {
  image: string;
  alt: string;
  reverse?: boolean;
  aspect?: string;
  class?: string;
}

const {
  image,
  alt,
  reverse = false,
  aspect = '4/3',
  class: className = ''
} = Astro.props;
---

<div class:list={['content-block', { 'content-block-reverse': reverse }, className]}>
  <div class="content-block-text">
    <slot />
  </div>
  <div class="content-block-media">
    <img src={image} alt={alt} loading="lazy" style={`aspect-ratio: ${aspect};`} />
  </div>
</div>

<style>
  .content-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.75rem;
    align-items: center;
  }

  .content-block-reverse {
    direction: rtl;
  }

  .content-block-reverse > * {
    direction: ltr;
  }

  .content-block-text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .content-block-text :global(h2) {
    margin-bottom: 1.25rem;
  }

  .content-block-text :global(h3) {
    margin-bottom: 1rem;
  }

  .content-block-text :global(.btn) {
    align-self: flex-start;
    margin-top: 1.5rem;
  }

  .content-block-media img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .content-block,
    .content-block-reverse {
      grid-template-columns: 1fr;
      gap: 2rem;
      direction: ltr;
    }
  }
</style>
