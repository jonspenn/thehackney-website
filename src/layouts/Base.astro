---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schema?: string;
  pageType?: string;
  preloadImage?: string;
}

const {
  title,
  description = 'The Hackney is a restored 1856 brewery on Hackney Road, E2. One of East London\'s most sought-after wedding and events venues. 60 seated, 100 standing. Exclusively yours.',
  ogImage,
  schema,
  pageType = 'general',
  preloadImage,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- PRE-LAUNCH LOCKDOWN - remove on launch day 2026-05-01 -->
    <meta name="robots" content="noindex, nofollow" />
    <!-- Google Tag Manager - dataLayer init -->
    <script is:inline define:vars={{ pageType }}>
      window.dataLayer = window.dataLayer || [];
      dataLayer.push({
        'page_type': pageType
      });
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-W2JW4T2');
    </script>
    <!-- End Google Tag Manager -->

    <!-- Microsoft Clarity (heatmaps, session recordings, rage/dead clicks) -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "w7x4ji8j8k");
    </script>
    <!-- End Microsoft Clarity -->

    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} - The Hackney`} />
    <meta property="og:description" content={description} />
    {ogImage ? <meta property="og:image" content={ogImage} /> : <meta property="og:image" content="/images/the-hackney-og-default.webp" />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <link rel="canonical" href={`https://thehackney-website.pages.dev${Astro.url.pathname}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} type="image/webp" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@400;500;700&display=swap"
      as="style"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <!-- Organization Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "The Hackney",
        "url": "https://thehackney-website.pages.dev",
        "telephone": "+442079611604",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "503 Hackney Road",
          "addressLocality": "London",
          "postalCode": "E2 9ED",
          "addressCountry": "GB"
        },
        "sameAs": [
          "https://instagram.com/thehackney.co",
          "https://www.tiktok.com/@thehackney",
          "https://www.facebook.com/TheHackney.Co/"
        ]
      }
    </script>
    <!-- Page-specific Schema -->
    {schema && <script type="application/ld+json" set:html={schema} />}
    <title>{title} - The Hackney</title>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W2JW4T2" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <!-- D1 first-party tracking (prd-sys-d1-data-platform.md Phase 1) -->
    <script is:inline src="/scripts/tracking.js" defer></script>

    <script>
      // Fade-in on scroll intersection observer
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

      // Lazy background images
      const lazyBgs = document.querySelectorAll('.lazy-bg[data-bg]');
      if (lazyBgs.length) {
        const lazyBgObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const el = entry.target;
              const bg = el.dataset.bg;
              if (bg) {
                el.style.backgroundImage = `url('${bg}')`;
                el.style.backgroundSize = 'cover';
                el.style.backgroundPosition = el.dataset.bgPos || 'center center';
              }
              lazyBgObserver.unobserve(el);
            }
          });
        }, { rootMargin: '200px' });
        lazyBgs.forEach(el => lazyBgObserver.observe(el));
      }

      // FAQ accordion
      document.querySelectorAll('.faq-question').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq-item');
          const isOpen = item?.classList.contains('open');
          // Close all
          document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
          // Toggle current
          if (!isOpen) item?.classList.add('open');
        });
      });

      // Sticky mobile CTA
      const stickyCta = document.getElementById('stickyCta');
      if (stickyCta) {
        const hero = document.querySelector('.hero');
        if (hero) {
          const stickyObserver = new IntersectionObserver(([entry]) => {
            stickyCta.classList.toggle('visible', !entry.isIntersecting);
          });
          stickyObserver.observe(hero);
        }
      }
    </script>
  </body>
</html>
