---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<Base
  title="Book a Visit"
  description="See The Hackney in person or chat with our team. Book a venue tour or a quick discovery call to talk through your plans."
  pageType="conversion"
>

  <!-- Date context banner (visible when arriving from calendar with ?date=) -->
  <div class="date-context" id="date-context" style="display:none;">
    <div class="container">
      <p class="date-context__text">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style="vertical-align: middle; margin-right: 6px;">
          <circle cx="12" cy="12" r="12" fill="#2E4009"/>
          <path d="M7 12L10.5 15.5L17 8.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span id="date-context-text"></span>
      </p>
    </div>
  </div>

  <!-- Hero -->
  <Section bg="light" padding="compact" class="bookacall-hero">
    <SectionHeader
      eyebrow="Next Step"
      heading="Let's make it happen"
      subtext="Choose how you'd like to connect with us."
      align="center"
    />
  </Section>

  <!-- Tab navigation + booking panels -->
  <Section bg="light" padding="compact" class="bookacall-tabs-section">
    <div class="bk-tabs" role="tablist" aria-label="Booking options">
      <button
        type="button"
        role="tab"
        id="bk-tab-tour"
        class="bk-tab is-active"
        aria-selected="true"
        aria-controls="bk-panel-tour"
        data-tab="tour"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span>Book a venue tour</span>
        <span class="bk-tab__badge">Recommended</span>
      </button>
      <button
        type="button"
        role="tab"
        id="bk-tab-call"
        class="bk-tab"
        aria-selected="false"
        aria-controls="bk-panel-call"
        data-tab="call"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
        </svg>
        <span>Book a discovery call</span>
      </button>
    </div>

    <!-- Tour panel -->
    <div
      id="bk-panel-tour"
      class="bk-panel is-active"
      role="tabpanel"
      aria-labelledby="bk-tab-tour"
      tabindex="0"
    >
      <div class="booking-card">
        <div class="booking-card__content">
          <h2>See The Hackney in person</h2>
          <p class="booking-card__body">
            Nothing beats walking through the brewery, asking questions, and starting to picture your day.
            Tours run 7 days a week and take around 30 minutes.
          </p>
          <ul class="booking-card__details">
            <li>Meet Hugo, our General Manager</li>
            <li>See the ceremony and reception spaces</li>
            <li>Talk through your ideas, dates, and budget</li>
            <li>No obligation - just a chance to see if we're the right fit</li>
          </ul>
        </div>
        <div class="booking-card__action">
          <div class="meetings-iframe-container" data-src="https://meetings-eu1.hubspot.com/bookings-team/book-a-venue-tour?embed=true"></div>
          <script type="text/javascript" src="https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js" is:inline></script>
        </div>
      </div>
    </div>

    <!-- Call panel -->
    <div
      id="bk-panel-call"
      class="bk-panel"
      role="tabpanel"
      aria-labelledby="bk-tab-call"
      tabindex="0"
      hidden
    >
      <div class="booking-card">
        <div class="booking-card__content">
          <h2>Quick chat first?</h2>
          <p class="booking-card__body">
            Not ready to visit just yet? Jump on a quick call with our team.
            We'll answer your questions, talk availability, and help you decide if The Hackney is right for your day.
          </p>
          <ul class="booking-card__details">
            <li>15-minute video or phone call</li>
            <li>No pressure, no hard sell</li>
            <li>Get answers before committing to a visit</li>
          </ul>
        </div>
        <div class="booking-card__action">
          <div class="meetings-iframe-container" data-src="https://meetings-eu1.hubspot.com/bookings-team/book-a-discovery-call?embed=true"></div>
          <script type="text/javascript" src="https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js" is:inline></script>
        </div>
      </div>
    </div>
  </Section>

  <!-- Fallback contact -->
  <Section bg="light" padding="none" border="top" class="bookacall-fallback">
    <div class="contact-fallback">
      <p class="contact-fallback__label">Rather just get in touch?</p>
      <div class="contact-fallback__links">
        <a href="mailto:bookings@thehackney.co" class="contact-fallback__link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          bookings@thehackney.co
        </a>
        <a href="https://wa.me/442079611604" class="contact-fallback__link contact-fallback__link--whatsapp">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </Section>

  <!-- Page-level scripts: date context + tab switching -->
  <script is:inline>
    (function() {
      // === Date context banner ===
      var params = new URLSearchParams(window.location.search);
      var date = params.get('date');
      if (date) {
        try {
          var d = new Date(date + 'T00:00:00');
          var formatted = d.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
          document.getElementById('date-context-text').textContent = formatted + ' looks available at The Hackney';
          document.getElementById('date-context').style.display = 'block';
        } catch(e) {}
      }

      // === Tab switching ===
      var tabs = document.querySelectorAll('.bk-tab');
      var panels = {
        tour: document.getElementById('bk-panel-tour'),
        call: document.getElementById('bk-panel-call')
      };
      var tabButtons = {
        tour: document.getElementById('bk-tab-tour'),
        call: document.getElementById('bk-tab-call')
      };

      function activateTab(name) {
        Object.keys(panels).forEach(function(key) {
          var isActive = key === name;
          panels[key].classList.toggle('is-active', isActive);
          panels[key].hidden = !isActive;
          tabButtons[key].classList.toggle('is-active', isActive);
          tabButtons[key].setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
      }

      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          var name = tab.getAttribute('data-tab');
          activateTab(name);
          // Update hash without scrolling
          if (history.replaceState) {
            history.replaceState(null, '', '#' + name);
          }
        });
      });

      // === Activate tab from URL hash or ?type= param ===
      var hash = (window.location.hash || '').replace('#', '');
      var typeParam = params.get('type');
      if (hash === 'call' || typeParam === 'discovery-call') {
        activateTab('call');
      }

      // === Booking intent: record returning visitor intent ===
      // If a known visitor (has thk_vid cookie) lands on this page,
      // record their booking intent. Catches leads who submitted a form
      // weeks ago but come back later to book a call or tour.
      (function() {
        var match = document.cookie.match(/(?:^|;\s*)thk_vid=([^;]*)/);
        if (!match) return; // no visitor cookie — anonymous, nothing to record

        // Determine intent from active tab state
        var intent = (hash === 'call' || typeParam === 'discovery-call') ? 'discovery-call' : 'venue-tour';

        // Determine source from UTM campaign or fallback to page-visit
        var source = params.get('utm_campaign') || 'page-visit';

        fetch('/api/booking-intent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ intent: intent, source: source }),
          keepalive: true
        }).catch(function() {});
      })();
    })();
  </script>

</Base>

<style>
  /* === Date context banner === */
  .date-context {
    background: rgba(46, 64, 9, 0.06);
    border-bottom: 1px solid rgba(46, 64, 9, 0.1);
    padding: 14px 0;
    text-align: center;
  }

  .date-context__text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--brewery-dark);
    margin: 0;
  }

  /* === Hero override: tighter bottom padding for conversion page === */
  :global(.bookacall-hero) {
    padding-bottom: 0 !important;
  }

  :global(.bookacall-tabs-section) {
    padding-top: 24px !important;
    padding-bottom: 24px !important;
  }

  /* === Tab navigation === */
  .bk-tabs {
    display: flex;
    gap: 8px;
    justify-content: center;
    max-width: 1080px;
    margin: 0 auto 32px;
    border-bottom: 1px solid rgba(44, 24, 16, 0.12);
    flex-wrap: wrap;
  }

  .bk-tab {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 24px;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(44, 24, 16, 0.55);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
    margin-bottom: -1px;
  }

  .bk-tab:hover {
    color: var(--brewery-dark);
  }

  .bk-tab.is-active {
    color: var(--brewery-dark);
    border-bottom-color: var(--forest-olive);
  }

  .bk-tab svg {
    flex-shrink: 0;
    color: currentColor;
  }

  .bk-tab__badge {
    display: inline-block;
    padding: 2px 8px;
    background: var(--forest-olive);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 2px;
    margin-left: 4px;
  }

  /* === Tab panels === */
  .bk-panel {
    display: none;
    animation: fadeIn 0.25s ease;
  }

  .bk-panel.is-active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* === Booking Cards === */
  .booking-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
    max-width: 1080px;
    margin: 0 auto;
  }

  .booking-card__content {
    padding-right: var(--space-lg);
  }

  .booking-card__content h2 {
    margin-bottom: 1rem;
  }

  .booking-card__body {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: rgba(44, 24, 16, 0.8);
    margin-bottom: 1.5rem;
    max-width: 50ch;
  }

  .booking-card__details {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .booking-card__details li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(44, 24, 16, 0.7);
  }

  .booking-card__details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--forest-olive);
  }

  /* === HubSpot embed container ===
     HubSpot's MeetingsEmbedCode.js auto-resizes the iframe to fit
     its content. We don't set a min-height so there's no empty
     reserved space below the calendar before time slots are shown. */
  .meetings-iframe-container {
    width: 100%;
  }

  .meetings-iframe-container iframe {
    display: block;
  }

  /* === Fallback Contact === */
  :global(.bookacall-fallback) {
    padding: 32px 0 !important;
  }

  .contact-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .contact-fallback__label {
    color: rgba(44, 24, 16, 0.45);
    font-size: 0.875rem;
    margin-bottom: 0;
  }

  .contact-fallback__links {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .contact-fallback__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--dusty-coral);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-fallback__link:hover {
    color: var(--brewery-dark);
  }

  .contact-fallback__link--whatsapp {
    color: var(--forest-olive);
  }

  .contact-fallback__link--whatsapp:hover {
    color: var(--brewery-dark);
  }

  /* === Responsive === */
  @media (max-width: 768px) {
    .booking-card {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .booking-card__content {
      padding-right: 0;
    }

    .bk-tab {
      padding: 14px 16px;
      font-size: 0.875rem;
    }

    .bk-tab__badge {
      display: none;
    }
  }
</style>
