---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
---

<Base
  title="Book a Visit"
  description="See The Hackney in person or chat with our team. Book a venue tour or a quick discovery call to talk through your plans."
  pageType="conversion"
>

  <!-- Hero - tight, conversion-focused -->
  <div class="bookacall-hero">
    <div class="container">
      <p class="eyebrow">Next Step</p>
      <h1>Let's make it happen</h1>
      <p class="bookacall-hero__sub">You're one step closer. Choose how you'd like to connect with us.</p>
    </div>
  </div>

  <!-- Primary: Book a Venue Tour -->
  <Section bg="light" padding="compact" id="tour">
    <div class="booking-card booking-card--primary fade-in">
      <div class="booking-card__content">
        <p class="eyebrow">Recommended</p>
        <h2>Book a venue tour</h2>
        <p class="booking-card__body">
          Nothing beats seeing the space in person. Walk through the brewery, ask questions,
          and start picturing your day. Tours run 7 days a week and take around 30 minutes.
        </p>
        <ul class="booking-card__details">
          <li>Meet Hugo, our General Manager</li>
          <li>See the ceremony and reception spaces</li>
          <li>Talk through your ideas, dates, and budget</li>
          <li>No obligation - just a chance to see if we're the right fit</li>
        </ul>
      </div>
      <div class="booking-card__action">
        <!-- Placeholder: replace with Hugo's calendar embed (Calendly / Cal.com / custom) -->
        <div class="booking-placeholder">
          <div class="booking-placeholder__icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </div>
          <p class="booking-placeholder__text">Calendar booking will appear here</p>
          <p class="booking-placeholder__note">Waiting on booking tool setup</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Secondary: Book a Discovery Call -->
  <Section bg="light" padding="compact" border="top" id="call">
    <div class="booking-card booking-card--secondary fade-in">
      <div class="booking-card__content">
        <p class="eyebrow">Prefer to Chat First?</p>
        <h2>Book a discovery call</h2>
        <p class="booking-card__body">
          Not ready to visit just yet? Jump on a quick call with our team.
          We'll answer your questions, talk availability, and help you decide
          if The Hackney is right for your day.
        </p>
        <ul class="booking-card__details">
          <li>15-minute video or phone call</li>
          <li>No pressure, no hard sell</li>
          <li>Get answers before committing to a visit</li>
        </ul>
      </div>
      <div class="booking-card__action">
        <!-- Placeholder: replace with call booking embed (Calendly / Cal.com / custom) -->
        <div class="booking-placeholder">
          <div class="booking-placeholder__icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path>
            </svg>
          </div>
          <p class="booking-placeholder__text">Call booking will appear here</p>
          <p class="booking-placeholder__note">Waiting on booking tool setup</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Fallback contact -->
  <div class="contact-fallback">
    <div class="container">
      <div class="contact-fallback__inner">
        <p class="contact-fallback__label">Rather just get in touch?</p>
        <div class="contact-fallback__links">
          <a href="mailto:bookings@thehackney.co" class="contact-fallback__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            bookings@thehackney.co
          </a>
          <a href="https://wa.me/442079611604" class="contact-fallback__link contact-fallback__link--whatsapp">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>

</Base>

<style>
  /* === Hero === */
  .bookacall-hero {
    background-color: var(--warm-canvas);
    text-align: center;
    padding: 48px 0 24px;
  }

  .bookacall-hero h1 {
    color: var(--brewery-dark);
    margin-bottom: 0.75rem;
  }

  .bookacall-hero__sub {
    color: rgba(44, 24, 16, 0.7);
    font-size: 1.125rem;
    line-height: 1.65;
    max-width: 500px;
    margin: 0 auto;
  }

  /* === Booking Cards === */
  .booking-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
    max-width: 1080px;
    margin: 0 auto;
  }

  .booking-card__content {
    padding-right: var(--space-lg);
  }

  .booking-card__content h2 {
    margin-bottom: 1rem;
  }

  .booking-card__body {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: rgba(44, 24, 16, 0.8);
    margin-bottom: 1.5rem;
    max-width: 50ch;
  }

  .booking-card__details {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .booking-card__details li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(44, 24, 16, 0.7);
  }

  .booking-card__details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--forest-olive);
  }

  .booking-card--secondary .booking-card__details li::before {
    background-color: var(--dusty-coral);
  }

  /* === Placeholder (replaced with real embed later) === */
  .booking-placeholder {
    background: rgba(255, 255, 255, 0.6);
    border: 2px dashed rgba(44, 24, 16, 0.12);
    border-radius: 8px;
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
  }

  .booking-placeholder__icon {
    color: rgba(44, 24, 16, 0.2);
  }

  .booking-placeholder__text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(44, 24, 16, 0.4);
    margin-bottom: 0;
  }

  .booking-placeholder__note {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: rgba(44, 24, 16, 0.25);
    margin-bottom: 0;
  }

  /* === Fallback Contact === */
  .contact-fallback {
    background-color: var(--warm-canvas);
    border-top: 1px solid rgba(44, 24, 16, 0.08);
    padding: 32px 0;
  }

  .contact-fallback__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .contact-fallback__label {
    color: rgba(44, 24, 16, 0.45);
    font-size: 0.875rem;
    margin-bottom: 0;
  }

  .contact-fallback__links {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .contact-fallback__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--dusty-coral);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-fallback__link:hover {
    color: var(--brewery-dark);
  }

  .contact-fallback__link--whatsapp {
    color: var(--forest-olive);
  }

  .contact-fallback__link--whatsapp:hover {
    color: var(--brewery-dark);
  }

  /* === Responsive === */
  @media (max-width: 768px) {
    .booking-card {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .booking-card__content {
      padding-right: 0;
    }

    .booking-placeholder {
      min-height: 240px;
    }
  }
</style>
