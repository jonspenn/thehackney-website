---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<Base
  title="Book a Visit"
  description="See The Hackney in person or chat with our team. Book a venue tour or a quick discovery call to talk through your plans."
  pageType="conversion"
>

  <!-- Date context banner (visible when arriving from calendar with ?date=) -->
  <div class="date-context" id="date-context" style="display:none;">
    <div class="container">
      <p class="date-context__text">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style="vertical-align: middle; margin-right: 6px;">
          <circle cx="12" cy="12" r="12" fill="#2E4009"/>
          <path d="M7 12L10.5 15.5L17 8.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span id="date-context-text"></span>
      </p>
    </div>
  </div>

  <!-- Hero -->
  <Section bg="light" padding="compact" class="lets-talk-hero">
    <SectionHeader
      eyebrow="Next Step"
      heading="Let's make it happen"
      subtext="Choose how you'd like to connect with us."
      align="center"
    />
  </Section>

  <!-- Tab navigation + booking panels -->
  <Section bg="light" padding="compact" class="lets-talk-tabs-section">
    <div class="bk-tabs" role="tablist" aria-label="Booking options">
      <button
        type="button"
        role="tab"
        id="bk-tab-tour"
        class="bk-tab is-active"
        aria-selected="true"
        aria-controls="bk-panel-tour"
        data-tab="tour"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span>Book a venue tour</span>
        <span class="bk-tab__badge">Recommended</span>
      </button>
      <button
        type="button"
        role="tab"
        id="bk-tab-call"
        class="bk-tab"
        aria-selected="false"
        aria-controls="bk-panel-call"
        data-tab="call"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
        </svg>
        <span>Book a discovery call</span>
      </button>
    </div>

    <!-- Tour panel -->
    <div
      id="bk-panel-tour"
      class="bk-panel is-active"
      role="tabpanel"
      aria-labelledby="bk-tab-tour"
      tabindex="0"
    >
      <div class="booking-card">
        <div class="booking-card__content">
          <h2>See The Hackney in person</h2>
          <p class="booking-card__body">
            Nothing beats walking through the brewery, asking questions, and starting to picture your day.
            Tours run 7 days a week and take around 30 minutes.
          </p>
          <ul class="booking-card__details">
            <li>Meet our team in person</li>
            <li>See the ceremony and reception spaces</li>
            <li>Talk through your ideas, dates, and budget</li>
            <li>No obligation - just a chance to see if we're the right fit</li>
          </ul>
        </div>
        <div class="booking-card__action">
          <div class="meetings-iframe-container" data-src="https://meetings-eu1.hubspot.com/bookings-team/book-a-venue-tour?embed=true"></div>
          <script type="text/javascript" src="https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js" is:inline></script>
        </div>
      </div>
    </div>

    <!-- Call panel -->
    <div
      id="bk-panel-call"
      class="bk-panel"
      role="tabpanel"
      aria-labelledby="bk-tab-call"
      tabindex="0"
      hidden
    >
      <div class="booking-card">
        <div class="booking-card__content">
          <h2>Quick chat first?</h2>
          <p class="booking-card__body">
            Not ready to visit just yet? Jump on a quick call with our team.
            We'll answer your questions, talk availability, and help you decide if The Hackney is right for your day.
          </p>
          <ul class="booking-card__details">
            <li>15-minute video or phone call</li>
            <li>No pressure, no hard sell</li>
            <li>Get answers before committing to a visit</li>
          </ul>
        </div>
        <div class="booking-card__action">
          <div class="meetings-iframe-container" data-src="https://meetings-eu1.hubspot.com/bookings-team/book-a-discovery-call?embed=true"></div>
          <script type="text/javascript" src="https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js" is:inline></script>
        </div>
      </div>
    </div>
  </Section>

  <!-- Page-level scripts: date context + tab switching -->
  <script is:inline>
    (function() {
      // === Date context banner ===
      var params = new URLSearchParams(window.location.search);
      var date = params.get('date');
      if (date) {
        try {
          var d = new Date(date + 'T00:00:00');
          var formatted = d.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
          document.getElementById('date-context-text').textContent = formatted + ' looks available at The Hackney';
          document.getElementById('date-context').style.display = 'block';
        } catch(e) {}
      }

      // === Tab switching ===
      var tabs = document.querySelectorAll('.bk-tab');
      var panels = {
        tour: document.getElementById('bk-panel-tour'),
        call: document.getElementById('bk-panel-call')
      };
      var tabButtons = {
        tour: document.getElementById('bk-tab-tour'),
        call: document.getElementById('bk-tab-call')
      };

      function activateTab(name) {
        Object.keys(panels).forEach(function(key) {
          var isActive = key === name;
          panels[key].classList.toggle('is-active', isActive);
          panels[key].hidden = !isActive;
          tabButtons[key].classList.toggle('is-active', isActive);
          tabButtons[key].setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
      }

      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          var name = tab.getAttribute('data-tab');
          activateTab(name);
          // Update hash without scrolling
          if (history.replaceState) {
            history.replaceState(null, '', '#' + name);
          }
        });
      });

      // === Activate tab from URL hash or ?type= param ===
      var hash = (window.location.hash || '').replace('#', '');
      var typeParam = params.get('type');
      if (hash === 'call' || typeParam === 'discovery-call') {
        activateTab('call');
      }

      // === Booking intent: record returning visitor intent ===
      // If a known visitor (has thk_vid cookie) lands on this page,
      // record their booking intent. Catches leads who submitted a form
      // weeks ago but come back later to book a call or tour.
      (function() {
        var match = document.cookie.match(/(?:^|;\s*)thk_vid=([^;]*)/);
        if (!match) return; // no visitor cookie — anonymous, nothing to record

        // Determine intent from active tab state
        var intent = (hash === 'call' || typeParam === 'discovery-call') ? 'discovery-call' : 'venue-tour';

        // Determine source from UTM campaign or fallback to page-visit
        var source = params.get('utm_campaign') || 'page-visit';

        fetch('/api/booking-intent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ intent: intent, source: source }),
          keepalive: true
        }).catch(function() {});
      })();
    })();
  </script>

</Base>

<style>
  /* === Date context banner === */
  .date-context {
    background: rgba(46, 64, 9, 0.06);
    border-bottom: 1px solid rgba(46, 64, 9, 0.1);
    padding: 14px 0;
    text-align: center;
  }

  .date-context__text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--brewery-dark);
    margin: 0;
  }

  /* === Hero override: tighter bottom padding for conversion page === */
  :global(.lets-talk-hero) {
    padding-bottom: 0 !important;
  }

  :global(.lets-talk-tabs-section) {
    padding-top: 24px !important;
    padding-bottom: 24px !important;
  }

  /* === Tab navigation === */
  /* Tabs styled as a filled button-pair, matching the site's CTA language
     (Mid Olive fill = primary, outline = secondary). They functionally
     remain tabs but read as proper CTAs - the conversion paths on this
     page deserve more visual weight than the previous underline pattern. */
  .bk-tabs {
    display: flex;
    gap: 12px;
    justify-content: center;
    max-width: 1080px;
    margin: 0 auto 32px;
    flex-wrap: wrap;
  }

  .bk-tab {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: transparent;
    border: 1.5px solid var(--mid-olive);
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--mid-olive);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.1s ease;
    letter-spacing: 0.01em;
  }

  .bk-tab:hover:not(.is-active) {
    background: rgba(73, 89, 14, 0.08);
    border-color: var(--mid-olive);
    color: var(--brewery-dark);
  }

  .bk-tab.is-active {
    background: var(--mid-olive);
    color: #fff;
    border-color: var(--mid-olive);
    /* Subtle lift to reinforce the primary state */
    box-shadow: 0 2px 8px rgba(73, 89, 14, 0.18);
  }

  .bk-tab:active {
    transform: translateY(1px);
  }

  .bk-tab svg {
    flex-shrink: 0;
    color: currentColor;
  }

  /* Recommended badge sits inside the active button and uses an inverted
     palette so it reads on the green fill - Warm Canvas bg + Mid Olive text. */
  .bk-tab__badge {
    display: inline-block;
    padding: 3px 9px;
    background: var(--warm-canvas);
    color: var(--mid-olive);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 2px;
    margin-left: 4px;
  }

  /* === Tab panels === */
  .bk-panel {
    display: none;
    animation: fadeIn 0.25s ease;
  }

  .bk-panel.is-active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* === Booking Cards === */
  .booking-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
    max-width: 1080px;
    margin: 0 auto;
  }

  .booking-card__content {
    padding-right: var(--space-lg);
  }

  .booking-card__content h2 {
    margin-bottom: 1rem;
  }

  .booking-card__body {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: rgba(44, 24, 16, 0.8);
    margin-bottom: 1.5rem;
    max-width: 50ch;
  }

  .booking-card__details {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .booking-card__details li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(44, 24, 16, 0.7);
  }

  .booking-card__details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--forest-olive);
  }

  /* === HubSpot embed container ===
     HubSpot's MeetingsEmbedCode.js auto-resizes the iframe to fit
     its content. We don't set a min-height so there's no empty
     reserved space below the calendar before time slots are shown. */
  .meetings-iframe-container {
    width: 100%;
  }

  .meetings-iframe-container iframe {
    display: block;
  }

  /* === Responsive === */
  @media (max-width: 768px) {
    .booking-card {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .booking-card__content {
      padding-right: 0;
    }

    .bk-tab {
      padding: 14px 16px;
      font-size: 0.875rem;
    }

    .bk-tab__badge {
      display: none;
    }
  }
</style>
