---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
---

<Base title="Corporate Events" description="Corporate events, product launches, team socials and conferences at The Hackney, East London.">
  <Hero
    eyebrow="Corporate events"
    heading="Impress, connect, celebrate"
    subheading="From product launches to team away days, deliver an experience your guests will actually remember."
    ctaLabel="Get in touch"
    ctaHref="/contact/"
  />

  <section class="section">
    <div class="container">
      <h2>Corporate events at The Hackney</h2>
      <p>
        Content coming soon - event formats, AV capabilities, catering, case studies and enquiry process.
      </p>
    </div>
  </section>
</Base>
