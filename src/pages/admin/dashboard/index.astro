---
/**
 * Internal analytics dashboard - combined view.
 *
 * URL: /admin/dashboard/
 *
 * Protected by Cloudflare Access (zero trust). Only verified team
 * emails can reach this page. Cloudflare intercepts the request at the
 * edge before it hits the origin.
 *
 * NOT linked from anywhere on the public site. Hidden from:
 *   - Google + all search engines (meta robots)
 *   - AI training crawlers (named user-agents)
 *   - The public sitemap (filtered in astro.config.mjs)
 *   - Social previews (no og: tags, no canonical)
 *
 * Audience: Jon, Hugo, and James.
 * Built 2026-04-14.
 */
import AdminDashboard from '../../../components/AdminDashboard.jsx';
import pricing from '../../../data/wedding-pricing.json';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Hard noindex -->
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex, notranslate, nocache, max-snippet:0, max-image-preview:none, max-video-preview:0" />
    <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet, noimageindex" />
    <meta name="googlebot-news" content="noindex, nofollow" />
    <meta name="bingbot" content="noindex, nofollow, noarchive, nosnippet" />
    <meta name="slurp" content="noindex, nofollow, noarchive, nosnippet" />
    <meta name="duckduckbot" content="noindex, nofollow" />
    <meta name="baiduspider" content="noindex, nofollow" />
    <meta name="yandex" content="noindex, nofollow" />
    <meta name="ChatGPT-User" content="noindex, nofollow" />
    <meta name="GPTBot" content="noindex, nofollow" />
    <meta name="Google-Extended" content="noindex, nofollow" />
    <meta name="ClaudeBot" content="noindex, nofollow" />
    <meta name="anthropic-ai" content="noindex, nofollow" />
    <meta name="PerplexityBot" content="noindex, nofollow" />
    <meta name="CCBot" content="noindex, nofollow" />
    <meta name="Applebot-Extended" content="noindex, nofollow" />

    <meta name="referrer" content="no-referrer" />

    <title>Dashboard - The Hackney</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@400;500;700&display=swap"
    />

    <style is:global>
      :root {
        --color-warm-canvas: #F5F0E8;
        --color-warm-white: #FFFDF9;
        --color-brewery-dark: #2C1810;
        --color-forest-olive: #2E4009;
        --color-mid-olive: #49590E;
        --color-fired-brick: #8C472E;
        --color-dusty-coral: #BF7256;
        --color-mahogany: #40160C;
        --border-warm: rgba(64, 22, 12, 0.10);
        --border-subtle: rgba(64, 22, 12, 0.06);
        --text-muted: rgba(44, 24, 16, 0.55);
        --text-faint: rgba(44, 24, 16, 0.4);
        --serif: 'Cormorant Garamond', Georgia, serif;
        --sans: 'DM Sans', system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: var(--sans);
        background: var(--color-warm-canvas);
        color: var(--color-brewery-dark);
        font-size: 15px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }

      .rep-shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: 48px 32px 96px;
      }

      /* Dashboard page header - tightened to a single row (2026-04-27).
         Eyebrow + title left, auto-refresh meta right. ~60px total height. */
      .rep-header {
        display: flex; align-items: baseline; justify-content: space-between;
        gap: 16px; margin: 0 0 24px;
      }
      .rep-header__left { min-width: 0; }
      .rep-eyebrow {
        font-family: var(--sans);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-dusty-coral);
        margin: 0 0 2px;
      }
      .rep-title {
        font-family: var(--serif);
        font-size: 28px;
        font-weight: 500;
        margin: 0;
        color: var(--color-brewery-dark);
        letter-spacing: -0.01em;
        line-height: 1.05;
      }
      .rep-header__meta {
        font-family: var(--sans);
        font-size: 12px;
        color: rgba(44, 24, 16, 0.55);
        margin: 0; flex-shrink: 0; text-align: right;
      }
      /* Legacy rep-lede kept for backwards-compatibility (unused on dashboard) */
      .rep-lede {
        font-family: var(--sans);
        font-size: 14px;
        max-width: 640px;
        margin: 0 0 24px;
        color: rgba(44, 24, 16, 0.7);
      }

      .rep-state {
        padding: 64px;
        text-align: center;
        font-size: 16px;
        color: rgba(44, 24, 16, 0.6);
      }
      .rep-state--error { color: var(--color-fired-brick); }
      .rep-retry {
        margin-top: 16px;
        font-family: var(--sans);
        background: var(--color-mid-olive);
        color: var(--color-warm-canvas);
        border: none;
        padding: 10px 20px;
        border-radius: 2px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
      }

      .rep { position: relative; }

      /* ── Tabs ── */
      .adm-tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 24px;
        border-bottom: 1px solid var(--border-warm);
        padding-bottom: 0;
        align-items: flex-end;
      }
      .adm-tab {
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: transparent;
        border: 1px solid transparent;
        border-bottom: none;
        padding: 10px 20px;
        cursor: pointer;
        color: rgba(44, 24, 16, 0.55);
        border-radius: 2px 2px 0 0;
        transition: color 0.15s, background 0.15s;
        margin-bottom: -1px;
        text-decoration: none;
        display: inline-block;
        line-height: inherit;
      }
      a.adm-tab:hover,
      a.adm-tab:focus {
        text-decoration: none;
      }
      .adm-tab:hover {
        color: var(--color-brewery-dark);
        background: transparent;
      }
      .adm-tab--active {
        color: var(--color-brewery-dark);
        background: transparent;
        border-color: transparent;
        box-shadow: inset 0 -2.5px 0 0 #2E4009;
      }
      .adm-refresh {
        position: static;
        margin-left: auto;
        margin-bottom: 4px;
      }

      /* ── Stat cards ── */
      .rep-totals {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 12px;
      }
      .rep-totals--today { margin-bottom: 32px; }
      @media (max-width: 720px) { .rep-totals { grid-template-columns: repeat(2, 1fr); } }
      .rep-stat {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-radius: 2px;
        padding: 20px;
      }
      .rep-stat--today {
        background: rgba(73, 89, 14, 0.04);
        border-color: rgba(73, 89, 14, 0.15);
      }
      .rep-stat__num {
        font-family: var(--serif);
        font-size: 32px;
        font-weight: 500;
        line-height: 1.1;
        color: var(--color-brewery-dark);
      }
      .rep-stat__label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(44, 24, 16, 0.55);
        margin-top: 8px;
      }

      .rep-refresh {
        font-family: var(--sans);
        background: transparent;
        color: rgba(46, 64, 9, 0.85);
        border: 1px solid rgba(64, 22, 12, 0.18);
        padding: 6px 12px;
        border-radius: 2px;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
      }
      .rep-refresh:hover {
        background: rgba(140, 71, 46, 0.05);
        color: var(--color-brewery-dark);
      }

      .rep-empty {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-radius: 2px;
        padding: 32px;
        text-align: center;
        color: rgba(44, 24, 16, 0.7);
        margin-bottom: 32px;
      }
      .rep-empty-small {
        color: rgba(44, 24, 16, 0.5);
        font-size: 14px;
        padding: 16px 0;
      }

      .rep-section { margin-top: 48px; }
      .rep-h2 {
        font-family: var(--serif);
        font-size: 26px;
        font-weight: 500;
        margin: 0 0 4px;
        color: var(--color-brewery-dark);
      }
      .rep-sub {
        font-size: 13px;
        color: rgba(44, 24, 16, 0.6);
        margin: 0 0 20px;
      }

      /* ── Top lists ── */
      .rep-toplist {
        list-style: none;
        margin: 0;
        padding: 0;
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-radius: 2px;
      }
      .rep-toprow {
        display: grid;
        grid-template-columns: 32px minmax(180px, 1.5fr) 3fr 48px;
        align-items: center;
        gap: 16px;
        padding: 12px 20px;
        border-bottom: 1px solid var(--border-subtle);
      }
      .rep-toprow:last-child { border-bottom: none; }
      .rep-toprow--compact { grid-template-columns: 32px minmax(140px, 1.2fr) 3fr 48px; padding: 10px 20px; }
      .rep-toprank { font-family: var(--serif); font-size: 18px; color: var(--color-dusty-coral); font-weight: 500; }
      .rep-topdate { font-size: 14px; color: var(--color-brewery-dark); }
      .rep-topbar { background: rgba(44, 24, 16, 0.06); height: 8px; border-radius: 2px; overflow: hidden; }
      .rep-topbar__fill { display: block; height: 100%; background: var(--color-mid-olive); }
      .rep-topcount { font-family: var(--serif); font-size: 18px; text-align: right; color: var(--color-brewery-dark); font-weight: 500; }
      @media (max-width: 720px) {
        .rep-toprow, .rep-toprow--compact { grid-template-columns: 24px 1fr 40px; gap: 10px; }
        .rep-topbar { display: none; }
      }

      /* ── Two-column layout ── */
      .rep-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
      @media (max-width: 720px) { .rep-two-col { grid-template-columns: 1fr; } }

      /* ── Device cards ── */
      .rep-device-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; }
      .rep-device-card {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-radius: 8px;
        padding: 20px;
        text-align: center;
      }
      .rep-device-card__pct { font-family: var(--serif); font-size: 32px; font-weight: 500; color: var(--color-brewery-dark); line-height: 1.1; }
      .rep-device-card__label { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(44, 24, 16, 0.55); margin-top: 8px; }
      .rep-device-card__count { font-size: 12px; color: rgba(44, 24, 16, 0.45); margin-top: 4px; }

      /* ── Event badges ── */
      .rep-event-badge { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 2px 8px; border-radius: 2px; white-space: nowrap; }
      .rep-event-badge--page { background: rgba(46,64,9,0.1); color: var(--color-forest-olive); }
      .rep-event-badge--cta { background: rgba(73,89,14,0.12); color: var(--color-mid-olive); }
      .rep-event-badge--date { background: rgba(191,114,86,0.12); color: var(--color-dusty-coral); }
      .rep-event-badge--scroll { background: rgba(44,24,16,0.06); color: rgba(44,24,16,0.6); }
      .rep-event-badge--questionnaire { background: rgba(140,71,46,0.1); color: var(--color-fired-brick); }
      .rep-event-badge--form { background: rgba(73,89,14,0.12); color: var(--color-mid-olive); }
      .rep-event-badge--brochure { background: rgba(191,114,86,0.12); color: var(--color-dusty-coral); }

      /* ── Day of week chart ── */
      .rep-dow {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-radius: 8px;
        padding: 24px;
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 12px;
        align-items: end;
      }
      .rep-dow__col { display: flex; flex-direction: column; align-items: center; gap: 6px; }
      .rep-dow__bar { height: 160px; width: 100%; max-width: 56px; display: flex; align-items: flex-end; background: rgba(44, 24, 16, 0.04); border-radius: 2px; }
      .rep-dow__fill { width: 100%; background: var(--color-mid-olive); border-radius: 2px 2px 0 0; min-height: 2px; }
      .rep-dow__count { font-family: var(--serif); font-size: 16px; font-weight: 500; }
      .rep-dow__label { font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(44, 24, 16, 0.55); }

      /* ── Heatmap ── */
      .rep-heatmap { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
      @media (max-width: 1000px) { .rep-heatmap { grid-template-columns: repeat(3, 1fr); } }
      @media (max-width: 720px) { .rep-heatmap { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 480px) { .rep-heatmap { grid-template-columns: 1fr; } }
      .rep-month { background: var(--color-warm-white); border: 1px solid var(--border-warm); border-radius: 8px; padding: 14px; }
      .rep-month__label { font-family: var(--serif); font-size: 16px; font-weight: 500; text-align: center; margin-bottom: 8px; }
      .rep-month__dow { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; font-size: 9px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: rgba(44, 24, 16, 0.45); text-align: center; margin-bottom: 4px; }
      .rep-month__grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
      .rep-month__cell { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 500; background: rgba(44, 24, 16, 0.04); color: rgba(44, 24, 16, 0.55); border-radius: 2px; }
      .rep-month__cell--blank { background: transparent; }

      /* ── Tables ── */
      .rep-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: thin; scrollbar-color: rgba(44,24,16,0.2) transparent; }
      .rep-table-wrap::-webkit-scrollbar { height: 8px; }
      .rep-table-wrap::-webkit-scrollbar-track { background: rgba(44,24,16,0.04); border-radius: 4px; }
      .rep-table-wrap::-webkit-scrollbar-thumb { background: rgba(44,24,16,0.18); border-radius: 4px; }
      .rep-table-wrap::-webkit-scrollbar-thumb:hover { background: rgba(44,24,16,0.3); }
      .rep-table { width: 100%; background: var(--color-warm-white); border: 1px solid var(--border-warm); border-collapse: collapse; border-radius: 8px; overflow: hidden; min-width: 600px; }
      .rep-table th, .rep-table td { padding: 10px 16px; text-align: left; font-size: 13px; border-bottom: 1px solid var(--border-subtle); }
      .rep-table th { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-fired-brick); background: rgba(64, 22, 12, 0.03); }
      .rep-table tr:last-child td { border-bottom: none; }
      .rep-table__ref { color: rgba(44, 24, 16, 0.55); font-size: 12px; max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

      .rep-footer {
        margin-top: 64px;
        padding-top: 24px;
        border-top: 1px solid rgba(44, 24, 16, 0.1);
        font-size: 11px;
        color: rgba(44, 24, 16, 0.45);
        line-height: 1.6;
      }

      /* ── Wedding leads table ── */
      .rep-table--sortable th { cursor: pointer; user-select: none; }
      .rep-table--sortable th:hover { color: var(--color-brewery-dark, #2C1810); }
      .rep-table--sortable { min-width: 1400px; }
      .rep-row--hot { background: rgba(46, 64, 9, 0.06); }
      .rep-row--hot td:first-child { border-left: 3px solid rgba(46, 64, 9, 0.6); }

      .rep-urgency, .rep-budget {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 2px 8px;
        border-radius: 2px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.04em;
        white-space: nowrap;
      }
      .rep-urgency__stage {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        font-size: 10px;
        font-weight: 700;
        line-height: 1;
        flex-shrink: 0;
      }
      /* Stage 1 - Browsing: muted, low priority */
      .rep-urgency--browsing { background: rgba(44, 24, 16, 0.05); color: rgba(44, 24, 16, 0.50); }
      .rep-urgency--browsing .rep-urgency__stage { background: rgba(44, 24, 16, 0.10); color: rgba(44, 24, 16, 0.45); }
      /* Stage 2 - Shortlisting: warmer, they have a list */
      .rep-urgency--comparing { background: rgba(191, 114, 86, 0.08); color: var(--color-fired-brick); }
      .rep-urgency--comparing .rep-urgency__stage { background: rgba(191, 114, 86, 0.18); color: var(--color-fired-brick); }
      /* Stage 3 - Ready to book: strong olive, action needed */
      .rep-urgency--ready { background: rgba(46, 64, 9, 0.10); color: var(--color-forest-olive); }
      .rep-urgency--ready .rep-urgency__stage { background: var(--color-forest-olive); color: #fff; }
      /* Stage 4 - Urgent: bold olive, call now */
      .rep-urgency--asap { background: rgba(46, 64, 9, 0.15); color: var(--color-forest-olive); }
      .rep-urgency--asap .rep-urgency__stage { background: var(--color-mid-olive); color: #fff; }
      /* Fallbacks for unmapped values */
      .rep-urgency--exploring { background: rgba(44, 24, 16, 0.05); color: rgba(44, 24, 16, 0.50); }
      .rep-urgency--exploring .rep-urgency__stage { background: rgba(44, 24, 16, 0.10); color: rgba(44, 24, 16, 0.45); }
      .rep-urgency--unknown { background: rgba(44, 24, 16, 0.05); color: rgba(44, 24, 16, 0.50); }
      .rep-urgency--unknown .rep-urgency__stage { background: rgba(44, 24, 16, 0.10); color: rgba(44, 24, 16, 0.45); }

      .rep-budget--20k-plus { background: rgba(46, 64, 9, 0.15); color: #2E4009; }
      .rep-budget--10k-20k { background: rgba(46, 64, 9, 0.10); color: #2E4009; }
      .rep-budget--5k-10k { background: rgba(191, 114, 86, 0.12); color: #8C472E; }
      .rep-budget--under-5k { background: rgba(44, 24, 16, 0.06); color: rgba(44, 24, 16, 0.55); }

      /* ── Leads control panel (sub-tabs + filters unified) ── */
      .lead-panel {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-radius: 8px;
        margin-bottom: 8px;
        overflow: hidden;
      }
      .lead-panel__tabs {
        display: flex; gap: 4px; padding: 8px 12px;
        overflow-x: auto;
      }
      .lead-panel__divider {
        height: 1px;
        background: rgba(44, 24, 16, 0.08);
        margin: 0 12px;
      }
      .lead-panel__filters {
        padding: 12px 16px;
        display: flex; flex-direction: column; gap: 10px;
      }

      .adm-subtab {
        padding: 7px 14px; border: none; border-radius: 4px;
        background: transparent; cursor: pointer;
        font-family: 'DM Sans', sans-serif; font-size: 12px;
        font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
        color: rgba(44, 24, 16, 0.45); white-space: nowrap;
        transition: all 0.15s ease;
      }
      .adm-subtab:hover { color: rgba(44, 24, 16, 0.75); background: rgba(44, 24, 16, 0.04); }
      .adm-subtab--active {
        background: rgba(191, 114, 86, 0.10);
        color: var(--color-fired-brick);
      }
      .adm-subtab__count {
        display: inline-block; margin-left: 5px; padding: 1px 7px;
        border-radius: 10px; font-size: 11px; font-weight: 600;
        background: rgba(46, 64, 9, 0.12); color: #2E4009;
      }
      .adm-subtab--active .adm-subtab__count {
        background: rgba(46, 64, 9, 0.2);
      }
      .lead-panel__status {
        padding: 8px 16px 10px;
        font-size: 12px;
        color: var(--color-dusty-coral);
        border-top: 1px solid var(--border-subtle);
        display: flex; align-items: center; justify-content: space-between;
      }
      .lead-toolbar__recycle-btn {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 600;
        padding: 4px 10px; border-radius: 4px; cursor: pointer;
        background: none; border: 1px solid rgba(44,24,16,0.15); color: rgba(44,24,16,0.5);
        transition: all 0.15s;
      }
      .lead-toolbar__recycle-btn:hover { border-color: rgba(44,24,16,0.3); color: rgba(44,24,16,0.7); }
      .lead-toolbar__recycle-btn--active { background: rgba(44,24,16,0.06); color: #2C1810; border-color: rgba(44,24,16,0.2); }

      /* Selection action bar */
      .lead-panel__actions {
        display: flex; align-items: center; gap: 12px;
        padding: 8px 16px; background: rgba(140,71,46,0.06);
        border-top: 1px solid rgba(140,71,46,0.15);
        font-family: 'DM Sans', sans-serif; font-size: 12px;
      }
      .lead-panel__actions-count { font-weight: 700; color: #2C1810; }
      .lead-panel__delete-btn {
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600;
        padding: 5px 14px; border-radius: 4px; cursor: pointer;
        background: #8C472E; color: #fff; border: none;
      }
      .lead-panel__delete-btn:hover { background: #6e3722; }
      .lead-panel__restore-btn {
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600;
        padding: 5px 14px; border-radius: 4px; cursor: pointer;
        background: #2E4009; color: #fff; border: none;
      }
      .lead-panel__restore-btn:hover { background: #1f2d06; }
      .lead-panel__confirm {
        display: flex; align-items: center; gap: 8px;
        font-size: 12px; color: #2C1810;
      }
      .lead-panel__confirm-yes {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 700;
        padding: 4px 12px; border-radius: 4px; cursor: pointer;
        background: #8C472E; color: #fff; border: none;
      }
      .lead-panel__confirm-yes:hover { background: #6e3722; }
      .lead-panel__confirm-yes--final { background: #6e3722; }
      .lead-panel__confirm-yes--final:hover { background: #4a2517; }
      .lead-panel__confirm-no {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 600;
        padding: 4px 12px; border-radius: 4px; cursor: pointer;
        background: none; border: 1px solid rgba(44,24,16,0.2); color: rgba(44,24,16,0.6);
      }
      .lead-panel__confirm-no:hover { border-color: rgba(44,24,16,0.4); }
      .lead-checkbox {
        width: 15px; height: 15px; cursor: pointer; accent-color: #2E4009;
      }

      /* ── Pipeline view ── */
      .pipe-panel {
        background: var(--color-warm-white); border: 1px solid var(--border-warm);
        border-radius: 6px; overflow: hidden;
      }
      .pipe-panel__tabs {
        display: flex; gap: 4px; padding: 8px 12px; flex-wrap: wrap;
        border-bottom: 1px solid var(--border-subtle);
      }
      .pipe-funnel {
        display: flex; align-items: flex-end; gap: 0; padding: 32px 24px 24px;
        overflow-x: auto;
      }
      .pipe-stage-col {
        flex: 1; display: flex; flex-direction: column; align-items: center;
        min-width: 80px; position: relative;
      }
      .pipe-conv-arrow {
        position: absolute; top: -20px; left: 50%; transform: translateX(-50%);
        font-size: 11px; color: rgba(44,24,16,0.35); white-space: nowrap;
      }
      .pipe-conv-arrow__pct { font-weight: 600; }
      .pipe-stage {
        width: 100%; padding: 16px 8px 12px; border: 2px solid transparent;
        border-radius: 6px; background: none; cursor: pointer;
        display: flex; flex-direction: column; align-items: center; gap: 6px;
        transition: border-color 0.15s, background 0.15s;
      }
      .pipe-stage:hover { background: rgba(46,64,9,0.04); }
      .pipe-stage--selected {
        border-color: var(--color-forest-olive);
        background: rgba(46,64,9,0.06);
      }
      .pipe-stage--empty { opacity: 0.45; }
      .pipe-stage__bar {
        height: 8px; border-radius: 4px; background: var(--color-forest-olive);
        min-width: 8px; transition: width 0.3s;
      }
      .pipe-stage__count {
        font-size: 28px; font-weight: 700; color: var(--color-brewery-dark);
        line-height: 1;
      }
      .pipe-stage--empty .pipe-stage__count { color: rgba(44,24,16,0.25); }
      .pipe-stage__label {
        font-size: 12px; font-weight: 600; color: rgba(44,24,16,0.55);
        text-transform: uppercase; letter-spacing: 0.04em;
      }
      .pipe-stage--selected .pipe-stage__label { color: var(--color-forest-olive); }
      .pipe-terminal {
        display: flex; gap: 8px; padding: 0 24px 16px; flex-wrap: wrap;
      }
      .pipe-terminal__btn {
        padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 500;
        border: 1px solid rgba(140,71,46,0.2); background: rgba(140,71,46,0.06);
        color: #8C472E; cursor: pointer; transition: all 0.15s;
      }
      .pipe-terminal__btn:hover { background: rgba(140,71,46,0.12); }
      .pipe-terminal__btn--selected {
        border-color: #8C472E; background: rgba(140,71,46,0.15);
        font-weight: 700;
      }
      .pipe-panel__status {
        padding: 8px 16px 10px; font-size: 12px; color: var(--color-dusty-coral);
        border-top: 1px solid var(--border-subtle);
      }
      .pipe-panel__defn {
        color: rgba(44,24,16,0.4); font-style: italic;
      }
      .pipe-collapse-toggle {
        display: flex; align-items: center; gap: 8px; width: 100%;
        padding: 10px 16px; border: none; background: none; cursor: pointer;
        font-family: 'Cormorant Garamond', serif; font-size: 17px;
        font-weight: 600; color: var(--color-brewery-dark); text-align: left;
      }
      .pipe-collapse-toggle:hover { background: rgba(46,64,9,0.03); }
      .pipe-collapse-toggle__arrow {
        font-size: 10px; color: rgba(44,24,16,0.35);
        transition: transform 0.2s; display: inline-block;
      }
      .pipe-collapse-toggle__arrow--open { transform: rotate(90deg); }
      .pipe-collapse-toggle__summary {
        font-family: 'DM Sans', sans-serif; font-size: 12px;
        font-weight: 400; color: rgba(44,24,16,0.4); margin-left: 4px;
      }

      /* ── Pipeline monthly trends ── */
      .pipe-trends {
        margin-top: 8px; background: var(--color-warm-white);
        border: 1px solid var(--border-warm); border-radius: 6px;
        padding: 0 0 16px;
      }
      .pipe-trends__sub {
        font-size: 12px; color: rgba(44,24,16,0.45); margin: 0 16px 16px 16px;
      }
      .pipe-legend {
        display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 12px;
        padding: 0 16px;
      }
      .pipe-legend__item {
        display: flex; align-items: center; gap: 5px;
        font-size: 11px; color: rgba(44,24,16,0.6); font-weight: 500;
      }
      .pipe-legend__swatch {
        width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0;
      }
      .pipe-chart {
        display: flex; gap: 2px; align-items: flex-end;
        overflow-x: auto; padding: 0 16px 4px; min-height: 180px;
      }
      .pipe-chart__col {
        flex: 1; min-width: 36px; display: flex; flex-direction: column;
        align-items: center;
      }
      .pipe-chart__bars {
        display: flex; gap: 2px; align-items: flex-end;
        height: 140px; width: 100%;
        justify-content: center;
      }
      .pipe-chart__bar {
        flex: 1; max-width: 14px; border-radius: 2px 2px 0 0;
        position: relative; transition: height 0.3s;
        min-width: 4px;
      }
      .pipe-chart__bar--empty { background: transparent !important; }
      .pipe-chart__val {
        position: absolute; top: -16px; left: 50%; transform: translateX(-50%);
        font-size: 10px; font-weight: 600; color: var(--color-brewery-dark);
        white-space: nowrap;
      }
      .pipe-chart__label {
        font-size: 11px; color: rgba(44,24,16,0.5); margin-top: 6px;
        font-weight: 500;
      }
      .pipe-chart__col--future { opacity: 0.3; }
      .pipe-chart__col--future .pipe-chart__bars {
        background: repeating-linear-gradient(
          -45deg, transparent, transparent 3px,
          rgba(44,24,16,0.04) 3px, rgba(44,24,16,0.04) 6px
        );
        border-radius: 2px;
      }

      /* ── Bookings tab ── */
      .bookings-view { padding: 0 4px; }
      .bookings-kpis {
        display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px;
      }
      .bookings-kpi {
        flex: 1 1 140px; min-width: 140px; padding: 10px 14px;
        background: rgba(44,24,16,0.02); border-radius: 4px;
        border-left: 3px solid #2C1810;
      }
      .bookings-kpi__label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: rgba(44,24,16,0.45); margin-bottom: 2px; }
      .bookings-kpi__value { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: #2C1810; }
      .bookings-kpi__change { font-size: 11px; margin-top: 2px; font-weight: 500; }
      .bookings-chart { margin-bottom: 20px; }
      .bookings-chart__title { font-family: 'Cormorant Garamond', serif; font-size: 16px; font-weight: 600; color: #2C1810; margin: 0 0 8px 0; }
      .bookings-legend {
        display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 8px;
      }
      .bookings-legend__item {
        display: inline-flex; align-items: center; font-size: 12px; font-weight: 500;
        color: #2C1810; cursor: pointer; background: none; border: none;
        padding: 2px 6px; border-radius: 3px; transition: opacity 0.15s;
      }
      .bookings-legend__item:hover { background: rgba(44,24,16,0.04); }
      .bookings-table-wrap { overflow-x: auto; margin-bottom: 12px; }
      .bookings-table {
        width: 100%; border-collapse: collapse; font-size: 12px;
      }
      .bookings-table th {
        text-align: right; padding: 6px 10px; font-weight: 600; font-size: 11px;
        text-transform: uppercase; letter-spacing: 0.4px; color: rgba(44,24,16,0.5);
        border-bottom: 1px solid rgba(44,24,16,0.1);
      }
      .bookings-table th:first-child { text-align: left; }
      .bookings-table td {
        text-align: right; padding: 5px 10px; border-bottom: 1px solid rgba(44,24,16,0.04);
        color: #2C1810; font-variant-numeric: tabular-nums;
      }
      .bookings-table td:first-child { text-align: left; }
      .bookings-table__row--hover { background: rgba(44,24,16,0.02); }
      .bookings-table__total td { border-top: 2px solid rgba(44,24,16,0.15); font-weight: 700; }
      .bookings-table__cell--clickable:hover { background: rgba(44,24,16,0.03); }
      .bookings-drill {
        margin-bottom: 16px; padding: 12px 16px;
        background: rgba(44,24,16,0.02); border: 1px solid rgba(44,24,16,0.08);
        border-radius: 4px;
      }
      .bookings-drill__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
      .bookings-drill__title {
        font-family: 'Cormorant Garamond', serif; font-size: 15px; font-weight: 600;
        color: #2C1810; margin: 0;
      }
      .bookings-drill__total { font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 400; color: rgba(44,24,16,0.5); }
      .bookings-drill__close {
        background: none; border: none; font-size: 20px; color: rgba(44,24,16,0.3);
        cursor: pointer; padding: 0 4px; line-height: 1;
      }
      .bookings-drill__close:hover { color: #2C1810; }
      .bookings-drill__table-wrap { overflow-x: auto; }
      .bookings-drill__table { width: 100%; border-collapse: collapse; font-size: 12px; }
      .bookings-drill__table th {
        text-align: right; padding: 5px 10px; font-weight: 600; font-size: 10px;
        text-transform: uppercase; letter-spacing: 0.4px; color: rgba(44,24,16,0.45);
        border-bottom: 1px solid rgba(44,24,16,0.08);
      }
      .bookings-drill__table td {
        text-align: right; padding: 4px 10px; border-bottom: 1px solid rgba(44,24,16,0.04);
        color: #2C1810; font-variant-numeric: tabular-nums; font-size: 12px;
      }
      .bookings-footnote { font-size: 11px; color: rgba(44,24,16,0.35); font-style: italic; margin-top: 8px; }

      /* ── Customers tab ── */
      .cust-kpis {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px; margin-bottom: 16px;
      }
      .cust-kpi {
        background: #F5F0E8; border: 1px solid rgba(44,24,16,0.08); border-radius: 6px;
        padding: 14px 16px; min-width: 0;
      }
      .cust-kpi__label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: rgba(44,24,16,0.45); margin-bottom: 2px; }
      .cust-kpi__value { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: #2C1810; }
      .cust-row { transition: background 0.15s; }
      .cust-row:hover { background: rgba(46,64,9,0.04); }
      .cust-source-summary { margin-top: 24px; }
      .cust-source-summary__title {
        font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600;
        color: #2C1810; margin-bottom: 12px;
      }
      .cust-source-summary__grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 10px;
      }
      .cust-source-card {
        background: #F5F0E8; border: 1px solid rgba(44,24,16,0.08); border-radius: 6px;
        padding: 12px 14px;
      }
      .cust-source-card__label { font-size: 12px; font-weight: 600; color: #2C1810; margin-bottom: 4px; }
      .cust-source-card__value { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; color: #2E4009; }
      .cust-source-card__count { font-size: 11px; color: rgba(44,24,16,0.45); margin-top: 2px; }
      .cust-hs-link { color: #2E4009; font-weight: 500; text-decoration: none; font-size: 12px; }
      .cust-hs-link:hover { text-decoration: underline; color: #49590E; }

      /* ── Cross-sell badges ── */
      .rep-cross-sell { display: flex; gap: 4px; flex-wrap: wrap; }
      .rep-cross-sell__badge {
        display: inline-block; padding: 2px 8px; border-radius: 10px;
        font-size: 11px; font-weight: 500; white-space: nowrap;
        background: rgba(191, 114, 86, 0.12); color: #8C472E;
      }

      /* ── Lead scoring visuals ── */

      /* Heat distribution bar */
      .lead-heat-bar {
        display: flex; height: 8px; border-radius: 4px; overflow: hidden;
        background: rgba(44,24,16,0.06); margin-bottom: 10px;
      }
      .lead-heat-bar__seg { transition: width 0.3s ease; min-width: 2px; }

      /* Heat filter chips */
      .lead-heat-chips {
        display: flex; gap: 6px; flex-wrap: wrap;
      }
      .lead-heat-chip {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 12px; border-radius: 20px; border: 1px solid rgba(44,24,16,0.15);
        background: transparent; color: rgba(44,24,16,0.6);
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500;
        cursor: pointer; transition: all 0.15s ease;
      }
      .lead-heat-chip:hover { border-color: var(--chip-color, rgba(44,24,16,0.3)); color: rgba(44,24,16,0.9); }
      .lead-heat-chip--active {
        background: var(--chip-color, #2C1810); color: #fff; border-color: var(--chip-color, #2C1810);
      }
      .lead-heat-chip__dot {
        width: 8px; height: 8px; border-radius: 50%; display: inline-block;
      }
      .lead-heat-chip--active .lead-heat-chip__dot { background: #fff !important; }

      /* Pipeline stage bar */
      .lead-pipeline-bar {
        display: flex; align-items: center; gap: 0;
        background: rgba(44,24,16,0.03); border-radius: 6px; overflow: hidden;
        border: 1px solid rgba(44,24,16,0.08);
      }
      .lead-pipeline-stage {
        display: flex; align-items: center; position: relative;
      }
      .lead-pipeline-stage__fill {
        display: flex; align-items: center; justify-content: center; gap: 6px;
        padding: 8px 14px; background: rgba(46,64,9,0.08);
        transition: opacity 0.2s;
      }
      .lead-pipeline-stage:first-child .lead-pipeline-stage__fill { border-radius: 5px 0 0 5px; }
      .lead-pipeline-stage:last-child .lead-pipeline-stage__fill { border-radius: 0 5px 5px 0; }
      .lead-pipeline-stage__label {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.05em; color: rgba(44,24,16,0.5);
      }
      .lead-pipeline-stage__count {
        font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 700;
        color: #2E4009;
      }
      .lead-pipeline-arrow {
        font-size: 9px; color: rgba(44,24,16,0.2); margin: 0 -2px; z-index: 1;
      }

      /* Score badge */
      .lead-score-badge {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; border-radius: 50%;
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 700;
        line-height: 1;
      }

      /* Stage pills (4 dots showing progression) */
      .lead-stage-pills {
        display: inline-flex; align-items: center; gap: 3px;
      }
      .lead-stage-pill {
        width: 8px; height: 8px; border-radius: 50%;
        background: rgba(44,24,16,0.1);
        transition: background 0.15s;
      }
      .lead-stage-pill--filled { /* color set inline */ }
      .lead-stage-label {
        font-size: 10px; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.04em; color: rgba(44,24,16,0.5); margin-left: 4px;
      }

      /* Row styles */
      .lead-row { transition: background 0.15s; }
      .lead-row--dead { opacity: 0.5; }
      .lead-row--dead:hover { opacity: 0.8; }
      .lead-last-seen {
        display: block; font-size: 10px; color: rgba(44,24,16,0.4); margin-top: 2px;
      }

      /* Row selected state */
      .lead-row--selected { outline: 2px solid #2E4009; outline-offset: -2px; }
      .lead-row:hover { filter: brightness(0.97); }

      /* ── Lead profile full-page view ── */

      .lp-fullpage {
        animation: lpFadeIn 0.2s ease;
      }
      @keyframes lpFadeIn { from { opacity: 0; } to { opacity: 1; } }

      .lp-back {
        display: inline-flex; align-items: center; gap: 6px;
        background: none; border: 1px solid rgba(44,24,16,0.15);
        border-radius: 2px; padding: 6px 14px;
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600;
        color: #2C1810; cursor: pointer; transition: all 0.15s;
        margin-bottom: 20px;
      }
      .lp-back:hover { background: rgba(44,24,16,0.05); border-color: rgba(44,24,16,0.25); }

      /* ============================================================
         === Dashboard primitives ===================================
         ============================================================
         The CSS below powers the reusable primitives extracted into
         src/components/dashboard/primitives/. Each primitive maps to a
         set of class names; consumers (LeadProfile, future PipelineView,
         etc.) import the JSX wrapper and these styles resolve.

           CardSurface          → .lp-card (+ .lp-card-stack stack helper)
           StagePill            → .lp-stage-pill
           ScoreRing            → .lp-score-ring (+ .lp-score-ring--sm,
                                  .lp-score-ring__inner / __num / __tier)
           MetadataStrip / Cell → .lp-meta-strip, .lp-meta-cell
                                  (+ --ring, __eyebrow, __value,
                                  __value--muted, __dot)
           AttributeRow         → .lp-attr-row (+ __label / __value /
                                  __value--empty / __link)
           ActivityTimelineRow  → .activity-mini__row, __icon (+ --warn),
                                  __row-body, __row-top, __title, __when,
                                  __detail, __detail-box
           SoftPill             → inline styles (no shared class)
           EyebrowLabel         → inline styles (no shared class)

         The active rules live in this file in their original positions
         so cascade order is preserved. The comment block above is the
         single source of truth for "where does primitive X live".

         When adding a new primitive: register the CSS here in the same
         pattern (BEM class + variants), add the JSX in primitives/,
         export from primitives/index.js, and update DESIGN.md if the
         primitive introduces a new token.
         ============================================================ */

      /* Stack of separate profile cards (id+meta / funnel / body) */
      .lp-card-stack {
        display: flex;
        flex-direction: column;
        gap: 24px;
        margin-bottom: 32px;
      }

      /* Card wrapper - now applied to each of the three sibling cards */
      .lp-card {
        background: rgba(255,255,255,0.7); border: 1px solid rgba(64,22,12,0.10);
        border-radius: 8px; overflow: hidden;
      }

      .lp-hero {
        display: flex; align-items: center; gap: 20px;
        padding: 20px 24px 16px; margin-bottom: 0;
        background: rgba(44,24,16,0.025); border: none;
        border-bottom: 1px solid rgba(44,24,16,0.06);
        border-radius: 0;
      }
      .lp-hero__score {
        display: flex; flex-direction: column; align-items: center; gap: 4px; flex-shrink: 0;
      }
      .lp-hero__tier {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.08em;
      }
      .lp-hero__age {
        display: flex; flex-direction: column; align-items: center; gap: 2px; flex-shrink: 0;
      }
      .lp-hero__age-badge {
        display: flex; align-items: center; justify-content: center;
        width: 48px; height: 48px; border-radius: 50%;
        background: rgba(44,24,16,0.05); border: 1px solid rgba(44,24,16,0.1);
        font-family: 'DM Sans', sans-serif; font-size: 18px; font-weight: 700;
        color: rgba(44,24,16,0.6);
      }
      .lp-hero__age-label {
        font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.06em; color: rgba(44,24,16,0.35);
      }
      /* Shared key-lights row: primary score + urgency + age + source badges.
         One flex row so the badges stay visually locked together and respond
         as a single unit on narrow viewports. */
      .lp-hero__keylights {
        display: flex; align-items: center; gap: 14px; flex-shrink: 0;
      }
      .lp-hero__kl {
        display: flex; flex-direction: column; align-items: center; gap: 2px; flex-shrink: 0;
      }
      .lp-hero__kl-badge {
        display: flex; align-items: center; justify-content: center;
        width: 48px; height: 48px; border-radius: 50%;
        border: 1px solid transparent;
        font-family: 'DM Sans', sans-serif; font-size: 18px; font-weight: 700;
        line-height: 1;
      }
      .lp-hero__kl-label {
        font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.06em; color: rgba(44,24,16,0.4);
        max-width: 80px; text-align: center;
      }
      .lp-hero__info { flex: 1; min-width: 0; }
      .lp-hero__name {
        font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600;
        color: #2C1810; margin: 0 0 4px; line-height: 1.2;
      }
      .lp-hero__contact {
        display: flex; flex-wrap: wrap; align-items: center; gap: 6px;
        font-family: 'DM Sans', sans-serif; font-size: 13px; color: rgba(44,24,16,0.5);
        margin-bottom: 8px;
      }
      .lp-hero__link {
        color: #2E4009; text-decoration: none; font-weight: 500;
      }
      .lp-hero__link:hover { text-decoration: underline; }

      .lp-cols {
        display: grid; grid-template-columns: 1fr 1fr; gap: 0;
        margin-bottom: 0;
      }
      .lp-col {
        display: flex; flex-direction: column; gap: 0;
      }
      .lp-col:first-child {
        border-right: 1px solid rgba(44,24,16,0.06);
      }

      /* Stage progression bar in header */
      .lp-stage-bar {
        display: flex; justify-content: center; gap: 6px;
      }
      .lp-stage-step {
        padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600;
        font-family: 'DM Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.04em;
        border: 1.5px solid rgba(44,24,16,0.15); color: rgba(44,24,16,0.3);
        transition: all 0.15s;
      }
      .lp-stage-step--active { /* colours set inline */ }

      /* ── Funnel journey track ── */
      .lp-funnel {
        display: flex; align-items: flex-start; gap: 0; position: relative;
      }
      .lp-funnel__step {
        display: flex; flex-direction: column; align-items: center; gap: 3px;
        position: relative; min-width: 52px; flex: 1;
      }
      .lp-funnel__step--future { opacity: 0.3; }
      .lp-funnel__line {
        position: absolute; top: 10px; right: 50%; width: 100%; height: 2px;
        background: rgba(44,24,16,0.1); z-index: 0;
      }
      .lp-funnel__step:first-child .lp-funnel__line { display: none; }
      .lp-funnel__dot {
        width: 20px; height: 20px; border-radius: 50%;
        border: 2px solid rgba(44,24,16,0.15); background: #fff;
        display: flex; align-items: center; justify-content: center;
        position: relative; z-index: 1; transition: all 0.2s;
      }
      .lp-funnel__dot--done {
        border-color: transparent;
      }
      .lp-funnel__dot--current {
        width: 24px; height: 24px; border-color: transparent;
        box-shadow: 0 0 0 3px rgba(46,64,9,0.15);
      }
      .lp-funnel__check {
        color: #fff; font-size: 11px; font-weight: 700; line-height: 1;
      }
      .lp-funnel__pulse {
        position: absolute; inset: -4px; border-radius: 50%;
        border: 2px solid currentColor; opacity: 0;
        animation: funnelPulse 2s ease-out infinite;
      }
      @keyframes funnelPulse {
        0% { transform: scale(0.8); opacity: 0.6; }
        100% { transform: scale(1.4); opacity: 0; }
      }
      .lp-funnel__label {
        font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.04em; color: rgba(44,24,16,0.5);
        text-align: center; white-space: nowrap;
      }
      .lp-funnel__step--current .lp-funnel__label {
        color: #2C1810; font-weight: 700;
      }
      .lp-funnel__date {
        font-family: 'DM Sans', sans-serif; font-size: 10px; color: rgba(44,24,16,0.4);
        text-align: center;
      }
      .lp-funnel__health {
        display: inline-flex; align-items: center; gap: 2px; padding: 2px 8px; border-radius: 10px;
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 700;
        text-align: center; white-space: nowrap;
      }
      .lp-funnel__health-label {
        font-weight: 600; font-size: 10px; text-transform: uppercase; letter-spacing: 0.03em;
      }

      /* Engagement depth bar under funnel */
      .lp-funnel-engagement {
        display: flex; align-items: center; gap: 8px;
        font-family: 'DM Sans', sans-serif; font-size: 11px;
      }
      .lp-funnel-engagement__label {
        font-weight: 600; color: rgba(44,24,16,0.4); text-transform: uppercase;
        font-size: 9px; letter-spacing: 0.06em; min-width: 72px;
      }
      .lp-funnel-engagement__detail {
        color: rgba(44,24,16,0.5); font-size: 11px; min-width: 100px;
      }
      .lp-funnel-engagement__bar {
        flex: 1; height: 4px; background: rgba(44,24,16,0.06); border-radius: 2px;
        overflow: hidden; max-width: 200px;
      }
      .lp-funnel-engagement__fill {
        height: 100%; background: var(--color-forest-olive); border-radius: 2px;
        transition: width 0.3s ease;
      }

      /* Stage definition line */
      .lp-stage-def {
        display: flex; align-items: baseline; gap: 6px; margin-top: 6px;
        font-family: 'DM Sans', sans-serif; font-size: 11px; line-height: 1.4;
      }
      .lp-stage-def__stage {
        font-weight: 700; color: #2C1810; white-space: nowrap;
      }
      .lp-stage-def__text {
        color: rgba(44,24,16,0.45); font-style: italic;
      }

      /* ── Action buttons ── */
      .lp-actions {
        display: flex; align-items: center; gap: 8px; padding: 12px 24px;
        border-top: 1px solid var(--border-subtle); flex-wrap: wrap;
      }
      .lp-actions__label {
        font-family: 'DM Sans', sans-serif; font-size: 9px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em; color: rgba(44,24,16,0.35);
        margin-right: 4px;
      }
      .lp-actions__btn {
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600;
        padding: 5px 12px; border-radius: 4px; border: 1px solid;
        cursor: pointer; transition: all 0.15s ease;
      }
      .lp-actions__btn:disabled { opacity: 0.5; cursor: wait; }
      .lp-actions__btn--meeting { background: rgba(46,64,9,0.06); border-color: rgba(46,64,9,0.2); color: #2E4009; }
      .lp-actions__btn--meeting:hover:not(:disabled) { background: rgba(46,64,9,0.12); }
      .lp-actions__btn--proposal { background: rgba(191,114,86,0.06); border-color: rgba(191,114,86,0.2); color: #BF7256; }
      .lp-actions__btn--proposal:hover:not(:disabled) { background: rgba(191,114,86,0.12); }
      .lp-actions__btn--won { background: rgba(73,89,14,0.08); border-color: #49590E; color: #49590E; }
      .lp-actions__btn--won:hover:not(:disabled) { background: rgba(73,89,14,0.15); }
      .lp-actions__btn--lost { background: rgba(140,71,46,0.04); border-color: rgba(140,71,46,0.2); color: #8C472E; }
      .lp-actions__btn--lost:hover:not(:disabled) { background: rgba(140,71,46,0.1); }
      .lp-actions__btn--cancel { background: rgba(44,24,16,0.03); border-color: rgba(44,24,16,0.12); color: rgba(44,24,16,0.5); }
      .lp-actions__btn--cancel:hover:not(:disabled) { background: rgba(44,24,16,0.06); }
      .lp-actions__btn--revert { background: rgba(44,24,16,0.03); border-color: rgba(44,24,16,0.15); color: rgba(44,24,16,0.6); font-size: 12px; }
      .lp-actions__btn--revert:hover:not(:disabled) { background: rgba(44,24,16,0.08); color: #2C1810; }
      .lp-actions__confirm { display: inline-flex; align-items: center; gap: 8px; padding: 4px 12px; background: rgba(140,71,46,0.06); border: 1px solid rgba(140,71,46,0.2); border-radius: 4px; }
      .lp-actions__confirm-label { font-size: 13px; color: #2C1810; font-weight: 500; }
      .lp-actions__btn--confirm-yes { background: rgba(73,89,14,0.08); border-color: #49590E; color: #49590E; padding: 4px 14px; font-size: 13px; font-weight: 600; }
      .lp-actions__btn--confirm-yes:hover:not(:disabled) { background: rgba(73,89,14,0.18); }
      .lp-actions__btn--confirm-no { background: transparent; border-color: rgba(44,24,16,0.15); color: rgba(44,24,16,0.5); padding: 4px 14px; font-size: 13px; }
      .lp-actions__btn--confirm-no:hover:not(:disabled) { background: rgba(44,24,16,0.04); }

      /* ── Dialog (backdrop + card) ── */
      .lp-dialog-backdrop {
        position: fixed; inset: 0; background: rgba(44,24,16,0.5); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 100;
        display: flex; align-items: center; justify-content: center;
      }
      .lp-dialog {
        background: #F5F0E8; border-radius: 8px; padding: 24px;
        min-width: 380px; max-width: 480px; box-shadow: 0 12px 40px rgba(44,24,16,0.3);
        border: 1px solid rgba(44,24,16,0.12);
      }
      .lp-dialog--won { min-width: 420px; }
      .lp-dialog__title {
        font-family: 'Cormorant Garamond', Georgia, serif; font-size: 20px; font-weight: 600;
        color: var(--color-brewery-dark); margin: 0 0 16px;
      }
      .lp-dialog__label {
        font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.08em; color: rgba(44,24,16,0.4);
        display: block; margin: 12px 0 4px;
      }
      .lp-dialog__select, .lp-dialog__input {
        font-family: 'DM Sans', sans-serif; font-size: 13px; width: 100%; padding: 8px 10px;
        border: 1px solid var(--border-warm); border-radius: 4px; background: #fff;
        color: var(--color-brewery-dark);
      }
      .lp-dialog__input--number { padding-left: 24px; }
      .lp-dialog__currency { position: relative; }
      .lp-dialog__currency-symbol {
        position: absolute; left: 8px; top: 50%; transform: translateY(-50%);
        font-family: 'DM Sans', sans-serif; font-size: 13px; color: rgba(44,24,16,0.4);
      }
      .lp-dialog__muted { font-family: 'DM Sans', sans-serif; font-size: 12px; color: rgba(44,24,16,0.4); margin: 4px 0; }
      .lp-dialog__info { font-family: 'DM Sans', sans-serif; font-size: 12px; color: rgba(44,24,16,0.6); margin: 0 0 4px; }
      .lp-dialog__warn { color: #BF7256; font-weight: 600; }
      .lp-dialog__fields { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-top: 8px; }
      .lp-dialog__total {
        font-family: 'DM Sans', sans-serif; font-size: 20px; font-weight: 700;
        color: #49590E; margin: 8px 0 0;
      }
      .lp-dialog__daytype-row { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
      .lp-dialog__daytype-btn {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 600;
        padding: 4px 10px; border-radius: 3px; border: 1px solid var(--border-warm);
        background: transparent; color: rgba(44,24,16,0.6); cursor: pointer;
      }
      .lp-dialog__daytype-btn--active { background: rgba(73,89,14,0.1); border-color: #49590E; color: #49590E; }
      .lp-dialog__actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 20px; }
      .lp-dialog__btn {
        font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600;
        padding: 8px 16px; border-radius: 4px; border: none; cursor: pointer;
      }
      .lp-dialog__btn:disabled { opacity: 0.4; cursor: not-allowed; }
      .lp-dialog__btn--cancel { background: rgba(44,24,16,0.06); color: rgba(44,24,16,0.5); }
      .lp-dialog__btn--confirm { color: #fff; }
      .lp-dialog__btn--won { background: #49590E; }
      .lp-dialog__btn--won:hover:not(:disabled) { background: #2E4009; }
      .lp-dialog__btn--lost { background: #8C472E; }
      .lp-dialog__btn--lost:hover:not(:disabled) { background: #6A3622; }

      /* ── Deal value badge ── */
      .lp-deal-value {
        padding: 12px 24px; display: flex; align-items: baseline; gap: 12px;
        border-top: 1px solid var(--border-subtle); flex-wrap: wrap;
      }
      .lp-deal-value__label {
        font-family: 'DM Sans', sans-serif; font-size: 9px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em; color: rgba(44,24,16,0.35);
      }
      .lp-deal-value__amount {
        font-family: 'DM Sans', sans-serif; font-size: 22px; font-weight: 700; color: #49590E;
      }
      .lp-deal-value__breakdown {
        font-family: 'DM Sans', sans-serif; font-size: 11px; color: rgba(44,24,16,0.45);
      }
      .lp-deal-value__tier {
        font-family: 'DM Sans', sans-serif; font-size: 10px; color: rgba(44,24,16,0.3);
      }

      /* ── 5-band lead profile redesign (prd-sys-lead-profile.md) ── */

      /* Band 1: Identity strip - compact 2-row layout (2026-04-27 redesign).
         Avatar (left) + 2-row text (centre) + actions (right). Total height
         ~96-104px. Email/phone moved to Event details column. */
      .lp-id-strip {
        display: grid;
        grid-template-columns: auto 1fr auto;
        column-gap: 16px;
        align-items: center;
        padding: 24px 28px; background: rgba(255,255,255,0.7);
        border-bottom: 1px solid rgba(64,22,12,0.1);
      }
      .lp-id-strip__avatar {
        width: 48px; height: 48px; border-radius: 50%; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: #2E4009; color: #F5F0E8;
        font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.02em;
      }
      .lp-id-text {
        display: grid; grid-template-rows: auto auto; gap: 4px;
        min-width: 0;
      }
      .lp-id-name-row {
        display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;
        min-width: 0;
      }
      .lp-id-strip__name {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 30px; font-weight: 500;
        color: #2C1810; margin: 0; line-height: 1.05; letter-spacing: -0.015em;
      }
      .lp-stage-pill {
        display: inline-flex; align-items: center; height: 22px;
        padding: 0 10px; border-radius: 2px;
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.04em;
        white-space: nowrap; flex-shrink: 0;
      }
      .lp-id-subtitle {
        margin: 0;
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.13em;
        color: #BF7256; line-height: 1.2;
      }
      .lp-id-actions {
        display: flex; align-items: center; gap: 8px; flex-shrink: 0;
      }
      .lp-id-actions__btn {
        font-family: 'DM Sans', sans-serif; font-size: 11.5px; font-weight: 500;
        height: 30px; padding: 0 14px; border-radius: 2px;
        border: 1px solid; cursor: pointer;
        display: inline-flex; align-items: center; gap: 4px;
        text-decoration: none;
        transition: all 0.15s ease;
      }
      .lp-id-actions__btn--ghost {
        background: transparent; color: #2C1810; border-color: rgba(64,22,12,0.24);
      }
      .lp-id-actions__btn--ghost:hover {
        background: rgba(140,71,46,0.05);
      }
      .lp-id-actions__btn--primary {
        background: #49590E; color: #F5F0E8; border-color: #49590E;
      }
      .lp-id-actions__btn--primary:hover {
        background: #2E4009; border-color: #2E4009;
      }
      /* Email / phone link styling inside Event Details (moved from id strip) */
      .lp-attr-row__link {
        color: #BF7256; text-decoration: none; font-weight: 500;
      }
      .lp-attr-row__link:hover { text-decoration: underline; }

      /* Band 2: Metadata strip - 4 cells aligned to a shared 2-row grid.
         Row 1 = eyebrows (top-baseline). Row 2 = content (ring or value).
         Cells use display:contents so eyebrow + value become direct grid
         children of the strip - this locks the eyebrows to a single shared
         baseline regardless of the ring's height in cell 1.
         No border-bottom: this is the bottom band of Card 1, the card
         border closes it instead. */
      .lp-meta-strip {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: auto 64px; /* row 2 floor = ring height */
        column-gap: 32px;
        row-gap: 10px;
        padding: 24px 32px;
        background: rgba(255,255,255,0.5);
        align-items: start;
      }
      /* Cell wrapper is invisible to the grid - its children promote up. */
      .lp-meta-cell {
        display: contents;
      }
      .lp-meta-cell__eyebrow {
        grid-row: 1;
        align-self: start;
        font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.13em; color: #BF7256;
        line-height: 1;
        min-width: 0;
      }
      .lp-meta-cell__value {
        grid-row: 2;
        align-self: center; /* vertically centre against the ring's centre */
        display: inline-flex; align-items: center; gap: 8px;
        font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 500;
        color: #2C1810; line-height: 1.3; min-width: 0;
      }
      .lp-meta-cell__value--muted {
        color: rgba(44,24,16,0.5); font-style: italic;
      }
      .lp-meta-cell__dot {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
      }
      /* Score ring sits at the top of row 2 and is the row-height anchor. */
      .lp-meta-cell--ring .lp-score-ring {
        grid-row: 2;
        align-self: start;
        justify-self: start;
        margin: 0;
      }

      /* Band 3: Funnel hero - now its own card (Card 2). No border-bottom. */
      .lp-funnel-hero {
        padding: 32px 32px; background: rgba(255,255,255,0.7);
      }
      .stage-callout {
        display: flex; align-items: flex-start; justify-content: space-between;
        gap: 24px; margin-top: 28px; flex-wrap: wrap;
      }
      .stage-callout__head { flex: 1; min-width: 0; }
      .stage-callout__eyebrow {
        font-family: 'DM Sans', sans-serif; font-size: 9.5px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.14em; color: #BF7256;
        margin: 0 0 4px;
      }
      .stage-callout__row {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        margin-bottom: 8px;
      }
      .lp-stage-name {
        font-family: 'Cormorant Garamond', Georgia, serif; font-size: 28px; font-weight: 500;
        color: #2C1810; line-height: 1.1; letter-spacing: -0.01em;
        margin: 0 0 8px;
      }
      .lp-stage-stuck {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 3px 9px; border-radius: 2px;
        background: rgba(140,71,46,0.18); color: #5C2E1F;
        border: 1px solid rgba(140,71,46,0.28);
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
      }
      .lp-stage-stuck__dot {
        width: 6px; height: 6px; border-radius: 50%; background: #8C472E;
      }
      .stage-callout__def {
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 400;
        color: rgba(44,24,16,0.7); line-height: 1.4; margin: 0;
      }
      .stage-callout__def-sep { color: rgba(44,24,16,0.3); padding: 0 4px; }
      .lp-stage-actions {
        display: flex; flex-wrap: wrap; gap: 8px; align-items: flex-start;
        flex-shrink: 0;
        margin-top: 4px;
      }
      .lp-stage-actions__btn {
        font-family: 'DM Sans', sans-serif; font-size: 11.5px; font-weight: 500;
        height: 30px; padding: 0 14px; border-radius: 2px;
        border: 1px solid; cursor: pointer; transition: all 0.15s ease;
        display: inline-flex; align-items: center; gap: 4px;
      }
      .lp-stage-actions__btn:disabled { opacity: 0.5; cursor: wait; }
      .lp-stage-actions__btn--primary {
        background: #49590E; color: #F5F0E8; border-color: #49590E;
      }
      .lp-stage-actions__btn--primary:hover:not(:disabled) {
        background: #2E4009; border-color: #2E4009;
      }
      .lp-stage-actions__btn--ghost {
        background: transparent; color: #2C1810; border-color: rgba(64,22,12,0.24);
      }
      .lp-stage-actions__btn--ghost:hover:not(:disabled) {
        background: rgba(140,71,46,0.05);
      }
      .lp-stage-actions__btn--danger {
        background: transparent; color: #5C2E1F; border-color: rgba(140,71,46,0.4);
      }
      .lp-stage-actions__btn--danger:hover:not(:disabled) {
        background: rgba(140,71,46,0.06);
      }
      .lp-stage-actions__confirm {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 4px 10px; border-radius: 2px;
        background: rgba(140,71,46,0.06); border: 1px solid rgba(140,71,46,0.2);
      }
      .lp-stage-actions__confirm-label {
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500;
        color: #2C1810;
      }

      /* Body row - three separate cards (event / score / activity) sitting
         beneath the funnel hero with 16px gaps between them. Each card uses
         the standard .lp-card chrome (rgba bg + Mahogany 10% border + 8px). */
      .lp-body-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
      }
      /* Inside each body card, the column wrapper now provides padding.
         Border-right dividers from the old single-card layout are gone -
         the card borders + the row gap replace them. */
      .lp-body-col {
        padding: 28px 28px; min-width: 0;
      }
      /* Legacy .lp-body grid kept defined in case any helper renders it,
         but the active layout uses .lp-body-row with sibling cards. */
      .lp-body {
        display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0;
      }
      .lp-body-col__title {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.14em; color: #BF7256;
        margin: 0 0 16px;
        display: flex; align-items: center; justify-content: space-between; gap: 8px;
      }
      .lp-body-col__title-meta {
        font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 500;
        color: rgba(44,24,16,0.5); letter-spacing: 0; text-transform: none;
      }

      /* ── Activity summary (Stitch-style heading + tabs + iconised timeline) ── */
      /* Heading row: Cormorant "Activity timeline" + ALL/EMAILS/NOTES tabs. */
      .activity-mini__head {
        display: flex; align-items: baseline; justify-content: space-between;
        margin-bottom: 14px; padding-bottom: 12px;
        border-bottom: 1px solid rgba(64, 22, 12, 0.1);
        gap: 12px;
      }
      .activity-mini__heading {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-weight: 500; font-size: 18px;
        color: #2C1810; letter-spacing: -0.005em;
        margin: 0;
      }
      .activity-mini__tabs { display: flex; gap: 14px; }
      .activity-mini__tab {
        font-family: 'DM Sans', system-ui, sans-serif;
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.13em;
        color: rgba(44, 24, 16, 0.5);
        cursor: pointer; padding: 0 0 4px;
        background: none;
        border: none;
        border-bottom: 1.5px solid transparent;
      }
      .activity-mini__tab--active {
        color: #2E4009; border-bottom-color: #2E4009;
      }
      .activity-mini__tab:hover:not(.activity-mini__tab--active) { color: #2C1810; }

      .activity-mini { display: flex; flex-direction: column; gap: 0; }

      /* Each row: icon column (16px) + body column. Vertical Mahogany line
       * runs through the icons via the row's left border, with the icon
       * sitting on top of the line on a Warm Canvas background. */
      .activity-mini--timeline .activity-mini__row {
        display: flex; align-items: flex-start;
        gap: 14px;
        padding: 10px 0 14px;
        padding-left: 28px;
        margin-left: 8px;
        border-left: 1px solid rgba(64, 22, 12, 0.12);
        border-bottom: none;
        position: relative;
      }
      .activity-mini--timeline .activity-mini__row:first-child { padding-top: 8px; }
      .activity-mini--timeline .activity-mini__row:last-child { padding-bottom: 8px; }

      .activity-mini__icon {
        position: absolute; left: -8px; top: 8px;
        width: 16px; height: 16px;
        background: #F5F0E8;
        color: #2E4009;
        display: inline-flex; align-items: center; justify-content: center;
      }
      .activity-mini__icon svg { width: 16px; height: 16px; display: block; }
      .activity-mini__icon--warn { color: #5C2E1F; }

      /* Body holds title + timestamp on one row, then optional detail/box. */
      .activity-mini__row-body {
        flex: 1; min-width: 0;
        display: flex; flex-direction: column; gap: 0;
      }
      .activity-mini__row-top {
        display: flex; gap: 10px; align-items: baseline;
        justify-content: space-between;
      }
      .activity-mini__title {
        font-family: 'DM Sans', system-ui, sans-serif;
        font-weight: 500; font-size: 13px;
        color: #2C1810; line-height: 1.35;
        flex: 1; min-width: 0;
      }
      .activity-mini__when {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 400;
        color: rgba(44, 24, 16, 0.6);
        font-variant-numeric: tabular-nums;
        flex-shrink: 0;
        text-align: right;
      }
      .activity-mini__detail {
        font-family: 'DM Sans', system-ui, sans-serif;
        font-size: 11.5px; color: rgba(44, 24, 16, 0.65);
        margin-top: 4px; line-height: 1.4;
      }
      .activity-mini__detail-box {
        background: rgba(140, 71, 46, 0.06);
        border-left: 2px solid rgba(140, 71, 46, 0.22);
        padding: 8px 10px; margin-top: 8px;
        font-family: 'DM Sans', system-ui, sans-serif;
        font-size: 11.5px; line-height: 1.45;
        color: #2C1810; font-style: italic;
        border-radius: 0 2px 2px 0;
      }

      /* Legacy session-row styles (kept for any non-timeline use) */
      .activity-mini__row {
        display: flex; flex-direction: column; gap: 3px;
        padding: 11px 0;
        border-bottom: 1px solid rgba(64,22,12,0.08);
      }
      .activity-mini__row:last-child { border-bottom: none; }
      .activity-mini__top {
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
      }
      .activity-mini__src {
        display: inline-flex; align-items: center; gap: 4px;
        font-family: 'DM Sans', sans-serif; font-size: 10.5px;
        color: rgba(44,24,16,0.65);
      }
      .activity-mini__src-dot { width: 6px; height: 6px; border-radius: 50%; }
      .activity-mini__stats {
        font-family: 'DM Sans', sans-serif; font-size: 10.5px;
        color: rgba(44,24,16,0.6);
      }
      .activity-mini__link {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        color: #BF7256; text-decoration: none;
        background: none; border: none; cursor: pointer; padding: 12px 0 0;
        text-align: left;
      }
      .activity-mini__link:hover { text-decoration: underline; }
      .activity-mini__empty {
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-style: italic;
        color: rgba(44,24,16,0.5);
        padding: 16px 0;
      }

      /* Event detail K:V rows (column 1 of body) */
      .lp-attr-row {
        display: flex; align-items: baseline; justify-content: space-between;
        gap: 10px; padding: 9px 0;
        border-bottom: 1px solid rgba(64,22,12,0.08);
      }
      .lp-attr-row:last-child { border-bottom: none; }
      .lp-attr-row__label {
        font-family: 'DM Sans', sans-serif; font-size: 11px;
        color: rgba(44,24,16,0.6); flex-shrink: 0;
      }
      .lp-attr-row__value {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        color: #2C1810; text-align: right;
        font-variant-numeric: tabular-nums; word-break: break-word;
      }
      .lp-attr-row__value--empty {
        color: rgba(44,24,16,0.4); font-style: italic; font-weight: 400;
      }

      /* Score ring - large variant (legacy, no longer rendered in body but
         retained for any future use). Small variant lives in metadata strip
         cell 1 and is the active visual for the score now. */
      .lp-score-ring {
        position: relative; width: 96px; height: 96px;
        margin: 0 auto 16px;
      }
      .lp-score-ring--sm {
        width: 64px; height: 64px;
        margin: 0;
      }
      .lp-score-ring__inner {
        position: absolute; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center; gap: 4px;
      }
      .lp-score-ring__num {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-weight: 500; font-size: 32px; line-height: 1;
        color: #2C1810; letter-spacing: -0.01em;
      }
      .lp-score-ring--sm .lp-score-ring__num {
        font-size: 22px;
      }
      .lp-score-ring__tier {
        font-family: 'DM Sans', system-ui, sans-serif;
        font-weight: 500; font-size: 10px;
        text-transform: uppercase; letter-spacing: 0.13em;
      }
      .lp-score-ring--sm .lp-score-ring__tier {
        font-size: 9px; letter-spacing: 0.13em;
      }

      /* Score-bar rows for column 2 of body */
      .lp-sb-row {
        display: grid; grid-template-columns: 60px 1fr 32px; gap: 8px;
        align-items: center; padding: 8px 0;
      }
      .lp-sb-row__label {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        color: rgba(44,24,16,0.65);
      }
      .lp-sb-row__bar {
        height: 4px; border-radius: 2px;
        background: rgba(64,22,12,0.12); overflow: hidden;
      }
      .lp-sb-row__fill {
        height: 100%; border-radius: 2px;
        background: #2E4009; transition: width 0.3s ease;
      }
      .lp-sb-row__val {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        color: #2C1810; text-align: right;
        font-variant-numeric: tabular-nums;
      }

      /* Health badge in table rows */
      .lead-health-badge {
        display: inline-block; padding: 1px 5px; border-radius: 6px;
        font-family: 'DM Sans', sans-serif; font-size: 9px; font-weight: 700;
        margin-left: 4px; vertical-align: middle;
      }
      .lead-stage-pill--current {
        box-shadow: 0 0 0 2px rgba(44,24,16,0.08);
      }

      /* Sections */
      .lp-section {
        padding: 14px 20px;
        border-bottom: 1px solid rgba(44,24,16,0.06);
      }
      .lp-section:last-child { border-bottom: none; }
      .lp-section__title {
        font-family: 'DM Sans', sans-serif; font-size: 9px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em; color: rgba(44,24,16,0.35);
        margin: 0 0 8px;
      }

      /* Dates checked - compact summary of calendar date clicks.
         Source: prd-sys-date-click-history.md Phase 1. */
      .lp-dates .lp-section__title {
        display: flex; align-items: center; gap: 8px;
      }
      .lp-dates__count {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 18px; height: 16px; padding: 0 5px;
        font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 600;
        letter-spacing: 0; text-transform: none;
        background: rgba(140,71,46,0.1); color: #8C472E;
        border-radius: 2px;
      }
      .lp-dates__list {
        display: flex; flex-wrap: wrap; gap: 6px;
      }
      .lp-dates__tag {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        padding: 3px 9px; border-radius: 2px;
        background: rgba(46,64,9,0.07); color: #2E4009;
        border: 1px solid rgba(46,64,9,0.15);
        white-space: nowrap;
      }
      .lp-dates__more {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        padding: 3px 9px; color: rgba(44,24,16,0.5); font-style: italic;
      }

      /* Detail grid (label + value pairs) */
      .lp-detail-grid {
        display: grid; grid-template-columns: 1fr 1fr; gap: 8px 14px;
      }
      .lp-detail { display: flex; flex-direction: column; gap: 2px; }
      .lp-detail__label {
        font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.06em; color: rgba(44,24,16,0.4);
      }
      .lp-detail__value {
        font-family: 'DM Sans', sans-serif; font-size: 14px; color: #2C1810;
        word-break: break-word;
      }
      .lp-detail__link { color: #2E4009; text-decoration: none; }
      .lp-detail__link:hover { text-decoration: underline; }
      .lp-detail__muted { font-size: 13px; color: rgba(44,24,16,0.4); font-style: italic; }
      .lp-detail__value--empty { color: rgba(44,24,16,0.3); font-style: italic; }

      /* Score breakdown bars */
      .lp-score-toggle {
        display: flex; align-items: center; justify-content: space-between; width: 100%;
        background: none; border: none; padding: 0; cursor: pointer; gap: 8px;
      }
      .lp-score-toggle:hover .lp-score-toggle__arrow { color: #2C1810; }
      .lp-score-toggle__arrow {
        font-size: 10px; color: rgba(44,24,16,0.3); transition: color 0.15s;
      }
      .lp-score-grid { display: flex; flex-direction: column; gap: 6px; }
      .lp-score-row {
        display: grid; grid-template-columns: 72px 1fr 40px; gap: 8px; align-items: center;
      }
      .lp-score-row__label {
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600; color: rgba(44,24,16,0.6);
      }
      .lp-score-row__bar {
        height: 8px; border-radius: 4px; background: rgba(44,24,16,0.06); overflow: hidden;
      }
      .lp-score-row__fill {
        height: 100%; border-radius: 4px; transition: width 0.3s ease;
      }
      .lp-score-row__val {
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 700; color: #2C1810;
        text-align: right;
      }
      .lp-score-row__desc {
        grid-column: 2 / -1; font-size: 11px; color: rgba(44,24,16,0.4); margin-top: -4px;
      }

      /* Timeline */
      .lp-timeline { display: flex; flex-direction: column; gap: 0; position: relative; }
      .lp-timeline__item {
        display: grid; grid-template-columns: 14px 1fr; gap: 0 10px;
        padding: 8px 0; position: relative;
      }
      .lp-timeline__item:not(:last-child)::before {
        content: ''; position: absolute; left: 6px; top: 22px; bottom: -8px;
        width: 2px; background: rgba(44,24,16,0.08);
      }
      .lp-timeline__dot {
        width: 12px; height: 12px; border-radius: 50%; margin-top: 2px;
        border: 2px solid rgba(44,24,16,0.15); background: #F5F0E8;
        grid-row: 1 / 3;
      }
      .lp-timeline__dot--filled { background: #49590E; border-color: #49590E; }
      .lp-timeline__dot--action { background: #8C472E; border-color: #8C472E; }
      .lp-timeline__time {
        font-family: 'DM Sans', sans-serif; font-size: 10px; color: rgba(44,24,16,0.4);
      }
      .lp-timeline__event {
        font-family: 'DM Sans', sans-serif; font-size: 13px; color: #2C1810; font-weight: 500;
        grid-column: 2;
      }
      .lp-timeline__detail {
        font-family: 'DM Sans', sans-serif; font-size: 11px; color: rgba(44,24,16,0.4);
        grid-column: 2;
      }

      /* ── Clickable breakdown rows ── */
      .rep-toprow--clickable { cursor: pointer; transition: background 0.15s; }
      .rep-toprow--clickable:hover { background: rgba(73,89,14,0.06); }
      .rep-toprow--active { background: rgba(73,89,14,0.1); border-left: 3px solid #49590E; }
      .rep-topcount--link { color: #49590E; font-weight: 700; cursor: pointer; }
      .rep-toprow--clickable:hover .rep-topcount--link { text-decoration: underline; }
      .rep-stat--clickable { cursor: pointer; transition: all 0.15s; }
      .rep-stat--clickable:hover { border-color: rgba(73,89,14,0.3); background: rgba(73,89,14,0.04); }
      .rep-stat--active { border-color: #49590E; background: rgba(73,89,14,0.06); }

      /* ── Lead filter toolbar (inside lead-panel) ── */
      .lead-toolbar__search {
        display: flex; align-items: center; gap: 8px;
      }
      .lead-toolbar__input {
        flex: 1; max-width: 340px; padding: 9px 14px;
        font-family: 'DM Sans', sans-serif; font-size: 14px; color: #2C1810;
        background: var(--color-warm-canvas); border: 1px solid rgba(44,24,16,0.15);
        border-radius: 4px; outline: none; transition: border-color 0.15s;
      }
      .lead-toolbar__input::placeholder { color: rgba(44,24,16,0.35); }
      .lead-toolbar__input:focus { border-color: #49590E; }
      .lead-toolbar__search-btn {
        padding: 9px 18px; font-family: 'DM Sans', sans-serif; font-size: 12px;
        font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
        color: #fff; background: #49590E; border: none; border-radius: 4px;
        cursor: pointer; transition: background 0.15s; white-space: nowrap;
      }
      .lead-toolbar__search-btn:hover { background: #2E4009; }
      .lead-toolbar__filters {
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
      }
      .lead-toolbar__select {
        padding: 8px 12px; font-family: 'DM Sans', sans-serif; font-size: 13px;
        color: #2C1810; background: var(--color-warm-canvas);
        border: 1px solid rgba(44,24,16,0.15); border-radius: 4px;
        cursor: pointer; outline: none; transition: border-color 0.15s;
        appearance: none; -webkit-appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%232C1810' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat; background-position: right 10px center;
        padding-right: 28px;
      }
      .lead-toolbar__select:focus { border-color: #49590E; }
      .lead-toolbar__active {
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
        padding-top: 6px; border-top: 1px solid rgba(44,24,16,0.06);
      }
      .lead-toolbar__tag {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 500;
        font-family: 'DM Sans', sans-serif; color: var(--color-fired-brick);
        background: rgba(191, 114, 86, 0.08); border: 1px solid rgba(191, 114, 86, 0.18);
      }
      .lead-toolbar__tag button {
        background: none; border: none; color: rgba(44,24,16,0.4);
        cursor: pointer; font-size: 13px; padding: 0 0 0 2px; line-height: 1;
        transition: color 0.15s;
      }
      .lead-toolbar__tag button:hover { color: #2C1810; }
      .lead-toolbar__clear-all {
        background: none; border: none; font-family: 'DM Sans', sans-serif;
        font-size: 12px; color: rgba(44,24,16,0.45); cursor: pointer;
        text-decoration: underline; padding: 0 4px; transition: color 0.15s;
      }
      .lead-toolbar__clear-all:hover { color: #2C1810; }

      /* Source channel badge in leads table */
      .lead-source-badge {
        display: inline-block; font-family: 'DM Sans', sans-serif; font-size: 11px;
        font-weight: 600; padding: 2px 8px; border-radius: 3px; white-space: nowrap;
        letter-spacing: 0.01em;
      }
      td:has(.lead-source-badge) { min-width: 80px; }

      .rep-device-card--clickable { cursor: pointer; transition: all 0.15s; }
      .rep-device-card--clickable:hover { background: rgba(73,89,14,0.06); border-color: rgba(73,89,14,0.3); }
      .rep-device-card--active { border-color: #49590E; background: rgba(73,89,14,0.06); }

      /* ── Journey view ── */
      /* Journey summary */
      .jny-stats {
        display: flex; flex-wrap: wrap; gap: 14px; margin-bottom: 14px;
        padding: 12px 16px; background: rgba(44,24,16,0.02);
        border: 1px solid rgba(44,24,16,0.06); border-radius: 4px;
      }
      .jny-stat { display: flex; flex-direction: column; min-width: 70px; }
      .jny-stat__val {
        font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600;
        color: #2C1810; line-height: 1.1;
      }
      .jny-stat__label {
        font-family: 'DM Sans', sans-serif; font-size: 9px; font-weight: 500;
        color: rgba(44,24,16,0.4); text-transform: uppercase; letter-spacing: 0.04em;
      }
      .jny-milestones { margin-bottom: 14px; }
      .jny-milestones__title, .jny-toppages__title {
        font-family: 'DM Sans', sans-serif; font-size: 9px; font-weight: 700;
        color: rgba(44,24,16,0.35); text-transform: uppercase; letter-spacing: 0.1em;
        margin-bottom: 8px;
      }
      .jny-milestone {
        display: flex; align-items: center; gap: 8px; padding: 6px 0;
        border-bottom: 1px solid rgba(44,24,16,0.04);
      }
      .jny-milestone:last-child { border-bottom: none; }
      .jny-milestone__icon { font-size: 14px; width: 20px; text-align: center; flex-shrink: 0; }
      .jny-milestone__time {
        font-family: 'DM Sans', sans-serif; font-size: 11px; color: rgba(44,24,16,0.4);
        min-width: 120px; flex-shrink: 0;
      }
      .jny-milestone__label {
        font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; color: #2C1810;
      }
      .jny-milestone__detail {
        font-family: 'DM Sans', sans-serif; font-size: 11px; color: rgba(44,24,16,0.4);
        margin-left: 4px;
      }
      .jny-toppages { margin-bottom: 14px; }
      .jny-toppage {
        display: flex; justify-content: space-between; align-items: center;
        padding: 4px 0; border-bottom: 1px solid rgba(44,24,16,0.04);
      }
      .jny-toppage:last-child { border-bottom: none; }
      .jny-toppage__path {
        font-family: 'DM Sans', sans-serif; font-size: 12px; color: #2C1810;
      }
      .jny-toppage__count {
        font-family: 'DM Sans', sans-serif; font-size: 11px; color: rgba(44,24,16,0.4);
      }
      /* Tags row (sources + attribution) */
      .jny-tags-row {
        display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 14px;
      }
      .jny-tags-group {
        display: flex; flex-wrap: wrap; align-items: center; gap: 6px;
      }
      .jny-tags-group__label {
        font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 600;
        color: rgba(44,24,16,0.45); text-transform: uppercase; letter-spacing: 0.06em;
        margin-right: 2px;
      }
      .lp-journey-tag--campaign {
        background: rgba(191,114,86,0.1); border-color: rgba(191,114,86,0.2); color: #8C472E;
      }
      .lp-journey-tag--clickid {
        background: rgba(44,24,16,0.03); border-color: rgba(44,24,16,0.08);
        color: rgba(44,24,16,0.4); font-size: 10px;
      }

      .jny-expand-btn {
        display: block; width: 100%; padding: 10px 16px; margin-top: 8px;
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500;
        color: #49590E; background: rgba(73,89,14,0.04);
        border: 1px solid rgba(73,89,14,0.15); border-radius: 4px;
        cursor: pointer; text-align: center; transition: background 0.15s;
      }
      .jny-expand-btn:hover { background: rgba(73,89,14,0.1); }

      /* Full session log (when expanded) */
      .lp-journey-session {
        border: 1px solid rgba(44,24,16,0.1); border-radius: 6px;
        padding: 0; margin-bottom: 12px; margin-top: 12px;
        background: rgba(44,24,16,0.015); overflow: hidden;
      }
      .lp-journey-session--open {
        padding-bottom: 16px;
      }
      .lp-journey-session__header {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        padding: 12px 16px; margin-bottom: 10px;
        border-bottom: 1px solid rgba(44,24,16,0.06);
      }
      .lp-journey-session__header--static {
        cursor: default;
      }
      .lp-journey-session--open .lp-journey-session__source,
      .lp-journey-session--open .lp-journey-session__clickids,
      .lp-journey-session--open .lp-journey-pages,
      .lp-journey-session--open .lp-journey-actions {
        padding-left: 16px; padding-right: 16px;
      }
      .lp-journey-session__num {
        font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 700;
        color: #2C1810; letter-spacing: 0.04em; text-transform: uppercase;
      }
      .lp-journey-session__date {
        font-family: 'DM Sans', sans-serif; font-size: 12px; color: rgba(44,24,16,0.5);
      }
      .lp-journey-session__dur {
        font-family: 'DM Sans', sans-serif; font-size: 11px; color: #49590E;
        background: rgba(73,89,14,0.08); padding: 2px 8px; border-radius: 3px; font-weight: 600;
      }
      .lp-journey-session__source {
        display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px;
      }
      .lp-journey-tag {
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
        padding: 2px 8px; border-radius: 3px; color: #2C1810;
        background: rgba(44,24,16,0.05); border: 1px solid rgba(44,24,16,0.08);
      }
      .lp-journey-tag--platform {
        background: rgba(140,71,46,0.1); border-color: rgba(140,71,46,0.2); color: #8C472E; font-weight: 700;
      }
      .lp-journey-tag--keyword {
        background: rgba(73,89,14,0.08); border-color: rgba(73,89,14,0.15); color: #49590E; font-style: italic;
      }
      .lp-journey-session__clickids {
        display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px;
      }
      .lp-journey-clickid {
        font-family: 'DM Sans', sans-serif; font-size: 10px; color: rgba(44,24,16,0.4);
        background: rgba(44,24,16,0.03); padding: 1px 6px; border-radius: 2px;
        border: 1px solid rgba(44,24,16,0.06); cursor: default;
        max-width: 80px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .lp-journey-pages {
        border-left: 2px solid rgba(44,24,16,0.08); margin-left: 6px; padding-left: 14px;
      }
      .lp-journey-page {
        display: flex; align-items: baseline; gap: 8px; padding: 3px 0;
        font-family: 'DM Sans', sans-serif; font-size: 13px;
      }
      .lp-journey-page__time {
        font-size: 11px; color: rgba(44,24,16,0.35); min-width: 40px; flex-shrink: 0;
      }
      .lp-journey-page__path {
        color: #2C1810; word-break: break-all;
      }
      .lp-journey-page__dur {
        font-size: 11px; color: rgba(44,24,16,0.35); white-space: nowrap; margin-left: auto;
      }
      .lp-journey-actions {
        margin-top: 6px; padding-top: 6px; border-top: 1px dashed rgba(44,24,16,0.08);
      }
      .lp-journey-action {
        display: flex; align-items: center; gap: 8px; padding: 3px 0;
        font-family: 'DM Sans', sans-serif; font-size: 13px;
      }
      .lp-journey-action__dot {
        width: 7px; height: 7px; border-radius: 50%; background: #8C472E; flex-shrink: 0;
      }
      .lp-journey-action__time {
        font-size: 11px; color: rgba(44,24,16,0.35); min-width: 40px; flex-shrink: 0;
      }
      .lp-journey-action__label {
        color: #8C472E; font-weight: 600;
      }
      .lp-journey-action__detail {
        font-size: 11px; color: rgba(44,24,16,0.4);
      }
      /* .lp-journey-expand-btn removed - replaced by .jny-expand-btn */

      @media (max-width: 480px) {
        .rep-shell { padding: 24px 16px 64px; }
        .rep-header { flex-direction: column; align-items: flex-start; gap: 4px; margin-bottom: 16px; }
        .rep-header__meta { text-align: left; }
        .rep-title { font-size: 24px; }
        .adm-tab { padding: 8px 12px; font-size: 11px; letter-spacing: 0.06em; }
        .lead-panel__tabs { padding: 6px 8px; gap: 2px; }
        .lead-panel__filters { padding: 10px 12px; }
        .lead-toolbar__search { flex-wrap: wrap; }
        .lead-toolbar__input { max-width: none; }
        .lead-toolbar__filters { flex-direction: column; align-items: stretch; }
        .lead-toolbar__select { width: 100%; }
        .lead-heat-chips { gap: 4px; }
        .lead-heat-chip { font-size: 11px; padding: 3px 8px; }
        .lp-hero { flex-direction: column; text-align: center; padding: 14px; gap: 10px; }
        .lp-hero__contact { justify-content: center; }
        .lp-cols { grid-template-columns: 1fr; }
        .lp-col:first-child { border-right: none; border-bottom: 1px solid rgba(44,24,16,0.06); }
        .lp-detail-grid { grid-template-columns: 1fr; }
        .lp-journey-session { padding: 12px; }
        .lp-journey-page { font-size: 12px; }
        /* 5-band redesign mobile adjustments (~60% of desktop padding) */
        .lp-id-strip {
          padding: 18px 16px; column-gap: 12px;
          grid-template-columns: auto 1fr;
        }
        .lp-id-strip__avatar { width: 40px; height: 40px; font-size: 14px; }
        .lp-id-strip__name { font-size: 24px; }
        .lp-id-actions {
          grid-column: 1 / -1; margin-top: 12px;
          flex-wrap: wrap; width: 100%;
        }
        .lp-id-actions__btn { flex: 1; justify-content: center; }
        /* Mobile: revert to per-cell flex column - the 2-row alignment trick
           doesn't apply once we wrap to 2x2. Each cell stacks its own
           eyebrow + value vertically. */
        .lp-meta-strip {
          grid-template-columns: 1fr 1fr;
          grid-template-rows: auto;
          grid-auto-rows: auto;
          gap: 20px 16px;
          padding: 18px 18px;
        }
        .lp-meta-cell {
          display: flex; flex-direction: column; gap: 8px;
          min-width: 0;
        }
        .lp-meta-cell__eyebrow,
        .lp-meta-cell__value,
        .lp-meta-cell--ring .lp-score-ring {
          grid-row: auto; align-self: auto; justify-self: auto;
        }
        .lp-meta-cell__value { font-size: 14px; }
        .lp-funnel-hero { padding: 20px 18px; }
        .stage-callout { flex-direction: column; gap: 18px; margin-top: 20px; }
        .lp-stage-actions { width: 100%; }
        .lp-stage-actions__btn { flex: 1; justify-content: center; }
        .lp-body-row { grid-template-columns: 1fr; gap: 16px; }
        .lp-body { grid-template-columns: 1fr; }
        .lp-body-col { padding: 20px 18px; }
        .lp-meta-strip { min-height: 0; }
      }

      /* ═══════ Pricing tab (PricingView.jsx) ═══════ */
      .pr-view { display: block; }
      .pr-view-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
      }
      .pr-view-head .rep-h2 { margin-top: 0; }
      .pr-print-btn { flex-shrink: 0; align-self: flex-start; }

      .pr-section-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 12px;
      }
      .pr-h3 {
        font-family: var(--serif);
        font-size: 22px;
        font-weight: 500;
        margin: 0;
        color: var(--color-brewery-dark);
      }

      /* Meta strip - matches rep-totals feel */
      .pr-meta {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 24px;
      }
      @media (max-width: 720px) { .pr-meta { grid-template-columns: repeat(2, 1fr); } }
      .pr-meta-card {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-radius: 8px;
        padding: 16px 18px;
      }
      .pr-meta-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(44, 24, 16, 0.55);
        margin-bottom: 6px;
      }
      .pr-meta-value {
        font-family: var(--sans);
        font-size: 14px;
        color: var(--color-brewery-dark);
        font-variant-numeric: tabular-nums;
      }
      .pr-meta-value code {
        font-family: ui-monospace, Menlo, Consolas, monospace;
        font-size: 12px;
        background: rgba(64, 22, 12, 0.06);
        padding: 1px 6px;
        border-radius: 2px;
      }

      /* Status banner */
      .pr-status-banner {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-left: 3px solid var(--color-fired-brick);
        border-radius: 8px;
        padding: 14px 18px;
        font-size: 13px;
        color: var(--color-brewery-dark);
        margin-bottom: 32px;
        line-height: 1.5;
      }
      .pr-status-banner strong {
        font-weight: 700;
        color: var(--color-fired-brick);
        letter-spacing: 0.02em;
      }

      /* Anomaly callouts */
      .pr-callouts {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 12px;
        margin-bottom: 32px;
      }
      .pr-callout {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-left: 3px solid var(--color-dusty-coral);
        border-radius: 8px;
        padding: 16px 18px;
      }
      .pr-callout h3 {
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin: 0 0 8px;
        color: var(--color-brewery-dark);
      }
      .pr-callout p {
        font-size: 13px;
        line-height: 1.55;
        margin: 0;
        color: rgba(44, 24, 16, 0.75);
      }

      /* Legend */
      .pr-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        font-size: 12px;
        color: rgba(44, 24, 16, 0.65);
        margin-bottom: 14px;
      }
      .pr-legend-item { display: inline-flex; align-items: center; gap: 6px; }
      .pr-legend-swatch {
        display: inline-block;
        width: 14px;
        height: 14px;
        border: 1px solid rgba(64, 22, 12, 0.2);
        border-radius: 2px;
      }

      /* Table - scoped to .pr-table to avoid bleeding into other dashboard tables */
      .pr-table-wrap {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 32px;
      }
      .pr-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        min-width: 900px;
      }
      .pr-table thead th {
        background: rgba(44, 24, 16, 0.04);
        color: var(--color-brewery-dark);
        text-align: left;
        padding: 12px 14px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border-bottom: 1px solid var(--border-warm);
        position: sticky;
        top: 0;
        z-index: 2;
      }
      .pr-table thead th.draft {
        background: var(--color-fired-brick);
        color: var(--color-warm-canvas);
      }
      .pr-table tbody td {
        padding: 10px 14px;
        border-bottom: 1px solid var(--border-subtle);
        vertical-align: top;
      }
      .pr-table tbody tr:last-child td { border-bottom: none; }
      .pr-table tbody tr:hover td { background: rgba(140, 71, 46, 0.025); }
      .pr-table td.col-month {
        font-weight: 700;
        color: var(--color-brewery-dark);
        white-space: nowrap;
      }
      .pr-table td.col-daytype {
        color: rgba(44, 24, 16, 0.75);
        white-space: nowrap;
      }
      .pr-table .price {
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
      }
      .pr-table .price-delta {
        display: block;
        font-size: 10.5px;
        color: rgba(44, 24, 16, 0.5);
        margin-top: 2px;
        letter-spacing: 0.02em;
      }
      .pr-table .cell-up { background: rgba(46, 64, 9, 0.07); }
      .pr-table .cell-down { background: rgba(140, 71, 46, 0.09); }
      .pr-table .cell-flat { /* no tint */ }
      .pr-table td.draft-col {
        background: rgba(140, 71, 46, 0.06);
        border-left: 2px solid var(--color-fired-brick);
      }
      .pr-table td.draft-col.cell-up { background: rgba(140, 71, 46, 0.13); }
      .pr-table tr.month-first td { border-top: 1px solid var(--border-warm); }
      .pr-table tr.month-first:first-child td { border-top: none; }

      /* Footer */
      .pr-footer {
        background: var(--color-warm-white);
        border: 1px solid var(--border-warm);
        border-radius: 8px;
        padding: 20px 24px;
        font-size: 13px;
        color: rgba(44, 24, 16, 0.75);
        line-height: 1.6;
      }
      .pr-footer p { margin: 0 0 12px; }
      .pr-footer p:last-child { margin-bottom: 0; }
      .pr-footer strong { color: var(--color-brewery-dark); font-weight: 700; }
      .pr-footer code {
        font-family: ui-monospace, Menlo, Consolas, monospace;
        font-size: 12px;
        background: rgba(64, 22, 12, 0.06);
        padding: 1px 6px;
        border-radius: 2px;
      }

      /* Print view: landscape, remove non-essentials.
         Only the Pricing tab content is in the DOM when activeTab === "pricing",
         so we only need to hide dashboard chrome (shell header, tabs, refresh, footer). */
      @media print {
        @page { size: A4 landscape; margin: 12mm; }
        body { padding: 0; background: #fff; color: #000; }
        .rep-shell { padding: 0; max-width: none; }
        .rep-header, .rep-eyebrow, .rep-title, .rep-lede, .rep-footer,
        .adm-tabs, .rep-refresh, .pr-print-btn { display: none !important; }
        .pr-view-head { margin-bottom: 12px; }
        .pr-status-banner { background: #fff; color: #000; border: 2px solid #000; }
        .pr-callouts { page-break-after: always; }
        .pr-table-wrap { overflow: visible; border: none; background: #fff; }
        .pr-table { font-size: 10px; min-width: 0; }
        .pr-table thead th { background: #eee !important; color: #000 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .pr-table thead th.draft { background: #333 !important; color: #fff !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .pr-table td.draft-col { background: #f5f5f5 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .pr-table .cell-up { background: #f0f5e8 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .pr-table .cell-down { background: #fbeae4 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      }
    </style>
  </head>
  <body>
    <div class="rep-shell">
      <header class="rep-header">
        <div class="rep-header__left">
          <p class="rep-eyebrow">Internal &middot; The Hackney</p>
          <h1 class="rep-title">Dashboard</h1>
        </div>
        <p class="rep-header__meta">Auto-refreshes every 60s</p>
      </header>

      <AdminDashboard client:load pricing={pricing} />

      <div class="rep-footer">
        Protected by Cloudflare Access. First-party data only.
        Cookie consent is respected. Contact data is PII - do not share externally.
      </div>
    </div>
  </body>
</html>
