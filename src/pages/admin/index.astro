---
/**
 * Branded login landing page for the admin dashboard.
 *
 * URL: /admin/
 *
 * This page is NOT behind Cloudflare Access. It acts as a branded
 * entry point that links to /admin/dashboard/ (which IS protected).
 * When the user clicks "Sign In", Cloudflare Access intercepts and
 * shows the email verification flow.
 *
 * NOT linked from anywhere on the public site. Hidden from:
 *   - Google + all search engines (meta robots)
 *   - AI training crawlers (named user-agents)
 *   - The public sitemap (filtered in astro.config.mjs)
 *   - Social previews (no og: tags, no canonical)
 *
 * Audience: Jon, Hugo, and James.
 * Built 2026-04-14.
 */
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Hard noindex -->
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex, notranslate, nocache, max-snippet:0, max-image-preview:none, max-video-preview:0" />
    <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet, noimageindex" />
    <meta name="bingbot" content="noindex, nofollow, noarchive, nosnippet" />
    <meta name="ChatGPT-User" content="noindex, nofollow" />
    <meta name="GPTBot" content="noindex, nofollow" />
    <meta name="Google-Extended" content="noindex, nofollow" />
    <meta name="ClaudeBot" content="noindex, nofollow" />
    <meta name="anthropic-ai" content="noindex, nofollow" />
    <meta name="PerplexityBot" content="noindex, nofollow" />

    <meta name="referrer" content="no-referrer" />

    <title>Team Dashboard - The Hackney</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@400;500;700&display=swap"
    />

    <style>
      :root {
        --color-warm-canvas: #F5F0E8;
        --color-brewery-dark: #2C1810;
        --color-forest-olive: #2E4009;
        --color-mid-olive: #49590E;
        --color-fired-brick: #8C472E;
        --color-dusty-coral: #BF7256;
        --color-mahogany: #40160C;
        --serif: 'Cormorant Garamond', Georgia, serif;
        --sans: 'DM Sans', system-ui, sans-serif;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: var(--sans);
        background: var(--color-brewery-dark);
        color: var(--color-warm-canvas);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        -webkit-font-smoothing: antialiased;
      }

      .login-card {
        width: 100%;
        max-width: 440px;
        margin: 40px 24px;
        text-align: center;
      }

      .login-logo {
        width: 120px;
        height: auto;
        margin-bottom: 40px;
        opacity: 0.95;
      }

      .login-eyebrow {
        font-family: var(--sans);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--color-dusty-coral);
        margin-bottom: 12px;
      }

      .login-title {
        font-family: var(--serif);
        font-size: 36px;
        font-weight: 500;
        color: var(--color-warm-canvas);
        margin-bottom: 16px;
        letter-spacing: -0.01em;
        line-height: 1.15;
      }

      .login-body {
        font-size: 15px;
        line-height: 1.6;
        color: rgba(245, 240, 232, 0.65);
        margin-bottom: 40px;
        max-width: 360px;
        margin-left: auto;
        margin-right: auto;
      }

      .login-btn {
        display: inline-block;
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        background: var(--color-mid-olive);
        color: var(--color-warm-canvas);
        border: none;
        border-radius: 2px;
        padding: 16px 48px;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.2s;
      }

      .login-btn:hover {
        background: var(--color-forest-olive);
      }

      .login-divider {
        width: 48px;
        height: 1px;
        background: rgba(245, 240, 232, 0.15);
        margin: 40px auto 24px;
      }

      .login-footer {
        font-size: 12px;
        color: rgba(245, 240, 232, 0.35);
        line-height: 1.6;
      }

      .login-footer a {
        color: var(--color-dusty-coral);
        text-decoration: none;
        opacity: 0.8;
      }
      .login-footer a:hover {
        opacity: 1;
      }

      .login-lock {
        display: inline-block;
        margin-bottom: 4px;
        opacity: 0.4;
      }

      @media (max-width: 480px) {
        .login-title { font-size: 28px; }
        .login-btn { padding: 14px 36px; }
      }
    </style>
  </head>
  <body>
    <div class="login-card">
      <img
        src="/images/the-hackney-logo.webp"
        alt="The Hackney"
        class="login-logo"
        width="120"
        height="85"
      />

      <p class="login-eyebrow">Team Dashboard</p>
      <h1 class="login-title">Reporting and Analytics</h1>
      <p class="login-body">
        Visitor tracking, date clicks, CTA performance, and traffic sources
        - all in one place. Access is restricted to the team.
      </p>

      <a href="/admin/dashboard/" class="login-btn">Sign In</a>

      <div class="login-divider"></div>

      <p class="login-footer">
        <svg class="login-lock" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        Protected by Cloudflare Access.<br />
        You'll receive a one-time code via email to verify your identity.
      </p>
    </div>
  </body>
</html>
