          <div class="team-photo lazy-bg" data-bg="" data-bg-pos="center top" role="img" aria-label="Jon Penn - Director of The Hackney"></div>
          <div class="team-name">Jon Penn</div>
          <div class="team-role">Director</div>
          <p class="team-bio"><span class="placeholder">[PLACEHOLDER BIO - Jon to fill in.]</span></p>
