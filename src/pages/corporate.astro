---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofBar from '../components/ProofBar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import PhotoBreak from '../components/PhotoBreak.astro';
import IncludedGrid from '../components/IncludedGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CorporateQuestionnaire from '../components/CorporateQuestionnaire.astro';

// Corporate FAQ items
const faqItems = [
  {
    question: "How many guests can the venue hold?",
    answer: "Up to 60 seated for a formal dinner and up to 100 for a standing reception. The space reconfigures for presentations, workshops, dining, or networking. If you need more than 100 standing, we are probably not the right fit - but we are happy to recommend other venues."
  },
  {
    question: "What is included in the venue hire?",
    answer: "Exclusive hire of the entire building from 9am to 11pm, your dedicated events manager, full staffing, furniture, and our built-in sound and lighting system. Catering and bar are charged separately based on your requirements. See the Everything Included section above for the full breakdown."
  },
  {
    question: "Can we bring our own caterers?",
    answer: "Yes. We offer both full-service and dry hire. Most clients use our in-house kitchen and bar team because it keeps everything under one roof, but you are welcome to bring your own caterers, production teams, or suppliers. You can also mix and match - use our bar team but bring your own food, for example. We will work around whatever setup you need."
  },
  {
    question: "How far in advance should we book?",
    answer: "Most corporate events book four to eight weeks out. Christmas party dates and summer Fridays go earliest - two to three months ahead for the best availability. Board meetings and photo shoots often book the same week. The calendar on our Check Your Date page shows live availability."
  },
  {
    question: "Is there parking?",
    answer: "There is no on-site parking. Hackney Road has metered parking during the day and free parking from 7pm to 8am. Several NCP car parks are within 10 minutes. The venue is a one-minute walk from Cambridge Heath Overground and five to seven minutes from Bethnal Green Underground (Central line)."
  },
  {
    question: "Can we visit the venue before booking?",
    answer: "Yes. We run venue tours with Hugo, our General Manager. He will walk you through every space and talk through how your event could work. Book a visit through our Check Your Date page or call us directly."
  }
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "The Hackney",
  "description": "Corporate events venue in East London - conferences, team days, product launches, brand activations",
  "@id": "https://thehackney-website.pages.dev",
  "url": "https://thehackney-website.pages.dev/corporate/",
  "telephone": "+442079611604",
  "priceRange": "From £2,000 + VAT",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "503 Hackney Road",
    "addressLocality": "London",
    "postalCode": "E2 9ED",
    "addressCountry": "GB"
  }
};

const combinedSchema = JSON.stringify([localBusinessSchema]);
---

<Base title="Corporate Events Venue East London | The Hackney, E2" description="Host your corporate event at The Hackney - a restored 1856 brewery on Hackney Road. Conferences, team days, product launches, brand activations. 60 seated, 100 standing. Exclusively yours. Trusted by Adidas, Spotify, Samsung, Coca-Cola." schema={combinedSchema}>

  <!-- ==================== SECTION 1: HERO ==================== -->
  <HeroSection
    bg="image"
    image="/images/hackney-main-hall-long-tables-greenery-edison-bulbs.webp"
    alt="The Hackney main hall set for dinner with long tables, hanging greenery, Edison bulbs, and skylights"
    heading='One Venue.<br>Everything Handled.'
    cta={{ label: "Get A Proposal", href: "/corporate/#questionnaire" }}
    note="Dry hire or full-service. In-house catering, bar, and events team - or bring your own. Up to 100 guests, exclusively yours."
    height="mid"
    textGradient={true}
    position="center bottom"
  />

  <!-- ==================== SECTION 2: SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "Adidas, Spotify, Samsung", label: "Brands we've hosted" },
    { number: "Exclusive Hire", label: "The whole venue, just for you" },
    { number: "100 Standing, 60 Seated", label: "Flexible layouts" },
    { number: "In-House Catering & Bar", label: "One team, one invoice" }
  ]} />

  <!-- ==================== SECTION 3: LOGO STRIP ==================== -->
  <Section bg="light" padding="compact" border="bottom">
    <div class="logo-strip">
      <p class="eyebrow logo-strip-eyebrow">Trusted by</p>
      <div class="logo-strip-grid">
        <img class="logo-strip-item" src="/images/logos/adidas.svg" alt="Adidas" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/spotify.svg" alt="Spotify" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/samsung.svg" alt="Samsung" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/coca-cola.svg" alt="Coca-Cola" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/amazon.svg" alt="Amazon" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/diageo.svg" alt="Diageo" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/itv.svg" alt="ITV" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/unilever.svg" alt="Unilever" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/ocado.svg" alt="Ocado" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/bacardi.svg" alt="Bacardi" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/sainsburys.svg" alt="Sainsbury's" loading="lazy" />
        <img class="logo-strip-item" src="/images/logos/next.svg" alt="Next" loading="lazy" />
      </div>
    </div>
  </Section>

  <!-- ==================== SECTION 4: CORPORATE QUESTIONNAIRE (hot lane - early, like wedding quiz) ==================== -->
  <!-- Interactive multi-step quiz matching WeddingQuestionnaire pattern:
       Event Type → Guests → Date → Capture (name, company, email, phone) → Budget (optional)
       Lead is captured at step 4 - budget step can't kill the lead.
       Confirmation screen routes: Christmas → /christmas-parties/, high-value → venue tour, default → what happens next. -->
  <CorporateQuestionnaire />

  <!-- ==================== SECTION 5: ONE BOOKING. EVERYTHING HANDLED. ==================== -->
  <Section bg="light" border="bottom" id="included">
    <SectionHeader
      eyebrow="Why The Hackney"
      heading="One Booking. Everything Handled."
    />
    <div class="different-body">
      <p>We are more than a venue. We are an events team, a catering team, and a fully equipped space - all under one roof. Need us to run everything from planning to breakdown? We do that. Prefer dry hire so you can bring your own suppliers and run the day yourself? We do that too.</p>
      <p>Most corporate venues are one or the other. The Hackney gives you the choice - and you can mix and match. Hire the building and our bar team but bring your own caterer. Use our kitchen but manage the event yourself. Whatever your event needs, we fit around it.</p>
    </div>

    <IncludedGrid
      categories={[
        {
          title: "Full-Service",
          items: [
            "Dedicated events manager from planning to breakdown",
            "In-house kitchen - custom menus, breakfast to dinner",
            "Full bar team with signature cocktails",
            "All staffing, furniture, AV, and coordination"
          ]
        },
        {
          title: "Dry Hire",
          items: [
            "Exclusive hire of the entire building, 9am to 11pm",
            "All furniture, glassware, tableware included",
            "Projector, screens, professional sound system, wifi",
            "Bring your own caterers, suppliers, and production team"
          ]
        },
        {
          title: "Always Included",
          items: [
            "Exclusive hire - the whole building, just for you",
            "Flexible layouts - theatre, boardroom, banquet, standing",
            "No service charge, no hidden extras",
            "One clear price - the quote is the bill"
          ]
        }
      ]}
      promise='<strong>The price we quote is the price you pay.</strong> Whether you choose full-service or dry hire, there are no surprise invoices, no service charges, and no discovering that "venue hire" did not include the tables.'
    />
  </Section>

  <!-- ==================== SECTION 6: EVENTS WE HOST ==================== -->
  <Section bg="light" padding="compact" border="bottom">
    <SectionHeader
      eyebrow="What We Host"
      heading="From Boardrooms To Brand Launches"
    />
    <div class="event-grid">
      <div class="event-card fade-in">
        <h3>Conferences and Seminars</h3>
        <p>Boardroom sessions, strategy days, and multi-day conferences. Full AV, flexible breakout layouts, and catering from breakfast through to evening.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Team Days and Offsites</h3>
        <p>Take your team out of the office and into a space that inspires. Workshops, team meals, and informal collaboration - all under one roof.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Product Launches</h3>
        <p>A venue that photographs as well as it functions. Professional AV, in-house catering, and a backdrop that makes your launch the story.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Press and PR Events</h3>
        <p>Media gatherings, press lunches, and industry dinners in a space that sets the tone before you say a word. Full catering and bar service included.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Brand Activations</h3>
        <p>Experiential events in a space your audience will remember. Past activations include Adidas, Spotify, Samsung, and Coca-Cola.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Photography and Film</h3>
        <p>Our Winter Garden is a studio-style space with floor-to-ceiling windows and abundant natural light. Half-day and full-day dry hire available.</p>
      </div>
      <div class="event-card event-card-christmas fade-in">
        <h3>Christmas Parties</h3>
        <p>The most in-demand corporate booking of the year. Two all-inclusive packages from £100 + VAT per person.</p>
        <a href="/christmas-parties/" class="event-card-link">Explore Christmas Parties &rarr;</a>
      </div>
    </div>
  </Section>

  <!-- ==================== SECTION 6B: PAST EVENTS ==================== -->
  <Section bg="light">
    <SectionHeader
      eyebrow="Past Events"
      heading="Brands That Chose The Hackney"
    />

    <div class="past-events">
      <article class="past-event">
        <div class="past-event-image">
          <div class="past-event-image-bg lazy-bg" data-bg="/images/hackney-brand-activation-impulse-guest-pink-backdrop.webp" data-bg-pos="center center" role="img" aria-label="Guest at Impulse brand activation with pink crystal backdrop at The Hackney"></div>
        </div>
        <div class="past-event-content">
          <h3>Impulse</h3>
          <p class="past-event-meta">Brand Activation</p>
        </div>
      </article>

      <article class="past-event">
        <div class="past-event-image">
          <div class="past-event-image-bg lazy-bg" data-bg="/images/hackney-brand-activation-enfuse-dinner-presentation.webp" data-bg-pos="center center" role="img" aria-label="Enfuse corporate dinner with speaker presenting to guests surrounded by flowers and greenery at The Hackney"></div>
        </div>
        <div class="past-event-content">
          <h3>Enfuse</h3>
          <p class="past-event-meta">Corporate Dinner</p>
        </div>
      </article>

      <article class="past-event">
        <div class="past-event-image">
          <div class="past-event-image-bg lazy-bg" data-bg="/images/hackney-brand-activation-vagabond-guests-edison-bulbs.webp" data-bg-pos="center center" role="img" aria-label="Guests with champagne at Vagabond Shoemakers launch event under Edison bulbs at The Hackney"></div>
        </div>
        <div class="past-event-content">
          <h3>Vagabond</h3>
          <p class="past-event-meta">Product Launch</p>
        </div>
      </article>
    </div>
  </Section>

  <!-- ==================== PHOTO BREAK: VENUE INTERIOR ==================== -->
  <PhotoBreak
    image="/images/hackney-gozney-brand-activation-pizza-oven-crowd.webp"
    alt="Gozney brand activation at The Hackney - crowd gathered around pizza oven demo"
    position="center 50%"
  />

  <!-- ==================== SECTION 7: THE SPACE ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="The Venue"
      heading="Four Spaces. One Venue. Entirely Yours."
      subtext="A restored 1856 brewery on Hackney Road, East London. The architecture does the heavy lifting - exposed brick, original timber beams, natural skylights, high ceilings."
    />
    <p class="space-intro">Four interconnected areas adapt to your event: the main hall for presentations or dining, the bar for arrivals and networking, the winter garden for breakout sessions or drinks, and the covered terrace for fresh air without leaving the venue.</p>
    <div class="space-capacity">
      <div class="capacity-stat">
        <div class="capacity-number">60</div>
        <div class="capacity-label">Guests seated</div>
      </div>
      <div class="capacity-stat">
        <div class="capacity-number">100</div>
        <div class="capacity-label">Standing reception</div>
      </div>
    </div>

    <div class="space-details">
      <div class="space-feature">
        <h3>Exclusively Yours</h3>
        <p>The whole building is yours for the day. No shared spaces, no other events, no surprises. Standard hire runs from 9am with music until 11pm and guests departing by 11:30pm.</p>
      </div>
      <div class="space-feature">
        <h3>Built For Events</h3>
        <p>Professional AV is built into the venue - projector, screens, sound system, and wifi throughout. No need to hire external equipment. The space reconfigures from theatre-style presentations to long-table dinners to standing receptions.</p>
      </div>
    </div>

    <div class="space-image-container">
      <img class="space-image" src="/images/hackney-canapes-wooden-board-corporate-catering.webp" alt="Canapes on wooden boards served at a corporate event at The Hackney" loading="lazy" />
    </div>
  </Section>

  <!-- ==================== SECTION 8: PRICING + BROCHURE DOWNLOAD ==================== -->
  <Section bg="light" border="top" id="pricing">
    <SectionHeader
      eyebrow="Investment"
      heading="Pricing"
    />

    <div class="pricing-tiers">
      <div class="pricing-tier">
        <h3>Full Day Venue Hire</h3>
        <div class="pricing-tier-price">&pound;2,000 + VAT</div>
        <p>Exclusive hire of the entire venue, 9am to 11pm. All staffing, furniture, and AV included.</p>
      </div>
      <div class="pricing-tier">
        <h3>Catering Buy-Out</h3>
        <div class="pricing-tier-price">&pound;500 + VAT</div>
        <p class="pricing-tier-optional">Optional</p>
        <p>Bring our in-house kitchen into your event. Menu development, tasting, and full service.</p>
      </div>
      <div class="pricing-tier">
        <h3>Bar Service Buy-Out</h3>
        <div class="pricing-tier-price">&pound;500 + VAT</div>
        <p class="pricing-tier-optional">Optional</p>
        <p>Full bar team, premium spirits, wine, beer, soft drinks. Signature cocktails available.</p>
      </div>
    </div>

    <div class="pricing-note">
      <p>Three-course guest menus from £70 + VAT per person. All prices exclude VAT. Get in touch for a detailed proposal tailored to your event.</p>
    </div>

    <!-- Brochure download - warm/cold lane capture (same pattern as weddings pricing section) -->
    <div class="pricing-pivot">
      <h3>Want The Full Details?</h3>
      <p>Our corporate brochure covers venue specs, catering options, past events, and everything you need to share with your team. Download it now.</p>
    </div>

    <form class="pricing-form" id="corporate-brochure" data-form="corporate-brochure-download">
      <div class="form-row">
        <div class="form-group">
          <label for="brochure-name">Name</label>
          <input type="text" id="brochure-name" name="name" placeholder="Your name" required>
        </div>
        <div class="form-group">
          <label for="brochure-email">Work email</label>
          <input type="email" id="brochure-email" name="email" placeholder="you@company.com" required>
        </div>
      </div>
      <button type="submit" class="btn btn-primary pricing-form-submit">Download The Corporate Brochure</button>
      <p class="pricing-form-note">Sent instantly by email. No calls, no pitch.</p>
    </form>
  </Section>

  <!-- ==================== SECTION 9: HOW IT WORKS ==================== -->
  <Section bg="light" border="top">
    <SectionHeader
      eyebrow="How It Works"
      heading="From First Enquiry To Event Day"
    />

    <ProcessSteps steps={[
      {
        title: "Tell Us What You Need",
        description: "Fill in the enquiry form above or check availability on our live calendar. We will come back with a tailored proposal within 24 hours."
      },
      {
        title: "Visit The Venue",
        description: "Come and walk the space with Hugo, our General Manager. He will show you every corner of the building and talk you through how your event could work."
      },
      {
        title: "Your Proposal",
        description: "One document covering venue hire, catering, bar, AV, and every detail of your event. Clear pricing, no hidden costs, nothing buried in the small print."
      },
      {
        title: "Confirm and Relax",
        description: "A deposit secures your date. From that moment, your dedicated events manager handles every detail through to the last guest leaving."
      }
    ]} />

    <div class="section-cta-center">
      <a href="/check-your-date/?type=corporate&utm_source=website&utm_medium=cta&utm_campaign=corporate&utm_content=how-it-works" class="btn btn-primary">See The Calendar</a>
    </div>
  </Section>

  <!-- ==================== PHOTO BREAK: SKYLIGHTS ==================== -->
  <PhotoBreak
    image="/images/hackney-gozney-brand-activation-pizza-oven-closeup.webp"
    alt="Close-up of Gozney pizza oven with flames at brand activation event at The Hackney"
    position="center 40%"
  />

  <!-- ==================== SECTION 10: FAQ ==================== -->
  <Section bg="light" border="top" padding="compact">
    <SectionHeader
      eyebrow="Before You Enquire"
      heading="What Corporate Clients Ask"
    />
    <FAQ items={faqItems} />
  </Section>

  <!-- ==================== SECTION 11: CHRISTMAS PARTIES TEASER ==================== -->
  <Section bg="dark" padding="compact">
    <div class="christmas-teaser">
      <p class="eyebrow christmas-teaser-eyebrow">Seasonal</p>
      <h2>Christmas At The Hackney</h2>
      <p class="christmas-teaser-body">The most popular corporate booking of the year. Two all-inclusive packages - standing reception or seated dinner. Exclusive hire, in-house catering and bar, seasonal styling included.</p>
      <a href="/christmas-parties/" class="btn btn-primary-dark">Explore Christmas Parties</a>
    </div>
  </Section>

  <!-- ==================== SECTION 12: FINAL CTA ==================== -->
  <FinalCTA
    heading="Ready to book your event?"
    body="Check availability on our live calendar or send us an enquiry."
    primaryCTA={{ label: "Check Your Date", href: "/check-your-date/" }}
    whatsapp={true}
    utmCampaign="corporate"
  />

  <style>
    /* ==================== LOGO STRIP ==================== */
    .logo-strip {
      text-align: center;
    }

    .logo-strip-eyebrow {
      text-align: center;
      margin-bottom: 24px;
    }

    .logo-strip-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 16px 32px;
      max-width: 800px;
      margin: 0 auto;
    }

    .logo-strip-item {
      height: 32px;
      max-width: 120px;
      width: auto;
      object-fit: contain;
      filter: grayscale(100%) brightness(0) opacity(0.45);
      transition: filter 0.3s ease;
      padding: 4px 0;
    }

    .logo-strip-item:hover {
      filter: grayscale(100%) brightness(0) opacity(0.7);
    }

    /* ==================== ENQUIRY FORM CSS REMOVED ==================== */
    /* Static form replaced by CorporateQuestionnaire (React island).
       Quiz styles live in CorporateQuestionnaire.astro via .wq-* classes. */

    /* ==================== VALUE PROP (matches weddings Section 4) ==================== */
    .different-body {
      max-width: 760px;
    }

    .different-body p {
      font-size: 18px;
      margin-bottom: 20px;
      line-height: 1.7;
    }

    .different-body p:last-of-type {
      margin-bottom: 36px;
    }

    /* IncludedGrid styles now live in IncludedGrid.astro component */

    /* ==================== EVENT TYPES GRID ==================== */
    .event-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .event-card {
      padding: 28px 24px;
      border: 1px solid rgba(44, 24, 16, 0.1);
      border-top: 3px solid var(--forest-olive);
      border-radius: 2px;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .event-card:hover {
      border-color: var(--forest-olive);
      border-top-color: var(--forest-olive);
      transform: translateY(-4px);
    }

    .event-card h3 {
      font-size: 20px;
      margin-bottom: 12px;
      color: var(--mid-olive);
    }

    .event-card p {
      font-size: 16px;
      line-height: 1.6;
      opacity: 0.85;
    }

    /* Christmas card spans full width as the 5th card */
    .event-card-christmas {
      grid-column: 1 / -1;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px;
      border-top-color: var(--fired-brick);
    }

    .event-card-christmas h3 {
      color: var(--fired-brick);
    }

    .event-card-christmas p {
      flex: 1;
      min-width: 200px;
    }

    .event-card-link {
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 600;
      color: var(--dusty-coral);
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.2s ease;
    }

    .event-card-link:hover {
      color: var(--fired-brick);
    }

    /* ==================== THE SPACE ==================== */
    .space-intro {
      font-size: 17px;
      line-height: 1.7;
      max-width: 720px;
      margin: 0 auto 2.5rem;
      text-align: center;
    }

    .space-capacity {
      display: flex;
      justify-content: center;
      gap: 4rem;
      margin-bottom: 2.5rem;
    }

    .capacity-stat {
      text-align: center;
    }

    .capacity-number {
      font-family: var(--font-heading);
      font-size: 3.5rem;
      font-weight: 700;
      color: var(--brewery-dark);
      line-height: 1;
    }

    .capacity-label {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--dusty-coral);
      margin-top: 8px;
    }

    .space-details {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      margin-bottom: 2.5rem;
    }

    .space-feature h3 {
      font-size: 1.15rem;
      margin-bottom: 0.75rem;
      color: var(--mid-olive);
    }

    .space-feature p {
      font-size: 16px;
      line-height: 1.7;
      opacity: 0.85;
    }

    .space-image-container {
      max-width: 720px;
      margin: 0 auto;
    }

    .space-image {
      width: 100%;
      border-radius: 2px;
      border: 1px solid rgba(44, 24, 16, 0.08);
    }

    /* ==================== PRICING ==================== */
    .pricing-tiers {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 2rem;
    }

    .pricing-tier {
      padding: 32px 24px;
      border: 1.5px solid rgba(44, 24, 16, 0.1);
      border-radius: 2px;
      text-align: center;
      background: rgba(255, 255, 255, 0.6);
    }

    .pricing-tier h3 {
      font-size: 1.1rem;
      margin-bottom: 12px;
      color: var(--mid-olive);
    }

    .pricing-tier-price {
      font-family: var(--font-heading);
      font-size: 2rem;
      font-weight: 700;
      color: var(--brewery-dark);
      margin-bottom: 12px;
    }

    .pricing-tier-optional {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--dusty-coral);
      margin-bottom: 8px;
      font-weight: 600;
    }

    .pricing-tier p {
      font-size: 14px;
      line-height: 1.6;
      opacity: 0.75;
    }

    .pricing-note {
      text-align: center;
      margin-bottom: 3rem;
      padding: 20px;
      background: rgba(44, 24, 16, 0.03);
      border-radius: 2px;
    }

    .pricing-note p {
      font-size: 14px;
      font-style: italic;
      opacity: 0.7;
    }

    .pricing-pivot {
