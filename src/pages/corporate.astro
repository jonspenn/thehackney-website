---
import Base from '../layouts/Base.astro';
---

<style is:global>
  :root {
    --warm-canvas: #F5F0E8;
    --brewery-dark: #2C1810;
    --forest-olive: #2E4009;
    --fired-brick: #8C472E;
    --dusty-coral: #BF7256;
    --signal-green: #28A745;
    --font-heading: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'DM Sans', sans-serif;
  }

  /* Hero Section */
  .hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: var(--forest-olive) url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 800"><defs><pattern id="pattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse"><path d="M0 0L100 100M100 0L0 100" stroke="rgba(255,255,255,0.03)" stroke-width="1"/></pattern></defs><rect width="1200" height="800" fill="url(%23pattern)"/></svg>');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--warm-canvas);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(46, 64, 9, 0.5);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    padding: 40px 20px;
    animation: fadeInUp 0.8s ease;
  }

  .hero-content .eyebrow {
    color: var(--dusty-coral);
  }

  .hero-content h1 {
    color: var(--warm-canvas);
    margin-bottom: 25px;
  }

  .hero-content p {
    font-size: 18px;
    line-height: 1.65;
    opacity: 0.95;
  }

  /* Social Proof Bar */
  .social-proof {
    background-color: var(--brewery-dark);
    color: var(--warm-canvas);
    padding: 30px 20px;
  }

  .social-proof-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
    text-align: center;
  }

  .proof-item h4 {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 5px;
  }

  .proof-item p {
    font-size: 13px;
    opacity: 0.9;
  }

  /* Event Types Grid */
  .event-types {
    background-color: var(--warm-canvas);
  }

  .event-types h2 {
    text-align: center;
    margin-bottom: 50px;
  }

  .event-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
    margin-bottom: 40px;
  }

  .event-card {
    background: var(--warm-canvas);
    border: 1px solid rgba(44, 24, 16, 0.1);
    padding: 40px 30px;
    text-align: center;
    transition: all 0.3s ease;
  }

  .event-card:hover {
    box-shadow: 0 10px 30px rgba(44, 24, 16, 0.08);
    transform: translateY(-5px);
  }

  .event-card h3 {
    color: var(--fired-brick);
    margin-bottom: 15px;
  }

  .event-card p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--brewery-dark);
  }

  /* The Space Section */
  .the-space {
    background-color: var(--warm-canvas);
  }

  .the-space-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .the-space-text h2 {
    margin-bottom: 25px;
  }

  .the-space-text p {
    margin-bottom: 20px;
    line-height: 1.7;
  }

  .venue-features {
    margin-top: 30px;
    padding-top: 30px;
    border-top: 1px solid rgba(44, 24, 16, 0.1);
  }

  .venue-features p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--brewery-dark);
  }

  @media (max-width: 768px) {
    .the-space-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  /* What's Included Section */
  .whats-included {
    background-color: var(--warm-canvas);
  }

  .whats-included h2 {
    text-align: center;
    margin-bottom: 50px;
  }

  .included-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px;
  }

  .included-item {
    background: var(--warm-canvas);
    padding: 40px 30px;
    border-left: 4px solid var(--fired-brick);
  }

  .included-item h3 {
    color: var(--fired-brick);
    font-size: 20px;
    margin-bottom: 12px;
  }

  .included-item p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--brewery-dark);
  }

  /* Pricing Section */
  .pricing {
    background-color: var(--warm-canvas);
  }

  .pricing h2 {
    text-align: center;
    margin-bottom: 50px;
  }

  .pricing-items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-bottom: 40px;
  }

  .pricing-item {
    background: var(--warm-canvas);
    padding: 35px 30px;
    text-align: center;
    border: 1px solid rgba(44, 24, 16, 0.1);
  }

  .pricing-item p:first-child {
    font-size: 14px;
    color: var(--dusty-coral);
    margin-bottom: 10px;
  }

  .price {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    color: var(--brewery-dark);
    margin-bottom: 5px;
  }

  .pricing-note {
    text-align: center;
    font-size: 14px;
    color: var(--brewery-dark);
    font-style: italic;
    margin-top: 20px;
    padding: 20px;
    background: rgba(44, 24, 16, 0.03);
  }

  /* Final CTA Section */
  .final-cta {
    background-color: var(--brewery-dark);
    color: var(--warm-canvas);
    text-align: center;
  }

  .final-cta h2 {
    color: var(--warm-canvas);
    margin-bottom: 30px;
  }

  .final-cta .btn-primary {
    background-color: var(--dusty-coral);
    font-size: 14px;
    padding: 14px 35px;
    margin-bottom: 30px;
  }

  .final-cta .btn-primary:hover {
    background-color: var(--fired-brick);
  }

  .contact-note {
    font-size: 16px;
    margin-top: 20px;
  }

  .contact-note a {
    color: var(--dusty-coral);
    text-decoration: none;
    font-weight: 500;
  }

  .contact-note a:hover {
    text-decoration: underline;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in {
    animation: fadeInUp 0.8s ease forwards;
    opacity: 0;
  }
</style>

<Base title="Corporate Events Venue East London | The Hackney, E2" description="Host your corporate event at The Hackney. Conferences, team days, product launches, brand activations. 60 seated, 100 standing. Exclusively yours. Past clients include Adidas, Spotify, Samsung.">
<!-- Navigation -->


  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <div class="eyebrow">Corporate Events at The Hackney</div>
      <h1>Your event. Our brewery.</h1>
      <p>Conferences, team days, product launches and brand activations - inside a restored 1860s brewery on Hackney Road, East London. 60 seated, 100 standing.</p>
    </div>
  </section>

  <!-- Social Proof Bar -->
  <div class="social-proof">
    <div class="social-proof-inner">
      <div class="proof-item">
        <h4>200+</h4>
        <p>Events hosted</p>
      </div>
      <div class="proof-item">
        <h4>4.6</h4>
        <p>Google rating</p>
      </div>
      <div class="proof-item">
        <h4>Exclusive</h4>
        <p>Venue hire</p>
      </div>
      <div class="proof-item">
        <h4>In-house</h4>
        <p>Kitchen &amp; bar</p>
      </div>
    </div>
  </div>

  <!-- Event Types Section -->
  <section class="event-types">
    <h2>Events we host</h2>
    <div class="event-grid">
      <div class="event-card fade-in">
        <h3>Conferences & Seminars</h3>
        <p>From intimate roundtables to large conferences. AV available, flexible layouts, in-house catering.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Team Days & Offsites</h3>
        <p>Build culture and connection. Space for activities, breakout rooms, refreshments, team meals.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Product Launches</h3>
        <p>A unique backdrop for press events and experiential marketing. Flexible space, full AV, catering.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Brand Activations</h3>
        <p>Memorable experiences in an iconic setting. We have hosted Adidas, Spotify, Samsung, Coca-Cola, ITV, Unilever.</p>
      </div>
    </div>
  </section>

  <!-- The Space Section -->
  <section class="the-space">
    <div class="the-space-content">
      <div class="the-space-text">
        <h2>The space</h2>
        <p>The Hackney is a restored 1860s brewery with 60 seats and room for 100 standing. Your event is exclusive - you get the whole venue to yourself, all day and all night if you want it.</p>
        <p>Our in-house kitchen means proper food, proper drinks, and full control over your experience. No outside caterers, no corkage, no hidden fees. Just the space you need and the service to match.</p>
        <div class="venue-features">
          <p>The venue features exposed brick walls, skylights that flood the space with natural light, high ceilings for an open feel, and a flexible layout that adapts to how you want to use the space.</p>
        </div>
      </div>
      <div class="the-space-image">
        <div class="space-placeholder" style="width:100%;aspect-ratio:4/3;background:var(--brewery-dark);border-radius:2px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.4);font-size:14px;">Photo coming soon</div>
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section class="whats-included">
    <h2>What's included</h2>
    <div class="included-grid">
      <div class="included-item">
        <h3>Venue</h3>
        <p>Exclusive hire of the entire space. 60 seated, 100 standing. All day, all evening.</p>
      </div>
      <div class="included-item">
        <h3>Catering</h3>
        <p>In-house kitchen and team. Custom menus tailored to your event and your budget.</p>
      </div>
      <div class="included-item">
        <h3>Bar service</h3>
        <p>Full bar with wine, beer, spirits and soft drinks. No corkage, no outside alcohol.</p>
      </div>
      <div class="included-item">
        <h3>Coordination</h3>
        <p>Dedicated events coordinator. Eva or one of our team handles everything on the day.</p>
      </div>
      <div class="included-item">
        <h3>Layout flexibility</h3>
        <p>Banquet, cabaret, theatre style, cocktail - the space adapts to your needs.</p>
      </div>
      <div class="included-item">
        <h3>AV available</h3>
        <p>Projector, screen and sound system available if you need them for presentations.</p>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="pricing">
    <h2>Pricing</h2>
    <div class="pricing-items">
      <div class="pricing-item">
        <p>Half day hire</p>
        <p><span class="price">from £2,500</span></p>
      </div>
      <div class="pricing-item">
        <p>Full day hire</p>
        <p><span class="price">from £4,500</span></p>
      </div>
      <div class="pricing-item">
        <p>Evening events</p>
        <p><span class="price">from £3,000</span></p>
      </div>
    </div>
    <div class="pricing-note">
      Indicative pricing. Every event is different - get in touch for a tailored quote.
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="final-cta">
    <h2>Ready to book your event?</h2>
    <a href="/check-your-date/?utm_source=website&utm_medium=cta&utm_campaign=corporate" class="btn btn-primary">Check Your Date</a>
    <div class="contact-note">
      Or call us on <a href="tel:+442079611604">+44 20 7961 1604</a>
    </div>
  </section>

  <!-- Footer -->
</Base>
