---
import Base from '../layouts/Base.astro';
import ProofBar from '../components/ProofBar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PricingTable from '../components/PricingTable.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<Base title="Corporate Events Venue East London | The Hackney, E2" description="Host your corporate event at The Hackney. Conferences, team days, product launches, brand activations. 60 seated, 100 standing. Exclusively yours. Past clients include Adidas, Spotify, Samsung.">

  <!-- ==================== HERO ==================== -->
  <section class="corp-hero">
    <div class="container">
      <div class="corp-hero-content">
        <p class="eyebrow">Corporate Events at The Hackney</p>
        <h1>Your event. Our brewery.</h1>
        <p class="corp-hero-sub">Conferences, team days, product launches, brand activations. A unique venue with professional capabilities and the kind of backdrop that stays memorable long after the event ends.</p>
      </div>
    </div>
  </section>

  <!-- ==================== SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "200+", label: "Events hosted" },
    { number: "4.6", label: "Google rating" },
    { number: "Exclusive", label: "Venue hire" },
    { number: "In-house", label: "Kitchen & bar" }
  ]} />

  <!-- ==================== EVENT TYPES ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="What We Host"
      heading="Events We Host"
      align="center"
    />
    <div class="event-grid">
      <div class="event-card fade-in">
        <h3>Conferences and Seminars</h3>
        <p>From boardroom strategy sessions to multi-day conferences. Full AV and wifi, flexible layouts for breakout sessions, catering throughout.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Team Days and Offsites</h3>
        <p>Build culture and connection with your team. Flexible space for workshops, activities, team meals and informal collaboration.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Product Launches</h3>
        <p>Press events, experiential marketing, media launches. Professional AV, catering, flexible space, and a venue that photographs beautifully.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Brand Activations</h3>
        <p>Experiential events that leave an impression. Past clients include Adidas, Spotify, Samsung, Coca-Cola, and ITV.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== THE SPACE ==================== -->
  <Section bg="light" border="bottom">
    <div class="space-grid">
      <div class="space-text">
        <SectionHeader
          eyebrow="The Venue"
          heading="The Space"
        />
        <p>A professionally restored 1856 brewery designed for events. Capacity 60 seated, 100 standing. The whole venue is exclusively yours - all day access, no other events, full control of the environment.</p>
        <p>The industrial architecture - exposed brick walls, original timber beams, natural skylights, high ceilings - provides a distinctive backdrop that sets your event apart. Professional AV capabilities and wifi throughout.</p>
        <div class="space-promise">
          <p>Our in-house kitchen and service team mean consistent quality from start to finish. Custom catering, full bar, professional coordination. One team, one invoice, complete peace of mind.</p>
        </div>
      </div>
      <div class="space-image">
        <div class="space-placeholder" role="img" aria-label="Corporate event setup at The Hackney">Photo coming soon</div>
      </div>
    </div>
  </Section>

  <!-- ==================== WHAT'S INCLUDED ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="Everything Included"
      heading="What Is Included"
      align="center"
    />
    <div class="included-grid">
      <div class="included-item">
        <h3>Exclusive venue hire</h3>
        <p>The entire space is yours. 60 seated, 100 standing. All-day access with no other events or disruptions.</p>
      </div>
      <div class="included-item">
        <h3>Professional catering</h3>
        <p>Custom menus from our in-house kitchen. From breakfast through to evening service - full control over food and drink quality.</p>
      </div>
      <div class="included-item">
        <h3>Full bar service</h3>
        <p>Professional bar team. Wine, beer, spirits, soft drinks, or branded cocktails. No corkage, no outside alcohol.</p>
      </div>
      <div class="included-item">
        <h3>Event coordination</h3>
        <p>Dedicated events manager handles everything on the day - setup, coordination, breakdown. One point of contact from planning to finish.</p>
      </div>
      <div class="included-item">
        <h3>AV and tech</h3>
        <p>Projector, screens, sound system and wifi. Professional setup for presentations, live streaming, or multimedia content.</p>
      </div>
      <div class="included-item">
        <h3>Flexible space</h3>
        <p>Layouts adapt to your needs - theatre style for presentations, breakout areas for workshops, dance floor for evening events.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== PRICING ==================== -->
  <Section bg="light" border="top">
    <PricingTable
      eyebrow="Investment"
      heading="Pricing"
      tiers={[
        { name: "Half Day", period: "Up to 5 hours", price: "From £2,500", description: "Venue hire + in-house team" },
        { name: "Full Day", period: "All-day access", price: "From £4,500", description: "Venue hire + in-house team" },
        { name: "Evening Events", period: "From 6pm", price: "From £3,000", description: "Venue hire + in-house team" }
      ]}
    />
    <div class="pricing-note">
      <p>Indicative pricing. Event complexity varies - get in touch for a detailed proposal and timeline for your specific requirements.</p>
    </div>
  </Section>

  <!-- ==================== FINAL CTA ==================== -->
  <FinalCTA
    heading="Ready to book your event?"
    primaryCTA={{ label: "Check Your Date", href: "/check-your-date/" }}
    whatsapp={true}
    utmCampaign="corporate"
  />

  <style>
    /* ==================== HERO (olive, no image) ==================== */
    .corp-hero {
      position: relative;
      height: 50vh;
      min-height: 400px;
      background-color: var(--forest-olive);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
    }

    .corp-hero .container {
      width: 100%;
    }

    .corp-hero-content {
      max-width: 700px;
      margin: 0 auto;
    }

    .corp-hero-content :global(.eyebrow) {
      color: var(--dusty-coral);
      margin-bottom: 1.5rem;
    }

    .corp-hero-content h1 {
      color: var(--warm-canvas);
      margin-bottom: 1.25rem;
    }

    .corp-hero-sub {
      color: var(--warm-canvas);
      font-size: 1.125rem;
      line-height: 1.65;
      opacity: 0.95;
      max-width: 560px;
      margin-inline: auto;
    }

    /* ==================== EVENT TYPES GRID ==================== */
    .event-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .event-card {
      padding: 40px 30px;
      border: 1px solid rgba(44, 24, 16, 0.1);
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .event-card:hover {
      border-color: var(--dusty-coral);
      transform: translateY(-4px);
    }

    .event-card h3 {
      font-size: 20px;
      margin-bottom: 12px;
    }

    .event-card p {
      font-size: 16px;
      line-height: 1.6;
      opacity: 0.85;
    }

    /* ==================== THE SPACE ==================== */
    .space-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
    }

    .space-text p {
      font-size: 17px;
      line-height: 1.7;
      margin-bottom: 20px;
    }

    .space-promise {
      margin-top: 30px;
      padding-top: 30px;
      border-top: 1px solid rgba(44, 24, 16, 0.1);
    }

    .space-placeholder {
      width: 100%;
      aspect-ratio: 4/3;
      background: var(--brewery-dark);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255, 255, 255, 0.4);
      font-size: 14px;
      font-family: var(--font-body);
    }

    /* ==================== WHAT'S INCLUDED ==================== */
    .included-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }

    .included-item {
      padding: 40px 30px;
      border-left: 4px solid var(--fired-brick);
    }

    .included-item h3 {
      font-size: 20px;
      margin-bottom: 12px;
    }

    .included-item p {
      font-size: 15px;
      line-height: 1.7;
      opacity: 0.85;
    }

    /* ==================== PRICING NOTE ==================== */
    .pricing-note {
      text-align: center;
      margin-top: 2rem;
      padding: 20px;
      background: rgba(44, 24, 16, 0.03);
    }

    .pricing-note p {
      font-size: 14px;
      font-style: italic;
      opacity: 0.7;
    }

    /* ==================== SCROLL ANIMATIONS ==================== */
    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ==================== RESPONSIVE ==================== */
    @media (max-width: 768px) {
      .event-grid {
        grid-template-columns: 1fr;
      }

      .space-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .included-grid {
        grid-template-columns: 1fr;
        gap: 30px;
      }
    }
  </style>
</Base>
