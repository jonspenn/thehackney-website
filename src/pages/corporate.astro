---
import Base from '../layouts/Base.astro';
---

<style is:global>
  :root {
    --warm-canvas: #F5F0E8;
    --brewery-dark: #2C1810;
    --forest-olive: #2E4009;
    --fired-brick: #8C472E;
    --dusty-coral: #BF7256;
    --signal-green: #28A745;
    --font-heading: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'DM Sans', sans-serif;
  }

  /* Hero Section */
  .hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: var(--forest-olive) url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 800"><defs><pattern id="pattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse"><path d="M0 0L100 100M100 0L0 100" stroke="rgba(255,255,255,0.03)" stroke-width="1"/></pattern></defs><rect width="1200" height="800" fill="url(%23pattern)"/></svg>');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--warm-canvas);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(46, 64, 9, 0.5);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    padding: 40px 20px;
    animation: fadeInUp 0.8s ease;
  }

  .hero-content .eyebrow {
    color: var(--dusty-coral);
  }

  .hero-content h1 {
    color: var(--warm-canvas);
    margin-bottom: 25px;
  }

  .hero-content p {
    font-size: 18px;
    line-height: 1.65;
    opacity: 0.95;
  }

  /* Social Proof Bar */
  .social-proof {
    background-color: var(--brewery-dark);
    color: var(--warm-canvas);
    padding: 56px 20px;
  }

  .social-proof-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
    text-align: center;
  }

  .proof-item h4 {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 5px;
  }

  .proof-item p {
    font-size: 13px;
    opacity: 0.9;
  }

  /* Event Types Grid */
  .event-types {
    background-color: var(--warm-canvas);
    padding: 120px 0;
  }

  .event-types h2 {
    text-align: center;
    margin-bottom: 50px;
  }

  .event-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
    margin-bottom: 40px;
  }

  .event-card {
    background: var(--warm-canvas);
    border: 1px solid rgba(44, 24, 16, 0.1);
    padding: 40px 30px;
    text-align: center;
    transition: all 0.3s ease;
  }

  .event-card:hover {
    box-shadow: 0 10px 30px rgba(44, 24, 16, 0.08);
    transform: translateY(-5px);
  }

  .event-card h3 {
    color: var(--fired-brick);
    margin-bottom: 15px;
  }

  .event-card p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--brewery-dark);
  }

  /* The Space Section */
  .the-space {
    background-color: var(--warm-canvas);
    padding: 120px 0;
    border-top: 1px solid rgba(44, 24, 16, 0.06);
  }

  .the-space-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .the-space-text h2 {
    margin-bottom: 25px;
  }

  .the-space-text p {
    margin-bottom: 20px;
    line-height: 1.7;
  }

  .venue-features {
    margin-top: 30px;
    padding-top: 30px;
    border-top: 1px solid rgba(44, 24, 16, 0.1);
  }

  .venue-features p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--brewery-dark);
  }

  @media (max-width: 768px) {
    .the-space-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  /* What's Included Section */
  .whats-included {
    background-color: var(--warm-canvas);
    padding: 120px 0;
    border-top: 1px solid rgba(44, 24, 16, 0.06);
  }

  .whats-included h2 {
    text-align: center;
    margin-bottom: 50px;
  }

  .included-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px;
  }

  .included-item {
    background: var(--warm-canvas);
    padding: 40px 30px;
    border-left: 4px solid var(--fired-brick);
  }

  .included-item h3 {
    color: var(--fired-brick);
    font-size: 20px;
    margin-bottom: 12px;
  }

  .included-item p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--brewery-dark);
  }

  /* Pricing Section */
  .pricing {
    background-color: var(--warm-canvas);
    padding: 120px 0;
    border-top: 1px solid rgba(44, 24, 16, 0.06);
  }

  .pricing h2 {
    text-align: center;
    margin-bottom: 50px;
  }

  .pricing-items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-bottom: 40px;
  }

  .pricing-item {
    background: var(--warm-canvas);
    padding: 35px 30px;
    text-align: center;
    border: 1px solid rgba(44, 24, 16, 0.1);
  }

  .pricing-item p:first-child {
    font-size: 14px;
    color: var(--dusty-coral);
    margin-bottom: 10px;
  }

  .price {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    color: var(--brewery-dark);
    margin-bottom: 5px;
  }

  .pricing-note {
    text-align: center;
    font-size: 14px;
    color: var(--brewery-dark);
    font-style: italic;
    margin-top: 20px;
    padding: 20px;
    background: rgba(44, 24, 16, 0.03);
  }

  /* Final CTA Section */
  .final-cta {
    background-color: var(--brewery-dark);
    color: var(--warm-canvas);
    text-align: center;
    padding: 120px 0;
  }

  .final-cta h2 {
    color: var(--warm-canvas);
    margin-bottom: 30px;
  }

  .final-cta .btn-primary {
    background-color: var(--dusty-coral);
    font-size: 14px;
    padding: 14px 35px;
    margin-bottom: 30px;
  }

  .final-cta .btn-primary:hover {
    background-color: var(--fired-brick);
  }

  .contact-note {
    font-size: 16px;
    margin-top: 20px;
  }

  .contact-note a {
    color: var(--dusty-coral);
    text-decoration: none;
    font-weight: 500;
  }

  .contact-note a:hover {
    text-decoration: underline;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in {
    animation: fadeInUp 0.8s ease forwards;
    opacity: 0;
  }
</style>

<Base title="Corporate Events Venue East London | The Hackney, E2" description="Host your corporate event at The Hackney. Conferences, team days, product launches, brand activations. 60 seated, 100 standing. Exclusively yours. Past clients include Adidas, Spotify, Samsung.">
<!-- Navigation -->


  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <div class="eyebrow">Corporate Events at The Hackney</div>
      <h1>Your event. Our brewery.</h1>
      <p>Conferences, team days, product launches, brand activations. A unique venue with professional capabilities and the kind of backdrop that stays memorable long after the event ends.</p>
    </div>
  </section>

  <!-- Social Proof Bar -->
  <div class="social-proof">
    <div class="social-proof-inner">
      <div class="proof-item">
        <h4>200+</h4>
        <p>Events hosted</p>
      </div>
      <div class="proof-item">
        <h4>4.6</h4>
        <p>Google rating</p>
      </div>
      <div class="proof-item">
        <h4>Exclusive</h4>
        <p>Venue hire</p>
      </div>
      <div class="proof-item">
        <h4>In-house</h4>
        <p>Kitchen &amp; bar</p>
      </div>
    </div>
  </div>

  <!-- Event Types Section -->
  <section class="event-types">
    <h2>Events we host</h2>
    <div class="event-grid">
      <div class="event-card fade-in">
        <h3>Conferences & Seminars</h3>
        <p>From boardroom strategy sessions to multi-day conferences. Full AV and wifi, flexible layouts for breakout sessions, catering throughout.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Team Days & Offsites</h3>
        <p>Build culture and connection with your team. Flexible space for workshops, activities, team meals and informal collaboration.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Product Launches</h3>
        <p>Press events, experiential marketing, media launches. Professional AV, catering, flexible space, and a venue that photographs beautifully.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Brand Activations</h3>
        <p>Experiential events that leave an impression. Past clients include Adidas, Spotify, Samsung, Coca-Cola, and ITV.</p>
      </div>
    </div>
  </section>

  <!-- The Space Section -->
  <section class="the-space">
    <div class="the-space-content">
      <div class="the-space-text">
        <h2>The space</h2>
        <p>A professionally restored 1856 brewery designed for events. Capacity 60 seated, 100 standing. The whole venue is exclusively yours - all day access, no other events, full control of the environment.</p>
        <p>The industrial architecture - exposed brick walls, original timber beams, natural skylights, high ceilings - provides a distinctive backdrop that sets your event apart. Professional AV capabilities and wifi throughout.</p>
        <div class="venue-features">
          <p>Our in-house kitchen and service team mean consistent quality from start to finish. Custom catering, full bar, professional coordination. One team, one invoice, complete peace of mind.</p>
        </div>
      </div>
      <div class="the-space-image">
        <div class="space-placeholder" style="width:100%;aspect-ratio:4/3;background:var(--brewery-dark);border-radius:2px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.4);font-size:14px;">Photo coming soon</div>
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section class="whats-included">
    <h2>What's included</h2>
    <div class="included-grid">
      <div class="included-item">
        <h3>Exclusive venue hire</h3>
        <p>The entire space is yours. 60 seated, 100 standing. All-day access with no other events or disruptions.</p>
      </div>
      <div class="included-item">
        <h3>Professional catering</h3>
        <p>Custom menus from our in-house kitchen. From breakfast through to evening service - full control over food and drink quality.</p>
      </div>
      <div class="included-item">
        <h3>Full bar service</h3>
        <p>Professional bar team. Wine, beer, spirits, soft drinks, or branded cocktails. No corkage, no outside alcohol.</p>
      </div>
      <div class="included-item">
        <h3>Event coordination</h3>
        <p>Dedicated events manager handles everything on the day - setup, coordination, breakdown. One point of contact from planning to finish.</p>
      </div>
      <div class="included-item">
        <h3>AV and tech</h3>
        <p>Projector, screens, sound system and wifi. Professional setup for presentations, live streaming, or multimedia content.</p>
      </div>
      <div class="included-item">
        <h3>Flexible space</h3>
        <p>Layouts adapt to your needs - theatre style for presentations, breakout areas for workshops, dance floor for evening events.</p>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="pricing">
    <h2>Pricing</h2>
    <div class="pricing-items">
      <div class="pricing-item">
        <p>Half day venue hire</p>
        <p><span class="price">from £2,500</span></p>
      </div>
      <div class="pricing-item">
        <p>Full day venue hire</p>
        <p><span class="price">from £4,500</span></p>
      </div>
      <div class="pricing-item">
        <p>Evening events</p>
        <p><span class="price">from £3,000</span></p>
      </div>
    </div>
    <div class="pricing-note">
      Indicative pricing. Event complexity varies - get in touch for a detailed proposal and timeline for your specific requirements.
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="final-cta">
    <h2>Ready to book your event?</h2>
    <a href="/check-your-date/?utm_source=website&utm_medium=cta&utm_campaign=corporate" class="btn btn-primary">Check Your Date</a>
    <div class="contact-note">
      Or call us on <a href="tel:+442079611604">+44 20 7961 1604</a>
    </div>
  </section>

  <!-- Footer -->
</Base>
