---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofBar from '../components/ProofBar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
---

<Base title="Supper Club East London | Guest Chef Dinners at The Hackney, E2" description="Supper club nights at The Hackney - guest chef dinners and paired wines inside a restored 1856 brewery on Hackney Road. Sign up for upcoming dates.">

  <!-- ==================== HERO ==================== -->
  <HeroSection
    image="/images/hackney-supper-club-hero-candlelit-long-table-greenery.webp"
    alt="Long candlelit banquet table at The Hackney set for dinner, with hanging greenery, Edison bulb chandelier and exposed brick"
    heading="One Night. One Menu.<br>Heard First By The List."
    cta={{ label: "Get First Access", href: "/supper-club/?utm_source=website&utm_medium=cta&utm_campaign=supper-club&utm_content=hero#signup" }}
    note="Forty seats per night. Dates drop to the list 48 hours before public release."
    height="mid"
    textGradient={true}
    position="center 20%"
  />

  <!-- ==================== SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "40 Seats Only", label: "Limited covers per dinner" },
    { number: "First Access", label: "List hears 48 hours before public release" },
    { number: "One Night Only", label: "Each menu runs for a single evening" },
    { number: "Featured Creators", label: "@sepps, The Nudge and more" }
  ]} />

  <!-- ==================== PRIMARY SIGNUP (moved up - conversion priority) ==================== -->
  <Section bg="light" border="bottom" id="signup">
    <div class="signup-primary-inner">
      <SectionHeader
        eyebrow="How First Access Works"
        heading="Three Steps. First In Line."
      />
      <ProcessSteps steps={[
        { title: "Join The List", description: "Drop your email below. You are in, no verification hoops." },
        { title: "Get The Drop First", description: "We email the date, chef and menu 48 hours before public release." },
        { title: "Book Before Public Release", description: "Claim your seat while the list has priority. Public booking only opens if seats remain." }
      ]} />

      <form class="signup-form-primary" id="signupFormPrimary" action="/api/supperclub-signup" method="POST" data-form="supperclub-signup" data-form-location="primary">
        <input type="email" name="email" placeholder="Email address" required aria-label="Email address">
        <button type="submit" class="btn btn-primary">Get First Access</button>
      </form>
      <p class="signup-form-status" data-status-for="primary" hidden></p>
      <p class="signup-primary-note">We will only email when a new supper club is about to drop.</p>
    </div>
  </Section>

  <!-- ==================== THE CONCEPT ==================== -->
  <Section bg="light" border="bottom">
    <div class="concept-inner">
      <SectionHeader
        eyebrow="The Concept"
        heading="Dinner Without Distraction"
      />
      <p>Our supper club is a series of one-off dining events inside The Hackney - a restored 1856 brewery on Hackney Road with soaring ceilings, skylights and exposed brick.</p>
      <p>Each night features a guest chef cooking a multi-course menu with wines paired to every dish, a room lit almost entirely by candlelight, and a playlist curated for the evening.</p>

      <div class="concept-highlight">
        Good food. Good wine. Actual conversation. That is the whole idea.
      </div>

      <p>We are launching the series in partnership with <strong>The Nudge</strong>, curators of some of London's most talked-about nights. As we grow, we will host our own dinners and invite chefs, producers and makers from across East London and beyond.</p>
      <p class="concept-read-more"><a href="/journal/the-hackney-supper-club-chef-led-dinners-east-london/">Read the full story of the series.</a></p>
    </div>
  </Section>

  <!-- ==================== UPCOMING EVENTS ==================== -->
  <Section bg="dark" border="bottom" id="upcoming">
    <SectionHeader
      eyebrow="Upcoming Dates"
      heading="Next Supper Club"
    />
    <p class="upcoming-intro">New dates drop to the list first. Subscribers hear 48 hours before public release.</p>

    <div class="event-cards">
      <div class="event-card event-card-holding">
        <div class="event-date">Next Drop, Coming Soon</div>
        <h3>To Be Announced</h3>
        <div class="event-chef">Guest chef reveal to follow</div>
        <p class="event-desc">The next supper club is in planning. The date, chef and menu go to the list 48 hours before public booking opens. Past dinners filled fast.</p>
        <div class="event-meta">
          <div class="event-meta-item"><strong>Format:</strong> Welcome cocktail, multi-course dinner, paired pours</div>
          <div class="event-meta-item"><strong>Seats:</strong> Limited to 40 per night</div>
        </div>
        <a href="#signup" class="btn btn-outline-dark">Get First Access</a>
      </div>

      <div class="event-card event-card-past">
        <div class="event-badge">Past Event</div>
        <div class="event-date">Wednesday 26 March 2026</div>
        <h3>Do Not Disturb: A Dopamine Reset Dinner</h3>
        <div class="event-chef">Guest Chef Ella Williams</div>
        <p class="event-desc">An evening of modern Caribbean-inspired cooking. Welcome cocktail, three courses with paired wines, and a room set by candlelight.</p>
        <div class="event-meta">
          <div class="event-meta-item"><strong>Price:</strong> £75pp</div>
          <div class="event-meta-item"><strong>Includes:</strong> Cocktail, 3 courses, 3 wines</div>
          <div class="event-meta-item"><strong>Partner:</strong> The Nudge</div>
        </div>
        <span class="btn btn-outline-dark" style="opacity: 0.5; cursor: default;">Sold Out</span>
      </div>

      <!-- TEMPLATE: copy this card for future events
      <div class="event-card">
        <div class="event-date">DATE HERE</div>
        <h3>EVENT TITLE</h3>
        <div class="event-chef">Guest Chef NAME</div>
        <p class="event-desc">DESCRIPTION</p>
        <div class="event-meta">
          <div class="event-meta-item"><strong>Price:</strong> £XXpp</div>
          <div class="event-meta-item"><strong>Includes:</strong> DETAILS</div>
        </div>
        <a href="LINK" target="_blank" rel="noopener" class="btn btn-outline-dark">Get Tickets</a>
      </div>
     -->
    </div>
  </Section>

  <!-- ==================== WHAT TO EXPECT ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="What To Expect"
      heading="How The Evening Works"
    />
    <div class="expect-grid">
      <div class="expect-item">
        <div class="expect-number">01</div>
        <h3>Arrive At The Bar</h3>
        <p>You arrive at The Hackney and take a welcome cocktail at the bar. The room is set, candles lit, the playlist running. A chance to settle in before you sit down.</p>
      </div>
      <div class="expect-item">
        <div class="expect-number">02</div>
        <h3>Sit Down To Eat</h3>
        <p>Move through to a long candlelit table for a multi-course dinner from that evening's guest chef. Each dish is paired with a wine selected to match. Conversation flows naturally.</p>
      </div>
      <div class="expect-item">
        <div class="expect-number">03</div>
        <h3>Leave Lighter</h3>
        <p>Dessert, a final pour, goodbyes to the people you have actually spoken to. You head home having had a proper evening out, not another night on your phone.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== THE KITCHEN ==================== -->
  <Section bg="olive" border="bottom">
    <div class="kitchen-inner">
      <SectionHeader
        eyebrow="The Kitchen"
        heading="Guest Chefs. In-House Kitchen."
      />
      <p>The Hackney has its own professional kitchen led by Chef Marco Mannoni, who cooks modern European menus for our weddings and events throughout the year.</p>
      <p>For supper club nights, we invite guest chefs to take over the kitchen and bring something different - rotating styles, cuisines and stories across the series.</p>
      <p>Our first guest is Chef Ella Williams, a London-born chef whose cooking is shaped by her Jamaican heritage. Her CV includes Cafe Murano, Mountain in Soho and Hausu in Peckham. For The Hackney, she is cooking a modern Caribbean-inspired menu.</p>
    </div>
  </Section>

  <!-- ==================== GALLERY PLACEHOLDER ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="The Atmosphere"
      heading="An Evening At The Hackney"
    />
    <div class="gallery-grid">
      <div class="gallery-block">
        <div class="gallery-block-bg lazy-bg" data-bg="/images/hackney-supper-club-venue-verity-andy-dinner-setting.webp" style="background-color:#2C1810;"></div>
        <div class="gallery-caption">The Winter Garden</div>
      </div>
      <div class="gallery-block">
        <div class="gallery-block-bg lazy-bg" data-bg="/images/hackney-supper-club-food-verity-andy-plated-closeup.webp" style="background-color:#3D2117;"></div>
        <div class="gallery-caption">The Food</div>
      </div>
      <div class="gallery-block">
        <div class="gallery-block-bg lazy-bg" data-bg="/images/hackney-supper-club-bar-verity-andy-guests-enjoying.webp" style="background-color:#2E4009;"></div>
        <div class="gallery-caption">First Drinks</div>
      </div>
      <div class="gallery-block">
        <div class="gallery-block-bg lazy-bg" data-bg="/images/hackney-supper-club-table-verity-andy-long-table.webp" style="background-color:#8C472E;"></div>
        <div class="gallery-caption">The Room</div>
      </div>
      <div class="gallery-block">
        <div class="gallery-block-bg lazy-bg" data-bg="/images/hackney-supper-club-details-verity-andy-table-details.webp" style="background-color:#4A3228;"></div>
        <div class="gallery-caption">The Details</div>
      </div>
      <div class="gallery-block">
        <div class="gallery-block-bg lazy-bg" data-bg="/images/hackney-supper-club-courtyard-verity-andy-guests.webp" style="background-color:#2C1810;"></div>
        <div class="gallery-caption">The Courtyard</div>
      </div>
    </div>
  </Section>

  <!-- ==================== EMAIL SIGNUP (reinforcement capture - moved above chef section so consumer audience doesn't bounce past it) ==================== -->
  <Section bg="dark" padding="standard" id="signup-reinforce">
    <div class="signup-inner">
      <SectionHeader
        eyebrow="One More Chance"
        heading="The Next Menu Will Not Stay Open For Long."
        align="center"
      />
      <p class="signup-body">Small room. Limited seats. First access goes to the list. Public booking only opens if seats remain after subscribers have had their pick.</p>
      <form class="signup-form" id="signupForm" action="/api/supperclub-signup" method="POST" data-form="supperclub-signup" data-form-location="reinforce">
        <input type="email" name="email" placeholder="Email address" required aria-label="Email address">
        <button type="submit" class="btn btn-primary-dark">Notify Me First</button>
      </form>
      <p class="signup-form-status" data-status-for="reinforce" hidden></p>
      <p class="signup-note">We will only email you when a new supper club is about to drop. Unsubscribe any time.</p>
    </div>
  </Section>

  <!-- ==================== COOK WITH US ==================== -->
  <Section bg="light" border="bottom" id="chefs">
    <div class="cook-inner">
      <div class="cook-text">
        <SectionHeader
          eyebrow="For Chefs"
          heading="Cook With Us"
        />
        <p>We are building a rotating roster of guest chefs for our supper club series. If you are a chef with a story to tell through food, we want to hear from you.</p>
        <p>The Hackney has a fully equipped professional kitchen, an in-house bar team, and a dining room that seats up to 60 covers. We handle the space, the service, the drinks and the audience. You bring the menu.</p>

        <ul class="cook-what-you-get">
          <li>Professional kitchen with full extraction, gas and prep space</li>
          <li>Front-of-house and bar team provided</li>
          <li>Wine pairing handled by our team (or bring your own sommelier)</li>
          <li>Promotion to our mailing list and social channels</li>
          <li>A stunning 1856 brewery dining room with skylights and candlelight</li>
        </ul>

        <p>Whether you are running your own pop-up, launching a concept, or just want to cook for an appreciative room - get in touch.</p>

        <a href="mailto:hello@thehackney.co?subject=Supper%20Club%20Chef%20Enquiry" class="btn btn-primary">Get In Touch</a>
      </div>
      <div class="cook-image lazy-bg" data-bg="/images/hackney-supper-club-chef-ella-williams-cooking.webp" data-bg-pos="center center" role="img" aria-label="Chef Ella Williams cooking in the kitchen at The Hackney"></div>
    </div>
  </Section>

  <!-- ==================== CROSS-SELL ==================== -->
  <Section bg="light" border="top">
    <SectionHeader
      eyebrow="More At The Hackney"
      heading="Explore The Venue"
    />
    <div class="cross-sell-grid">
      <a href="/weddings/" class="cross-sell-card">
        <h3>Weddings</h3>
        <p>Exclusive hire of the entire venue for up to 60 seated guests and 100 standing. An 1856 brewery with skylights, exposed brick and an in-house kitchen.</p>
      </a>
      <a href="/private-events/" class="cross-sell-card">
        <h3>Private Events</h3>
        <p>Birthdays, milestones, intimate dinners. The same room, the same kitchen, built around the night you are planning.</p>
      </a>
      <a href="/cafe-bar/" class="cross-sell-card">
        <h3>Cafe &amp; Bar</h3>
        <p>Speciality coffee, light bites and natural wines. Open Tuesday to Sunday - walk-ins welcome, dogs too.</p>
      </a>
    </div>
  </Section>

  <style>
    /* ==================== PRIMARY SIGNUP (Section 3) ==================== */
    .signup-primary-inner {
      max-width: 960px;
    }

    .signup-form-primary {
      display: flex;
      gap: 12px;
      max-width: 560px;
      margin: 40px 0 16px;
    }

    .signup-form-primary input[type="email"] {
      flex: 1;
      padding: 16px 20px;
      font-family: var(--font-body);
      font-size: 15px;
      border: 2px solid rgba(44, 24, 16, 0.15);
      background: var(--warm-canvas);
      color: var(--brewery-dark);
      outline: none;
      transition: border-color 0.3s ease;
      border-radius: 2px;
    }

    .signup-form-primary input[type="email"]::placeholder {
      color: rgba(44, 24, 16, 0.4);
    }

    .signup-form-primary input[type="email"]:focus {
      border-color: var(--forest-olive);
    }

    .signup-form-primary .btn-primary {
      white-space: nowrap;
      padding: 16px 28px;
    }

    .signup-primary-note {
      font-family: var(--font-heading);
      font-style: italic;
      font-size: 16px;
      color: var(--fired-brick);
      line-height: 1.5;
      max-width: 600px;
      margin: 0;
    }

    @media (max-width: 640px) {
      .signup-form-primary {
        flex-direction: column;
      }
      .signup-form-primary .btn-primary {
        width: 100%;
        text-align: center;
      }
    }

    /* ==================== UPCOMING EVENTS: HOLDING STATE ==================== */
    .event-card-holding {
      border-color: var(--dusty-coral);
      border-left: 3px solid var(--dusty-coral);
    }

    .event-card-holding .event-date {
      color: var(--dusty-coral);
    }

    .event-card-holding h3 {
      color: var(--warm-canvas);
    }

    .event-card-past {
      opacity: 0.7;
    }

    /* ==================== THE CONCEPT ==================== */
    .concept-inner {
      max-width: 720px;
    }

    .concept-inner p {
      font-size: 18px;
      line-height: 1.8;
      margin-bottom: 20px;
    }

    .concept-highlight {
      background: rgba(44, 24, 16, 0.04);
      border-left: 4px solid var(--forest-olive);
      padding: 28px 32px;
      margin: 36px 0;
      font-family: var(--font-heading);
      font-size: 22px;
      font-style: italic;
      color: var(--brewery-dark);
      line-height: 1.5;
    }

    /* ==================== UPCOMING EVENTS ==================== */
    .upcoming-intro {
      color: rgba(245, 240, 232, 0.7);
      font-size: 18px;
      max-width: 600px;
      margin-bottom: 48px;
      line-height: 1.7;
    }

    .event-cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
      max-width: 800px;
    }

    .event-card {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 40px;
      position: relative;
    }

    .event-date {
      font-family: var(--font-body);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--dusty-coral);
      margin-bottom: 12px;
    }

    .event-card h3 {
      color: var(--warm-canvas);
      margin-bottom: 8px;
    }

    .event-chef {
      font-family: var(--font-heading);
      font-style: italic;
      font-size: 18px;
      color: rgba(245, 240, 232, 0.6);
      margin-bottom: 16px;
    }

    .event-desc {
      color: rgba(245, 240, 232, 0.65);
      font-size: 16px;
      line-height: 1.7;
      margin-bottom: 24px;
    }

    .event-meta {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .event-meta-item {
      font-size: 14px;
      color: rgba(245, 240, 232, 0.5);
    }

    .event-meta-item strong {
      color: rgba(245, 240, 232, 0.8);
      font-weight: 600;
    }

    .event-badge {
      position: absolute;
      top: 24px;
      right: 24px;
      background: var(--fired-brick);
      color: var(--warm-canvas);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 6px 14px;
    }

    /* ==================== WHAT TO EXPECT ==================== */
    .expect-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
      margin-top: 48px;
    }

    .expect-item h3 {
      font-size: 24px;
      margin-bottom: 12px;
    }

    .expect-item p {
      font-size: 16px;
      line-height: 1.7;
      opacity: 0.85;
    }

    .expect-number {
      font-family: var(--font-heading);
      font-size: 48px;
      color: var(--forest-olive);
      opacity: 0.25;
      margin-bottom: 8px;
    }

    /* ==================== THE KITCHEN ==================== */
    .kitchen-inner {
      max-width: 720px;
    }

    .kitchen-inner p {
      color: rgba(245, 240, 232, 0.75);
      font-size: 18px;
      line-height: 1.8;
      margin-bottom: 20px;
    }

    /* ==================== GALLERY ==================== */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 48px;
    }

    .gallery-block {
      aspect-ratio: 4/3;
      position: relative;
      overflow: hidden;
    }

    .gallery-block-bg {
      width: 100%;
      height: 100%;
    }

    .gallery-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 12px 16px;
      background: linear-gradient(transparent, rgba(44, 24, 16, 0.7));
      color: rgba(255, 255, 255, 0.8);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.5px;
    }

    /* ==================== COOK WITH US ==================== */
    .cook-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }

    .cook-text p {
      font-size: 17px;
      line-height: 1.8;
      margin-bottom: 16px;
      opacity: 0.85;
    }

    .cook-what-you-get {
      list-style: none;
      margin: 28px 0;
    }

    .cook-what-you-get li {
      padding: 12px 0;
      border-bottom: 1px solid rgba(44, 24, 16, 0.08);
      font-size: 16px;
      display: flex;
      gap: 12px;
      align-items: baseline;
      opacity: 0.85;
    }

    .cook-what-you-get li::before {
      content: '-';
      color: var(--forest-olive);
      font-weight: 700;
      flex-shrink: 0;
    }

    .cook-image {
      aspect-ratio: 4/5;
      background: var(--forest-olive);
    }

    /* ==================== EMAIL SIGNUP ==================== */
    .signup-inner {
      max-width: 600px;
      margin: 0 auto;
      text-align: center;
    }

    .signup-body {
      color: rgba(245, 240, 232, 0.65);
      font-size: 18px;
      line-height: 1.7;
      margin-bottom: 36px;
    }

    .signup-form {
      display: flex;
      gap: 12px;
      max-width: 480px;
      margin: 0 auto 24px;
    }

    .signup-form input[type="email"] {
      flex: 1;
      padding: 16px 20px;
      font-family: var(--font-body);
      font-size: 15px;
      border: 2px solid rgba(255, 255, 255, 0.2);
      background: rgba(255, 255, 255, 0.06);
      color: var(--warm-canvas);
      outline: none;
      transition: border-color 0.3s ease;
    }

    .signup-form input[type="email"]::placeholder {
      color: rgba(255, 255, 255, 0.35);
    }

    .signup-form input[type="email"]:focus {
      border-color: var(--dusty-coral);
    }

    .signup-form .btn-primary-dark {
      white-space: nowrap;
      padding: 16px 28px;
    }

    .signup-note {
      color: rgba(245, 240, 232, 0.35);
      font-size: 13px;
    }

    /* ==================== CROSS-SELL ==================== */
    .cross-sell-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }

    @media (max-width: 960px) {
      .cross-sell-grid { grid-template-columns: 1fr; }
    }

    /* ==================== FORM STATUS ==================== */
    .signup-form-status {
      font-family: var(--font-body);
      font-size: 14px;
      margin: -4px 0 12px;
      line-height: 1.5;
    }
    .signup-form-status[data-state="success"] {
      color: var(--forest-olive);
      font-weight: 500;
    }
    .signup-form-status[data-state="error"] {
      color: var(--fired-brick);
    }
    /* dark-section status visible against dark bg */
    #signup-reinforce .signup-form-status[data-state="success"] {
      color: var(--dusty-coral);
    }

    .cross-sell-card {
      padding: 40px;
      background: var(--warm-canvas);
      border: 1px solid rgba(44, 24, 16, 0.1);
      text-decoration: none;
      color: var(--brewery-dark);
      transition: transform 0.3s ease, border-color 0.3s ease;
    }

    .cross-sell-card:hover {
      transform: translateY(-3px);
      border-color: var(--dusty-coral);
    }

    .cross-sell-card h3 {
      font-size: 28px;
      margin-bottom: 12px;
    }

    .cross-sell-card p {
      opacity: 0.75;
      font-size: 15px;
      line-height: 1.6;
    }

    /* ==================== RESPONSIVE ==================== */
    @media (max-width: 768px) {
      .expect-grid { grid-template-columns: 1fr; gap: 32px; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .cook-inner { grid-template-columns: 1fr; gap: 40px; }
      .cook-image { aspect-ratio: 16/9; }
      .signup-form { flex-direction: column; }
      .signup-form .btn-primary-dark { width: 100%; text-align: center; }
    }

    .concept-read-more {
      margin-top: 28px;
    }
    .concept-read-more a {
      color: var(--dusty-coral);
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      text-decoration: none;
      border-bottom: 1px solid var(--dusty-coral);
      padding-bottom: 2px;
    }
    .concept-read-more a:hover {
      color: var(--forest-olive);
      border-bottom-color: var(--forest-olive);
    }
  </style>

  <script>
    // Supper club signup form handler. Posts to /api/supperclub-signup
    // (Cloudflare Pages Function) and shows inline success/error. Until
    // Klaviyo/Brevo is wired, emails are captured server-side via the
    // function's console.log + D1 insert.
    (function () {
      const forms = document.querySelectorAll('form[data-form="supperclub-signup"]');
      forms.forEach((form) => {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const input = form.querySelector('input[type="email"]');
          const button = form.querySelector('button[type="submit"]');
          const location = form.dataset.formLocation || 'unknown';
          const status = form.parentElement.querySelector(
            `.signup-form-status[data-status-for="${location}"]`
          );
          if (!input || !button) return;

          const email = (input.value || '').trim();
          if (!email) return;

          button.disabled = true;
          const originalLabel = button.textContent;
          button.textContent = 'Sending...';

          try {
            const res = await fetch('/api/supperclub-signup', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ email, location }),
            });
            if (!res.ok) throw new Error('bad_response');
            if (status) {
              status.textContent = "You're on the list. We'll email you the moment the next dinner drops.";
              status.setAttribute('data-state', 'success');
              status.hidden = false;
            }
            input.value = '';
            button.textContent = 'On The List';

            // dataLayer signal for GTM / GA4
            if (window.dataLayer) {
              window.dataLayer.push({
                event: 'supperclub_signup',
                signup_location: location,
              });
            }
          } catch (err) {
            if (status) {
              status.textContent = 'Something went wrong. Please try again or email hello@thehackney.co.';
              status.setAttribute('data-state', 'error');
              status.hidden = false;
            }
            button.disabled = false;
            button.textContent = originalLabel;
          }
        });
      });
    })();
  </script>
</Base>
