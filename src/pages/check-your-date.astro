---
import Base from '../layouts/Base.astro';
import UtilityHeader from '../components/UtilityHeader.astro';
import CheckDateForm from '../components/CheckDateForm.astro';
---

<Base
  title="Check Your Date | The Hackney, East London E2"
  description="Check if your date is available at The Hackney - East London's restored 1856 brewery venue. Weddings, corporate events, private celebrations. 60 seated, 100 standing."
  pageType="check-your-date"
>

<UtilityHeader
  eyebrow="Availability"
  heading="Check your date"
  intro="Browse our calendar to see what's available. Select a date that works and book a tour of the space."
/>

<CheckDateForm />

<!-- Trust signals below the form -->
<section class="cd-trust">
  <div class="container">
    <div class="cd-trust-grid">
      <!-- What happens next -->
      <div class="cd-trust-box">
        <h3>What happens next?</h3>
        <ol class="cd-steps">
          <li>
            <span class="cd-step-num">1</span>
            <p><strong>Find your date</strong> - browse the calendar and pick an available date</p>
          </li>
          <li>
            <span class="cd-step-num">2</span>
            <p><strong>Book a venue tour</strong> - see the space in person with Hugo, no obligation</p>
          </li>
          <li>
            <span class="cd-step-num">3</span>
            <p><strong>We'll hold your date</strong> - love it? We reserve it while you decide</p>
          </li>
        </ol>
      </div>

      <!-- Social proof -->
      <div class="cd-trust-box cd-trust-box--stats">
        <div class="cd-stat">
          <span class="cd-stat-number">400+</span>
          <span class="cd-stat-label">Weddings managed</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number cd-stat-number--text">Everything Included</span>
          <span class="cd-stat-label">Venue, food, drinks, team</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number cd-stat-number--text">Exclusive Hire</span>
          <span class="cd-stat-label">The whole venue, just for you</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">4.9 ★</span>
          <span class="cd-stat-label">Couple rating on Hitched</span>
        </div>
      </div>
    </div>
  </div>
</section>

</Base>

<style>
  /* ==================== TIGHTER HEADER SPACING ==================== */
  .utility-header {
    padding-bottom: 24px;
  }

  /* ==================== TRUST SECTION ==================== */
  .cd-trust {
    padding: 0 0 80px;
  }

  .cd-trust-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    max-width: 800px;
    margin: 0 auto;
  }

  .cd-trust-box {
    background: rgba(44, 24, 16, 0.025);
    border: 1px solid rgba(44, 24, 16, 0.06);
    border-radius: 2px;
    padding: 32px;
  }

  .cd-trust-box h3 {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    color: var(--brewery-dark);
    margin: 0 0 24px;
  }

  /* Steps */
  .cd-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cd-steps li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .cd-step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    width: 32px;
    height: 32px;
    background: var(--forest-olive);
    color: #fff;
    border-radius: 50%;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    flex-shrink: 0;
  }

  .cd-steps p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--brewery-dark);
    margin: 0;
    padding-top: 4px;
  }

  .cd-steps strong {
    font-weight: 600;
  }

  /* Stats */
  .cd-trust-box--stats {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    text-align: center;
  }

  .cd-stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    color: var(--forest-olive);
    line-height: 1.1;
    margin-bottom: 6px;
  }

  /* Text-style number (e.g. "Everything Included") - smaller so longer
     phrases fit on a single line in the side panel */
  .cd-stat-number--text {
    font-size: 17px;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .cd-stat-label {
    font-family: var(--font-body);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(44, 24, 16, 0.5);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cd-trust {
      padding: 0 0 60px;
    }

    .cd-trust-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .cd-trust-box {
      padding: 24px;
    }

    .cd-trust-box--stats {
      flex-direction: row;
      justify-content: space-around;
    }
  }
</style>
