---
import Base from '../layouts/Base.astro';
import UtilityHeader from '../components/UtilityHeader.astro';
import CheckDateForm from '../components/CheckDateForm.astro';
---

<Base
  title="Check Your Date | The Hackney, East London E2"
  description="Check if your date is available at The Hackney - East London's restored 1856 brewery venue. Weddings, corporate events, private celebrations. 60 seated, 100 standing."
  pageType="check-your-date"
>

<UtilityHeader
  eyebrow="Availability"
  heading="Check your date"
  intro="Browse our calendar to see what's available. Select a date that works and book a tour of the space."
/>

<CheckDateForm />

<!-- Trust signals below the form. Three variants render in HTML; inline
     script below reads ?type= and reveals the matching one. Wedding is the
     default + stays visible if no ?type= or an unrecognised value is passed.
     Same routing model as the date-context banner on /bookacall/. -->
<section class="cd-trust">
  <div class="container">

    <!-- Wedding variant (default). Visible unless script swaps it out. -->
    <div class="cd-trust-grid" data-trust-variant="wedding">
      <div class="cd-trust-box">
        <h3>What happens next?</h3>
        <ol class="cd-steps">
          <li>
            <span class="cd-step-num">1</span>
            <p><strong>Find your date</strong> - pick an available date from the calendar</p>
          </li>
          <li>
            <span class="cd-step-num">2</span>
            <p><strong>Tour with Hugo</strong> - 30 minutes, 7 days a week. Or book a call first if you'd rather chat.</p>
          </li>
          <li>
            <span class="cd-step-num">3</span>
            <p><strong>Decide together</strong> - we'll talk you through holding the date</p>
          </li>
        </ol>
      </div>
      <div class="cd-trust-box cd-trust-box--stats">
        <div class="cd-stat">
          <span class="cd-stat-number">400+</span>
          <span class="cd-stat-label">Weddings managed</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">1856</span>
          <span class="cd-stat-label">Brewery, restored</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">60 / 100</span>
          <span class="cd-stat-label">Seated / standing capacity</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">4.9 ★</span>
          <span class="cd-stat-label">From 63 couples on Hitched</span>
        </div>
      </div>
    </div>

    <!-- Corporate variant. Past clients pulled from corporate.astro logo strip. -->
    <div class="cd-trust-grid" data-trust-variant="corporate" hidden>
      <div class="cd-trust-box">
        <h3>What happens next?</h3>
        <ol class="cd-steps">
          <li>
            <span class="cd-step-num">1</span>
            <p><strong>Find your date</strong> - pick a date that works for your team</p>
          </li>
          <li>
            <span class="cd-step-num">2</span>
            <p><strong>Brief Hugo</strong> - 15-minute call, we'll scope your event and talk through requirements</p>
          </li>
          <li>
            <span class="cd-step-num">3</span>
            <p><strong>Get a proposal</strong> - dedicated events manager handles delivery from brief to debrief</p>
          </li>
        </ol>
      </div>
      <div class="cd-trust-box cd-trust-box--stats">
        <div class="cd-stat">
          <span class="cd-stat-number cd-stat-number--text">Adidas, Spotify, Samsung</span>
          <span class="cd-stat-label">Past clients</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">1856</span>
          <span class="cd-stat-label">Brewery, restored</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number cd-stat-number--text">Exclusive Hire</span>
          <span class="cd-stat-label">No shared spaces, no surprises</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">100</span>
          <span class="cd-stat-label">Up to 100 guests (60 seated)</span>
        </div>
      </div>
    </div>

    <!-- Private variant: birthdays, baby showers, anniversaries, engagements. -->
    <div class="cd-trust-grid" data-trust-variant="private" hidden>
      <div class="cd-trust-box">
        <h3>What happens next?</h3>
        <ol class="cd-steps">
          <li>
            <span class="cd-step-num">1</span>
            <p><strong>Find your date</strong> - pick a date for your celebration</p>
          </li>
          <li>
            <span class="cd-step-num">2</span>
            <p><strong>Discovery call with Hugo</strong> - 15 minutes, no pressure, we'll talk through the options</p>
          </li>
          <li>
            <span class="cd-step-num">3</span>
            <p><strong>Plan it together</strong> - dedicated events manager handles every detail on the day</p>
          </li>
        </ol>
      </div>
      <div class="cd-trust-box cd-trust-box--stats">
        <div class="cd-stat">
          <span class="cd-stat-number cd-stat-number--text">Birthdays, baby showers, anniversaries</span>
          <span class="cd-stat-label">What we host</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">1856</span>
          <span class="cd-stat-label">Brewery, restored</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number cd-stat-number--text">Exclusive Hire</span>
          <span class="cd-stat-label">The whole venue, just for you</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">60 / 100</span>
          <span class="cd-stat-label">Seated / standing capacity</span>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Trust strip routing. Reads ?type= synchronously at parse, before paint,
     so corporate/private visitors never see the wedding variant flash.
     Mirrors the URL param consumption shipped in CheckDateForm.jsx (commit
     6813462) so dataLayer event_type and the trust strip variant always
     agree on what kind of visitor we have. -->
<script is:inline>
  (function() {
    var params = new URLSearchParams(window.location.search);
    var type = params.get('type');
    if (!type) return; // wedding stays visible by default
    var allowed = { wedding: 1, corporate: 1, private: 1 };
    if (!allowed[type]) return; // unknown value -> wedding default
    var nodes = document.querySelectorAll('[data-trust-variant]');
    for (var i = 0; i < nodes.length; i++) {
      nodes[i].hidden = nodes[i].getAttribute('data-trust-variant') !== type;
    }
  })();
</script>

</Base>

<style>
  /* ==================== TIGHTER HEADER SPACING ==================== */
  .utility-header {
    padding-bottom: 24px;
  }

  /* ==================== TRUST SECTION ==================== */
  .cd-trust {
    padding: 0 0 80px;
  }

  .cd-trust-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    max-width: 800px;
    margin: 0 auto;
  }

  /* The HTML5 [hidden] attribute applies display:none via UA stylesheet,
     but the .cd-trust-grid class rule above (display: grid) wins on
     specificity and renders hidden variants visible. This explicit
     override matches specificity and keeps the variant routing working. */
  .cd-trust-grid[hidden] {
    display: none;
  }

  .cd-trust-box {
    background: rgba(44, 24, 16, 0.025);
    border: 1px solid rgba(44, 24, 16, 0.06);
    border-radius: 2px;
    padding: 32px;
  }

  .cd-trust-box h3 {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    color: var(--brewery-dark);
    margin: 0 0 24px;
  }

  /* Steps */
  .cd-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cd-steps li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .cd-step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    width: 32px;
    height: 32px;
    background: var(--forest-olive);
    color: #fff;
    border-radius: 50%;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    flex-shrink: 0;
  }

  .cd-steps p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--brewery-dark);
    margin: 0;
    padding-top: 4px;
  }

  .cd-steps strong {
    font-weight: 600;
  }

  /* Stats */
  .cd-trust-box--stats {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    text-align: center;
  }

  .cd-stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    color: var(--forest-olive);
    line-height: 1.1;
    margin-bottom: 6px;
  }

  /* Text-style number (e.g. "Everything Included") - smaller so longer
     phrases fit on a single line in the side panel */
  .cd-stat-number--text {
    font-size: 17px;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .cd-stat-label {
    font-family: var(--font-body);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(44, 24, 16, 0.5);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cd-trust {
      padding: 0 0 60px;
    }

    .cd-trust-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .cd-trust-box {
      padding: 24px;
    }

    .cd-trust-box--stats {
      flex-direction: row;
      justify-content: space-around;
    }
  }
</style>
