---
import Base from '../layouts/Base.astro';
---

<Base title="Check Your Date | The Hackney, East London E2" description="Check if your date is available at The Hackney - East London's restored 1856 brewery venue. Weddings, events, celebrations. 60 seated, 100 standing. Exclusively yours.">

<style is:global>
  /* ==================== HERO (COMPACT) ==================== */
  .hero {
    position: relative;
    padding: 120px 0 80px;
    margin-top: 72px;
    display: flex;
    align-items: center;
    background: var(--warm-canvas);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dusty-coral);
    margin-bottom: 24px;
  }

  .hero h1 {
    color: var(--brewery-dark);
    margin-bottom: 20px;
  }

  .hero-sub {
    color: var(--brewery-dark);
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 0;
    max-width: 560px;
  }

  /* ==================== MAIN CONTENT - TWO COLUMN ==================== */
  .content-section {
    padding: 80px 0;
  }

  .two-column {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 80px;
    align-items: flex-start;
  }

  /* Availability calendar section */
  .calendar-section {
    padding: 80px 0 40px;
  }

  .calendar-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 40px;
  }

  .calendar-header p:last-of-type {
    color: rgba(44, 24, 16, 0.7);
    margin-top: 12px;
  }

  .calendar-embed {
    max-width: 900px;
    margin: 0 auto;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(44, 24, 16, 0.08);
  }

  .calendar-embed iframe {
    display: block;
  }

  .form-column {
    display: flex;
    flex-direction: column;
  }

  .sidebar-column {
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  /* HubSpot meetings embed container */
  .hubspot-form {
    width: 100%;
    margin-bottom: 32px;
  }

  .hubspot-form .meetings-iframe-container {
    min-height: 700px;
  }

  .hubspot-form iframe {
    width: 100%;
    min-height: 700px;
    border: none;
    border-radius: 4px;
  }

  .form-note {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(44, 24, 16, 0.6);
    margin-top: 16px;
  }

  .form-note a {
    color: var(--fired-brick);
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .form-note a:hover {
    color: var(--dusty-coral);
  }

  /* ==================== TRUST SIGNALS SIDEBAR ==================== */
  .trust-box {
    background: rgba(44, 24, 16, 0.03);
    padding: 40px 32px;
    border-radius: 4px;
  }

  .trust-box h3 {
    margin-bottom: 28px;
    color: var(--brewery-dark);
  }

  .steps-list {
    list-style: none;
  }

  .step-item {
    display: flex;
    gap: 20px;
    margin-bottom: 32px;
  }

  .step-item:last-child {
    margin-bottom: 0;
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    width: 40px;
    height: 40px;
    background: var(--fired-brick);
    color: #fff;
    border-radius: 50%;
    font-weight: 600;
    font-size: 16px;
    flex-shrink: 0;
  }

  .step-text {
    flex: 1;
    padding-top: 2px;
  }

  .step-text p {
    margin: 0;
    font-size: 15px;
    line-height: 1.6;
    color: var(--brewery-dark);
  }

  /* Stats */
  .stats-box {
    background: rgba(44, 24, 16, 0.03);
    padding: 32px;
    border-radius: 4px;
    text-align: center;
  }

  .stat {
    margin-bottom: 24px;
  }

  .stat:last-child {
    margin-bottom: 0;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 700;
    color: var(--fired-brick);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-label {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(44, 24, 16, 0.5);
  }

  /* Testimonial */
  .testimonial-box {
    background: rgba(44, 24, 16, 0.03);
    padding: 32px;
    border-radius: 4px;
    border-left: 4px solid var(--fired-brick);
  }

  .testimonial-quote {
    font-size: 16px;
    font-style: italic;
    line-height: 1.7;
    color: var(--brewery-dark);
    margin-bottom: 16px;
  }

  .testimonial-attribution {
    font-size: 13px;
    font-weight: 600;
    color: rgba(44, 24, 16, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Scroll fade-in animation */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 1200px) {
    .two-column {
      grid-template-columns: 1fr 1fr;
      gap: 60px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 100px 0 60px;
      margin-top: 72px;
    }

    .hero h1 {
      font-size: 36px;
    }

    .hero-sub {
      font-size: 16px;
    }

    .content-section {
      padding: 60px 0;
    }

    .two-column {
      grid-template-columns: 1fr;
      gap: 60px;
    }

    .sidebar-column {
      gap: 40px;
    }

    .hubspot-form iframe {
      height: 600px;
    }

    .trust-box,
    .stats-box,
    .testimonial-box {
      padding: 28px 24px;
    }

    .trust-box h3 {
      font-size: 20px;
    }

    .step-item {
      gap: 16px;
      margin-bottom: 24px;
    }

    .step-number {
      min-width: 36px;
      width: 36px;
      height: 36px;
      font-size: 14px;
    }
  }
</style>

<!-- ==================== HERO ==================== -->
<section class="hero">
  <div class="container">
    <div class="hero-content fade-in">
      <div class="eyebrow">Check Your Date</div>
      <h1>See if your date is available</h1>
      <p class="hero-sub">It takes 30 seconds. Tell us your date and we will let you know if The Hackney is free.</p>
    </div>
  </div>
</section>

<!-- ==================== AVAILABILITY CALENDAR ==================== -->
<section class="calendar-section fade-in">
  <div class="container">
    <div class="calendar-header">
      <p class="section-label">Availability</p>
      <h2>Check the calendar</h2>
      <p>See which dates are already booked. If your date looks free, book a discovery call below and we will confirm within 24 hours.</p>
    </div>
    <div class="calendar-embed">
      <iframe src="https://calendar.google.com/calendar/embed?src=c_v2a5l8vh2qenad1lm0ejd8hq7s%40group.calendar.google.com&ctz=Europe%2FLondon&showTitle=0&showNav=1&showDate=1&showPrint=0&showTabs=0&showCalendars=0&showTz=0&mode=MONTH&wkst=2" style="border:none;" width="100%" height="500" frameborder="0" scrolling="no"></iframe>
    </div>
  </div>
</section>

<!-- ==================== BOOK A DISCOVERY CALL ==================== -->
<section class="content-section">
  <div class="container">
    <div class="two-column fade-in">
      <!-- LEFT COLUMN: Form -->
      <div class="form-column">
        <h2 style="margin-bottom:8px;">Book a discovery call</h2>
        <p style="margin-bottom:32px; color: rgba(44,24,16,0.7);">A 15-minute chat with Hugo. No obligation. He will confirm your date and answer any questions.</p>
        <div class="hubspot-form">
          <!-- HubSpot Meetings Embed -->
          <div class="meetings-iframe-container" data-src="https://meetings-eu1.hubspot.com/bookings-team/book-a-discovery-call?embed=true"></div>
          
        </div>
        <p class="form-note">Prefer to call? Ring us on <a href="tel:+442079611604">+44 20 7961 1604</a> - available Mon to Sun, 9am to 7pm</p>
      </div>

      <!-- RIGHT COLUMN: Trust Signals -->
      <div class="sidebar-column">
        <!-- What happens next -->
        <div class="trust-box">
          <h3>What happens next?</h3>
          <ul class="steps-list">
            <li class="step-item">
              <div class="step-number">1</div>
              <div class="step-text">
                <p><strong>Check your date</strong> - we will confirm availability within 24 hours</p>
              </div>
            </li>
            <li class="step-item">
              <div class="step-number">2</div>
              <div class="step-text">
                <p><strong>Book a discovery call</strong> - a 15-minute chat with Hugo to answer your questions</p>
              </div>
            </li>
            <li class="step-item">
              <div class="step-number">3</div>
              <div class="step-text">
                <p><strong>Tour the venue</strong> - see the space in person. No obligation.</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Stats -->
        <div class="stats-box">
          <div class="stat">
            <div class="stat-number">4.6</div>
            <div class="stat-label">Google Rating</div>
          </div>
          <div class="stat">
            <div class="stat-number">98</div>
            <div class="stat-label">NPS Score</div>
          </div>
          <div class="stat">
            <div class="stat-number">200+</div>
            <div class="stat-label">Events Hosted</div>
          </div>
        </div>

        <!-- Testimonial -->
        <div class="testimonial-box">
          <p class="testimonial-quote">&ldquo;From the first tour we knew this was the one. Hugo made everything feel easy.&rdquo;</p>
          <p class="testimonial-attribution">Sarah &amp; Lee</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== FOOTER ==================== -->


<!-- ==================== JAVASCRIPT ==================== -->
</Base>
