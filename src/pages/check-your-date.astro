---
import Base from '../layouts/Base.astro';
import UtilityHeader from '../components/UtilityHeader.astro';
import CheckDateForm from '../components/CheckDateForm.astro';
---

<Base
  title="Check Your Date | The Hackney, East London E2"
  description="Check if your date is available at The Hackney - East London's restored 1856 brewery venue. Weddings, corporate events, private celebrations. 60 seated, 100 standing."
  pageType="check-your-date"
>

<UtilityHeader
  eyebrow="Check Your Date"
  heading="See if your date is available"
  intro="Tell us what you're planning and we'll check availability. Takes 60 seconds. No obligation."
/>

<CheckDateForm />

<!-- Trust signals below the form -->
<section class="cd-trust">
  <div class="container">
    <div class="cd-trust-grid">
      <!-- What happens next -->
      <div class="cd-trust-box">
        <h3>What happens next?</h3>
        <ol class="cd-steps">
          <li>
            <span class="cd-step-num">1</span>
            <p><strong>We check your date</strong> and get back to you within 24 hours</p>
          </li>
          <li>
            <span class="cd-step-num">2</span>
            <p><strong>15-minute call with Hugo</strong> to answer your questions</p>
          </li>
          <li>
            <span class="cd-step-num">3</span>
            <p><strong>See the space</strong> - book a tour, no obligation</p>
          </li>
        </ol>
      </div>

      <!-- Social proof -->
      <div class="cd-trust-box cd-trust-box--stats">
        <div class="cd-stat">
          <span class="cd-stat-number">4.6</span>
          <span class="cd-stat-label">Google Rating</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">98</span>
          <span class="cd-stat-label">NPS Score</span>
        </div>
        <div class="cd-stat">
          <span class="cd-stat-number">400+</span>
          <span class="cd-stat-label">Events Hosted</span>
        </div>
      </div>
    </div>
  </div>
</section>

</Base>

<style>
  /* ==================== TRUST SECTION ==================== */
  .cd-trust {
    padding: 0 0 80px;
  }

  .cd-trust-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    max-width: 800px;
    margin: 0 auto;
  }

  .cd-trust-box {
    background: rgba(44, 24, 16, 0.025);
    border: 1px solid rgba(44, 24, 16, 0.06);
    border-radius: 2px;
    padding: 32px;
  }

  .cd-trust-box h3 {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    color: var(--brewery-dark);
    margin: 0 0 24px;
  }

  /* Steps */
  .cd-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cd-steps li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .cd-step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    width: 32px;
    height: 32px;
    background: var(--forest-olive);
    color: #fff;
    border-radius: 50%;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    flex-shrink: 0;
  }

  .cd-steps p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--brewery-dark);
    margin: 0;
    padding-top: 4px;
  }

  .cd-steps strong {
    font-weight: 600;
  }

  /* Stats */
  .cd-trust-box--stats {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 24px;
    text-align: center;
  }

  .cd-stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 700;
    color: var(--forest-olive);
    line-height: 1;
    margin-bottom: 4px;
  }

  .cd-stat-label {
    font-family: var(--font-body);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(44, 24, 16, 0.5);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cd-trust {
      padding: 0 0 60px;
    }

    .cd-trust-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .cd-trust-box {
      padding: 24px;
    }

    .cd-trust-box--stats {
      flex-direction: row;
      justify-content: space-around;
    }
  }
</style>
