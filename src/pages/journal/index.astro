---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import FinalCTA from '../../components/FinalCTA.astro';

const posts = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function readingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  const mins = Math.ceil(words / 230);
  return `${mins} min read`;
}

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "The Hackney Journal",
  "description": "Stories from a restored 1856 brewery on Hackney Road - heritage, weddings, and East London life.",
  "url": "https://thehackney-website.pages.dev/journal/",
  "publisher": {
    "@type": "Organization",
    "name": "The Hackney"
  }
});
---

<Base
  title="Journal"
  description="Stories from a restored 1856 brewery on Hackney Road. Heritage, weddings, local guides, and life at The Hackney."
  schema={schema}
>
  <!-- Journal listing — single unified section -->
  <section class="journal-listing section">
    <div class="container">
      <header class="journal-header">
        <span class="eyebrow">Journal</span>
        <h1>Stories From Hackney Road</h1>
        <p class="journal-intro">Heritage, weddings, and life at a restored 1856 brewery in the heart of East London.</p>
      </header>

      {posts.length === 0 ? (
        <p>Coming soon.</p>
      ) : (
        <div class="posts-grid">
          {posts.map((post) => (
            <article class="post-card fade-in">
              {post.data.image && (
                <a href={`/journal/${post.slug}/`} class="post-card-image-link">
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt || post.data.title}
                    class="post-card-image"
                    loading="lazy"
                    width="600"
                    height="400"
                  />
                </a>
              )}
              <div class="post-card-body">
                <span class="post-category">{post.data.category}</span>
                <h2 class="post-title">
                  <a href={`/journal/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p class="post-excerpt">{post.data.description}</p>
                <div class="post-card-footer">
                  <span class="post-date">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                    </time>
                  </span>
                  <a href={`/journal/${post.slug}/`} class="post-read-more">Read the full story <span class="arrow">&rarr;</span></a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->

  <FinalCTA
    eyebrow="Your Celebration"
    heading="Start Planning Your Day"
    body="Whether it's a wedding, a birthday, or a corporate away day - check if your date is available."
    primaryCTA={{ label: "See The Calendar", href: "/check-your-date/" }}
    utmCampaign="journal"
  />
</Base>

<style>
  /* Journal listing — unified section with header + grid */
  .journal-listing {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-lg);
  }

  .journal-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--space-xl);
  }

  .journal-header .eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dusty-coral);
    margin-bottom: var(--space-sm);
  }

  .journal-header h1 {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    margin-bottom: var(--space-md);
  }

  .journal-intro {
    font-size: 1.125rem;
    line-height: 1.65;
    opacity: 0.8;
    max-width: none;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    max-width: 1100px;
    margin-inline: auto;
  }

  /* Last odd card centres itself instead of stretching full-width */
  .post-card:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    max-width: 520px;
    margin-inline: auto;
  }

  .post-card {
    display: flex;
    flex-direction: column;
  }

  .post-card-image-link {
    display: block;
    margin-bottom: var(--space-sm);
    overflow: hidden;
    border-radius: 2px;
  }

  .post-card-image {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .post-card-image-link:hover .post-card-image {
    transform: scale(1.02);
  }

  .post-card-body {
    padding-top: var(--space-sm, 0.75rem);
  }

  .post-category {
    display: block;
    font-family: var(--font-body);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dusty-coral);
    font-size: 0.75rem;
    margin-bottom: var(--space-sm, 0.75rem);
  }

  .post-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: var(--space-sm, 0.75rem);
  }

  .post-date {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--brewery-dark);
    opacity: 0.45;
  }

  h2.post-title {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.3;
    margin-bottom: var(--space-sm, 0.75rem);
  }

  .post-title a {
    color: var(--brewery-dark);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-title a:hover {
    color: var(--fired-brick);
  }

  .post-excerpt {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.75;
    margin-bottom: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-read-more {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--dusty-coral);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-read-more .arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .post-read-more:hover {
    color: var(--fired-brick);
  }

  .post-read-more:hover .arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .journal-listing {
      padding-top: var(--space-lg);
    }

    .journal-header {
      margin-bottom: var(--space-lg);
    }

    .posts-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .post-card:last-child:nth-child(odd) {
      max-width: none;
    }

  }
</style>
