---
import Base from '../../layouts/Base.astro';
import HeroSection from '../../components/HeroSection.astro';
import { getCollection } from 'astro:content';
import FinalCTA from '../../components/FinalCTA.astro';

const posts = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function readingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  const mins = Math.ceil(words / 230);
  return `${mins} min read`;
}

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "The Hackney Journal",
  "description": "Stories from a restored 1856 brewery on Hackney Road - heritage, weddings, and East London life.",
  "url": "https://thehackney-website.pages.dev/journal/",
  "publisher": {
    "@type": "Organization",
    "name": "The Hackney"
  }
});
---

<Base
  title="Journal"
  description="Stories from a restored 1856 brewery on Hackney Road. Heritage, weddings, local guides, and life at The Hackney."
  schema={schema}
>
  <!-- Hero -->
  <div class="journal-hero-wrap">
    <HeroSection
      bg="light"
      height="auto"
      align="center"
      eyebrow="Journal"
      heading="Stories From Hackney Road"
      subtext="Heritage, weddings, and life at a restored 1856 brewery in the heart of East London."
    />
  </div>

  <!-- Posts -->
  <section class="journal-list section">
    <div class="container">
      {posts.length === 0 ? (
        <p>Coming soon.</p>
      ) : (
        <div class="posts-grid">
          {posts.map((post) => (
            <article class="post-card fade-in">
              {post.data.image && (
                <a href={`/journal/${post.slug}/`} class="post-card-image-link">
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt || post.data.title}
                    class="post-card-image"
                    loading="lazy"
                    width="600"
                    height="400"
                  />
                </a>
              )}
              <div class="post-card-body">
                <div class="post-meta">
                  <span class="post-category">{post.data.category}</span>
                  <span class="post-date">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                    </time>
                  </span>
                  <span class="post-reading-time">{readingTime(post.body || '')}</span>
                </div>
                <h2 class="post-title">
                  <a href={`/journal/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p class="post-excerpt">{post.data.description}</p>
                <a href={`/journal/${post.slug}/`} class="post-read-more">Read the full story <span class="arrow">&rarr;</span></a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <FinalCTA
    eyebrow="Your Celebration"
    heading="Start Planning Your Day"
    body="Whether it's a wedding, a birthday, or a corporate away day - check if your date is available."
    primaryCTA={{ label: "Check Your Date", href: "/check-your-date/" }}
    utmCampaign="journal"
  />
</Base>

<style>
  /* Scope the hero H1 down for the journal index - keeps visual
     hierarchy below the article H1.
     Wrapper div avoids leaking into contact page hero. */
  .journal-hero-wrap :global(.hero-section-content h1) {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
  }

  .journal-list {
    padding-top: var(--space-md);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    max-width: 1100px;
    margin-inline: auto;
  }

  /* Last odd card spans full width as a horizontal layout */
  .post-card:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    flex-direction: row;
    gap: var(--space-lg);
  }

  .post-card:last-child:nth-child(odd) .post-card-image-link {
    flex: 0 0 45%;
    margin-bottom: 0;
  }

  .post-card:last-child:nth-child(odd) .post-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-card {
    display: flex;
    flex-direction: column;
  }

  .post-card-image-link {
    display: block;
    margin-bottom: var(--space-sm);
    overflow: hidden;
    border-radius: 2px;
  }

  .post-card-image {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .post-card-image-link:hover .post-card-image {
    transform: scale(1.02);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    letter-spacing: 0.05em;
  }

  .post-category {
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dusty-coral);
    font-size: 0.75rem;
  }

  .post-date,
  .post-reading-time {
    color: var(--brewery-dark);
    opacity: 0.55;
  }

  .post-date::before,
  .post-reading-time::before {
    content: '';
    display: inline-block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--brewery-dark);
    opacity: 0.3;
    vertical-align: middle;
    margin-right: var(--space-sm);
  }

  h2.post-title {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.3;
    margin-bottom: var(--space-xs, 0.5rem);
  }

  .post-title a {
    color: var(--brewery-dark);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-title a:hover {
    color: var(--fired-brick);
  }

  .post-excerpt {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.75;
    margin-bottom: var(--space-sm);
  }

  .post-read-more {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--dusty-coral);
    text-decoration: none;
    transition: color 0.2s ease;
    margin-top: auto;
  }

  .post-read-more .arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .post-read-more:hover {
    color: var(--fired-brick);
  }

  .post-read-more:hover .arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .journal-list {
      padding-top: var(--space-sm);
    }

    .posts-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    /* On mobile, orphan card reverts to vertical like all others */
    .post-card:last-child:nth-child(odd) {
      flex-direction: column;
      gap: 0;
    }

    .post-card:last-child:nth-child(odd) .post-card-image-link {
      flex: none;
      margin-bottom: var(--space-sm);
    }

    .post-meta {
      gap: var(--space-sm);
    }
  }
</style>
