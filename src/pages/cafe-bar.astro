---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofBar from '../components/ProofBar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FAQ from '../components/FAQ.astro';

const cafeFaqs = [
  { question: "Is The Hackney cafe-bar dog friendly?", answer: "Yes. Dogs are welcome inside and on the terrace." },
  { question: "Do I need to book a table?", answer: "No. The cafe-bar is walk-in only. Just turn up." },
  { question: "What are the opening hours?", answer: "We are open Tuesday to Sunday (closed Mondays). Weekdays from 8am, weekends from 9am. Hours may change when the venue hosts a private event, so check Google Maps for today's live hours." },
  { question: "Is this the same place as Hackney Coffee Company?", answer: "Yes. We started as the Hackney Coffee Company and rebranded to The Hackney. Same building, same coffee, same team." },
  { question: "Can I work from the cafe?", answer: "Yes. We have free wifi, plug sockets, and plenty of space during the day. Lots of freelancers and remote workers use us as a regular spot." },
  { question: "Where exactly is The Hackney cafe-bar?", answer: "503 Hackney Road, London E2 9ED. Two minutes walk from Cambridge Heath Overground, eight minutes from Bethnal Green Underground on the Central line." }
];
---

<Base title="Cafe & Bar East London | Speciality Coffee & Light Bites | The Hackney, Hackney Road E2" description="Dog-friendly cafe-bar inside a restored 1856 brewery on Hackney Road, East London. Speciality coffee, craft cocktails, natural wines. Two minutes from Cambridge Heath station. Walk-ins welcome." preloadImage="/images/hackney-cafe-bar-bartender-pouring-champagne.webp">

  <!-- ==================== HERO ==================== -->
  <HeroSection
    image="/images/hackney-cafe-bar-bartender-pouring-champagne.webp"
    alt="Bartender pouring champagne at The Hackney cafe-bar with exposed brick backdrop"
    heading="Coffee, Cocktails<br>and Good Company."
    cta={{ label: "See The Menu", href: "#menu" }}
    note="Walk-ins welcome, no booking needed"
    height="mid"
    textGradient={true}
  />

  <!-- ==================== SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "Open 7 Days", label: "Weekdays from 8am, weekends from 9am" },
    { number: "Dog Friendly", label: "Inside and on the terrace" },
    { number: "Free Wi-Fi", label: "Plug sockets, good for remote work" },
    { number: "Hackney Road E2", label: "2 min from Cambridge Heath" }
  ]} />

  <!-- ==================== THE SPACE ==================== -->
  <Section bg="light" border="bottom">
    <div class="space-grid">
      <div class="space-text">
        <SectionHeader
          eyebrow="The Space"
          heading="A Proper Cafe-Bar In East London"
        />
        <p>We are at 503 Hackney Road, London E2 9ED, right between Bethnal Green and Cambridge Heath. The building is a former Victorian brewery with high ceilings, exposed brick, a skylit winter garden and a covered courtyard terrace.</p>
        <p>It is a nice place to sit with a laptop, meet someone for coffee, or come for drinks after work. Free wifi, plenty of plug sockets, and a good atmosphere all day.</p>
        <p>Dogs are welcome. You do not need to book. Just walk in.</p>
        <p class="history-note">Some of you might remember us as the Hackney Coffee Company. We started as a speciality coffee house, and good coffee is still at the heart of what we do. The space has grown since then, but the coffee has not changed.</p>
      </div>
      <div class="space-images">
        <div class="space-placeholder lazy-bg" data-bg="" data-bg-pos="center center" role="img" aria-label="The Hackney winter garden with natural light and greenery"></div>
        <div class="space-placeholder lazy-bg" data-bg="" data-bg-pos="center center" role="img" aria-label="The Hackney bar area with exposed brick"></div>
      </div>
    </div>
  </Section>

  <!-- ==================== WHAT WE SERVE ==================== -->
  <Section bg="light" border="bottom" id="menu">
    <SectionHeader
      eyebrow="The Menu"
      heading="What We Serve"
    />
    <div class="serve-grid">
      <div class="serve-category">
        <h3>Coffee and Drinks</h3>
        <p>Speciality coffee made properly. Espresso, flat whites, long blacks, oat milk as standard. We also do teas, fresh juices and soft drinks.</p>
        <p>We also serve natural wines by the glass, beers on tap and soft drinks. For cocktails and evening dining, check out our <a href="/supper-club/">Supper Club</a> nights.</p>
        <p class="serve-highlight">We make a good Negroni.</p>
      </div>
      <div class="serve-category">
        <h3>Food</h3>
        <p>Light bites through the day. Pastries in the morning, seasonal snacks and bar food as the day goes on.</p>
        <p>Nothing complicated, just well-made food to go with your drink.</p>
        <p>Our in-house kitchen is led by Chef Marco Mannoni. Seasonal menus, locally sourced ingredients, modern European cooking.</p>
      </div>
    </div>
    <a href="/private-events/" class="btn btn-outline-dark">Explore Events</a>
  </Section>

  <!-- ==================== OPENING HOURS ==================== -->
  <Section bg="dark" padding="standard">
    <div class="hours-inner">
      <SectionHeader
        eyebrow="Opening Hours"
        heading="Opening Hours"
        align="center"
      />

      <div class="hours-table">
        <div class="hours-row"><span>Monday</span><span>Closed</span></div>
        <div class="hours-row"><span>Tuesday</span><span>8am - 4pm</span></div>
        <div class="hours-row"><span>Wednesday</span><span>8am - 5pm</span></div>
        <div class="hours-row"><span>Thursday</span><span>8am - 5pm</span></div>
        <div class="hours-row"><span>Friday</span><span>8am - 5pm</span></div>
        <div class="hours-row"><span>Saturday</span><span>9am - 5pm</span></div>
        <div class="hours-row"><span>Sunday</span><span>9am - 4pm</span></div>
      </div>

      <p class="hours-note">On days when the venue is booked for a private event, the cafe-bar may close earlier than usual. Check Google Maps for today's live hours before heading over.</p>

      <a href="https://maps.app.goo.gl/RwT31Y6tmXPzyqGQ9" target="_blank" rel="noopener" class="btn btn-primary-dark">Check Today's Hours on Google</a>
    </div>
  </Section>

  <!-- ==================== FIND US ==================== -->
  <Section bg="light" border="top">
    <div class="find-us-grid">
      <div class="find-us-details">
        <SectionHeader
          eyebrow="Location"
          heading="Find Us"
        />
        <div class="find-us-address">503 Hackney Road<br>London, E2 9ED</div>

        <ul class="transport-list">
          <li>Cambridge Heath Overground - 2 minute walk</li>
          <li>Bethnal Green Underground (Central line) - 8 minute walk</li>
          <li>Bus routes 106, 254 and D6 stop directly outside</li>
        </ul>

        <p class="parking-note">No customer parking on site, but Hackney Road has free parking from 7pm onwards.</p>

        <a href="https://maps.app.goo.gl/RwT31Y6tmXPzyqGQ9" target="_blank" rel="noopener" class="btn btn-primary">Get Directions</a>
      </div>
      <div class="find-us-map">
        <span class="map-placeholder-text">Map - coming soon</span>
      </div>
    </div>
  </Section>

  <!-- ==================== FAQs ==================== -->
  <Section bg="light" border="top">
    <SectionHeader
      eyebrow="FAQs"
      heading="Frequently Asked Questions"
    />
    <FAQ items={cafeFaqs} />
  </Section>

  <!-- ==================== CROSS-SELL ==================== -->
  <Section bg="olive" padding="standard">
    <div class="cross-sell-inner">
      <p class="eyebrow">More Than A Cafe</p>
      <h2>Planning Something Special?</h2>
      <p class="cross-sell-body">From intimate weddings to private parties, The Hackney hosts it all. Same building, same team, same attention to detail.</p>
      <div class="cross-sell-buttons">
        <a href="/weddings/" class="btn btn-primary-dark">Explore Weddings</a>
        <a href="/private-events/" class="btn btn-outline-dark">Explore Events</a>
      </div>
    </div>
  </Section>

  <style>
    /* ==================== THE SPACE ==================== */
    .space-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
    }

    .space-text p {
      font-size: 17px;
      line-height: 1.7;
      margin-bottom: 16px;
    }

    .history-note {
      font-style: italic;
      opacity: 0.75;
      margin-top: 24px;
    }

    .space-images {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .space-placeholder {
      width: 100%;
      aspect-ratio: 16/10;
      background-color: var(--brewery-dark);
      border: 1px solid rgba(44, 24, 16, 0.08);
    }

    /* ==================== SERVE ==================== */
    .serve-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      margin-bottom: 48px;
    }

    .serve-category h3 {
      font-size: 20px;
      margin-bottom: 16px;
      color: var(--mid-olive);
    }

    .serve-category p {
      font-size: 16px;
      line-height: 1.7;
      margin-bottom: 12px;
    }

    .serve-category a {
      color: var(--forest-olive);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .serve-highlight {
      font-family: var(--font-heading);
      font-size: 20px;
      font-style: italic;
      color: var(--fired-brick);
      margin-top: 16px;
    }

    /* ==================== HOURS ==================== */
    .hours-inner {
      max-width: 500px;
      margin: 0 auto;
      text-align: center;
    }

    .hours-table {
      margin: 2rem 0;
    }

    .hours-row {
      display: flex;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid rgba(245, 240, 232, 0.1);
      font-size: 16px;
      color: var(--warm-canvas);
    }

    .hours-note {
      font-size: 14px;
      opacity: 0.6;
      margin-bottom: 2rem;
      line-height: 1.6;
      color: var(--warm-canvas);
    }

    /* ==================== FIND US ==================== */
    .find-us-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
    }

    .find-us-address {
      font-family: var(--font-heading);
      font-size: 24px;
      font-weight: 600;
      line-height: 1.4;
      margin-bottom: 24px;
    }

    .transport-list {
      list-style: none;
      margin-bottom: 16px;
    }

    .transport-list li {
      padding: 8px 0;
      padding-left: 20px;
      position: relative;
      font-size: 15px;
      line-height: 1.5;
    }

    .transport-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 14px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--forest-olive);
    }

    .parking-note {
      font-size: 14px;
      opacity: 0.6;
      margin-bottom: 24px;
    }

    .find-us-map {
      width: 100%;
      aspect-ratio: 4/3;
      background: var(--brewery-dark);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .map-placeholder-text {
      color: rgba(255, 255, 255, 0.4);
      font-size: 14px;
      font-family: var(--font-body);
    }

    /* ==================== CROSS-SELL ==================== */
    .cross-sell-inner {
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
    }

    .cross-sell-body {
      font-size: 18px;
      line-height: 1.7;
      margin-bottom: 2rem;
      color: var(--warm-canvas);
      opacity: 0.9;
    }

    .cross-sell-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ==================== RESPONSIVE ==================== */
    @media (max-width: 768px) {
      .space-grid { grid-template-columns: 1fr; gap: 40px; }
      .serve-grid { grid-template-columns: 1fr; gap: 40px; }
      .find-us-grid { grid-template-columns: 1fr; gap: 40px; }
      .cross-sell-buttons { flex-direction: column; align-items: center; }
    }
  </style>
</Base>
