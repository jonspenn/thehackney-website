---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofBar from '../components/ProofBar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FAQ from '../components/FAQ.astro';

const cafeFaqs = [
  { question: "Is The Hackney cafe-bar dog friendly?", answer: "Yes. Dogs are welcome inside and on the terrace." },
  { question: "Do I need to book a table?", answer: "No. The cafe-bar is walk-in only. Just turn up." },
  { question: "What are the opening hours?", answer: "We are open Tuesday to Sunday (closed Mondays). Weekdays from 8am, weekends from 9am. Hours may change when the venue hosts a private event, so check Google Maps for today's live hours." },
  { question: "Is this the same place as Hackney Coffee Company?", answer: "Yes. We started as the Hackney Coffee Company and rebranded to The Hackney. Same building, same coffee, same team." },
  { question: "Can I work from the cafe?", answer: "Yes. We have free wifi, plug sockets, and plenty of space during the day. Lots of freelancers and remote workers use us as a regular spot." },
  { question: "Where exactly is The Hackney cafe-bar?", answer: "503 Hackney Road, London E2 9ED. Two minutes walk from Cambridge Heath Overground, eight minutes from Bethnal Green Underground on the Central line." }
];

const mapsUrl = "https://maps.app.goo.gl/RwT31Y6tmXPzyqGQ9";

// JSON-LD structured data for local SEO
const cafeSchema = {
  "@context": "https://schema.org",
  "@type": "CafeOrCoffeeShop",
  "name": "The Hackney Cafe-Bar",
  "image": "https://thehackney.co/images/hackney-cafe-bar-bartender-pouring-champagne.webp",
  "url": "https://thehackney.co/cafe-bar/",
  "telephone": "+44 20 XXXX XXXX",
  "priceRange": "££",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "503 Hackney Road",
    "addressLocality": "London",
    "postalCode": "E2 9ED",
    "addressCountry": "GB"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 51.5325459,
    "longitude": -0.0584213
  },
  "servesCuisine": ["Speciality Coffee", "Brunch", "Light Bites", "Natural Wine"],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "08:00", "closes": "16:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "17:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "17:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "09:00", "closes": "16:00" }
  ],
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Wi-Fi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Dog Friendly", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Power Outlets", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Outdoor Seating", "value": true }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "634"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": cafeFaqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<Base title="Cafe & Bar East London | Speciality Coffee & Brunch | The Hackney, Hackney Road E2" description="Daytime cafe-bar in a restored 1856 brewery on Hackney Road, East London. Speciality coffee, brunch, natural wine. Dog friendly. Two minutes from Cambridge Heath. Walk-ins welcome." preloadImage="/images/hackney-cafe-bar-bartender-pouring-champagne.webp">

  <!-- ==================== SCHEMA ==================== -->
  <script type="application/ld+json" set:html={JSON.stringify(cafeSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ==================== HERO ==================== -->
  <HeroSection
    image="/images/hackney-cafe-bar-bartender-pouring-champagne.webp"
    alt="The Hackney cafe-bar interior with exposed brick and warm lighting"
    heading="Speciality Coffee and Brunch<br>on Hackney Road."
    subtext="A daytime cafe-bar in a restored 1856 brewery. Dog friendly. Walk-ins welcome."
    cta={{ label: "Get Directions", href: mapsUrl }}
    secondaryCta={{ label: "See Today's Hours", href: "#hours" }}
    height="mid"
    textGradient={true}
  />

  <!-- ==================== SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "4.6 ★", label: "634 Google reviews" },
    { number: "Dog Friendly", label: "Inside and on the terrace" },
    { number: "Free Wi-Fi", label: "Plug sockets, good for working" },
    { number: "2 min walk", label: "From Cambridge Heath Overground" }
  ]} />

  <!-- ==================== THE SPACE ==================== -->
  <Section bg="light" border="bottom">
    <div class="space-text">
      <SectionHeader
        eyebrow="The Space"
        heading="A Proper Cafe-Bar In East London"
      />
      <p>We are at 503 Hackney Road, London E2 9ED, right between Bethnal Green and Cambridge Heath. The building is a former Victorian brewery with high ceilings, exposed brick, a skylit winter garden and a covered courtyard terrace.</p>
      <p>It is a nice place to sit with a laptop, meet someone for coffee, or come in for a drink during the day. Free wifi, plenty of plug sockets, and a good atmosphere all day.</p>
      <p>Dogs are welcome. You do not need to book. Just walk in.</p>
      <p class="history-note">Some of you might remember us as the Hackney Coffee Company. We started as a speciality coffee house, and good coffee is still at the heart of what we do. The space has grown since then, but the coffee has not changed.</p>
    </div>
  </Section>

  <!-- ==================== HOW LOCALS USE THE HACKNEY (DAYPARTS) ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="How Locals Use It"
      heading="A Cafe-Bar For Most Of Your Week"
      align="center"
    />
    <div class="daypart-grid">
      <div class="daypart-card">
        <p class="daypart-eyebrow">Weekday Mornings</p>
        <h3>Coffee Meetings</h3>
        <p>Flat whites, a quiet table, and no one rushing you out. Open from 8am Tuesday to Friday. A good spot for a 1-on-1 before the day kicks off.</p>
      </div>
      <div class="daypart-card">
        <p class="daypart-eyebrow">Weekdays All Day</p>
        <h3>Laptop Work</h3>
        <p>Free wifi, plenty of plugs, long tables in the winter garden. Stay for an hour or stay for the afternoon. Plenty of local freelancers call us their regular.</p>
      </div>
      <div class="daypart-card">
        <p class="daypart-eyebrow">Saturdays</p>
        <h3>When We're Open</h3>
        <p>Most Saturdays we open at 9am for coffee, pastries and weekend brunch. Some Saturdays the venue is booked for a private event. Check our <a href="/check-your-date/">availability calendar</a> to see which Saturdays are clear.</p>
      </div>
      <div class="daypart-card">
        <p class="daypart-eyebrow">Sundays</p>
        <h3>Brunch And A Glass Of Something</h3>
        <p>Open 9am to 4pm. Brunch, natural wine by the glass, and the terrace when the sun is out. Bring the dog. Bring the paper.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== WHAT WE SERVE ==================== -->
  <Section bg="light" border="bottom" id="menu">
    <SectionHeader
      eyebrow="The Menu"
      heading="What We Serve"
    />
    <div class="serve-grid">
      <div class="serve-category">
        <h3>Coffee and Drinks</h3>
        <p>Speciality coffee made properly. Espresso, flat whites, long blacks, oat milk as standard. We also do teas, fresh juices and soft drinks.</p>
        <p>Natural wines by the glass, beers on tap. For a full evening of food and wine, take a look at our <a href="/supper-club/">Supper Club</a> nights.</p>
        <p class="serve-highlight">We make a good Negroni.</p>
      </div>
      <div class="serve-category">
        <h3>Food</h3>
        <p>Brunch, pastries and light bites through the day. Seasonal, locally sourced, modern European cooking from our in-house kitchen led by Chef Marco Mannoni.</p>
        <p>Nothing complicated, just well-made food you want to come back for.</p>
      </div>
    </div>
    <div class="menu-cta-row">
      <a href="#" class="btn btn-primary" data-cafe-cta="menu-pdf">View Full Menu (PDF)</a>
      <a href="/supper-club/" class="btn btn-outline-dark" data-cafe-cta="supper-club-from-menu">See Our Supper Clubs</a>
    </div>
    <p class="menu-note">Menu PDF coming soon. In the meantime, drop in or give us a call.</p>
  </Section>

  <!-- ==================== OPENING HOURS ==================== -->
  <Section bg="dark" padding="standard" id="hours">
    <div class="hours-inner">
      <SectionHeader
        eyebrow="Opening Hours"
        heading="Opening Hours"
        align="center"
      />

      <div class="hours-table">
        <div class="hours-row"><span>Monday</span><span>Closed</span></div>
        <div class="hours-row"><span>Tuesday</span><span>8am - 4pm</span></div>
        <div class="hours-row"><span>Wednesday</span><span>8am - 5pm</span></div>
        <div class="hours-row"><span>Thursday</span><span>8am - 5pm</span></div>
        <div class="hours-row"><span>Friday</span><span>8am - 5pm</span></div>
        <div class="hours-row"><span>Saturday</span><span>9am - 5pm</span></div>
        <div class="hours-row"><span>Sunday</span><span>9am - 4pm</span></div>
      </div>

      <p class="hours-note">On days when the venue is booked for a private event, the cafe-bar may close earlier than usual or not open at all. See our <a href="/check-your-date/" class="hours-link">availability calendar</a> for event days, or Google Maps for today's live hours.</p>

      <a href={mapsUrl} target="_blank" rel="noopener" class="btn btn-primary-dark" data-cafe-cta="hours-google">Check Today's Hours on Google</a>
    </div>
  </Section>

  <!-- ==================== FIND US ==================== -->
  <Section bg="light" border="top">
    <div class="find-us-grid">
      <div class="find-us-details">
        <SectionHeader
          eyebrow="Location"
          heading="Find Us"
        />
        <div class="find-us-address">503 Hackney Road<br>London, E2 9ED</div>

        <ul class="transport-list">
          <li>Cambridge Heath Overground - 2 minute walk</li>
          <li>Bethnal Green Underground (Central line) - 8 minute walk</li>
          <li>Bus routes 106, 254 and D6 stop directly outside</li>
        </ul>

        <p class="parking-note">No customer parking on site, but Hackney Road has free parking from 7pm onwards.</p>

        <a href={mapsUrl} target="_blank" rel="noopener" class="btn btn-primary" data-cafe-cta="directions-findus">Get Directions</a>
      </div>
      <div class="find-us-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1241.3!2d-0.0584213!3d51.5325459!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48761cd4e2b5f3d9%3A0x0!2sThe+Hackney%2C+503+Hackney+Rd%2C+London+E2+9ED!5e0!3m2!1sen!2suk!4v1712000000000"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="The Hackney location map - 503 Hackney Road, London E2 9ED"
        ></iframe>
      </div>
    </div>
  </Section>

  <!-- ==================== WHAT'S ON - EMAIL CAPTURE ==================== -->
  <Section bg="light" border="top">
    <div class="whatson-inner">
      <SectionHeader
        eyebrow="What's On"
        heading="One Email, Once A Week"
        align="center"
      />
      <p class="whatson-body">New menus, upcoming supper club dates, Sunday specials. Just the useful stuff. No spam.</p>
      <form class="whatson-form" data-cafe-cta="email-signup" onsubmit="event.preventDefault(); alert('Thanks - we will launch this properly soon.'); return false;">
        <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
        <button type="submit" class="btn btn-primary">Sign Me Up</button>
      </form>
      <p class="whatson-note">Launching soon - we will confirm your signup by email.</p>
    </div>
  </Section>

  <!-- ==================== FAQs ==================== -->
  <Section bg="light" border="top">
    <SectionHeader
      eyebrow="FAQs"
      heading="Frequently Asked Questions"
    />
    <FAQ items={cafeFaqs} />
  </Section>

  <!-- ==================== CROSS-SELL ==================== -->
  <Section bg="olive" padding="standard">
    <div class="cross-sell-inner">
      <p class="eyebrow">More At The Hackney</p>
      <h2>Supper Clubs, Weddings and Private Events</h2>
      <p class="cross-sell-body">By day we are a cafe-bar. By night and on event days, the same building hosts intimate supper clubs, private parties and weddings. Same space, same team, same attention to detail.</p>
      <div class="cross-sell-buttons">
        <a href="/supper-club/" class="btn btn-primary-dark" data-cafe-cta="crosssell-supperclub">Explore Supper Clubs</a>
        <a href="/weddings/" class="btn btn-outline-dark" data-cafe-cta="crosssell-weddings">Weddings</a>
        <a href="/private-events/" class="btn btn-outline-dark" data-cafe-cta="crosssell-events">Private Events</a>
      </div>
    </div>
  </Section>

  <!-- ==================== GA4 DATALAYER WIRING ==================== -->
  <script is:inline>
    (function() {
      window.dataLayer = window.dataLayer || [];
      function push(ev, params) { window.dataLayer.push(Object.assign({ event: ev, page: 'cafe-bar' }, params || {})); }

      // Tag all buttons/links with data-cafe-cta
      document.querySelectorAll('[data-cafe-cta]').forEach(function(el) {
        el.addEventListener('click', function() {
          push('cafe_cta_click', { cta: el.getAttribute('data-cafe-cta') });
        });
      });

      // Directions (Google Maps) gets its own named event
      document.querySelectorAll('a[href*="maps.app.goo.gl"]').forEach(function(el) {
        el.addEventListener('click', function() { push('cafe_directions_click'); });
      });

      // Menu section scroll-into-view
      var menuEl = document.getElementById('menu');
      if (menuEl && 'IntersectionObserver' in window) {
        var seen = false;
        new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting && !seen) { seen = true; push('cafe_menu_view'); }
          });
        }, { threshold: 0.5 }).observe(menuEl);
      }

      // Hours section scroll-into-view
      var hoursEl = document.getElementById('hours');
      if (hoursEl && 'IntersectionObserver' in window) {
        var seenHours = false;
        new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting && !seenHours) { seenHours = true; push('cafe_hours_view'); }
          });
        }, { threshold: 0.5 }).observe(hoursEl);
      }

      // Email signup
      var form = document.querySelector('form[data-cafe-cta="email-signup"]');
      if (form) form.addEventListener('submit', function() { push('cafe_email_signup_attempt'); });
    })();
  </script>

  <style>
    /* ==================== THE SPACE ==================== */
    .space-text {
      max-width: 720px;
      margin: 0 auto;
    }

    .space-text p {
      font-size: 17px;
      line-height: 1.7;
      margin-bottom: 16px;
    }

    .history-note {
      font-style: italic;
      opacity: 0.75;
      margin-top: 24px;
    }

    /* ==================== DAYPARTS ==================== */
    .daypart-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      margin-top: 48px;
    }

    .daypart-card {
      background: var(--warm-canvas);
      border: 1px solid rgba(44, 24, 16, 0.08);
      border-radius: 2px;
      padding: 28px 24px;
    }

    .daypart-eyebrow {
      font-family: var(--font-body);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dusty-coral);
      margin-bottom: 12px;
    }

    .daypart-card h3 {
      font-family: var(--font-heading);
      font-size: 22px;
      line-height: 1.25;
      color: var(--brewery-dark);
      margin-bottom: 12px;
    }

    .daypart-card p {
      font-size: 15px;
      line-height: 1.6;
      color: var(--brewery-dark);
      opacity: 0.85;
    }

    .daypart-card a {
      color: var(--forest-olive);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    /* ==================== SERVE ==================== */
    .serve-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      margin-bottom: 32px;
    }

    .serve-category h3 {
      font-size: 20px;
      margin-bottom: 16px;
      color: var(--mid-olive);
    }

    .serve-category p {
      font-size: 16px;
      line-height: 1.7;
      margin-bottom: 12px;
    }

    .serve-category a {
      color: var(--forest-olive);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .serve-highlight {
      font-family: var(--font-heading);
      font-size: 20px;
      font-style: italic;
      color: var(--fired-brick);
      margin-top: 16px;
    }

    .menu-cta-row {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .menu-note {
      font-size: 13px;
      opacity: 0.6;
      margin-top: 12px;
      font-style: italic;
    }

    /* ==================== HOURS ==================== */
    .hours-inner {
      max-width: 500px;
      margin: 0 auto;
      text-align: center;
    }

    .hours-table {
      margin: 2rem 0;
    }

    .hours-row {
      display: flex;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid rgba(245, 240, 232, 0.1);
      font-size: 16px;
      color: var(--warm-canvas);
    }

    .hours-note {
      font-size: 14px;
      opacity: 0.6;
      margin-bottom: 2rem;
      line-height: 1.6;
      color: var(--warm-canvas);
    }

    .hours-note .hours-link {
      color: var(--warm-canvas);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    /* ==================== FIND US ==================== */
    .find-us-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
    }

    .find-us-address {
      font-family: var(--font-heading);
      font-size: 24px;
      font-weight: 600;
      line-height: 1.4;
      margin-bottom: 24px;
    }

    .transport-list {
      list-style: none;
      margin-bottom: 16px;
    }

    .transport-list li {
      padding: 8px 0;
      padding-left: 20px;
      position: relative;
      font-size: 15px;
      line-height: 1.5;
    }

    .transport-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 14px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--forest-olive);
    }

    .parking-note {
      font-size: 14px;
      opacity: 0.6;
      margin-bottom: 24px;
    }

    .find-us-map {
      width: 100%;
      aspect-ratio: 4/3;
      background: var(--brewery-dark);
      overflow: hidden;
    }

    .find-us-map iframe {
      display: block;
      width: 100%;
      height: 100%;
    }

    /* ==================== WHAT'S ON ==================== */
    .whatson-inner {
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
    }

    .whatson-body {
      font-size: 17px;
      line-height: 1.6;
      margin: 16px 0 28px;
    }

    .whatson-form {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 12px;
    }

    .whatson-form input[type="email"] {
      flex: 1 1 260px;
      padding: 14px 16px;
      border: 1px solid rgba(44, 24, 16, 0.2);
      border-radius: 2px;
      background: var(--warm-canvas);
      font-family: var(--font-body);
      font-size: 15px;
      color: var(--brewery-dark);
    }

    .whatson-form input[type="email"]:focus {
      outline: 2px solid var(--forest-olive);
      outline-offset: 1px;
    }

    .whatson-note {
      font-size: 13px;
      opacity: 0.6;
      font-style: italic;
    }

    /* ==================== CROSS-SELL ==================== */
    .cross-sell-inner {
      text-align: center;
      max-width: 640px;
      margin: 0 auto;
    }

    .cross-sell-body {
      font-size: 18px;
      line-height: 1.7;
      margin-bottom: 2rem;
      color: var(--warm-canvas);
      opacity: 0.9;
    }

    .cross-sell-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ==================== RESPONSIVE ==================== */
    @media (max-width: 960px) {
      .daypart-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .serve-grid { grid-template-columns: 1fr; gap: 40px; }
      .find-us-grid { grid-template-columns: 1fr; gap: 40px; }
      .cross-sell-buttons { flex-direction: column; align-items: center; }
      .daypart-grid { grid-template-columns: 1fr; gap: 16px; }
      .menu-cta-row { flex-direction: column; align-items: stretch; }
    }
  </style>
</Base>
