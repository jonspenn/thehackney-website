---
import Base from '../layouts/Base.astro';
---

<Base title="Wedding & Events Venue East London | The Hackney, E2" description="The Hackney is a converted 1856 brewery on Hackney Road, E2. One of East London's most sought-after wedding and events venues. 60 seated, 100 standing. Exclusively yours.">
<!-- ==================== HERO ==================== -->
  <section class="hero">
    <div class="hero-bg" style="background: var(--forest-olive) url('/images/hackney-wedding-venue-hero-long-tables-edison-bulbs.webp') center center / cover no-repeat;"></div>
    <div class="container">
      <div class="hero-content">
        <p class="eyebrow">East London &nbsp;-&nbsp; 503 Hackney Road &nbsp;-&nbsp; E2</p>
        <h1>Where East London<br>Gets Married</h1>
        <p class="hero-sub">An 1856 brewery building. 60 seated, 100 standing.<br>Exclusively yours for the day.</p>
        <a href="/check-your-date/?utm_source=website&utm_medium=cta&utm_campaign=homepage" class="btn btn-primary">Check Your Date</a>
        <p class="hero-note">Free. No obligation. See if your date is available.</p>
      </div>
    </div>
  </section>

  <!-- ==================== SOCIAL PROOF BAR ==================== -->
  <section class="proof-bar">
    <div class="container">
      <div class="proof-bar-inner">
        <div class="proof-stat fade-in">
          <div class="proof-stat-number">98</div>
          <div class="proof-stat-label">NPS Score</div>
        </div>
        <div class="proof-stat fade-in">
          <div class="proof-stat-number">4.6</div>
          <div class="proof-stat-label">Google Rating</div>
        </div>
        <div class="proof-stat fade-in">
          <div class="proof-stat-number">75</div>
          <div class="proof-stat-label">Weddings Per Year</div>
        </div>
        <div class="proof-stat fade-in">
          <div class="proof-stat-number">1856</div>
          <div class="proof-stat-label">Brewery Building</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== VENUE INTRODUCTION ==================== -->
  <section class="venue-intro">
    <div class="container">
      <div class="venue-intro-grid">
        <div class="fade-in">
          <h2 class="pull-quote">"Industrial Romance. East London. Entirely Yours."</h2>
        </div>
        <div class="venue-intro-body fade-in">
          <p>The Hackney is a converted 1856 brewery on Hackney Road, E2. One of East London's most sought-after wedding and events venues.</p>
          <p>Exclusively hired. 60 seated, 100 standing. Everything in-house - catering, bar, florals, coordination.</p>
          <p>No corkage. No hidden fees. No outside caterers. Just one team, one venue, one day that is entirely yours.</p>

          <div class="differentiators">
            <div>
              <div class="diff-item-label">Exclusively Hired</div>
              <div class="diff-item-text">The whole venue is yours. No other events, no shared spaces.</div>
            </div>
            <div>
              <div class="diff-item-label">Everything In-House</div>
              <div class="diff-item-text">Kitchen, bar, florals and coordination. One team from start to finish.</div>
            </div>
            <div>
              <div class="diff-item-label">East London</div>
              <div class="diff-item-text">503 Hackney Road E2. 5 minutes from Bethnal Green tube.</div>
            </div>
          </div>

          <a href="/check-your-date/?utm_source=website&utm_medium=cta&utm_campaign=homepage" class="btn btn-primary">Check Your Date</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FIVE OCCASIONS ==================== -->
  <section class="occasions">
    <div class="container">
      <div class="occasions-grid">
        <a href="/weddings/" class="occasion-card" style="background-image: url('/images/hackney-wedding-ceremony-kiss-industrial-backdrop.webp');">
          <div class="occasion-card-content">
            <h3>Weddings</h3>
            <p class="occasion-card-desc">Exclusively yours. Ceremony to last dance.</p>
          </div>
        </a>
        <a href="/corporate/" class="occasion-card" style="background-image: url('/images/hackney-wedding-breakfast-guests-edison-bulbs-skylights.webp');">
          <div class="occasion-card-content">
            <h3>Corporate</h3>
            <p class="occasion-card-desc">Conferences, launches and team events.</p>
          </div>
        </a>
        <a href="/private-events/" class="occasion-card" style="background-image: url('/images/hackney-wedding-evening-celebration-couple-entrance.webp');">
          <div class="occasion-card-content">
            <h3>Private Events</h3>
            <p class="occasion-card-desc">Birthdays, anniversaries, celebrations.</p>
          </div>
        </a>
        <a href="/supper-club/" class="occasion-card" style="background-image: url('/images/hackney-wedding-table-detail-flowers-place-settings.webp');">
          <div class="occasion-card-content">
            <h3>Supper Club</h3>
            <p class="occasion-card-desc">Guest chef dinners. Communal dining.</p>
          </div>
        </a>
        <a href="/cafe-bar/" class="occasion-card" style="background-image: url('/images/hackney-wedding-couple-portrait-exposed-brick.webp');">
          <div class="occasion-card-content">
            <h3>Cafe and Bar</h3>
            <p class="occasion-card-desc">Coffee, brunch and natural wine. Open daily.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== TESTIMONIALS ==================== -->
  <section class="testimonials">
    <div class="container">
      <p class="eyebrow">What Couples Say</p>
      <div class="testimonials-grid">
        <div class="fade-in">
          <p class="testimonial-quote">"The Hackney made our wedding feel completely effortless. The team thought of everything. We just showed up and it was perfect."</p>
          <p class="testimonial-attribution">Sophie and James, October 2025</p>
        </div>
        <div class="fade-in">
          <p class="testimonial-quote">"From the first tour we knew this was the one. The space is stunning and the food genuinely impressed our guests."</p>
          <p class="testimonial-attribution">Priya and Tom, August 2025</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PRICING ==================== -->
  <section class="pricing">
    <div class="container">
      <div class="pricing-header fade-in">
        <p class="section-label">Investment</p>
        <h2>Honest Pricing. No Hidden Fees.</h2>
        <p>Most couples spend between £10,000 and £18,000 all in. Everything is in-house - what you see is what you pay.</p>
      </div>
      <div class="pricing-grid">
        <div class="pricing-card fade-in">
          <h3>Off-Peak</h3>
          <p class="pricing-card-guests">Jan - Mar, any day</p>
          <p class="pricing-card-price">From &pound;5,000</p>
          <p class="pricing-card-desc">Exclusive hire + minimum spend</p>
        </div>
        <div class="pricing-card fade-in">
          <h3>Mid-Season</h3>
          <p class="pricing-card-guests">Apr, Oct - Dec</p>
          <p class="pricing-card-price">From &pound;5,000</p>
          <p class="pricing-card-desc">Exclusive hire + minimum spend</p>
        </div>
        <div class="pricing-card fade-in">
          <h3>Peak Season</h3>
          <p class="pricing-card-guests">May - Sep</p>
          <p class="pricing-card-price">From &pound;7,000</p>
          <p class="pricing-card-desc">Exclusive hire + minimum spend</p>
        </div>
      </div>
      <div class="pricing-cta">
        <a href="/check-your-date/?utm_source=website&utm_medium=cta&utm_campaign=homepage" class="btn btn-primary">Check Your Date</a>
      </div>
    </div>
  </section>

  <!-- ==================== THE TEAM ==================== -->
  <section class="team">
    <div class="container">
      <div class="team-header fade-in">
        <p class="section-label">The Team</p>
        <h2>The People Who Make It Happen.</h2>
        <p>Every wedding at The Hackney is run by the same team from your first tour to the moment you leave. No agency hand-offs. No strangers on your day.</p>
      </div>
      <div class="team-grid">
        <div class="team-card fade-in">
          <div class="team-card-photo"></div>
          <h3>Hugo Correia</h3>
          <p class="team-card-role">General Manager</p>
          <p>Your first point of contact. Hugo runs venue tours, answers every question, and makes sure everything is locked in before your day.</p>
        </div>
        <div class="team-card fade-in">
          <div class="team-card-photo"></div>
          <h3>Eva</h3>
          <p class="team-card-role">Events Manager</p>
          <p>Eva coordinates every detail of your wedding day. She has delivered over 150 events at The Hackney and knows the venue better than anyone.</p>
        </div>
        <div class="team-card fade-in">
          <div class="team-card-photo"></div>
          <h3>The Kitchen</h3>
          <p class="team-card-role">In-House Catering Team</p>
          <p>Everything cooked on site. Seasonal menus, dietary flexibility, nothing outsourced.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="final-cta">
    <div class="container">
      <h2>Ready to see the space?</h2>
      <p class="final-cta-body">Tours run 7 days a week. No obligation. 45 minutes with Hugo and you will know if The Hackney is the right venue for you.</p>
      <div class="final-cta-buttons">
        <a href="/check-your-date/?utm_source=website&utm_medium=cta&utm_campaign=homepage" class="btn btn-primary">Check Your Date</a>
        <a href="/weddings/#brochure" class="btn btn-outline">Download The Brochure</a>
      </div>
      <p class="final-cta-note">Or call us on +44 20 7961 1604 - available Mon to Sun, 9am to 7pm</p>
      <p class="final-cta-note" style="margin-top: 12px;">Prefer to message? <a href="https://wa.me/442079611604" style="color: var(--dusty-coral);">Chat on WhatsApp</a></p>
    </div>
  </section>

  <!-- ==================== FOOTER ==================== -->
</Base>

<style is:global>
  /* ==================== HERO ==================== */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    background: var(--forest-olive);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    z-index: 1;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: var(--forest-olive) url('/images/hackney-wedding-venue-hero-long-tables-edison-bulbs.webp') center center / cover no-repeat;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .hero .container {
    width: 100%;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dusty-coral);
    margin-bottom: 24px;
  }

  .hero h1 {
    color: #fff;
    margin-bottom: 20px;
  }

  .hero-sub {
    color: #fff;
    font-size: 20px;
    line-height: 1.5;
    margin-bottom: 36px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-note {
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
    margin-top: 14px;
  }

  /* ==================== SOCIAL PROOF BAR ==================== */
  .proof-bar {
    background: var(--warm-canvas);
    border-bottom: 1px solid rgba(44, 24, 16, 0.08);
    padding: 40px 0;
  }

  .proof-bar-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
  }

  .proof-stat-number {
    font-family: var(--font-heading);
    font-size: clamp(36px, 4vw, 52px);
    font-weight: 800;
    color: var(--brewery-dark);
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .proof-stat-label {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dusty-coral);
    margin-top: 6px;
    font-weight: 500;
  }

  /* ==================== VENUE INTRO ==================== */
  .venue-intro {
    padding: 100px 0;
  }

  .venue-intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .pull-quote {
    font-family: var(--font-heading);
    font-size: clamp(28px, 3.5vw, 40px);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.15;
    color: var(--brewery-dark);
  }

  .venue-intro-body p {
    margin-bottom: 20px;
  }

  .differentiators {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .diff-item-label {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fired-brick);
    margin-bottom: 4px;
  }

  .diff-item-text {
    font-size: 16px;
    color: var(--brewery-dark);
    opacity: 0.85;
  }

  .venue-intro .btn {
    margin-top: 40px;
  }

  /* ==================== FIVE OCCASIONS ==================== */
  .occasions {
    padding: 0 0 100px;
  }

  .occasions-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }

  .occasion-card {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    cursor: pointer;
    display: flex;
    align-items: flex-end;
    padding: 24px;
    border-top: 3px solid transparent;
    transition: border-color 0.3s ease;
    background-size: cover;
    background-position: center;
    background-color: var(--brewery-dark);
  }

  .occasion-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: rgba(0, 0, 0, 0.4);
    transition: opacity 0.3s ease;
  }

  .occasion-card:hover::before {
    background: rgba(0, 0, 0, 0.25);
  }

  .occasion-card:hover {
    border-top-color: var(--fired-brick);
  }

  .occasion-card-content {
    position: relative;
    z-index: 1;
  }

  .occasion-card h3 {
    color: #fff;
    font-size: 18px;
    letter-spacing: 0.1em;
  }

  .occasion-card-desc {
    color: rgba(255, 255, 255, 0.8);
    font-size: 14px;
    line-height: 1.5;
    margin-top: 8px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: all 0.3s ease;
  }

  .occasion-card:hover .occasion-card-desc {
    max-height: 80px;
    opacity: 1;
  }

  /* ==================== TESTIMONIALS ==================== */
  .testimonials {
    background: var(--forest-olive);
    padding: 80px 0;
  }

  .testimonials .eyebrow {
    text-align: center;
    margin-bottom: 48px;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .testimonial-quote {
    font-size: clamp(20px, 2.5vw, 26px);
    color: #fff;
    font-style: italic;
    line-height: 1.5;
    margin-bottom: 20px;
  }

  .testimonial-attribution {
    font-family: var(--font-heading);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dusty-coral);
  }

  /* ==================== PRICING ==================== */
  .pricing {
    padding: 100px 0;
  }

  .pricing-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 60px;
  }

  .pricing-header .section-label {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--dusty-coral);
    margin-bottom: 16px;
  }

  .pricing-header h2 {
    margin-bottom: 20px;
  }

  .pricing-header p {
    font-size: 18px;
    opacity: 0.85;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  .pricing-card {
    background: #fff;
    border: 1px solid rgba(44, 24, 16, 0.08);
    padding: 40px 32px;
    transition: box-shadow 0.3s ease;
  }

  .pricing-card:hover {
    box-shadow: 0 8px 32px rgba(44, 24, 16, 0.08);
  }

  .pricing-card h3 {
    font-size: 20px;
    margin-bottom: 4px;
  }

  .pricing-card-guests {
    font-size: 14px;
    color: var(--dusty-coral);
    margin-bottom: 20px;
  }

  .pricing-card-price {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 800;
    color: var(--fired-brick);
    margin-bottom: 20px;
    letter-spacing: 0.02em;
  }

  .pricing-card-desc {
    font-size: 15px;
    line-height: 1.6;
    opacity: 0.8;
  }

  .pricing-cta {
    text-align: center;
  }

  /* ==================== TEAM ==================== */
  .team {
    padding: 100px 0;
    border-top: 1px solid rgba(44, 24, 16, 0.06);
  }

  .team-header {
    max-width: 600px;
    margin-bottom: 60px;
  }

  .team-header .section-label {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--dusty-coral);
    margin-bottom: 16px;
  }

  .team-header h2 {
    margin-bottom: 20px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 36px;
  }

  .team-card-photo {
    aspect-ratio: 4/5;
    background: var(--forest-olive);
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }

  .team-card-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.06'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .team-card h3 {
    font-size: 18px;
    margin-bottom: 2px;
  }

  .team-card-role {
    font-size: 13px;
    color: var(--dusty-coral);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    margin-bottom: 12px;
  }

  .team-card p {
    font-size: 15px;
    line-height: 1.6;
    opacity: 0.8;
  }

  /* ==================== FINAL CTA ==================== */
  .final-cta {
    background: var(--brewery-dark);
    padding: 80px 0;
    text-align: center;
  }

  .final-cta h2 {
    color: #fff;
    margin-bottom: 20px;
  }

  .final-cta-body {
    color: rgba(255, 255, 255, 0.7);
    font-size: 18px;
    max-width: 500px;
    margin: 0 auto 36px;
  }

  .final-cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .final-cta-note {
    color: rgba(255, 255, 255, 0.45);
    font-size: 14px;
    margin-top: 24px;
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 1200px) {
    .occasions-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 0;
    }

    .hero h1 {
      font-size: 36px;
    }

    .hero-sub {
      font-size: 17px;
    }

    .proof-bar-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }

    .venue-intro-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .occasions-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .occasion-card:last-child {
      grid-column: span 2;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .team-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .final-cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }

  /* Section label shared style override */
  .section-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--dusty-coral);
    margin-bottom: 16px;
  }
</style>
