---
import Base from '../layouts/Base.astro';
---

<Base title="The Hackney - East London Wedding & Events Venue" description="The Hackney is a converted 1860s brewery on Hackney Road, E2. One of East London's most sought-after wedding and events venues. 60 seated, 100 standing. Exclusively yours.">
<!-- ==================== NAVIGATION ==================== -->
  

  <!-- ==================== HERO ==================== -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container">
      <div class="hero-content">
        <p class="eyebrow">East London &nbsp;-&nbsp; 503 Hackney Road &nbsp;-&nbsp; E2</p>
        <h1>Where East London<br>Gets Married</h1>
        <p class="hero-sub">An 1860s brewery building. 60 seated, 100 standing.<br>Exclusively yours for the day.</p>
        <a href="/check-your-date" class="btn btn-primary">Check Your Date</a>
        <p class="hero-note">Free. No obligation. See if your date is available.</p>
      </div>
    </div>
  </section>

  <!-- ==================== SOCIAL PROOF BAR ==================== -->
  <section class="proof-bar">
    <div class="container">
      <div class="proof-bar-inner">
        <div class="proof-stat fade-in">
          <div class="proof-stat-number">98</div>
          <div class="proof-stat-label">NPS Score</div>
        </div>
        <div class="proof-stat fade-in">
          <div class="proof-stat-number">4.9</div>
          <div class="proof-stat-label">Google Rating</div>
        </div>
        <div class="proof-stat fade-in">
          <div class="proof-stat-number">75</div>
          <div class="proof-stat-label">Weddings Per Year</div>
        </div>
        <div class="proof-stat fade-in">
          <div class="proof-stat-number">1860s</div>
          <div class="proof-stat-label">Brewery Building</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== VENUE INTRODUCTION ==================== -->
  <section class="venue-intro">
    <div class="container">
      <div class="venue-intro-grid">
        <div class="fade-in">
          <h2 class="pull-quote">"Industrial Romance. East London. Entirely Yours."</h2>
        </div>
        <div class="venue-intro-body fade-in">
          <p>The Hackney is a converted 1860s brewery on Hackney Road, E2. One of East London's most sought-after wedding and events venues.</p>
          <p>Exclusively hired. 60 seated, 100 standing. Everything in-house - catering, bar, florals, coordination.</p>
          <p>No corkage. No hidden fees. No outside caterers. Just one team, one venue, one day that is entirely yours.</p>

          <div class="differentiators">
            <div>
              <div class="diff-item-label">Exclusively Hired</div>
              <div class="diff-item-text">The whole venue is yours. No other events, no shared spaces.</div>
            </div>
            <div>
              <div class="diff-item-label">Everything In-House</div>
              <div class="diff-item-text">Kitchen, bar, florals and coordination. One team from start to finish.</div>
            </div>
            <div>
              <div class="diff-item-label">East London</div>
              <div class="diff-item-text">503 Hackney Road E2. 5 minutes from Bethnal Green tube.</div>
            </div>
          </div>

          <a href="/check-your-date" class="btn btn-primary">Check Your Date</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FIVE OCCASIONS ==================== -->
  <section class="occasions">
    <div class="container">
      <div class="occasions-grid">
        <a href="/weddings/" class="occasion-card" style="background-image: url('images/hackney-wedding-ceremony-kiss-industrial-backdrop.webp');">
          <div class="occasion-card-content">
            <h3>Weddings</h3>
            <p class="occasion-card-desc">Exclusively yours. Ceremony to last dance.</p>
          </div>
        </a>
        <a href="/events/" class="occasion-card" style="background-image: url('images/hackney-wedding-breakfast-guests-edison-bulbs-skylights.webp');">
          <div class="occasion-card-content">
            <h3>Corporate</h3>
            <p class="occasion-card-desc">Conferences, launches and team events.</p>
          </div>
        </a>
        <a href="/events/" class="occasion-card" style="background-image: url('images/hackney-wedding-evening-celebration-couple-entrance.webp');">
          <div class="occasion-card-content">
            <h3>Private Events</h3>
            <p class="occasion-card-desc">Birthdays, anniversaries, celebrations.</p>
          </div>
        </a>
        <a href="/supper-club/" class="occasion-card" style="background-image: url('images/hackney-wedding-table-detail-flowers-place-settings.webp');">
          <div class="occasion-card-content">
            <h3>Supper Club</h3>
            <p class="occasion-card-desc">Guest chef dinners. Communal dining.</p>
          </div>
        </a>
        <a href="/cafe-bar/" class="occasion-card" style="background-image: url('images/hackney-wedding-couple-portrait-exposed-brick.webp');">
          <div class="occasion-card-content">
            <h3>Cafe and Bar</h3>
            <p class="occasion-card-desc">Coffee, brunch and natural wine. Open daily.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== TESTIMONIALS ==================== -->
  <section class="testimonials">
    <div class="container">
      <p class="eyebrow">What Couples Say</p>
      <div class="testimonials-grid">
        <div class="fade-in">
          <p class="testimonial-quote">"The Hackney made our wedding feel completely effortless. The team thought of everything. We just showed up and it was perfect."</p>
          <p class="testimonial-attribution">Sophie and James, October 2025</p>
        </div>
        <div class="fade-in">
          <p class="testimonial-quote">"From the first tour we knew this was the one. The space is stunning and the food genuinely impressed our guests."</p>
          <p class="testimonial-attribution">Priya and Tom, August 2025</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PRICING ==================== -->
  <section class="pricing">
    <div class="container">
      <div class="pricing-header fade-in">
        <p class="section-label">Investment</p>
        <h2>Honest Pricing. No Hidden Fees.</h2>
        <p>Weddings at The Hackney start from &pound;8,500 for an intimate celebration and range to &pound;25,000+ for a full exclusive hire with premium catering and florals. Everything is in-house - what you see is what you pay.</p>
      </div>
      <div class="pricing-grid">
        <div class="pricing-card fade-in">
          <h3>Intimate</h3>
          <p class="pricing-card-guests">Up to 40 guests</p>
          <p class="pricing-card-price">From &pound;8,500</p>
          <p class="pricing-card-desc">Exclusive hire, in-house catering, bar package, coordination.</p>
        </div>
        <div class="pricing-card fade-in">
          <h3>Signature</h3>
          <p class="pricing-card-guests">Up to 60 guests</p>
          <p class="pricing-card-price">From &pound;14,000</p>
          <p class="pricing-card-desc">Everything in Intimate plus florals, premium bar, full planning.</p>
        </div>
        <div class="pricing-card fade-in">
          <h3>Bespoke</h3>
          <p class="pricing-card-guests">Up to 100 standing</p>
          <p class="pricing-card-price">POA</p>
          <p class="pricing-card-desc">Fully tailored. Talk to us.</p>
        </div>
      </div>
      <div class="pricing-cta">
        <a href="/check-your-date" class="btn btn-primary">Check Your Date</a>
      </div>
    </div>
  </section>

  <!-- ==================== THE TEAM ==================== -->
  <section class="team">
    <div class="container">
      <div class="team-header fade-in">
        <p class="section-label">The Team</p>
        <h2>The People Who Make It Happen.</h2>
        <p>Every wedding at The Hackney is run by the same team from your first tour to the moment you leave. No agency hand-offs. No strangers on your day.</p>
      </div>
      <div class="team-grid">
        <div class="team-card fade-in">
          <div class="team-card-photo"></div>
          <h3>Hugo Correia</h3>
          <p class="team-card-role">General Manager</p>
          <p>Your first point of contact. Hugo runs venue tours, answers every question, and makes sure everything is locked in before your day.</p>
        </div>
        <div class="team-card fade-in">
          <div class="team-card-photo"></div>
          <h3>Eva</h3>
          <p class="team-card-role">Events Manager</p>
          <p>Eva coordinates every detail of your wedding day. She has delivered over 150 events at The Hackney and knows the venue better than anyone.</p>
        </div>
        <div class="team-card fade-in">
          <div class="team-card-photo"></div>
          <h3>The Kitchen</h3>
          <p class="team-card-role">In-House Catering Team</p>
          <p>Everything cooked on site. Seasonal menus, dietary flexibility, nothing outsourced.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="final-cta">
    <div class="container">
      <h2>Ready to see the space?</h2>
      <p class="final-cta-body">Tours run 7 days a week. No obligation. 45 minutes with Hugo and you will know if The Hackney is the right venue for you.</p>
      <div class="final-cta-buttons">
        <a href="/check-your-date" class="btn btn-primary">Check Your Date</a>
        <a href="/weddings/#brochure" class="btn btn-outline">Download The Brochure</a>
      </div>
      <p class="final-cta-note">Or call us on +44 20 7961 1604 - available Mon to Sun, 9am to 7pm</p>
    </div>
  </section>

  <!-- ==================== FOOTER ==================== -->
</Base>
