---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ContentBlock from '../components/ContentBlock.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import ProofBar from '../components/ProofBar.astro';
import PhotoBreak from '../components/PhotoBreak.astro';
import PhotoStrip from '../components/PhotoStrip.astro';
import FinalCTA from '../components/FinalCTA.astro';

// Hide team section until photos ship. One-line flip when ready.
const showTeam = false;

// Homepage EventVenue + LocalBusiness JSON-LD.
// Sitewide Organization schema is in Base.astro; this adds page-specific
// venue-level structured data so Google can serve a venue knowledge panel.
// Rating: 4.9 / 63 reviews on Hitched (Apr 2026).
//   - Lesley's misplaced 1-star review (was about Hackney Council, not the venue)
//     was removed by Hitched, restoring the rating from 4.8 back to 4.9.
const homepageSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["EventVenue", "LocalBusiness"],
  "@id": "https://thehackney.co/#venue",
  "name": "The Hackney",
  "description": "Converted 1856 brewery on Hackney Road, E2. Exclusive-hire wedding and events venue. 60 seated, 100 standing. Everything in-house.",
  "url": "https://thehackney.co/",
  "image": "https://thehackney.co/images/hackney-wedding-venue-hero-couple-edison-bulbs-greenery.webp",
  "telephone": "+442079611604",
  "priceRange": "\u00a3\u00a3\u00a3\u00a3",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "503 Hackney Road",
    "addressLocality": "London",
    "postalCode": "E2 9ED",
    "addressCountry": "GB"
  },
  "sameAs": [
    "https://instagram.com/thehackney.co",
    "https://www.tiktok.com/@thehackney",
    "https://www.facebook.com/TheHackney.Co/"
  ],
  "maximumAttendeeCapacity": 100,
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Sophie and James" },
      "datePublished": "2025-10",
      "reviewBody": "The Hackney made our wedding feel completely effortless. The team thought of everything. We just showed up and it was perfect.",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Priya and Tom" },
      "datePublished": "2025-08",
      "reviewBody": "From the first tour we knew this was the one. The space is stunning and the food genuinely impressed our guests.",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "63",
    "bestRating": "5"
  }
});
---

<Base title="Wedding & Events Venue East London | The Hackney, E2" description="The Hackney is a converted 1856 brewery on Hackney Road, E2. One of East London's most sought-after wedding and events venues. 60 seated, 100 standing. Exclusively yours." preloadImage="/images/hackney-wedding-venue-hero-couple-edison-bulbs-greenery.webp" schema={homepageSchema}>

  <!-- ==================== HERO ==================== -->
  <HeroSection
    image="/images/hackney-wedding-venue-hero-couple-edison-bulbs-greenery.webp"
    alt="A bride and groom walking through The Hackney's main hall set up for their wedding breakfast - hanging Edison bulbs, cascading greenery, white brick walls, long banquet tables. Photo by This Modern Revelry."
    heading="Industrial Romance.<br>East London. Entirely Yours."
    subtext="An 1856 brewery building. 60 seated, 100 standing. Exclusively yours for the day."
    cta={{ label: "See If Your Date Is Free", href: "/check-your-date/?utm_source=website&utm_medium=cta&utm_campaign=homepage&utm_content=hero" }}
    height="mid"
    textGradient={true}
  />

  <!-- ==================== SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "400+", label: "Weddings managed" },
    { number: "Everything Included", label: "Venue, food, drinks, team" },
    { number: "Exclusive Hire", label: "The whole venue, just for you" },
    { number: "4.9 ★", label: "Couple rating on Hitched" }
  ]} />

  <!-- ==================== FIVE OCCASIONS ==================== -->
  <Section bg="light" padding="standard" border="bottom" class="occasions-section">
    <div class="container">
      <div class="occasions-grid">
        <a href="/weddings/" class="occasion-card" style="background-image: url('/images/hackney-wedding-tile-bride-main-hall-disco-balls.webp'); background-position: center;">
          <div class="occasion-card-content">
            <h3>Weddings</h3>
            <p class="occasion-card-desc">Exclusively yours. Ceremony to last dance.</p>
          </div>
        </a>
        <a href="/corporate/" class="occasion-card" style="background-image: url('/images/hackney-corporate-tile-brand-activation-enfuce.webp'); background-position: center;">
          <div class="occasion-card-content">
            <h3>Corporate Events</h3>
            <p class="occasion-card-desc">Conferences, launches and team events. Everything in-house.</p>
          </div>
        </a>
        <a href="/private-events/" class="occasion-card" style="background-image: url('/images/hackney-private-events-tile-friends-celebration-terrace.webp'); background-position: 65% center;">
          <div class="occasion-card-content">
            <h3>Private Events</h3>
            <p class="occasion-card-desc">Birthdays, anniversaries, celebrations.</p>
          </div>
        </a>
        <a href="/supper-club/" class="occasion-card" style="background-image: url('/images/hackney-supper-club-tile-chef-plate-fish-caviar.webp'); background-position: center;">
          <div class="occasion-card-content">
            <h3>Supper Club</h3>
            <p class="occasion-card-desc">Guest chef dinners. Communal dining.</p>
          </div>
        </a>
        <a href="/cafe-bar/" class="occasion-card" style="background-image: url('/images/hackney-cafe-bar-tile-courtyard-bench-greenery.webp'); background-position: center;">
          <div class="occasion-card-content">
            <h3>Cafe and Bar</h3>
            <p class="occasion-card-desc">Coffee, brunch and natural wine. Open daily.</p>
          </div>
        </a>
      </div>
    </div>
  </Section>

  <!-- ==================== VENUE INTRODUCTION ==================== -->
  <Section bg="light" padding="standard" border="bottom">
    <ContentBlock
      image="/images/hackney-wedding-venue-main-hall-aisle-edison-bulbs.webp"
      alt="The Hackney's main hall set for a wedding - long banquet tables with bentwood chairs flanking the central aisle, hanging Edison bulbs and pampas, white brick walls, deep navy curtains on factory windows. Photo by Caitlin and Jones."
      reverse={true}
      aspect="4/3"
    >
      <p>The Hackney is a converted 1856 brewery on Hackney Road, E2. One of East London's most sought-after wedding and events venues.</p>
      <p>Exclusively hired. 60 seated, 100 standing. Everything in-house - catering, bar, florals, coordination.</p>
      <p>No corkage. No hidden fees. No outside caterers. Just one team, one venue, one day that is entirely yours.</p>

      <div class="differentiators">
        <div>
          <div class="diff-item-label">Exclusively Hired</div>
          <div class="diff-item-text">The whole venue is yours. No other events, no shared spaces.</div>
        </div>
        <div>
          <div class="diff-item-label">Everything In-House</div>
          <div class="diff-item-text">Kitchen, bar, florals and coordination. One team from start to finish.</div>
        </div>
        <div>
          <div class="diff-item-label">East London</div>
          <div class="diff-item-text">503 Hackney Road E2. 8 minutes from Bethnal Green tube.</div>
        </div>
      </div>

      <a href="/check-your-date/?utm_source=website&utm_medium=cta&utm_campaign=homepage&utm_content=venue-intro" class="btn btn-primary">See Pricing &amp; Dates</a>
    </ContentBlock>
  </Section>

  <!-- ==================== FULL-BLEED PHOTO BREAK ==================== -->
  <!-- Photo selected per prd-t1-homepage.md Photo Selection Rules:
       brand mood (warm Edison bulb interior), section job (rest between
       text blocks - establishing shot, no people-portrait), tonal
       continuity (sits between dark occasions grid + olive testimonials).
       Swapped 2026-04-30 from a pink-tassel couple shot that was breaking
       all three rules. -->
  <PhotoBreak
    image="/images/hackney-main-hall-long-tables-greenery-edison-bulbs.webp"
    alt="The Hackney main hall set for a wedding breakfast - long banquet tables, hanging Edison bulbs, cascading greenery"
  />

  <!-- ==================== TESTIMONIALS ==================== -->
  <Section bg="olive" padding="standard">
    <SectionHeader eyebrow="What Couples Say" align="center" />
    <TestimonialBlock testimonials={[
      { quote: "The Hackney made our wedding feel completely effortless. The team thought of everything. We just showed up and it was perfect.", attribution: "Sophie and James, October 2025" },
      { quote: "From the first tour we knew this was the one. The space is stunning and the food genuinely impressed our guests.", attribution: "Priya and Tom, August 2025" }
    ]} />
  </Section>

  <!-- ==================== PRICING ==================== -->
  <!-- Hook pattern adopted from /weddings/ canonical: one big number,
       transparent hire+min split, period context. No 3-card breakdown
       (full season-by-day-type table lives on /weddings/). Cross-link
       below routes the 15% non-wedding visitors who scrolled past the
       occasions grid at position 3 without using it. -->
  <Section bg="light" padding="standard" border="top">
    <SectionHeader
      eyebrow="Wedding Investment"
      heading="Honest Pricing. No Hidden Fees."
      align="center"
    />

    <div class="pricing-hook fade-in">
      <div class="pricing-hook-label">Weddings From</div>
      <div class="pricing-hook-amount">&pound;5,000</div>
      <div class="pricing-hook-breakdown">Venue hire &pound;1,000 &nbsp;+&nbsp; minimum spend &pound;4,000</div>
      <div class="pricing-hook-context">Off-peak weddings, any day of the week</div>
    </div>

    <p class="pricing-cross-link">
      Hosting a corporate event, private celebration, supper club or cafe-bar visit?
      <a href="/corporate/">Corporate</a>,
      <a href="/private-events/">Private Events</a>,
      <a href="/supper-club/">Supper Club</a> and
      <a href="/cafe-bar/">Cafe + Bar</a> have their own pricing.
    </p>

    <div class="pricing-cta">
      <a href="/check-your-date/?utm_source=website&utm_medium=cta&utm_campaign=homepage&utm_content=pricing" class="btn btn-primary">Lock In Your Date</a>
    </div>
  </Section>

  <!-- ==================== DETAIL PHOTO STRIP ==================== -->
  <PhotoStrip images={[
    { src: "/images/hackney-wedding-detail-strip-table-seated-our-favourite-people.webp", alt: "Wedding guests seated at long banquet tables at The Hackney, hanging Edison bulbs and greenery overhead, an 'Our Favourite People' seating chart in the foreground. Photo by AM Wedding Photo." },
    { src: "/images/hackney-wedding-detail-strip-table-set-greenery.webp", alt: "The Hackney's main hall set for a wedding breakfast - long banquet tables with bentwood chairs, hanging Edison bulbs and pampas grass, white brick walls. Photo by AM Wedding Photo." },
    { src: "/images/hackney-wedding-detail-strip-guests-celebrate-people.webp", alt: "A bride leans into the centre of a long banquet table at The Hackney to clink glasses with her guests for a champagne toast under hanging Edison bulbs. Photo by AM Wedding Photo." }
  ]} />

  <!-- ==================== THE TEAM ==================== -->
  <!-- Hidden pre-launch until team photos exist (Hugo, Eva, Kitchen).
       Flip showTeam to true once photos ship. See TASKS.md "Get team photos". -->
  {showTeam && (
  <Section bg="light" padding="standard" border="top" class="team-section">
    <SectionHeader
      eyebrow="The Team"
      heading="The People Who Make It Happen."
      subtext="Every wedding at The Hackney is run by the same team from your first tour to the moment you leave. No agency hand-offs. No strangers on your day."
    />
    <div class="team-grid">
      <div class="team-card fade-in">
        <div class="team-card-photo"></div>
        <h3>Hugo Correia</h3>
        <p class="team-card-role">General Manager</p>
        <p>Your first point of contact. Hugo runs venue tours, answers every question, and makes sure everything is locked in before your day.</p>
      </div>
      <div class="team-card fade-in">
        <div class="team-card-photo"></div>
        <h3>Eva</h3>
        <p class="team-card-role">Events Manager</p>
        <p>Eva coordinates every detail of your wedding day. She has delivered over 150 events at The Hackney and knows the venue better than anyone.</p>
      </div>
      <div class="team-card fade-in">
        <div class="team-card-photo"></div>
        <h3>The Kitchen</h3>
        <p class="team-card-role">In-House Catering Team</p>
        <p>Everything cooked on site. Seasonal menus, dietary flexibility, nothing outsourced.</p>
      </div>
    </div>
  </Section>
  )}

  <!-- ==================== FINAL CTA ==================== -->
  <FinalCTA
    heading="Ready to see the space?"
    body="Tours run 7 days a week. No obligation. 45 minutes with Hugo and you will know if The Hackney is the right venue for you."
    primaryCTA={{ label: "See The Calendar", href: "/check-your-date/?utm_content=final" }}
    secondaryCTA={{ label: "Download The Brochure", href: "/weddings/#brochure" }}
    utmCampaign="homepage"
  />

</Base>

<style>
  /* ==================== VENUE INTRO - pull quote ==================== */
  .pull-quote {
    font-family: var(--font-heading);
    font-size: clamp(28px, 3.5vw, 40px);
    letter-spacing: 0.01em;
    line-height: 1.2;
    color: var(--brewery-dark);
    margin-bottom: 2rem;
  }

  .differentiators {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .diff-item-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--forest-olive);
    margin-bottom: 0.25rem;
  }

  .diff-item-text {
    font-size: 1rem;
    color: var(--brewery-dark);
    opacity: 0.85;
  }

  /* ==================== OCCASIONS GRID ==================== */
  /* Section padding now handled by the Section component (padding="standard").
     Was previously padding="none" with inline overrides that caused the
     PhotoBreak to crowd the grid. */
  .occasions-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
  }

  .occasion-card {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    cursor: pointer;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    border: 1px solid rgba(44, 24, 16, 0.12);
    transition: border-color 0.3s ease;
    background-size: cover;
    background-position: center;
    background-color: var(--brewery-dark);
    text-decoration: none;
  }

  .occasion-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: rgba(0, 0, 0, 0.4);
    transition: opacity 0.3s ease;
  }

  .occasion-card:hover::before {
    background: rgba(0, 0, 0, 0.25);
  }

  .occasion-card:hover {
    border-color: var(--dusty-coral);
    color: inherit;
  }

  .occasion-card-content {
    position: relative;
    z-index: 1;
  }

  .occasion-card h3 {
    color: #fff;
    font-size: 1.125rem;
    letter-spacing: 0.1em;
  }

  .occasion-card-desc {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.875rem;
    line-height: 1.5;
    margin-top: 0.5rem;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: all 0.3s ease;
  }

  .occasion-card:hover .occasion-card-desc {
    max-height: 80px;
    opacity: 1;
  }

  /* ==================== TEAM ==================== */
  .team-section {
    border-top: 1px solid rgba(44, 24, 16, 0.06);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.25rem;
  }

  .team-card-photo {
    aspect-ratio: 4/5;
    background: var(--forest-olive);
    margin-bottom: 1.25rem;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(44, 24, 16, 0.08);
  }

  .team-card-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.06'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .team-card h3 {
    font-size: 1.125rem;
    margin-bottom: 0.125rem;
  }

  .team-card-role {
    font-size: 0.8125rem;
    color: var(--dusty-coral);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .team-card p {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.8;
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 1200px) {
    .occasions-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .occasions-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .occasion-card:last-child {
      grid-column: span 2;
    }

    .team-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* ==================== PRICING HOOK ==================== */
  /* Adopted from /weddings/ canonical pattern. */
  .pricing-hook {
    text-align: center;
    max-width: 720px;
    margin: -8px auto 32px;
    padding: 48px 32px;
    background: rgba(73, 89, 14, 0.04);
    border: 1px solid rgba(73, 89, 14, 0.12);
    border-radius: 2px;
  }

  .pricing-hook-label {
    font-family: var(--font-body);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--dusty-coral);
    font-weight: 500;
    margin-bottom: 12px;
  }

  .pricing-hook-amount {
    font-family: var(--font-heading);
    font-size: clamp(72px, 12vw, 128px);
    font-weight: 600;
    line-height: 1;
    color: var(--forest-olive);
    margin-bottom: 16px;
  }

  .pricing-hook-breakdown {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.6vw, 18px);
    color: var(--brewery-dark);
    margin-bottom: 8px;
  }

  .pricing-hook-context {
    font-family: var(--font-body);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brewery-dark);
    opacity: 0.55;
  }

  /* Cross-link line for non-wedding routing */
  .pricing-cross-link {
    max-width: 720px;
    margin: 0 auto 32px;
    text-align: center;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--brewery-dark);
    opacity: 0.85;
  }

  .pricing-cross-link a {
    color: var(--dusty-coral);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .pricing-cross-link a:hover {
    color: var(--forest-olive);
  }

  /* Pricing CTA centred below */
  .pricing-cta {
    text-align: center;
  }
</style>
