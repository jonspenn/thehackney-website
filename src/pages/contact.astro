---
import Base from '../layouts/Base.astro';
---

<Base title="Contact The Hackney | Wedding & Events Venue, East London E2" description="Get in touch with The Hackney - a restored 1860s brewery venue on Hackney Road, East London. Two minutes from Cambridge Heath station. Call +44 20 7961 1604.">

<style is:global>
  /* Hero Section */
  .hero {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .hero h1 {
    margin-bottom: 1.5rem;
  }

  .hero p {
    font-size: 18px;
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1.5rem;
    }

    .hero h1 {
      margin-bottom: 1rem;
    }

    .hero p {
      font-size: 16px;
    }
  }

  /* Main Content */
  .main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 1200px) {
    .content-grid {
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* HubSpot Form */
  .form-container {
    background-color: var(--warm-canvas);
  }

  #hubspot-contact-form {
    margin-bottom: 2rem;
  }

  /* HubSpot form styling overrides */
  .hbspt-form {
    font-family: var(--font-body) !important;
  }

  .hbspt-form input,
  .hbspt-form textarea,
  .hbspt-form select {
    font-family: var(--font-body) !important;
    font-size: 16px !important;
    border-radius: 4px !important;
    border: 1px solid #e0dbd0 !important;
    padding: 12px !important;
  }

  .hbspt-form input:focus,
  .hbspt-form textarea:focus,
  .hbspt-form select:focus {
    outline: none !important;
    border-color: var(--fired-brick) !important;
    box-shadow: 0 0 0 3px rgba(140, 71, 46, 0.1) !important;
  }

  .hbspt-form .hs-button {
    background-color: var(--fired-brick) !important;
    color: var(--warm-canvas) !important;
    font-family: var(--font-body) !important;
    font-size: 13px !important;
    font-weight: 500 !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    padding: 12px 24px !important;
    border: none !important;
    border-radius: 4px !important;
    cursor: pointer !important;
    transition: background-color 0.3s ease !important;
  }

  .hbspt-form .hs-button:hover {
    background-color: var(--brewery-dark) !important;
  }

  /* Contact Details */
  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .contact-section h3 {
    margin-bottom: 1rem;
    font-size: clamp(18px, 2vw, 24px);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-info a {
    color: var(--fired-brick);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-info a:hover {
    color: var(--brewery-dark);
  }

  .contact-info p {
    line-height: 1.65;
  }

  .map-link {
    display: block;
    width: 100%;
    margin-top: 2rem;
    text-decoration: none;
  }

  .map-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--brewery-dark);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .contact-details {
      gap: 2rem;
    }

    .map-container {
      height: 300px;
    }
  }

  /* Animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero, .content-grid {
    animation: fadeIn 0.6s ease-out forwards;
  }

  .contact-section {
    animation: fadeIn 0.6s ease-out forwards;
    animation-delay: 0.1s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero, .content-grid, .contact-section {
      animation: none;
    }
  }
</style>

<!-- Hero Section -->
<section class="hero">
  <div class="hero-content">
    <span class="eyebrow">Contact Us</span>
    <h1>Get in touch</h1>
    <p>Whether you have a question, want to discuss your event, or just want to say hello - we would love to hear from you.</p>
  </div>
</section>

<!-- Main Content -->
<div class="content-grid">
      <!-- HubSpot Form Column -->
      <div class="form-container">
        <div id="hubspot-contact-form"></div>
      </div>

      <!-- Contact Details Column -->
      <aside class="contact-details">
        <!-- Address Section -->
        <div class="contact-section">
          <h3>Visit us</h3>
          <div class="contact-info">
            <p>503 Hackney Road<br>London E2 9ED<br>United Kingdom</p>
          </div>
        </div>

        <!-- Contact Section -->
        <div class="contact-section">
          <h3>Get in touch</h3>
          <div class="contact-info">
            <p><strong>Phone:</strong><br><a href="tel:+442079611604">+44 20 7961 1604</a></p>
            <p><strong>Email:</strong><br><a href="mailto:hello@thehackney.co">hello@thehackney.co</a></p>
          </div>
        </div>

        <!-- Hours Section -->
        <div class="contact-section">
          <h3>Opening hours</h3>
          <div class="contact-info">
            <p><strong>Cafe &amp; Bar</strong><br>Tuesday to Friday 8am - 5pm, Weekends 9am - 5pm (closed Mondays)</p>
            <p><strong>Events</strong><br>7 days by appointment</p>
          </div>
        </div>

        <!-- Getting Here Section -->
        <div class="contact-section">
          <h3>Getting here</h3>
          <div class="contact-info">
            <p>Two minutes walk from Cambridge Heath station (London Overground). Bethnal Green tube (Central line) is a 10-minute walk. Bus routes 106, 254, D6 stop outside.</p>
          </div>
        </div>

        <!-- Map -->
        <a href="https://maps.app.goo.gl/RwT31Y6tmXPzyqGQ9" target="_blank" rel="noopener" class="map-link">
          <div class="map-placeholder">View on Google Maps</div>
        </a>
      </aside>
    </div>

<script>
  // Initialize HubSpot form when page loads
  if (typeof hbspt !== 'undefined') {
    hbspt.forms.create({
      region: 'eu1',
      portalId: '25870094',
      formId: '6966c5ba-2f16-4229-ab5b-7fe24774fad6',
      target: '#hubspot-contact-form'
    });
  }
</script>

</Base>
