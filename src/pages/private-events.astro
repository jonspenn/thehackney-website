---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
---

<Base title="Weddings & Private Events" description="Host your wedding, party or private celebration at The Hackney - an industrial-chic venue in East London.">
  <Hero
    eyebrow="Weddings & private events"
    heading="Celebrate in style"
    subheading="Weddings, engagements, birthdays, milestones - The Hackney is your canvas for unforgettable private events."
    ctaLabel="Check your date"
    ctaHref="/check-your-date/"
  />

  <section class="section">
    <div class="container">
      <h2>Private events at The Hackney</h2>
      <p>
        Content coming soon - event types, spaces, capacity, catering options, packages and pricing guidance.
      </p>
    </div>
  </section>
</Base>
