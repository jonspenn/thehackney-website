---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofBar from '../components/ProofBar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import PhotoBreak from '../components/PhotoBreak.astro';
import PhotoStrip from '../components/PhotoStrip.astro';
import IncludedGrid from '../components/IncludedGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';

// Private Events FAQ items
const faqItems = [
  {
    question: "How many guests can you accommodate?",
    answer: "Up to 60 seated for a sit-down meal and up to 100 for a standing celebration. The space reconfigures for any format - long tables, cocktail rounds, or open dance floor. If you need more than 100, we are probably not the right fit but we are happy to recommend other venues."
  },
  {
    question: "What is included in the hire?",
    answer: "Exclusive use of the entire building, your dedicated events manager, full staffing, all furniture, and our built-in sound and lighting system. For baby showers, food and drink are included in the package price. For birthdays and celebrations, everything you spend on food and drink counts towards your minimum spend."
  },
  {
    question: "Can we bring our own cake?",
    answer: "Yes. Most clients bring a celebration cake from their favourite baker. We will store it, set it up, and handle the cutting and serving. There is no cake fee."
  },
  {
    question: "Can we decorate the venue?",
    answer: "Absolutely. Balloons, banners, flowers, photo walls - you are welcome to personalise the space. We ask that nothing is fixed permanently to walls or floors (no nails, screws, or strong adhesive). Our team can help with setup and will handle the takedown after your event."
  },
  {
    question: "Can we bring a DJ or live music?",
    answer: "Yes. Our professional sound system is built in and connects to Spotify, so you can run your own playlist or bring a DJ. Live musicians work too, but we have noise restrictions because of our neighbours - acoustic groups up to a quartet, finishing by 10pm. If music is central to your event, mention it when you get in touch."
  },
  {
    question: "How does the minimum spend work for birthdays?",
    answer: "The Hackney is a sought-after wedding venue. When a date is available within three months and unlikely to sell for a wedding, we open it up for private celebrations at a fraction of the cost. There is no venue hire fee - you simply need to meet the minimum spend on food and drink. Everything your guests order at the bar counts towards it. The minimum is lower on weekdays than Saturdays, so if your date is flexible you can get more for your money."
  },
  {
    question: "How do the baby shower packages work?",
    answer: "Our baby shower packages are all-inclusive and priced per person. The package covers exclusive venue hire, food, drinks, and service for four hours. You choose from three tiers depending on whether you want afternoon tea, bottomless prosecco, or bottomless cocktails. The price includes everything - no surprises."
  },
  {
    question: "How far in advance should we book?",
    answer: "Most private events book two to eight weeks out. Saturday evenings go first. Weekday dates and daytime slots are often available at shorter notice. The best way to check is to book a quick discovery call - Hugo can tell you what is available and talk you through the options."
  },
  {
    question: "Is there parking?",
    answer: "There is no on-site parking. Hackney Road has metered parking during the day and free parking from 7pm to 8am. Several NCP car parks are within 10 minutes. The venue is a one-minute walk from Cambridge Heath Overground and five to seven minutes from Bethnal Green Underground (Central line)."
  },
  {
    question: "Is the venue accessible?",
    answer: "Honest answer: not fully. The Hackney is a Victorian brewery with a protected facade, which means there is a 15cm step at the entrance and the pavement outside is too narrow for a permanent ramp. The doorway is wide enough for a wheelchair with a little help. We do not currently have accessible toilets on site. If accessibility matters for any of your guests, please tell us up front and we will be straight with you about whether we can make it work."
  },
  {
    question: "Can we visit the venue before booking?",
    answer: "Yes. Hugo, our General Manager, runs venue tours. He will walk you through every space and talk through how your celebration could work. Book a discovery call and Hugo will arrange a time that works for you."
  },
  {
    question: "Where is the venue?",
    answer: "503 Hackney Road, East London, E2 9ED. Cambridge Heath Overground is a one-minute walk and Bethnal Green Underground on the Central line is five to seven minutes away. For larger events, we can share a travel info sheet to send to your guests."
  }
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "The Hackney",
  "description": "Private events venue in East London - birthdays, baby showers, celebrations, engagement parties, anniversaries",
  "@id": "https://thehackney-website.pages.dev",
  "url": "https://thehackney-website.pages.dev/private-events/",
  "telephone": "+442079611604",
  "priceRange": "From £55 per person",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "503 Hackney Road",
    "addressLocality": "London",
    "postalCode": "E2 9ED",
    "addressCountry": "GB"
  }
};

const combinedSchema = JSON.stringify([localBusinessSchema]);
---

<Base title="Private Events Venue East London | Birthdays, Baby Showers | The Hackney, E2" description="Host your private celebration at The Hackney - a restored 1856 brewery on Hackney Road. Birthdays, baby showers, anniversaries, engagement parties. 60 seated, 100 standing. Exclusively yours. All-inclusive packages from £55 per person." schema={combinedSchema} preloadImage="/images/hackney-private-events-hero-terrace-laughing.webp">

  <!-- ==================== SECTION 1: HERO ==================== -->
  <HeroSection
    bg="image"
    image="/images/hackney-private-events-hero-terrace-laughing.webp"
    alt="Friends laughing on the terrace at The Hackney"
    heading='Your Celebration.<br>Our Brewery.'
    cta={{ label: "Check Availability", href: "/check-your-date/?type=private&utm_source=website&utm_medium=cta&utm_campaign=private-events&utm_content=hero" }}
    note="Birthdays, baby showers, anniversaries, engagement parties and more - exclusively yours"
    height="mid"
    textGradient={true}
    position="center 35%"
  />

  <!-- ==================== SECTION 2: SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "Exclusive Hire", label: "The whole venue, just for you" },
    { number: "In-House Catering", label: "Food, drinks and service included" },
    { number: "60 Seated", label: "Up to 100 standing" },
    { number: "Hackney Road E2", label: "1 min from Cambridge Heath" }
  ]} />

  <!-- ==================== SECTION 3: DIRECT CONTACT BAR ==================== -->
  <!-- Primary conversion: book a discovery call with Hugo. Filters for serious
       enquiries and protects Hugo's time. Same pattern as weddings/corporate. -->
  <Section bg="dark" padding="compact">
    <div class="contact-bar">
      <div class="contact-bar-text">
        <h2>Got a date in mind?</h2>
        <p>Book a quick discovery call with Hugo. He will check availability, talk you through the options, and give you a clear idea of pricing.</p>
      </div>
      <div class="contact-bar-actions">
        <a href="/bookacall/?type=private&utm_source=website&utm_medium=cta&utm_campaign=private-events&utm_content=contact-bar" class="btn btn-primary" data-cta-section="contact-bar-discovery-call">Book A Discovery Call</a>
      </div>
    </div>
  </Section>

  <!-- ==================== SECTION 4: EVENTS WE HOST ==================== -->
  <Section bg="light" padding="compact" border="bottom">
    <SectionHeader
      eyebrow="Celebrations"
      heading="Events We Host"
    />
    <div class="event-grid">
      <div class="event-card fade-in">
        <h3>Birthday Parties</h3>
        <p>From intimate 30th dinners to full-scale 50th celebrations. The whole venue is yours for the evening - dinner, dancing, speeches, and a proper party.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Baby Showers</h3>
        <p>A bright, beautiful space for celebrating new life. All-inclusive daytime packages with food, drinks, and four hours of exclusive hire. Bring your own decorations and cake.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Gender Reveals</h3>
        <p>Make the big moment unforgettable. Our Winter Garden skylight floods the space with natural light - perfect for photos. Bottomless packages available.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Anniversaries</h3>
        <p>Mark the milestone in a setting that matches the occasion. Seated dinners for up to 60 or standing receptions for 100 - with in-house catering and a full bar.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Engagement Parties</h3>
        <p>Celebrate the next chapter surrounded by everyone who matters. Cocktails, canapes, dancing - or a seated dinner if that is more your style.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== SECTION 5: VALUE PROP / WHAT'S INCLUDED ==================== -->
  <Section bg="light" border="bottom" id="included">
    <SectionHeader
      eyebrow="Why The Hackney"
      heading="One Venue. Everything Included."
    />
    <div class="different-body">
      <p>We are more than a venue. We are an events team, an in-house kitchen, and a fully stocked bar - all under one roof. You tell us what you are celebrating and we handle the rest. No sourcing caterers, no coordinating suppliers, no hidden invoices.</p>
      <p>The whole building is exclusively yours. No other events running at the same time, no shared spaces, no background noise. Just your celebration, your guests, your way.</p>
    </div>

    <IncludedGrid
      categories={[
        {
          title: "Your Space",
          items: [
            "Exclusive hire of the entire building",
            "Flexible layouts - long tables, rounds, standing, or dance floor",
            "Winter Garden, Lounge, Bar Area, and Covered Terrace",
            "Professional sound system with Spotify or bring your own DJ"
          ]
        },
        {
          title: "Food and Drink",
          items: [
            "In-house kitchen - menus designed around your celebration",
            "From grazing tables and canapes to three-course dinners",
            "Full cocktail bar with signature drinks available",
            "All dietary needs handled as standard"
          ]
        },
        {
          title: "On The Day",
          items: [
            "Dedicated events manager from planning to breakdown",
            "Full staffing - bar team, kitchen, front of house",
            "Set-up and clear-down handled by our team",
            "No service charge, no hidden extras, one clear price"
          ]
        }
      ]}
      promise='<strong>The price we quote is the price you pay.</strong> Baby shower packages are all-inclusive per person. Birthday and celebration hires are a simple minimum spend with no venue hire fee. No surprises on the invoice.'
    />
  </Section>

  <!-- ==================== SECTION 6: IN-HOUSE EXTRAS ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="Beyond The Venue"
      heading="More Than Just A Space"
    />
    <div class="details-intro">
      <p>Some clients want everything handled. Others want to bring their own touches. Either way, our team is here to make it easy.</p>
    </div>

    <div class="details-grid">
      <div class="details-card">
        <h3>Styling and Decor</h3>
        <p>Balloon installations, table centrepieces, photo walls, and full room styling. Our team helps with setup on the day and handles everything afterwards. Bring your own decorator or let us coordinate.</p>
      </div>
      <div class="details-card">
        <h3>Catering Design</h3>
        <p>Feasting tables, sharing platters, street food, afternoon tea, or a seated dinner. Our kitchen builds your menu around what you love. Dietary needs from vegan to halal, fully covered.</p>
      </div>
      <div class="details-card">
        <h3>Music and Entertainment</h3>
        <p>Our sound system is built in and connects to any playlist. DJs are welcome. Acoustic live music up to a quartet works beautifully in the space. We handle the sound - you pick the soundtrack.</p>
      </div>
    </div>

    <div class="details-cta">
      <p>Have questions about what we can do for your celebration? Book a call with Hugo.</p>
      <a href="/bookacall/?type=private&utm_source=website&utm_medium=cta&utm_campaign=private-events&utm_content=details-extras" class="btn btn-primary" data-cta-section="details-extras-discovery-call">Book A Discovery Call</a>
    </div>
  </Section>

  <!-- ==================== SECTION 7: THE SPACE ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="The Venue"
      heading="An 1856 Brewery. Entirely Yours."
      subtext="The Hackney is a converted Victorian brewery on Hackney Road in East London - exposed brick, original timber beams, and industrial character that sets the scene without needing to dress it up."
    />
    <p class="space-intro">The venue is yours exclusively. No shared spaces, no other events running alongside yours. Four interconnected areas adapt to your celebration: the Winter Garden for dining, the Lounge for cocktails, the Bar Area for drinks and dancing, and the Covered Terrace for fresh air without leaving the venue.</p>
    <div class="space-capacity">
      <div class="capacity-stat">
        <div class="capacity-number">60</div>
        <div class="capacity-label">Guests seated</div>
      </div>
      <div class="capacity-stat">
        <div class="capacity-number">100</div>
        <div class="capacity-label">Standing reception</div>
        <div class="capacity-note">A little more for the right event. Just ask.</div>
      </div>
    </div>

    <div class="space-gallery">
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-private-events-winter-garden-dinner-setup.webp" data-bg-pos="center center" role="img" aria-label="The Winter Garden at The Hackney set for dinner with long tables, Edison bulbs, and greenery"></div>
        <div class="space-image-caption">The Winter Garden</div>
      </div>
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-private-events-canapes-rustic-board.webp" data-bg-pos="center center" role="img" aria-label="Canapés served on a rustic wooden board at The Hackney"></div>
        <div class="space-image-caption">In-house catering</div>
      </div>
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-private-events-terrace-friends-sunshine.webp" data-bg-pos="center center" role="img" aria-label="Friends enjoying drinks on the covered terrace at The Hackney"></div>
        <div class="space-image-caption">The Covered Terrace</div>
      </div>
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-private-events-dancefloor-party.webp" data-bg-pos="center center" role="img" aria-label="Guests dancing with pink lighting at The Hackney"></div>
        <div class="space-image-caption">Day to night</div>
      </div>
    </div>

    <div class="space-features">
      <div class="space-feature">
        <h3>Your Music, Your Way</h3>
        <p>Our professional sound and lighting system is built into the venue - no need to hire external AV. Run your own Spotify playlist, bring a DJ, or book acoustic musicians. Music runs until 11pm, with guests departing by 11:30pm.</p>
      </div>
      <div class="space-feature">
        <h3>Everything Handled</h3>
        <p>Your dedicated events manager handles every detail from menu planning to room layout. In-house catering, a full bar team, and all the furniture and tableware you need - nothing to source, nothing to coordinate.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== PHOTO BREAK: QUOTE ==================== -->
  <PhotoBreak
    image="/images/hackney-private-events-cocktails-party-atmosphere.webp"
    alt="Guests enjoying cocktails with atmospheric lighting at The Hackney"
    position="55% 60%"
    quote="The Hackney delivered beyond our expectations. The grazing table was incredible, the bar team kept the drinks flowing, and the space looked stunning. Everyone kept saying how personal and relaxed it felt."
    attribution="Daniel, 30th Birthday, May 2025"
    quotePosition="bottom"
  />

  <!-- ==================== SECTION 8: PRICING (THE FORK) ==================== -->
  <!-- Two distinct pricing models side by side: baby showers (per-person packages)
       and birthdays/celebrations (minimum spend). Source: 2025 brochures.
       James to review and update if prices have changed for 2026. -->
  <Section bg="light" border="top" id="pricing">
    <SectionHeader
      eyebrow="Investment"
      heading="Pricing"
    />

    <div class="pricing-fork">
      <!-- BABY SHOWERS -->
      <div class="pricing-block">
        <div class="pricing-block-header">
          <h3>Baby Showers</h3>
          <p class="pricing-block-subtitle">All-inclusive daytime packages - 4 hours exclusive hire</p>
        </div>

        <div class="pricing-package">
          <div class="pricing-package-name">Classic</div>
          <div class="pricing-package-price">From &pound;55 <span>per person</span></div>
          <p class="pricing-package-basis">Based on 20 guests</p>
          <ul class="pricing-package-includes">
            <li>4 hours exclusive venue hire</li>
            <li>Afternoon tea - sandwiches, cakes and pastries</li>
            <li>Unlimited tea, coffee and juices</li>
            <li>Room hire with your own music</li>
          </ul>
        </div>

        <div class="pricing-package">
          <div class="pricing-package-name">Bottomless</div>
          <div class="pricing-package-price">From &pound;75 <span>per person</span></div>
          <p class="pricing-package-basis">Based on 20 guests</p>
          <ul class="pricing-package-includes">
            <li>4 hours exclusive venue hire</li>
            <li>Beautifully presented grazing table</li>
            <li>90 minutes bottomless prosecco</li>
            <li>Unlimited tea, coffee and juice</li>
          </ul>
        </div>

        <div class="pricing-package">
          <div class="pricing-package-name">Bottomless Cocktails</div>
          <div class="pricing-package-price">From &pound;95 <span>per person</span></div>
          <p class="pricing-package-basis">Minimum 25 guests</p>
          <ul class="pricing-package-includes">
            <li>4 hours exclusive venue hire</li>
            <li>Grazing table and dessert table</li>
            <li>90 minutes bottomless mocktails and cocktails</li>
            <li>Premium tableware, printed menus, name cards</li>
            <li>Dedicated event host</li>
          </ul>
        </div>

        <div class="pricing-block-cta">
          <a href="/bookacall/?type=private&utm_source=website&utm_medium=cta&utm_campaign=private-events&utm_content=pricing-babyshower" class="btn btn-primary" data-cta-section="pricing-babyshower-discovery-call">Book A Discovery Call</a>
        </div>
      </div>

      <!-- BIRTHDAYS & CELEBRATIONS -->
      <div class="pricing-block">
        <div class="pricing-block-header">
          <h3>Birthdays and Celebrations</h3>
          <p class="pricing-block-subtitle">A wedding venue, exclusively yours - at a fraction of the price</p>
        </div>

        <div class="pricing-package pricing-package-highlight">
          <div class="pricing-package-name">Saturday</div>
          <div class="pricing-package-price">&pound;3,000 <span>minimum spend</span></div>
          <p class="pricing-package-basis">No venue hire fee</p>
          <ul class="pricing-package-includes">
            <li>Exclusive hire of the entire venue</li>
            <li>All food and bar spend counts towards minimum</li>
            <li>Up to 100 guests standing</li>
            <li>Music until 11pm, guests depart by 11:30pm</li>
          </ul>
        </div>

        <div class="pricing-package">
          <div class="pricing-package-name">Sunday to Friday</div>
          <div class="pricing-package-price">&pound;2,000 <span>minimum spend</span></div>
          <p class="pricing-package-basis">No venue hire fee</p>
          <ul class="pricing-package-includes">
            <li>Exclusive hire of the entire venue</li>
            <li>All food and bar spend counts towards minimum</li>
            <li>Up to 100 guests standing</li>
            <li>Earlier start times available</li>
          </ul>
        </div>

        <div class="pricing-minspend-note">
          <p><strong>Why these prices?</strong> The Hackney is a sought-after wedding venue. When a date is available within three months and unlikely to sell for a wedding, we open it up for private celebrations. You get the same exclusive venue, the same team, and the same experience. There is no venue hire fee - everything you and your guests spend on food and drink counts towards the minimum.</p>
        </div>

        <div class="pricing-block-cta">
          <a href="/bookacall/?type=private&utm_source=website&utm_medium=cta&utm_campaign=private-events&utm_content=pricing-birthday" class="btn btn-primary" data-cta-section="pricing-birthday-discovery-call">Book A Discovery Call</a>
        </div>
      </div>
    </div>

    <div class="pricing-note">
      <p>Prices may vary by date and guest count. Book a discovery call for a tailored quote that matches your celebration and your budget.</p>
    </div>
  </Section>

  <!-- ==================== PHOTO STRIP ==================== -->
  <PhotoStrip images={[
    { src: "/images/hackney-private-events-strip-winter-garden-ceiling.webp", alt: "Winter Garden ceiling with pampas grass and Edison bulbs at The Hackney" },
    { src: "/images/hackney-private-events-strip-guests-cocktails-bw.webp", alt: "Guests with cocktails at a celebration at The Hackney" },
    { src: "/images/hackney-private-events-strip-table-setting-candles.webp", alt: "Table setting with candles and flowers at The Hackney" }
  ]} />

  <!-- ==================== SECTION 9: HOW IT WORKS ==================== -->
  <Section bg="light" border="top">
    <SectionHeader
      eyebrow="How It Works"
      heading="From First Message To Celebration Day"
    />

    <ProcessSteps steps={[
      {
        title: "Book A Discovery Call",
        description: "Check your date on our live calendar and book a quick call with Hugo, our General Manager. Tell us what you are celebrating, roughly how many guests, and when you are thinking. No hard sell, just honest answers."
      },
      {
        title: "Visit The Venue",
        description: "Come and see the space in person. Hugo will walk you through every room and help you picture how your celebration will look and flow. Optional but recommended."
      },
      {
        title: "Your Quote",
        description: "One clear quote covering venue hire, catering, drinks, and every detail of your event. No hidden costs, nothing buried in the small print."
      },
      {
        title: "Confirm and Celebrate",
        description: "A deposit secures your date. From that moment, your events manager handles every detail - from menu planning to room layout to the last guest leaving."
      }
    ]} />

    <div class="section-cta-center">
      <a href="/bookacall/?type=private&utm_source=website&utm_medium=cta&utm_campaign=private-events&utm_content=how-it-works" class="btn btn-primary" data-cta-section="how-it-works-discovery-call">Book A Discovery Call</a>
    </div>
  </Section>

  <!-- ==================== SECTION 10: FAQ ==================== -->
  <Section bg="light" border="top" padding="compact">
    <SectionHeader
      eyebrow="Before You Get In Touch"
      heading="What Our Clients Ask"
    />
    <FAQ items={faqItems} />
  </Section>

  <!-- ==================== PHOTO BREAK: BEFORE FINAL CTA ==================== -->
  <PhotoBreak
    image="/images/hackney-private-events-hero-champagne-service.webp"
    alt="Champagne glasses being served on a tray at The Hackney"
    position="center 60%"
  />

  <!-- ==================== SECTION 12: FINAL CTA ==================== -->
  <FinalCTA
    eyebrow="Your Next Step"
    heading="Ready To Celebrate?"
    body="Check availability on our live calendar and book a discovery call with Hugo. One conversation to get started."
    primaryCTA={{ label: "Check Your Date", href: "/check-your-date/?type=private&utm_source=website&utm_medium=cta&utm_campaign=private-events&utm_content=final-cta" }}
    note="Weekday and daytime dates often available at short notice."
    utmCampaign="private-events"
  />

  <!-- ==================== STICKY MOBILE CONTACT BAR ==================== -->
  <!-- Always visible on mobile. Routes to discovery call booking. -->
  <div class="sticky-contact-bar">
    <a href="/bookacall/?type=private&utm_source=website&utm_medium=cta&utm_campaign=private-events&utm_content=sticky-bar" class="sticky-contact-btn sticky-contact-cta" data-cta-section="sticky-discovery-call">Book A Discovery Call</a>
  </div>

  <style>
    /* ==================== CONTACT BAR ==================== */
    .contact-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      max-width: 900px;
      margin: 0 auto;
    }

    .contact-bar-text h2 {
      font-family: var(--font-heading);
      font-size: clamp(24px, 3vw, 32px);
      font-weight: 500;
      color: var(--warm-canvas);
      margin-bottom: 8px;
    }

    .contact-bar-text p {
      font-size: 16px;
      color: rgba(245, 240, 232, 0.75);
      margin: 0;
    }

    .contact-bar-actions {
      display: flex;
      gap: 12px;
      flex-shrink: 0;
    }

    /* Contact bar actions use .btn-primary from global styles */

    /* ==================== EVENT TYPES ==================== */
    .event-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .event-card {
      padding: 28px 24px;
      border: 1px solid rgba(44, 24, 16, 0.1);
      border-top: 3px solid var(--forest-olive);
      border-radius: 2px;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .event-card:hover {
      border-color: var(--forest-olive);
      border-top-color: var(--forest-olive);
      transform: translateY(-4px);
    }

    .event-card h3 {
      font-family: var(--font-heading);
      font-size: 20px;
      font-weight: 500;
      margin-bottom: 12px;
      color: var(--mid-olive);
    }

    .event-card p { font-size: 16px; line-height: 1.6; opacity: 0.85; }

    /* ==================== VALUE PROP ==================== */
    .different-body {
      max-width: 760px;
    }

    .different-body p {
      font-size: 18px;
      margin-bottom: 20px;
      line-height: 1.7;
    }

    .different-body p:last-of-type {
