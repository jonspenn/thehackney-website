---
import Base from '../layouts/Base.astro';
import ProofBar from '../components/ProofBar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PricingTable from '../components/PricingTable.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<Base title="Private Events Venue East London | The Hackney, E2" description="Host your private celebration at The Hackney. Birthday parties, anniversaries, baby showers, engagement parties. 60 seated, 100 standing. Exclusively yours.">

  <!-- ==================== HERO ==================== -->
  <section class="pe-hero">
    <div class="container">
      <div class="pe-hero-content">
        <p class="eyebrow">Private Events at The Hackney</p>
        <h1>Your celebration. <span style="white-space: nowrap;">Our brewery.</span></h1>
        <p class="pe-hero-sub">Birthdays, anniversaries, baby showers, engagement parties - celebrate the moments that matter inside a restored 1856 brewery. The whole venue is yours.</p>
      </div>
    </div>
  </section>

  <!-- ==================== SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "200+", label: "Events hosted" },
    { number: "4.6", label: "Google rating" },
    { number: "Exclusive", label: "Venue hire" },
    { number: "In-house", label: "Kitchen & bar" }
  ]} />

  <!-- ==================== EVENT TYPES ==================== -->
  <Section bg="light" padding="compact" border="bottom">
    <SectionHeader
      eyebrow="Celebrations"
      heading="Events We Host"
    />
    <div class="event-grid">
      <div class="event-card">
        <h3>Private Celebrations</h3>
        <p>Mark the milestone - whether it is a milestone birthday, anniversary, baby shower or engagement party. A moment made memorable.</p>
      </div>
      <div class="event-card">
        <h3>Christmas Parties</h3>
        <p>Festive gatherings with in-house catering, drinks packages, and space for everyone to celebrate together.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== THE SPACE ==================== -->
  <Section bg="light" padding="compact" border="bottom">
    <div class="space-grid">
      <div class="space-text">
        <SectionHeader
          eyebrow="The Venue"
          heading="The Space"
        />
        <p>A restored 1856 brewery with character you cannot find elsewhere. Soaring brick walls, skylights flooding the space with natural light, high ceilings for an open feel, and flexible layout that adapts to your celebration.</p>
        <p>Capacity is 60 seated, 100 standing. The whole venue is exclusively yours - that means no background events, no surprises, just your moment.</p>
        <div class="space-promise">
          <p>Our in-house kitchen and bar team mean you get exactly the food, drinks and service you want. No outside caterers, no corkage, no hidden fees. Just one team, one invoice, and a celebration run exactly your way.</p>
        </div>
      </div>
      <div class="space-image">
        <div class="space-placeholder" role="img" aria-label="Private event setup at The Hackney">Photo coming soon</div>
      </div>
    </div>
  </Section>

  <!-- ==================== WHAT'S INCLUDED ==================== -->
  <Section bg="light" padding="compact" border="bottom">
    <SectionHeader
      eyebrow="Everything Included"
      heading="What Is Included"
    />
    <div class="included-grid">
      <div class="included-item">
        <h3>Your own space</h3>
        <p>The whole venue, exclusively. No other events, no background noise, the entire brewery is yours to celebrate in.</p>
      </div>
      <div class="included-item">
        <h3>Food and drink</h3>
        <p>Our chef creates menus to match your celebration. Wine, beer, spirits, soft drinks, or signature cocktails - everything in-house.</p>
      </div>
      <div class="included-item">
        <h3>Full service</h3>
        <p>Our events manager Eva, bar team, and kitchen team run the day. You relax and celebrate with your guests.</p>
      </div>
      <div class="included-item">
        <h3>Layout and AV</h3>
        <p>Flexible layouts for dining, dancing or mingling. Projector, screen and sound system available if you need them.</p>
      </div>
      <div class="included-item">
        <h3>No hidden extras</h3>
        <p>One price quote, one invoice, all-inclusive. No corkage fees, no service charges, no surprises.</p>
      </div>
      <div class="included-item">
        <h3>All-day access</h3>
        <p>Whether you are doing a tea-time celebration or an all-night party, the space is yours for as long as you need it.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== PRICING ==================== -->
  <Section bg="light" padding="compact" border="top">
    <PricingTable
      eyebrow="Investment"
      heading="Pricing"
      tiers={[
        { name: "Afternoon", period: "Tea-time celebration", price: "From £2,500", description: "Venue hire + in-house team" },
        { name: "Full Day", period: "All-day access", price: "From £4,500", description: "Venue hire + in-house team" },
        { name: "Evening Party", period: "From 6pm", price: "From £3,000", description: "Venue hire + in-house team" }
      ]}
    />
    <div class="pricing-note">
      <p>Indicative pricing. Every celebration is different - get in touch for a tailored quote that matches your budget and your day.</p>
    </div>
  </Section>

  <!-- ==================== FINAL CTA ==================== -->
  <FinalCTA
    heading="Ready to book your event?"
    primaryCTA={{ label: "Check Your Date", href: "/check-your-date/" }}
    whatsapp={true}
    utmCampaign="private-events"
  />

  <style>
    /* ==================== HERO (olive, no image) ==================== */
    .pe-hero {
      position: relative;
      height: 50vh;
      min-height: 400px;
      padding-top: var(--header-height, 96px);
      background-color: var(--forest-olive);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
    }

    .pe-hero .container { width: 100%; }

    .pe-hero-content {
      max-width: 700px;
      margin: 0 auto;
    }

    .pe-hero-content :global(.eyebrow) {
      color: var(--dusty-coral);
      margin-bottom: 1.5rem;
      max-width: none;
    }

    .pe-hero-content h1 {
      color: var(--warm-canvas);
      margin-bottom: 1.25rem;
    }

    .pe-hero-sub {
      color: var(--warm-canvas);
      font-size: 1.125rem;
      line-height: 1.65;
      opacity: 0.95;
      max-width: 560px;
      margin-inline: auto;
    }

    /* ==================== EVENT TYPES ==================== */
    .event-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .event-card {
      padding: 28px 24px;
      border: 1px solid rgba(44, 24, 16, 0.1);
      border-top: 3px solid var(--forest-olive);
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .event-card:hover {
      border-color: var(--forest-olive);
      border-top-color: var(--forest-olive);
      transform: translateY(-4px);
    }

    .event-card h3 { font-size: 20px; margin-bottom: 12px; color: var(--mid-olive); }
    .event-card p { font-size: 16px; line-height: 1.6; opacity: 0.85; }

    /* ==================== THE SPACE ==================== */
    .space-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
    }

    .space-text p { font-size: 17px; line-height: 1.7; margin-bottom: 20px; }

    .space-promise {
      margin-top: 30px;
      padding-top: 30px;
      border-top: 1px solid rgba(44, 24, 16, 0.1);
    }

    .space-placeholder {
      width: 100%;
      aspect-ratio: 4/3;
      background: var(--brewery-dark);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255, 255, 255, 0.4);
      font-size: 14px;
      font-family: var(--font-body);
    }

    /* ==================== INCLUDED ==================== */
    .included-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }

    .included-item {
      padding: 28px 24px;
      border-left: 4px solid var(--forest-olive);
    }

    .included-item h3 { font-size: 20px; margin-bottom: 12px; color: var(--mid-olive); }
    .included-item p { font-size: 15px; line-height: 1.7; opacity: 0.85; }

    /* ==================== PRICING NOTE ==================== */
    .pricing-note {
      text-align: center;
      margin-top: 2rem;
      padding: 20px;
      background: rgba(44, 24, 16, 0.03);
    }

    .pricing-note p { font-size: 14px; font-style: italic; opacity: 0.7; }

    /* ==================== RESPONSIVE ==================== */
    @media (max-width: 768px) {
      .event-grid { grid-template-columns: 1fr; }
      .space-grid { grid-template-columns: 1fr; gap: 40px; }
      .included-grid { grid-template-columns: 1fr; gap: 30px; }
    }
  </style>
</Base>
