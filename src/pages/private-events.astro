---
import Base from '../layouts/Base.astro';
---

<Base title="Private Events East London | Birthday Parties & Celebrations | The Hackney, E2" description="Host your private celebration at The Hackney. Birthday parties, anniversaries, baby showers, engagement parties. 60 seated, 100 standing. Exclusively yours.">
<!-- Navigation -->
  

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <div class="eyebrow">Private Events at The Hackney</div>
      <h1>Your celebration. Our brewery.</h1>
      <p>Private celebrations and everything in between - inside a restored 1860s brewery on Hackney Road, East London. Birthdays, anniversaries, baby showers, engagement parties.</p>
    </div>
  </section>

  <!-- Social Proof Bar -->
  <div class="social-proof">
    <div class="social-proof-inner">
      <div class="proof-item">
        <h4>200+</h4>
        <p>Events hosted</p>
      </div>
      <div class="proof-item">
        <h4>4.9</h4>
        <p>Google rating</p>
      </div>
      <div class="proof-item">
        <h4>Exclusive</h4>
        <p>Venue hire</p>
      </div>
      <div class="proof-item">
        <h4>In-house</h4>
        <p>Kitchen &amp; bar</p>
      </div>
    </div>
  </div>

  <!-- Event Types Section -->
  <section class="event-types">
    <h2>Events we host</h2>
    <div class="event-grid">
      <div class="event-card fade-in">
        <h3>Private Celebrations</h3>
        <p>Birthdays, anniversaries, baby showers, engagement parties. The whole venue is yours.</p>
      </div>
      <div class="event-card fade-in">
        <h3>Christmas Parties</h3>
        <p>Festive packages from November to January. In-house catering, drinks packages, DJ options.</p>
      </div>
    </div>
  </section>

  <!-- The Space Section -->
  <section class="the-space">
    <div class="the-space-content">
      <div class="the-space-text">
        <h2>The space</h2>
        <p>The Hackney is a restored 1860s brewery with 60 seats and room for 100 standing. Your event is exclusive - you get the whole venue to yourself, all day and all night if you want it.</p>
        <p>Our in-house kitchen means proper food, proper drinks, and full control over your experience. No outside caterers, no corkage, no hidden fees. Just the space you need and the service to match.</p>
        <div class="venue-features">
          <p>The venue features exposed brick walls, skylights that flood the space with natural light, high ceilings for an open feel, and a flexible layout that adapts to how you want to use the space.</p>
        </div>
      </div>
      <div class="the-space-image">
        <img src="/images/events-space.jpg" alt="The Hackney events space" style="width: 100%; height: auto; border-radius: 2px;">
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section class="whats-included">
    <h2>What's included</h2>
    <div class="included-grid">
      <div class="included-item">
        <h3>Venue</h3>
        <p>Exclusive hire of the entire space. 60 seated, 100 standing. All day, all evening.</p>
      </div>
      <div class="included-item">
        <h3>Catering</h3>
        <p>In-house kitchen and team. Custom menus tailored to your event and your budget.</p>
      </div>
      <div class="included-item">
        <h3>Bar service</h3>
        <p>Full bar with wine, beer, spirits and soft drinks. No corkage, no outside alcohol.</p>
      </div>
      <div class="included-item">
        <h3>Coordination</h3>
        <p>Dedicated events coordinator. Eva or one of our team handles everything on the day.</p>
      </div>
      <div class="included-item">
        <h3>Layout flexibility</h3>
        <p>Banquet, cabaret, theatre style, cocktail - the space adapts to your needs.</p>
      </div>
      <div class="included-item">
        <h3>AV available</h3>
        <p>Projector, screen and sound system available if you need them for presentations.</p>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="pricing">
    <h2>Pricing</h2>
    <div class="pricing-items">
      <div class="pricing-item">
        <p>Half day hire</p>
        <p><span class="price">from £2,500</span></p>
      </div>
      <div class="pricing-item">
        <p>Full day hire</p>
        <p><span class="price">from £4,500</span></p>
      </div>
      <div class="pricing-item">
        <p>Evening events</p>
        <p><span class="price">from £3,000</span></p>
      </div>
    </div>
    <div class="pricing-note">
      Indicative pricing. Every event is different - get in touch for a tailored quote.
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="final-cta">
    <h2>Ready to book your event?</h2>
    <a href="/check-your-date" class="btn btn-primary">Check Your Date</a>
    <div class="contact-note">
      Or call us on <a href="tel:+442079611604">+44 20 7961 1604</a>
    </div>
  </section>

  <!-- Footer -->
</Base>
