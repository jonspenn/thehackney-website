        <!-- Story 3 - Kate & James, photographed by This Modern Revelry -->
        <div class="wedding-story">
          <div class="wedding-story-image">
            <div class="wedding-story-image-bg lazy-bg" data-bg="images/hackney-wedding-couple-london-bus.webp" data-bg-pos="center center" role="img" aria-label="Wedding couple with vintage red London bus outside The Hackney"></div>
