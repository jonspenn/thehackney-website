---
import Base from '../layouts/Base.astro';

// Build FAQPage schema from wedding FAQs
const faqItems = [
  {
    question: "How many guests can the venue hold?",
    answer: "Up to 60 seated for dinner and up to 100 for standing receptions. We are an intimate venue - if you are planning for more than 60 seated guests, we are probably not the right fit, but we are happy to recommend alternatives."
  },
  {
    question: "Can we hold our ceremony here?",
    answer: "Yes. Civil ceremonies, humanist celebrations, and symbolic services all work beautifully in the space. Many couples choose to have their ceremony and reception in the same venue - it keeps the day flowing and means no transfers between locations."
  },
  {
    question: "What time does the venue open and close?",
    answer: "Standard hire runs from 3pm. Music finishes at 11pm and guests depart by 11:30pm. If you would like an earlier start - for getting-ready time, a morning ceremony, or a longer reception - earlier access is available from £170 for a 2pm start."
  },
  {
    question: "Is there a curfew for music?",
    answer: "Music runs until 11pm. Our built-in sound system covers the full space - you can bring your own playlist, hire a DJ, or book a live band. No need for external speakers or AV hire."
  },
  {
    question: "Can we bring our own suppliers?",
    answer: "Our food, drinks, and coordination are all in-house - that is what makes the model work. For flowers, photography, entertainment, and other personal touches, you are welcome to bring whoever you like. We work with external suppliers regularly and are happy to recommend trusted partners."
  },
  {
    question: "Do you cater for dietary requirements?",
    answer: "Absolutely. Our kitchen handles vegetarian, vegan, gluten-free, halal, kosher, and other dietary needs as standard. Just let us know during planning and we will build it into your menu."
  },
  {
    question: "What is included in the venue hire fee?",
    answer: "Exclusive hire of the entire building, your dedicated on-day coordinator, full events team, all staffing, furniture, decor, tableware basics, and our built-in sound and lighting system. See the Everything Included section above for the full list."
  },
  {
    question: "How far in advance should we book?",
    answer: "Most couples book 8-9 months ahead of their wedding date. Peak season Saturdays (May - September) fill fastest. If you have a specific date in mind, check availability sooner rather than later."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "The Hackney",
  "description": "Exclusive hire wedding venue in East London",
  "@id": "https://thehackney-website.pages.dev",
  "url": "https://thehackney-website.pages.dev/weddings/",
  "telephone": "+442079611604",
  "priceRange": "£5,000-£18,000",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "503 Hackney Road",
    "addressLocality": "London",
    "postalCode": "E2 9ED",
    "addressCountry": "GB"
  }
};

// Combine schemas into array
const combinedSchema = JSON.stringify([localBusinessSchema, faqSchema]);
---

<Base title="Wedding Venue East London | Intimate Weddings at The Hackney, Hackney Road E2" description="Exclusive hire wedding venue in East London for up to 60 guests. In-house kitchen, dedicated team, everything included. Check your date at The Hackney, Hackney Road E2." schema={combinedSchema}>
