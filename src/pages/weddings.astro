---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofBar from '../components/ProofBar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PhotoBreak from '../components/PhotoBreak.astro';
import PhotoStrip from '../components/PhotoStrip.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import WeddingQuestionnaire from '../components/WeddingQuestionnaire.astro';
import {
  getLowestCombo,
  getLowestBreakdown,
  getSeasons,
} from '../data/wedding-pricing';

// Pricing for Section 7 - sourced from src/data/wedding-pricing.json
// (single source of truth, will become a database call later).
const PRICING_YEAR = 2026;
const lowestCombo = getLowestCombo(PRICING_YEAR);
const gbp = (n: number) => `£${n.toLocaleString('en-GB')}`;
const seasonRows = getSeasons().map((season) => {
  const cell = (dayType: 'sun-thu' | 'fri' | 'sat') => {
    const b = getLowestBreakdown(PRICING_YEAR, season.id, dayType);
    return {
      total: `From ${gbp(b.total)}`,
      breakdown: `${gbp(b.hire)} hire + ${gbp(b.min)} min spend`,
    };
  };
  return {
    ...season,
    sunThu: cell('sun-thu'),
    fri: cell('fri'),
    sat: cell('sat'),
  };
});

// FAQ items used by both the FAQ component (rendering + schema) and the page schema
const faqItems = [
  {
    question: "How many guests can the venue hold?",
    answer: "Up to 60 seated for dinner and up to 100 for a standing reception. We are an intimate venue. If you are planning more than 60 seated, we are probably not the right fit, but we are happy to recommend other venues we trust. A little wriggle on the standing number for the right event - just ask."
  },
  {
    question: "How far in advance should we book?",
    answer: "Most couples book 12 to 18 months ahead, and peak season Saturdays (May to September) often go a year or more in advance. That said, we keep dates open across the year and last-minute weddings do happen here - if you are getting married this year and your date is on the calendar, get in touch. Whether you are planning two years out or two months out, the answer starts the same way: check your date."
  },
  {
    question: "What is included in the venue hire fee?",
    answer: "Exclusive hire of the entire building, your dedicated on-day coordinator, full events team and all staffing, furniture, decor, tableware basics, and our built-in sound and lighting system. Food and drinks are charged on top against your minimum spend. See the Everything Included section above for the full list."
  },
  {
    question: "What time does the venue open and close?",
    answer: "Standard hire runs from 3pm. Music finishes at 11pm and guests depart by 11:30pm. The garden terrace closes to guests at 9pm. If you would like an earlier start - for getting-ready time, a morning ceremony, or a longer reception - earlier access is available, just ask and we will share the current rate."
  },
  {
    question: "Can we hold our ceremony here?",
    answer: "Yes, but it will be a celebratory ceremony, not the legal one. The Hackney is not licensed for legal weddings. Most couples do the legal paperwork at a registry office beforehand - Hackney Town Hall is ten minutes away, or Islington, Marylebone and Clissold House are all popular - then have the ceremony they actually want here, with all their guests. Humanist celebrations, blessings, symbolic services and personal vows all work beautifully. With smaller weddings the same room is reset for the reception afterwards."
  },
  {
    question: "Can we bring our own suppliers?",
    answer: "Food and drinks are in-house, and that is what makes the all-in model work - one team, one timeline, one bill. Flowers, stationery and tableware are also available as in-house options if you want them handled under one roof - just mention it when you enquire. For everything else - photography, music, cake, hair and makeup - bring whoever you like. We work with a long list of suppliers we trust and are happy to recommend."
  },
  {
    question: "Are there any restrictions on decorations or confetti?",
    answer: "We are a confetti-free venue. The dyes stain the tables and floors, so we ask couples to skip it. You are welcome to bring your own flowers, balloons or other decorations - we just ask that you choose plastic-free or recyclable options where you can. If you want to drop off decorations the day before, talk to your events coordinator and we can usually arrange it."
  },
  {
    question: "Are children and dogs welcome?",
    answer: "Yes to both. Children are very welcome and we have highchairs available. Well-behaved dogs are happy here too - lots of couples bring theirs as ring-bearers."
  },
  {
    question: "Do you cater for dietary requirements?",
    answer: "Absolutely. Our kitchen handles vegetarian, vegan, gluten-free, halal, kosher, and other dietary needs as standard. Just let us know during planning and we will build it into your menu."
  },
  {
    question: "Is the venue accessible?",
    answer: "Honest answer: not fully. The Hackney is a Victorian brewery with a protected facade, which means there is a 15cm step at the entrance and the pavement outside is too narrow for a permanent ramp. The doorway is wide enough for a wheelchair or buggy with a little help. We do not currently have accessible toilets on site. If accessibility matters for any of your guests, please tell us up front and we will be straight with you about whether we can make it work."
  },
  {
    question: "Where is the venue and how do guests get there?",
    answer: "We are on Hackney Road in East London (E2 9ED). Cambridge Heath overground is a one-minute walk and Bethnal Green tube on the Central line is five to seven minutes away. There is no on-site customer parking, but parking on Hackney Road is free from 7pm to 8am, and metered parking is available on nearby roads before 7pm."
  },
  {
    question: "Can we have a DJ, live band or our own playlist?",
    answer: "All three. Our built-in sound system covers the whole venue and connects directly to Spotify, so you can bring a playlist and we will play it. DJs are welcome. Live bands work too, but we have noise restrictions because of our neighbours - acoustic groups up to a quartet, with finish times by 10pm. See our Music Policy page for the detail."
  }
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "The Hackney",
  "description": "Exclusive hire wedding venue in East London",
  "@id": "https://thehackney-website.pages.dev",
  "url": "https://thehackney-website.pages.dev/weddings/",
  "telephone": "+442079611604",
  "priceRange": "£5,000-£18,000",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "503 Hackney Road",
    "addressLocality": "London",
    "postalCode": "E2 9ED",
    "addressCountry": "GB"
  }
};

// LocalBusiness schema only - FAQ schema is handled by the FAQ component
const combinedSchema = JSON.stringify([localBusinessSchema]);
---

<Base title="Wedding Venue East London | Intimate Weddings at The Hackney, Hackney Road E2" description="Exclusive hire wedding venue in East London for up to 60 guests. In-house kitchen, dedicated team, everything included. Check your date at The Hackney, Hackney Road E2." schema={combinedSchema} preloadImage="/images/hackney-wedding-venue-hero-amy-john-gallery-industrial.webp">

  <!-- ==================== SECTION 1: HERO ==================== -->
  <HeroSection
    image="/images/hackney-wedding-venue-hero-amy-john-gallery-industrial.webp"
    alt="The Hackney wedding venue interior with long banquet tables, hanging greenery, disco balls and skylight"
    heading="One Team. One Place.<br>Your Whole Wedding."
    cta={{ label: "Send Me The Pricing", href: "#questionnaire" }}
    note="Pricing for 2026, 2027 and 2028 - emailed to you in seconds."
    height="mid"
    textGradient={true}
  />

  <!-- ==================== SECTION 2: SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "400+", label: "Weddings managed" },
    { number: "Everything Included", label: "Venue, food, drinks, team" },
    { number: "Exclusive Hire", label: "The whole venue, just for you" },
    { number: "4.9 ★", label: "Couple rating on Hitched" }
  ]} />

  <!-- ==================== SECTION 3: WEDDING QUESTIONNAIRE ==================== -->
  <WeddingQuestionnaire />

  <!-- ==================== SECTION 4: ONE TEAM. ONE BILL. NOTHING EXTRA. ==================== -->
  <!-- Merged from former Sections 4 (value prop) and 6 (everything included) on 2026-04-07.
       Anchor id="included" preserved for any external links still pointing to /weddings/#included. -->
  <Section bg="light" border="bottom" id="included">
    <SectionHeader
      eyebrow="Why The Hackney"
      heading="One Team. One Bill. Nothing Extra."
    />
    <div class="different-body">
      <p>Most wedding venues hand you a list of approved suppliers. You end up coordinating a caterer, a florist, a bar team and a planner - four timelines, four invoices, four different ideas of how your day should run.</p>
      <p>At The Hackney, everything is in-house. Our kitchen prepares your menu. Our bar team pours your drinks. Our events team plans your day. Our coordinator runs it on the morning. One team who know the building, know each other, and know exactly how to make your wedding feel effortless.</p>
    </div>

    <div class="included-grid">
      <div class="included-category">
        <h3>Your Dedicated Team</h3>
        <ul class="included-list">
          <li>Personal on-day coordinator from setup to send-off</li>
          <li>Dedicated events team for planning in the months before</li>
          <li>All staffing costs included - kitchen, bar, front of house</li>
          <li>Five-star service with no service charge added</li>
        </ul>
      </div>
      <div class="included-category">
        <h3>The Venue, Fully Equipped</h3>
        <ul class="included-list">
          <li>Exclusive hire of the entire building</li>
          <li>All furniture and decor - tables, chairs, linens, glassware</li>
          <li>Built-in sound and lighting system</li>
          <li>The space set up and styled to your brief</li>
        </ul>
      </div>
      <div class="included-category">
        <h3>Planning Support</h3>
        <ul class="included-list">
          <li>Bespoke planning form tailored to your wedding</li>
          <li>Menu tasting for you and your partner</li>
          <li>Timeline planning and supplier coordination</li>
          <li>Everything managed through one point of contact</li>
        </ul>
      </div>
    </div>

    <div class="included-promise">
      <p><strong>The price we quote is the price you pay.</strong> No surprise staffing invoice. No service charge on top. No discovery that "venue hire" did not include the tables. One team, one conversation, one bill.</p>
    </div>
  </Section>

  <!-- ==================== SECTION 4B: THE DETAILS, ALSO IN-HOUSE ==================== -->
  <!-- Added 2026-04-07. Extends the in-house narrative from Section 4 to cover
       flowers, stationery and tableware - three revenue lines that previously
       had no presence on the new wedding page. Flowers leads (priority growth
       target for 2026 per Jon). Soft brochure CTA at the bottom routes to the
       questionnaire (one funnel, not two). Positioned as reassurance not
       decision - the goal is to plant the in-house seed and reinforce the
       one-team narrative, not to push a configurator on the booking page. -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="The Finishing Touches"
      heading="The Details, Also In-House"
    />
    <div class="details-intro">
      <p>Most venues hand you a supplier list. We have an in-house design team for the things that matter most on the day. Choose what you want, leave what you don't - it all runs through the same one team and one bill.</p>
    </div>

    <div class="details-grid">
      <div class="details-card">
        <h3>Flowers</h3>
        <p>Six seasonal collections, from wild and natural to bold colour. Bridal bouquets, buttonholes, table centrepieces, statement installations - including our signature wall arrangements and the fireplace piece couples remember from their tours.</p>
      </div>
      <div class="details-card">
        <h3>Stationery</h3>
        <p>Nine design collections, from contemporary minimalism to floral and chic. Save the dates, invitations, menus, place cards, signage. Designed and printed by our team, customisable to your day.</p>
      </div>
      <div class="details-card">
        <h3>Tableware</h3>
        <p>Three curated tablescape packages - from refined and simple to gold-charger statement. Linen, crockery, glassware, cutlery, candlelight, all chosen by our team to suit the room and the season.</p>
      </div>
    </div>

    <div class="details-cta">
      <p>Full collections, photos and pricing are inside our wedding brochure.</p>
      <a href="#questionnaire" class="btn btn-primary" data-cta-section="details-extras">Send Me The Brochure</a>
    </div>
  </Section>

  <!-- ==================== SECTION 5: THE SPACE ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="The Venue"
      heading="An 1856 Brewery. Yours For The Day."
      subtext="The Hackney is a converted Victorian brewery on Hackney Road in East London - exposed brick, original timber beams, and industrial character that photographs beautifully without needing to dress it up."
    />
    <p class="space-intro">The venue is yours exclusively. No shared spaces, no other events running alongside yours, no strangers wandering through your reception. Standard hire runs from 3pm, with music until 11pm and guests away by 11:30pm. Earlier start times are available if you want a longer day.</p>
    <div class="space-capacity">
      <div class="capacity-stat">
        <div class="capacity-number">60</div>
        <div class="capacity-label">Guests seated</div>
      </div>
      <div class="capacity-stat">
        <div class="capacity-number">100</div>
        <div class="capacity-label">Standing reception</div>
        <div class="capacity-note">A little more for the right event. Just ask.</div>
      </div>
    </div>

    <div class="space-gallery">
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-wedding-breakfast-guests-edison-bulbs-skylights.webp" data-bg-pos="center center" role="img" aria-label="Wedding breakfast at The Hackney with 60 guests seated at long tables under Edison bulbs"></div>
        <div class="space-image-caption">Wedding breakfast - 60 seated</div>
      </div>
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-wedding-ceremony-kiss-industrial-backdrop.webp" data-bg-pos="center center" role="img" aria-label="Intimate wedding ceremony kiss against industrial perforated metal wall at The Hackney"></div>
        <div class="space-image-caption">Ceremony setup</div>
      </div>
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-wedding-evening-celebration-couple-entrance.webp" data-bg-pos="center center" role="img" aria-label="Wedding couple entering evening celebration at The Hackney with guests cheering and disco balls overhead"></div>
        <div class="space-image-caption">Evening celebration</div>
      </div>
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-wedding-table-detail-flowers-place-settings.webp" data-bg-pos="center center" role="img" aria-label="Wedding table detail with flower centrepiece, glassware and place settings at The Hackney"></div>
        <div class="space-image-caption">Detail &amp; decor</div>
      </div>
    </div>

    <div class="space-features">
      <div class="space-feature">
        <h3>The Ceremony You Actually Want</h3>
        <p>Hold your celebratory ceremony and reception in the same space. Humanist celebrations, personal vows, and symbolic services all work beautifully here. The legal paperwork happens separately - most couples visit Hackney Town Hall beforehand, then have the ceremony they actually want with all their guests at The Hackney.</p>
      </div>
      <div class="space-feature">
        <h3>When The Room Transforms</h3>
        <p>After dinner, the space transforms. Our sound and lighting system is built into the venue - no need to hire external AV. Music runs until 11pm, with guests departing by 11:30pm.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== SECTION 6: PHOTO BREAK + VALUE-JUSTIFIER QUOTE ==================== -->
  <!-- Rebuilt 2026-04-07. Was a silent mood photo (couple between tables). Now does
       two jobs: (1) emotional peak moment immediately before pricing, (2) value-
       justifier pull-quote from a real couple so the price feels earned. The quote
       is a lightly-trimmed verbatim lift from Rosemary Anstead's wedding feedback
       form (1 Nov 2024 wedding) - source CSV at sales & marketing/reporting/
       exports/google-forms/wedding-feedback-responses.csv row 12. Image swapped
       to first-dance-with-guests because it shows BOTH the room "put together"
       (matches the quote) AND a peak emotional moment (the "best day" payoff).
       Uses the new quote-overlay variant of <PhotoBreak> - homepage usage stays
       silent. -->
  <PhotoBreak
    image="/images/hackney-wedding-first-dance-guests-venue.webp"
    alt="Wedding first dance with guests gathered around at The Hackney"
    position="center 50%"
    quote="It felt far more put together than weddings of friends who paid triple the amount. Absolutely the best day."
    attribution="Rosemary, married November 2024"
  />

  <!-- ==================== SECTION 7: PRICING ==================== -->
  <!-- Rebuilt 2026-04-07 around the lead-capture play.
       Previous 6-row "season summary" table had stale numbers that didn't match
       the live brochure rate card. New approach (per Bridebook 2026 market data):
       - Big "From £5,000" hook satisfies the 88% who expect pricing online
       - Simple 4-row 2026 season table = "indicative pricing" the 41% accept
       - Pivot to 2027/2028 brochure form because 86% of current shoppers are
         planning 2027+ weddings (avg engagement-to-wedding = 23.8 months)
       - Brochure form merged in here from old standalone Section 11. -->
  <Section bg="light" border="top" id="pricing">
    <SectionHeader
      eyebrow="Pricing"
      heading={`${PRICING_YEAR} Pricing By Season`}
    />

    <div class="pricing-hook">
      <div class="pricing-hook-label">Weddings From</div>
      <div class="pricing-hook-amount">&pound;{lowestCombo.total.toLocaleString('en-GB')}</div>
      <div class="pricing-hook-breakdown">Venue hire &pound;{lowestCombo.hire.toLocaleString('en-GB')} &nbsp;+&nbsp; minimum spend &pound;{lowestCombo.min.toLocaleString('en-GB')}</div>
      <div class="pricing-hook-context">{lowestCombo.context}</div>
    </div>

    <p class="pricing-intro">Every Hackney wedding is venue hire plus a minimum spend on food, drinks and extras. Here is what {PRICING_YEAR} weddings start at, by season and day of the week.</p>

    <div class="pricing-table-wrap">
      <table class="pricing-table pricing-season-table">
        <thead>
          <tr>
            <th>Season</th>
            <th>Sun - Thu</th>
            <th>Friday</th>
            <th>Saturday</th>
          </tr>
        </thead>
        <tbody>
          {seasonRows.map((row) => (
            <tr>
              <td>{row.label}<br><span class="pricing-period">{row.period}</span></td>
              <td>
                <span class="cell-total">{row.sunThu.total}</span>
                <span class="cell-breakdown">{row.sunThu.breakdown}</span>
              </td>
              <td>
                <span class="cell-total">{row.fri.total}</span>
                <span class="cell-breakdown">{row.fri.breakdown}</span>
              </td>
              <td class="total">
                <span class="cell-total">{row.sat.total}</span>
                <span class="cell-breakdown">{row.sat.breakdown}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="pricing-table-note">All prices "from" and exclude VAT. December dates available - festive pricing in the full guide.</p>
    </div>

    <!-- Pivot to brochure capture - works for any wedding year, not just 2027+.
         Heading deliberately year-agnostic so 2026 couples don't think it's not for them. -->
    <div class="pricing-pivot">
      <h3>Want The Full Pricing Guide?</h3>
      <p>The table above is the headline. The brochure has every month, every day of the week, plus drinks packages, food, flowers and tableware. Pricing for 2026, 2027 and 2028 - emailed and WhatsApped to you in seconds.</p>
    </div>

    <form class="pricing-form" id="brochure" data-form="brochure-download">
      <div class="form-row">
        <div class="form-group">
          <label for="brochure-firstName">First name</label>
          <input type="text" id="brochure-firstName" name="firstName" placeholder="Your first name" required>
        </div>
        <div class="form-group">
          <label for="brochure-email">Email address</label>
          <input type="email" id="brochure-email" name="email" placeholder="you@email.com" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="brochure-mobile">Mobile number</label>
          <input type="tel" id="brochure-mobile" name="mobile" placeholder="07..." required>
        </div>
        <div class="form-group">
          <label for="brochure-year">Wedding year <span class="form-optional">(optional)</span></label>
          <select id="brochure-year" name="weddingYear">
            <option value="">Select a year</option>
            <option value="2026">2026</option>
            <option value="2027">2027</option>
            <option value="2028">2028</option>
            <option value="not-sure">Not sure yet</option>
          </select>
        </div>
      </div>
      <button type="submit" class="btn btn-primary pricing-form-submit">Get The Full Pricing Guide</button>
      <p class="pricing-form-note">We will send the guide immediately by email and WhatsApp. No phone calls. No sales pitch. Just every date, every option, every number. Unsubscribe any time.</p>
    </form>
  </Section>

  <!-- ==================== SECTION 8: REAL WEDDINGS ==================== -->
  <Section bg="light">
    <SectionHeader
      eyebrow="Real Weddings"
      heading="Real Couples. Real Weddings."
    />

    <div class="wedding-stories">
      <article class="wedding-story">
        <div class="wedding-story-image">
          <div class="wedding-story-image-bg lazy-bg" data-bg="/images/hackney-real-wedding-charlotte-stephen-winter-garden-pink-installation.webp" data-bg-pos="center center" role="img" aria-label="Charlotte and Stephen in the Winter Garden at The Hackney, dressed with hot pink florals and disco balls"></div>
        </div>
        <div class="wedding-story-content">
          <h3>Charlotte &amp; Stephen</h3>
          <p class="wedding-story-meta">August 2024</p>
          <p class="wedding-story-credit">Photography by This Modern Revelry</p>
        </div>
      </article>

      <article class="wedding-story">
        <div class="wedding-story-image">
          <div class="wedding-story-image-bg lazy-bg" data-bg="/images/hackney-real-wedding-verity-andy-long-table-feast.webp" data-bg-pos="center center" role="img" aria-label="Verity and Andy's wedding guests at the long table feast at The Hackney"></div>
        </div>
        <div class="wedding-story-content">
          <h3>Verity &amp; Andy</h3>
          <p class="wedding-story-meta">June 2024</p>
          <p class="wedding-story-credit">Photography by Ollie Hinds</p>
        </div>
      </article>

      <article class="wedding-story">
        <div class="wedding-story-image">
          <div class="wedding-story-image-bg lazy-bg" data-bg="/images/hackney-real-wedding-kate-james-brewery-toast.webp" data-bg-pos="center center" role="img" aria-label="Kate and James toasting at the head of the long table at The Hackney"></div>
        </div>
        <div class="wedding-story-content">
          <h3>Kate &amp; James</h3>
          <p class="wedding-story-meta">August 2023</p>
          <p class="wedding-story-credit">Photography by This Modern Revelry</p>
        </div>
      </article>
    </div>

    <div class="section-cta-center">
      <a href="#questionnaire" class="btn btn-primary">Start Planning Yours</a>
    </div>
  </Section>

  <!-- ==================== SECTION 9: PHOTO STRIP - WEDDING DETAILS ==================== -->
  <PhotoStrip images={[
    { src: "/images/hackney-wedding-table-detail-candles-gold-chargers-eucalyptus.webp", alt: "Wedding table detail with candles, gold chargers and eucalyptus at The Hackney" },
    { src: "/images/hackney-wedding-ceremony-celebration-colourful-flowers.webp", alt: "Wedding ceremony celebration with colourful flowers at The Hackney" },
    { src: "/images/hackney-wedding-bride-laughing-dinner-pink-flowers.webp", alt: "Bride laughing at dinner table with pink flowers at The Hackney" }
  ]} />

  <!-- ==================== SECTION 10: PLANNING PROCESS ==================== -->
  <Section bg="light" border="top">
    <SectionHeader
      eyebrow="How It Works"
      heading="From First Click To Last Dance"
    />

    <div class="process-steps">
      <div class="process-step">
        <div class="process-step-number">01</div>
        <h3>Check Your Date</h3>
        <p>See your date instantly on our live calendar. Pricing for every season, availability you can see at a glance. No forms, no waiting.</p>
      </div>
      <div class="process-step">
        <div class="process-step-number">02</div>
        <h3>Have Questions First? <span class="process-step-optional">(optional)</span></h3>
        <p>If there is anything you would like to talk through before visiting, book a call with Hugo, our General Manager. Otherwise, skip straight to the tour.</p>
      </div>
      <div class="process-step">
        <div class="process-step-number">03</div>
        <h3>Visit The Venue</h3>
        <p>Come and walk the space with Hugo. He will show you every corner of the building, talk you through how the day flows, and answer everything on your mind.</p>
      </div>
      <div class="process-step">
        <div class="process-step-number">04</div>
        <h3>Your Proposal</h3>
        <p>One document, one total. Your full proposal covering menu, drinks, timeline, and every extra. Nothing buried, nothing hidden.</p>
      </div>
      <div class="process-step">
        <div class="process-step-number">05</div>
        <h3>Secure Your Date</h3>
        <p>A deposit holds your date and unlocks your dedicated events team. From that moment until the last dance, we handle every decision with you.</p>
      </div>
    </div>

    <div class="section-cta-center">
      <a href="/check-your-date/" class="btn btn-primary" data-cta-section="planning-process">See If We're Free</a>
    </div>
  </Section>

