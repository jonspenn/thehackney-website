---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofBar from '../components/ProofBar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PhotoBreak from '../components/PhotoBreak.astro';
import PhotoStrip from '../components/PhotoStrip.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import WeddingQuestionnaire from '../components/WeddingQuestionnaire.astro';

// FAQ items used by both the FAQ component (rendering + schema) and the page schema
const faqItems = [
  {
    question: "How many guests can the venue hold?",
    answer: "Up to 60 seated for dinner and up to 110 for standing receptions. We are an intimate venue - if you are planning for more than 60 seated guests, we are probably not the right fit, but we are happy to recommend alternatives."
  },
  {
    question: "Can we hold our ceremony here?",
    answer: "Yes. Civil ceremonies, humanist celebrations, and symbolic services all work beautifully in the space. Many couples choose to have their ceremony and reception in the same venue - it keeps the day flowing and means no transfers between locations."
  },
  {
    question: "What time does the venue open and close?",
    answer: "Standard hire runs from 3pm. Music finishes at 11pm and guests depart by 11:30pm. If you would like an earlier start - for getting-ready time, a morning ceremony, or a longer reception - earlier access is available from £170 for a 2pm start."
  },
  {
    question: "Is there a curfew for music?",
    answer: "Music runs until 11pm. Our built-in sound system covers the full space - you can bring your own playlist, hire a DJ, or book a live band. No need for external speakers or AV hire."
  },
  {
    question: "Can we bring our own suppliers?",
    answer: "Our food, drinks, and coordination are all in-house - that is what makes the model work. For flowers, photography, entertainment, and other personal touches, you are welcome to bring whoever you like. We work with external suppliers regularly and are happy to recommend trusted partners."
  },
  {
    question: "Do you cater for dietary requirements?",
    answer: "Absolutely. Our kitchen handles vegetarian, vegan, gluten-free, halal, kosher, and other dietary needs as standard. Just let us know during planning and we will build it into your menu."
  },
  {
    question: "What is included in the venue hire fee?",
    answer: "Exclusive hire of the entire building, your dedicated on-day coordinator, full events team, all staffing, furniture, decor, tableware basics, and our built-in sound and lighting system. See the Everything Included section above for the full list."
  },
  {
    question: "How far in advance should we book?",
    answer: "Most couples book 8-9 months ahead of their wedding date. Peak season Saturdays (May - September) fill fastest. If you have a specific date in mind, check availability sooner rather than later."
  }
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "The Hackney",
  "description": "Exclusive hire wedding venue in East London",
  "@id": "https://thehackney-website.pages.dev",
  "url": "https://thehackney-website.pages.dev/weddings/",
  "telephone": "+442079611604",
  "priceRange": "£5,000-£18,000",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "503 Hackney Road",
    "addressLocality": "London",
    "postalCode": "E2 9ED",
    "addressCountry": "GB"
  }
};

// LocalBusiness schema only - FAQ schema is handled by the FAQ component
const combinedSchema = JSON.stringify([localBusinessSchema]);
---

<Base title="Wedding Venue East London | Intimate Weddings at The Hackney, Hackney Road E2" description="Exclusive hire wedding venue in East London for up to 60 guests. In-house kitchen, dedicated team, everything included. Check your date at The Hackney, Hackney Road E2." schema={combinedSchema} preloadImage="/images/hackney-wedding-venue-hero-long-tables-edison-bulbs.webp">

  <!-- ==================== SECTION 1: HERO ==================== -->
  <HeroSection
    image="/images/hackney-wedding-venue-hero-long-tables-edison-bulbs.webp"
    alt="The Hackney wedding venue interior with long dinner tables, Edison bulbs and exposed brick"
    eyebrow="Wedding Venue - Hackney Road, East London E2"
    heading="Your Wedding. Your Way. One Team. One Place."
    subtext="An 1856 brewery in the heart of East London. Exclusive hire. In-house kitchen. Every detail handled by a single dedicated team - from the first call to the last dance."
    cta={{ label: "Plan Your Wedding", href: "#questionnaire" }}
    note="2026 dates filling fast - check availability now"
    height="mid"
  />

  <!-- ==================== SECTION 2: SOCIAL PROOF BAR ==================== -->
  <ProofBar stats={[
    { number: "75+", label: "Weddings a year" },
    { number: "4.6", label: "Google rating" },
    { number: "Est. 1856", label: "A historic brewery, reimagined" },
    { number: "98", label: "NPS score - 98% would recommend" }
  ]} />

  <!-- ==================== SECTION 3: WEDDING QUESTIONNAIRE ==================== -->
  <WeddingQuestionnaire />

  <!-- ==================== SECTION 4: WHAT MAKES US DIFFERENT ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="Why The Hackney"
      heading="One Team. Not Twenty Vendors."
    />
    <div class="different-body">
      <p>Most wedding venues hand you a list of approved suppliers and wish you luck. You end up coordinating a caterer, a florist, a bar team, a DJ, a coordinator - each with their own timeline, their own invoice, and their own idea of how your day should run.</p>
      <p>We do it differently.</p>
      <p>At The Hackney, everything is in-house. Our kitchen prepares your menu. Our bar team pours your drinks. Our events team plans your day. Our coordinator runs it on the morning. One team who know the building, know each other, and know exactly how to make your wedding feel effortless.</p>
      <p>No hidden costs. No surprise invoices. No chasing five different suppliers the week before your wedding. Just one conversation, one team, and one bill at the end.</p>
      <a href="#included" class="btn btn-primary">See What Is Included</a>
    </div>
  </Section>

  <!-- ==================== SECTION 4: THE SPACE ==================== -->
  <Section bg="light" border="bottom">
    <SectionHeader
      eyebrow="The Venue"
      heading="An 1856 Brewery. Yours For The Day."
      subtext="The Hackney is a converted Victorian brewery on Hackney Road in East London - exposed brick, original timber beams, and industrial character that photographs beautifully without needing to dress it up."
    />
    <p class="space-intro">The venue is yours exclusively. No shared spaces, no other events running alongside yours, no strangers wandering through your reception. From 3pm until 11:30pm, the entire building belongs to you and your guests.</p>
    <div class="space-capacity">Up to 60 guests seated / 110 standing</div>

    <div class="space-gallery">
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-wedding-breakfast-guests-edison-bulbs-skylights.webp" data-bg-pos="center center" role="img" aria-label="Wedding breakfast at The Hackney with 60 guests seated at long tables under Edison bulbs"></div>
        <div class="space-image-caption">Wedding breakfast - 60 seated</div>
      </div>
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-wedding-ceremony-kiss-industrial-backdrop.webp" data-bg-pos="center center" role="img" aria-label="Intimate wedding ceremony kiss against industrial perforated metal wall at The Hackney"></div>
        <div class="space-image-caption">Ceremony setup</div>
      </div>
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-wedding-evening-celebration-couple-entrance.webp" data-bg-pos="center center" role="img" aria-label="Wedding couple entering evening celebration at The Hackney with guests cheering and disco balls overhead"></div>
        <div class="space-image-caption">Evening celebration</div>
      </div>
      <div class="space-image">
        <div class="space-image-bg lazy-bg" data-bg="/images/hackney-wedding-table-detail-flowers-place-settings.webp" data-bg-pos="center center" role="img" aria-label="Wedding table detail with flower centrepiece, glassware and place settings at The Hackney"></div>
        <div class="space-image-caption">Detail &amp; decor</div>
      </div>
    </div>

    <div class="space-features">
      <div class="space-feature">
        <h3>Ceremonies</h3>
        <p>Hold your ceremony and reception in the same space. Humanist celebrations, blessings, and symbolic services all work beautifully in the space. For civil ceremonies, we can recommend local registry offices nearby. No transferring 60 guests across London between the ceremony and the party.</p>
      </div>
      <div class="space-feature">
        <h3>The Evening</h3>
        <p>After dinner, the space transforms. Our sound and lighting system is built into the venue - no need to hire external AV. Music runs until 11pm, with guests departing by 11:30pm.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== SECTION 5: EVERYTHING INCLUDED ==================== -->
  <Section bg="light" border="bottom" id="included">
    <SectionHeader
      eyebrow="What You Get"
      heading="Transparent Pricing. No Surprises."
      subtext="Every Hackney wedding includes everything you need to host your day - your team, your venue, and your planning support. Here is what comes as standard."
    />

    <div class="included-grid">
      <div class="included-category">
        <h3>Your Dedicated Team</h3>
        <ul class="included-list">
          <li>Personal on-day coordinator from setup to send-off</li>
          <li>Dedicated events team for planning in the months before</li>
          <li>All staffing costs included - kitchen, bar, front of house</li>
          <li>Five-star service with no service charge added</li>
        </ul>
      </div>
      <div class="included-category">
        <h3>The Venue, Fully Equipped</h3>
        <ul class="included-list">
          <li>Exclusive hire of the entire building</li>
          <li>All furniture and decor - tables, chairs, linens, glassware</li>
          <li>Built-in sound and lighting system</li>
          <li>The space set up and styled to your brief</li>
        </ul>
      </div>
      <div class="included-category">
        <h3>Planning Support</h3>
        <ul class="included-list">
          <li>Bespoke planning form tailored to your wedding</li>
          <li>Menu tasting for you and your partner</li>
          <li>Timeline planning and supplier coordination</li>
          <li>Everything managed through one point of contact</li>
        </ul>
      </div>
    </div>

    <div class="included-promise">
      <p><strong>What this means in practice:</strong> You will not receive a surprise staffing invoice. You will not be charged a service fee on top of your food and drink bill. You will not discover that "venue hire" does not include tables, or that lighting is an extra. The price we quote is the price you pay.</p>
    </div>
  </Section>

  <!-- ==================== PHOTO BREAK: VENUE ATMOSPHERE ==================== -->
  <PhotoBreak
    image="/images/hackney-wedding-couple-between-tables-pampas-edison-bulbs.webp"
    alt="Wedding couple standing between long dinner tables with pampas grass and Edison bulbs at The Hackney"
    position="center 40%"
  />

  <!-- ==================== SECTION 6: PRICING ==================== -->
  <Section bg="light" border="top" id="pricing">
    <SectionHeader
      eyebrow="Pricing"
      heading="What A Hackney Wedding Costs"
      subtext="We believe you should know what your wedding costs before you enquire - not after three emails and a phone call. Here is how our pricing works."
    />

    <div class="pricing-how">
      <h3>How It Works</h3>
      <p>Every wedding has two parts:</p>
      <ol>
        <li><strong>Venue hire fee</strong> - This secures exclusive use of the building, your dedicated team, all furniture, decor, sound and lighting. It varies by day of the week and time of year.</li>
        <li><strong>Minimum spend on food, drinks, and extras</strong> - This is the minimum you will spend on catering, drinks packages, flowers, tableware, and any additional services. Most couples spend above the minimum because they want to - not because they have to.</li>
      </ol>
    </div>

    <div class="pricing-table-wrap">
      <table class="pricing-table">
        <thead>
          <tr>
            <th></th>
            <th>Venue Hire</th>
            <th>Min. Spend</th>
            <th>Total From</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Off-Peak<br><span class="pricing-period">Jan - Mar, any day</span></td>
            <td>From &pound;1,000</td>
            <td>From &pound;4,000</td>
            <td class="total">From &pound;5,000</td>
          </tr>
          <tr>
            <td>Mid-Season<br><span class="pricing-period">Apr, Oct - Dec, Sun - Thu</span></td>
            <td>From &pound;2,000</td>
            <td>From &pound;3,000</td>
            <td class="total">From &pound;5,000</td>
          </tr>
          <tr>
            <td>Mid-Season<br><span class="pricing-period">Apr, Oct - Dec, Fri - Sat</span></td>
            <td>From &pound;2,000</td>
            <td>From &pound;4,500</td>
            <td class="total">From &pound;6,500</td>
          </tr>
          <tr>
            <td>Peak Season<br><span class="pricing-period">May - Sep, Sun - Thu</span></td>
            <td>From &pound;2,000</td>
            <td>From &pound;3,000</td>
            <td class="total">From &pound;5,000</td>
          </tr>
          <tr>
            <td>Peak Season<br><span class="pricing-period">May - Sep, Friday</span></td>
            <td>From &pound;2,000</td>
            <td>From &pound;5,000</td>
            <td class="total">From &pound;7,000</td>
          </tr>
          <tr>
            <td>Peak Season<br><span class="pricing-period">May - Sep, Saturday</span></td>
            <td>From &pound;2,850</td>
            <td>From &pound;5,500</td>
            <td class="total">From &pound;8,350</td>
          </tr>
        </tbody>
      </table>
      <p class="pricing-table-note">All prices exclude VAT. Full rate card available in our wedding brochure.</p>
    </div>

    <div class="pricing-extras">
      <h3>What Does The Minimum Spend Cover?</h3>
      <div class="extras-grid">
        <div class="extra-item">
          <span>Canapes</span>
          <span class="extra-price">From &pound;16pp</span>
        </div>
        <div class="extra-item">
          <span>Three-course seated dinner</span>
          <span class="extra-price">From &pound;65pp</span>
        </div>
        <div class="extra-item">
          <span>Sharing-style feast</span>
          <span class="extra-price">From &pound;70pp</span>
        </div>
        <div class="extra-item">
          <span>Unlimited drinks packages</span>
          <span class="extra-price">From &pound;18pp/hr</span>
        </div>
        <div class="extra-item">
          <span>Champagne packages</span>
          <span class="extra-price">From &pound;30pp/hr</span>
        </div>
        <div class="extra-item">
          <span>Flower packages</span>
          <span class="extra-price">From &pound;550</span>
        </div>
        <div class="extra-item">
          <span>Tableware and styling</span>
          <span class="extra-price">From &pound;6pp</span>
        </div>
      </div>
    </div>

    <div class="pricing-example">
      <p>For a Saturday wedding in peak season with 50 guests, a three-course dinner, four hours of unlimited drinks, and a flower package, the total is approximately &pound;8,350 + food and drink spend. That is one invoice, from one team, with no hidden extras.</p>
    </div>

    <div class="pricing-cta">
      <a href="#brochure" class="btn btn-primary">Download Our Full Pricing Guide</a>
    </div>
  </Section>

  <!-- ==================== SECTION 8: REAL WEDDINGS ==================== -->
  <Section bg="light">
    <SectionHeader
      eyebrow="Real Weddings"
      heading="Real Couples. Real Weddings."
    />

    <div class="wedding-stories">
      <div class="wedding-story">
        <div class="wedding-story-image">
          <div class="wedding-story-image-bg lazy-bg" data-bg="/images/hackney-wedding-couple-portrait-exposed-brick.webp" data-bg-pos="center top" role="img" aria-label="Wedding couple portrait against exposed brick wall at The Hackney"></div>
        </div>
        <div class="wedding-story-content">
          <h3>A Winter Wedding For 45 Guests</h3>
          <p class="wedding-story-quote">"We looked at twelve venues before we found The Hackney. Every other place gave us a supplier list and said good luck. Here, everything was handled by one team. On the day, we did not have to think about a single thing."</p>
          <ul class="wedding-story-details">
            <li>45 guests</li>
            <li>December</li>
            <li>Candlelit dinner</li>
            <li>Sharing platters</li>
          </ul>
        </div>
      </div>

      <div class="wedding-story">
        <div class="wedding-story-image">
          <div class="wedding-story-image-bg lazy-bg" data-bg="/images/hackney-wedding-couple-east-london-streets.webp" data-bg-pos="center center" role="img" aria-label="Wedding couple walking through East London streets near The Hackney"></div>
        </div>
        <div class="wedding-story-content">
          <h3>A Summer Celebration For 58 Guests</h3>
          <p class="wedding-story-quote">"The building is stunning - we barely needed any decoration. The exposed brick and the beams did all the work. And having the ceremony and reception in the same place meant no rushing around."</p>
          <ul class="wedding-story-details">
            <li>58 guests</li>
            <li>July</li>
            <li>Three-course dinner</li>
            <li>Champagne reception</li>
          </ul>
        </div>
      </div>

      <div class="wedding-story">
        <div class="wedding-story-image">
          <div class="wedding-story-image-bg lazy-bg" data-bg="/images/hackney-wedding-couple-london-bus.webp" data-bg-pos="center center" role="img" aria-label="Wedding couple with vintage red London bus outside The Hackney"></div>
        </div>
        <div class="wedding-story-content">
          <h3>An Intimate Spring Wedding For 30 Guests</h3>
          <p class="wedding-story-quote">"We wanted something small and personal - not a massive venue where we would feel lost. The Hackney was exactly the right size. And the fact that everything was included meant we could plan the whole thing in eight weeks."</p>
          <ul class="wedding-story-details">
            <li>30 guests</li>
            <li>April</li>
            <li>Sharing-style feast</li>
            <li>Evening drinks</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="section-cta-center">
      <a href="#questionnaire" class="btn btn-primary">Start Planning Yours</a>
    </div>
  </Section>

  <!-- ==================== PHOTO STRIP: WEDDING DETAILS ==================== -->
  <PhotoStrip images={[
    { src: "/images/hackney-wedding-table-detail-candles-gold-chargers-eucalyptus.webp", alt: "Wedding table detail with candles, gold chargers and eucalyptus at The Hackney" },
    { src: "/images/hackney-wedding-ceremony-celebration-colourful-flowers.webp", alt: "Wedding ceremony celebration with colourful flowers at The Hackney" },
    { src: "/images/hackney-wedding-bride-laughing-dinner-pink-flowers.webp", alt: "Bride laughing at dinner table with pink flowers at The Hackney" }
  ]} />

  <!-- ==================== SECTION 9: PLANNING PROCESS ==================== -->
  <Section bg="light" border="top">
    <SectionHeader
      eyebrow="How It Works"
      heading="From First Call To Last Dance"
    />

    <div class="process-steps">
      <div class="process-step">
        <div class="process-step-number">01</div>
        <h3>Check Your Date</h3>
        <p>Use our quick form to tell us your preferred date, guest count, and what you are looking for. We will get back to you within 24 hours.</p>
      </div>
      <div class="process-step">
        <div class="process-step-number">02</div>
        <h3>Discovery Call</h3>
        <p>A 15-minute call with Hugo to see if we are the right fit. No pressure, no hard sell - just an honest conversation about your wedding.</p>
      </div>
      <div class="process-step">
        <div class="process-step-number">03</div>
        <h3>Visit The Venue</h3>
        <p>If it is a match, we will invite you in to see the space in person and talk through how your wedding would work in the building.</p>
      </div>
      <div class="process-step">
        <div class="process-step-number">04</div>
        <h3>Your Proposal</h3>
        <p>A detailed proposal based on everything you have discussed - your menu, drinks, timeline, extras. One document, one total.</p>
      </div>
      <div class="process-step">
        <div class="process-step-number">05</div>
        <h3>Secure Your Date</h3>
        <p>A deposit secures your date. From there, your dedicated events team guides you through every decision until the big day.</p>
      </div>
    </div>

    <div class="section-cta-center">
      <a href="#questionnaire" class="btn btn-primary">Start Here - It Takes 30 Seconds</a>
    </div>
  </Section>

  <!-- ==================== BROCHURE DOWNLOAD ==================== -->
  <Section bg="light" border="top" id="brochure" class="brochure-section">
    <SectionHeader
      eyebrow="Wedding Brochure"
      heading="Get Our Wedding Brochure"
    />
    <div class="brochure-inner">
      <div class="brochure-content">
        <p>Everything you need in one place - the full rate card, sample menus, what is included, and how the day works. Download it now and share it with your partner.</p>
      </div>
      <div class="brochure-form">
        <div class="form-group">
          <label for="firstName">First Name</label>
          <input type="text" id="firstName" placeholder="Your first name">
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" placeholder="you@email.com">
        </div>
        <div class="form-group">
          <label for="partnerName">Partner's Name <span class="form-optional">(optional)</span></label>
          <input type="text" id="partnerName" placeholder="Their first name">
        </div>
        <div class="form-group">
          <label for="weddingDate">Preferred Wedding Date <span class="form-optional">(optional)</span></label>
          <input type="text" id="weddingDate" placeholder="e.g. June 2027">
        </div>
        <button class="btn btn-primary">Download The Brochure</button>
        <p class="brochure-form-note">We will send you the brochure immediately. You may also receive a small number of helpful emails about planning your Hackney wedding. You can unsubscribe at any time.</p>
      </div>
    </div>
  </Section>

  <!-- ==================== FAQs ==================== -->
  <Section bg="light" border="top">
    <SectionHeader
      eyebrow="FAQs"
      heading="Questions Couples Ask Us"
    />
    <FAQ items={faqItems} />
  </Section>

  <!-- ==================== SECTION 12: FINAL CTA ==================== -->
  <FinalCTA
    eyebrow="Start Here"
    heading="Ready To Check Your Date?"
    body="Tell us when you are thinking, how many guests, and what you are looking for. We will get back to you within 24 hours."
    primaryCTA={{ label: "Check Your Date", href: "/check-your-date/" }}
    secondaryCTA={{ label: "Call Us", href: "tel:+442079611604" }}
    whatsapp={true}
    note="2026 dates are filling fast. Saturday availability for peak season is limited."
    utmCampaign="weddings"
  />

  <!-- ==================== STICKY MOBILE CTA ==================== -->
  <div class="sticky-cta" id="stickyCta">
    <a href="#questionnaire">Plan Your Wedding</a>
  </div>

  <style>
    /* ==================== DIFFERENT (Why The Hackney) ==================== */
    .different-body {
      max-width: 760px;
    }

    .different-body p {
      font-size: 18px;
      margin-bottom: 20px;
      line-height: 1.7;
    }

    .different-body p:last-of-type {
      margin-bottom: 36px;
    }

    /* ==================== THE SPACE ==================== */
    .space-intro {
      font-size: 18px;
      line-height: 1.7;
      max-width: 700px;
      margin-bottom: 12px;
    }

    .space-capacity {
      font-family: var(--font-body);
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--forest-olive);
      font-weight: 500;
      margin-top: 16px;
      margin-bottom: 48px;
    }

    .space-gallery {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 48px;
    }

    .space-image {
      position: relative;
      aspect-ratio: 16/10;
      overflow: hidden;
      border: 1px solid rgba(44, 24, 16, 0.08);
    }

    .space-image-bg {
      width: 100%;
      height: 100%;
    }

    .space-image:nth-child(1) .space-image-bg { background-color: #3D2117; }
    .space-image:nth-child(2) .space-image-bg { background-color: var(--forest-olive); }
    .space-image:nth-child(3) .space-image-bg { background-color: #4A3228; }
    .space-image:nth-child(4) .space-image-bg { background-color: #5C3A1E; }

    .space-image::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 50%;
      background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 100%);
      pointer-events: none;
    }

    .space-image-caption {
      position: absolute;
      bottom: 16px;
      left: 16px;
      color: #fff;
      font-size: 13px;
      font-family: var(--font-body);
      text-transform: uppercase;
      letter-spacing: 0.1em;
