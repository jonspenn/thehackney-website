---
import Base from '../layouts/Base.astro';
import UtilityHeader from '../components/UtilityHeader.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<Base
  title="Music guidelines | The Hackney, East London E2"
  description="Music policies, DJ setup, live music rules and professional audio equipment at The Hackney. Everything your DJ or band needs to know before your event."
>

<UtilityHeader
  eyebrow="Your Event"
  heading="Music Guidelines"
  intro="Everything your DJ, band or musician needs to know about performing at The Hackney - from our sound system to noise policies."
/>

<!-- Key Policies -->
<Section bg="light">
  <SectionHeader
    eyebrow="Before you book"
    heading="The basics"
  />
  <div class="policy-intro">
    <p>These are the rules that apply to every event at The Hackney.</p>
  </div>
  <div class="policy-grid">
    <div class="policy-card">
      <h3>Music end times</h3>
      <p>All music must finish by <strong>11pm</strong>. Live music finishes by <strong>10pm</strong>.</p>
    </div>
    <div class="policy-card">
      <h3>No outdoor music</h3>
      <p>No music is allowed in the outdoor terrace area.</p>
    </div>
    <div class="policy-card">
      <h3>Sound levels</h3>
      <p>Our team manages sound levels throughout the event. If we receive a noise complaint, volume may need to be reduced immediately.</p>
    </div>
    <div class="policy-card">
      <h3>Volume control</h3>
      <p>Management reserves the right to adjust volume at any point during the event.</p>
    </div>
  </div>
</Section>

<!-- Live Music -->
<Section bg="light" border="top">
  <SectionHeader
    eyebrow="Live music"
    heading="What we allow and what we don't"
    subtext="We love live music. The space sounds brilliant with an acoustic set or a small band - but some instruments are too loud for our setting. Here's the full list."
  />
  <div class="instruments-grid">
    <div class="instruments-list instruments-allowed">
      <h3>Allowed</h3>
      <ul>
        <li>Singer / A Cappella</li>
        <li>Acoustic guitar (and similar - ukulele, banjo, sitar)</li>
        <li>Electric guitar and electric bass <span class="instrument-note">venue approval required</span></li>
        <li>Double bass and cello</li>
        <li>Violin</li>
        <li>Small percussion - cajon, congas or bongos <span class="instrument-note">limited to one, venue approval required</span></li>
        <li>Electric drums</li>
        <li>Harp</li>
        <li>Piano</li>
        <li>Keyboard</li>
      </ul>
    </div>
    <div class="instruments-list instruments-not-allowed">
      <h3>Not allowed</h3>
      <ul>
        <li>Brass instruments (including saxophone)</li>
        <li>Wind and pipe instruments</li>
        <li>Grand piano or organs</li>
        <li>Full drum kits and large percussion sets</li>
        <li>Zaffa bands</li>
        <li>Dhol players</li>
      </ul>
    </div>
  </div>
</Section>

<!-- DJ Guidelines -->
<Section bg="dark">
  <SectionHeader
    eyebrow="For DJs"
    heading="What to expect on the night"
    subtext="Every DJ uses our in-house PA system and sound equipment. No external speakers."
  />
  <div class="dj-rules">
    <div class="dj-rule">
      <h3>Connections</h3>
      <p>All connections are via XLR. DJs must supply their own laptop. Confirm compatibility with our team before your event.</p>
    </div>
    <div class="dj-rule">
      <h3>Volume</h3>
      <p>Our team controls volume throughout the night to keep the sound right for the room.</p>
    </div>
    <div class="dj-rule">
      <h3>Setup</h3>
      <p>We provide the full DJ setup including decks, booth monitoring and a DJ desk. Just bring your laptop and your music.</p>
    </div>
  </div>
</Section>

<!-- Audio System -->
<Section bg="light">
  <SectionHeader
    eyebrow="The setup"
    heading="Professional sound, built in"
    subtext="We have invested in a serious sound system so your DJ or band can focus on the music, not the logistics."
  />
  <div class="kit-grid">
    <div class="kit-card">
      <h3>Main system</h3>
      <p>4x Funktion One F81.2 loudspeakers with SB8 Mini subwoofer - a stereo four-point system designed for the room.</p>
    </div>
    <div class="kit-card">
      <h3>Processing and amplification</h3>
      <p>NST Audio VMX88 with VR1 remote volume control. Powersoft Quattrocannali DSP amplification. VDC cabling throughout.</p>
    </div>
    <div class="kit-card">
      <h3>DJ monitoring</h3>
      <p>1x Funktion One F81 for booth monitoring.</p>
    </div>
    <div class="kit-card">
      <h3>Live music mixing</h3>
      <p>Soundcraft Signature 12MTK multi-track mixer with built-in effects and USB input/output.</p>
    </div>
  </div>
</Section>

<!-- DJ Equipment -->
<Section bg="light" border="top">
  <SectionHeader
    eyebrow="DJ setup"
    heading="Pioneer XDJ-RX3"
    subtext="Our house deck is a 2-channel all-in-one system. It supports rekordbox, Serato DJ Pro, USB, aux and line/phono inputs. 3 USB ports for smooth back-to-back handovers. 2 mic inputs."
  />
  <div class="dj-equipment">
    <div class="dj-features">
      <div class="dj-feature">
        <h3>Inputs</h3>
        <p>4x aux and 2x line/phono input terminals. Connect CDJs, turntables, smartphones or any sound source.</p>
      </div>
      <div class="dj-feature">
        <h3>USB</h3>
        <p>3 USB ports - 2 top-loading for USB devices plus 1 laptop connection. Easy back-to-back handovers.</p>
      </div>
      <div class="dj-feature">
        <h3>Software</h3>
        <p>Hardware Unlock device - use rekordbox Performance mode for free. Also supports Serato DJ Pro for browsing playlists and streaming catalogues.</p>
      </div>
    </div>
    <div class="dj-desk-info">
      <h3>DJ desk</h3>
      <p>Innox Flexbooth 200 (W 101cm x D 50cm). A clean, professional booth that keeps cables tidy and gives your DJ a proper workspace.</p>
    </div>
  </div>
</Section>

<!-- Final CTA -->
<FinalCTA
  heading="Questions about your setup?"
  body="Get in touch and we will make sure everything is compatible before your event."
  primaryCTA={{ label: "Get in touch", href: "/contact/" }}
  whatsapp={true}
/>

</Base>

<style>
  /* === Key Policies === */
  .policy-intro {
    margin-bottom: 2rem;
  }

  .policy-intro p {
    font-size: 1.125rem;
    line-height: 1.65;
  }

  .policy-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .policy-card {
    padding: 2rem;
    border: 1px solid rgba(64, 22, 12, 0.06);
    border-top: 3px solid var(--forest-olive);
    border-radius: 2px;
  }

  .policy-card h3 {
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    margin-bottom: 0.75rem;
    color: var(--mid-olive);
  }

  .policy-card p {
    font-size: 1rem;
    line-height: 1.65;
    opacity: 0.85;
  }

  /* === Instruments === */
  .instruments-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-top: 1rem;
  }

  .instruments-list h3 {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--forest-olive);
  }

  .instruments-not-allowed h3 {
    border-bottom-color: var(--fired-brick);
  }

  .instruments-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .instruments-list li {
    padding: 0.625rem 0;
    border-bottom: 1px solid rgba(73, 89, 14, 0.12);
    font-size: 1rem;
    line-height: 1.5;
  }

  .instruments-list li:last-child {
    border-bottom: none;
  }

  .instrument-note {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--fired-brick);
    font-style: italic;
    margin-left: 0.25rem;
  }

  /* === DJ Rules (dark bg) === */
  .dj-rules {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    margin-top: 1rem;
  }

  .dj-rule {
    padding-top: 1rem;
    border-top: 2px solid var(--mid-olive);
  }

  .dj-rule h3 {
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    margin-bottom: 0.75rem;
    color: var(--dusty-coral);
  }

  .dj-rule p {
    font-size: 1rem;
    line-height: 1.65;
    opacity: 0.8;
  }

  /* === Kit List === */
  .kit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .kit-card {
    padding: 2rem;
    background: rgba(44, 24, 16, 0.03);
    border: 1px solid rgba(64, 22, 12, 0.06);
    border-top: 3px solid var(--mid-olive);
    border-radius: 2px;
  }

  .kit-card h3 {
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    margin-bottom: 0.75rem;
    color: var(--forest-olive);
  }

  .kit-card p {
    font-size: 1rem;
    line-height: 1.65;
    opacity: 0.85;
  }

  /* === DJ Equipment === */
  .dj-features {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .dj-feature h3 {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    margin-bottom: 0.5rem;
  }

  .dj-feature p {
    font-size: 0.9375rem;
    line-height: 1.65;
    opacity: 0.85;
  }

  .dj-desk-info {
    padding: 2rem;
    background: rgba(44, 24, 16, 0.03);
    border: 1px solid rgba(64, 22, 12, 0.06);
    border-radius: 2px;
  }

  .dj-desk-info h3 {
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    margin-bottom: 0.75rem;
  }

  .dj-desk-info p {
    font-size: 1rem;
    line-height: 1.65;
    opacity: 0.85;
  }

  /* === Responsive === */
  @media (max-width: 768px) {
    .policy-grid {
      grid-template-columns: 1fr;
    }

    .instruments-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .dj-rules {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .kit-grid {
      grid-template-columns: 1fr;
    }

    .dj-features {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
